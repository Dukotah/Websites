# The outreach factory needs NO API keys. Everything below is OPTIONAL — the
# pipeline runs fully free without any of it. Copy to .env only if you want one
# of these niceties:
#
#   cp .env.example .env
#   set -a && . ./.env && set +a        # load into your shell
#   npm run generate-prospects -- data/prospects.csv

# Optional: prefix for the outreach links written to data/outreach-links.json,
# e.g. https://demos.yourdomain.com  → links become https://demos.../p/<slug>
# Set this to your gallery's live domain so emailed links are click-ready.
GALLERY_BASE_URL=

# Optional: if set, Claude writes the marketing copy automatically instead of
# the built-in template. Not required — the agent writes copy itself in chat.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=
