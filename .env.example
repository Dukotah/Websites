# Copy to .env and fill in. The generator reads these; all are optional and it
# degrades gracefully when a key is missing.
#
#   cp .env.example .env
#   set -a && . ./.env && set +a        # load into your shell
#   npm run generate-prospects -- data/prospects.csv

# Claude API — writes the marketing copy. Without it, a built-in per-category
# fallback is used. Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=
# Optional model override (default: claude-sonnet-4-6)
ANTHROPIC_MODEL=

# Google Maps Platform key with "Places API (New)" enabled — pulls real photos,
# address, phone, hours, and an existing-website check from the business name +
# location in the CSV. Without it, demos use placeholder art.
# https://console.cloud.google.com/google/maps-apis
GOOGLE_MAPS_API_KEY=

# Optional: prefix for the outreach links written to data/outreach-links.json,
# e.g. https://demos.yourdomain.com  → links become https://demos.../p/<slug>
GALLERY_BASE_URL=
