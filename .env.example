# The outreach factory needs NO API keys. Everything below is OPTIONAL — the
# pipeline runs fully free without any of it. Copy to .env only if you want one
# of these niceties:
#
#   cp .env.example .env
#   set -a && . ./.env && set +a        # load into your shell
#   npm run generate -- data/prospects.csv

# Optional: prefix for the outreach links written to data/outreach-links.json,
# e.g. https://demos.yourdomain.com  → links become https://demos.../s/<slug>
# Set this to your gallery's live domain so emailed links are click-ready.
GALLERY_BASE_URL=

# Optional: push generated demo links straight into the Duke CRM so each lead
# shows a "Demo" badge + the preview URL (no manual copy-paste).
#   npm run push-to-crm          # after generate + git push
# CRM_BASE_URL is the Duke deployment's origin; CRM_ADMIN_TOKEN must match the
# CRM_ADMIN_TOKEN set on that Duke deployment. Without both, push-to-crm only
# runs in --dry-run mode.
CRM_BASE_URL=
CRM_ADMIN_TOKEN=

# Optional: if set, Claude writes the marketing copy automatically from the
# REAL facts scraped off each prospect's existing site. Not required — without
# it, the generator reuses their own scraped about-text + services and flags
# anything templated for a quick polish pass.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=

# Optional: AI-generate bespoke photos to fill any image slot the scraper
# couldn't fill from the business's own site. OFF by default — without a key,
# the photo chain is: their site → Wikimedia → built-in SVG library.
# Defaults target the OpenAI images API; override URL/MODEL for another
# OpenAI-compatible endpoint.
IMAGE_API_KEY=
# IMAGE_API_URL=https://api.openai.com/v1/images/generations
# IMAGE_API_MODEL=gpt-image-1
