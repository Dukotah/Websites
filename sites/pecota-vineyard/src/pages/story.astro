---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import { config } from '../config';
import jeffRenee from '../assets/images/jeff-renee.jpg';
import bird from '../assets/images/vineyard-bird.jpg';
---

<BaseLayout title="Our Story" description="The story of Pecota Vineyard — a self-taught winemaker, a two-acre family vineyard, and a commitment to sustainable, hands-on winemaking in El Dorado County.">
  <section class="pagehead">
    <div class="container container--narrow">
      <span class="kicker">Est. 2012 · Shingle Springs</span>
      <h1>{config.story.heading}</h1>
    </div>
  </section>

  <section class="section">
    <div class="container split">
      <div class="split__media reveal">
        <Image src={jeffRenee} alt="Jeff and Renée Pecota in their vineyard" widths={[480, 760, 1000]} sizes="(max-width:900px) 100vw, 520px" loading="eager" />
      </div>
      <div class="split__copy">
        {config.story.paragraphs.map((p) => <p>{p}</p>)}
        <p class="sign">{config.story.signoff}</p>
      </div>
    </div>
  </section>

  <section class="section section--ink">
    <div class="container split">
      <div class="split__copy">
        <span class="kicker">Sustainably grown</span>
        <h2>{config.sustainability.heading}</h2>
        <p>{config.sustainability.body}</p>
      </div>
      <div class="split__media reveal">
        <Image src={bird} alt="A bird among the vines at Pecota Vineyard" widths={[480, 760, 1000]} sizes="(max-width:900px) 100vw, 520px" loading="lazy" />
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="grid-4">
        {config.sustainability.points.map((pt) => (
          <div class="feature">
            <h3>{pt.title}</h3>
            <p>{pt.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container container--narrow numbers">
      <div><strong>2</strong><span>acres planted</span></div>
      <div><strong>2015</strong><span>first vintage</span></div>
      <div><strong>275–300</strong><span>cases a year</span></div>
      <div><strong>9</strong><span>varietals &amp; blends</span></div>
    </div>
  </section>
</BaseLayout>

<style>
  .pagehead {
    background: var(--bg-alt);
    border-bottom: 1px solid var(--border);
    padding-block: clamp(3rem, 8vw, 5.5rem);
    text-align: center;
  }
  .split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 5vw, 4.5rem);
    align-items: center;
  }
  .split__media :global(img) {
    width: 100%;
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    aspect-ratio: 4 / 3;
    object-fit: cover;
  }
  .split__copy p {
    font-size: 1.12rem;
    color: var(--text-muted);
  }
  .section--ink .split__copy p {
    color: rgba(243, 236, 225, 0.82);
  }
  .sign {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.3rem;
    color: var(--brand);
  }
  .grid-4 {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }
  .feature {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.6rem 1.5rem;
    box-shadow: var(--shadow-sm);
  }
  .feature h3 {
    font-size: 1.15rem;
    margin-bottom: 0.4rem;
  }
  .feature p {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.95rem;
  }
  .numbers {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    text-align: center;
  }
  .numbers strong {
    display: block;
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    color: var(--brand);
    line-height: 1;
  }
  .numbers span {
    font-size: 0.9rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  @media (max-width: 900px) {
    .split {
      grid-template-columns: 1fr;
    }
    .section--ink .split__media {
      order: -1;
    }
    .grid-4,
    .numbers {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
