---
// Open Props — pro-grade design primitives (layered shadows, refined easings,
// gradients). We consume these from the token emitter so every site gets them.
import 'open-props/easings.min.css';
import 'open-props/shadows.min.css';
import 'open-props/gradients.min.css';
import '../styles/global.css';
import '../styles/treatment.css';
import '../styles/arch-editorial.css';
import '../styles/arch-utility.css';
import '../lib/font-faces';
import { ClientRouter } from 'astro:transitions';
import { getImage } from 'astro:assets';
import { resolveArtDirection, inferCategory } from '../lib/art-direction';
import { artDirectionToCss } from '../lib/tokens';
import { resolveAsset } from '../lib/assets';
import { buildJsonLd } from '../lib/structured-data';
import { categoryLabelFor } from '../lib/labels';
import { getDisplayFontPreloadHref } from '../lib/fonts';
import StickyMobileBar from '../components/StickyMobileBar.astro';
import type { ProspectConfig } from '../types';

interface Props {
  config: ProspectConfig;
  title?: string;
  description?: string;
}

const { config } = Astro.props;
const title = Astro.props.title ?? config.name;
const description = Astro.props.description ?? config.seoDescription;

// Default page title: "Name — CategoryLabel in Area" (e.g. "Gellella Terra
// Vineyard — Winery & Tasting Room in Muncy, PA"). The label is a readable
// descriptor, not a raw slug; it falls back gracefully when unknown so the
// title degrades to "Name — Area" rather than printing nothing meaningful.
const categoryLabel = config.categoryLabel ?? categoryLabelFor(inferCategory(config));
const defaultTitle =
  categoryLabel && config.area
    ? `${config.name} — ${categoryLabel} in ${config.area}`
    : config.area
      ? `${config.name} — ${config.area}`
      : config.name;
const fullTitle = title === config.name ? defaultTitle : `${title} | ${config.name}`;

// Resolve the per-business visual identity and emit its token block. Seeded from
// name+brand so it matches what the page renderer composes.
const ad = resolveArtDirection(config);
const tokenCss = artDirectionToCss(ad);

// Preload the display font's latin woff2 so the LCP hero headline doesn't FOUT.
// Returns null when the path can't be verified (never emits a broken preload).
const displayFontPreloadHref = getDisplayFontPreloadHref(ad.fontId);

// Absolute canonical URL for this page (also used as og:url).
const canonical = Astro.site
  ? new URL(Astro.url.pathname, Astro.site).href
  : Astro.url.pathname;

// Social-share image: the hero rendered to a share-friendly JPEG (~1200w, the
// format link-preview scrapers reliably handle). Absolute URL so it resolves in
// an email/iMessage/Slack/LinkedIn preview. Falls back to the raw hero path when
// it isn't a managed raster (remote/SVG); empty when there's no real photo.
const heroAsset = resolveAsset(config.images?.hero);
let ogImage = '';
let ogImageW = 0;
let ogImageH = 0;
if (heroAsset) {
  const built = await getImage({ src: heroAsset, width: 1200, format: 'jpeg', quality: 80 });
  ogImage = Astro.site ? new URL(built.src, Astro.site).href : built.src;
  ogImageW = 1200;
  ogImageH = Math.round((1200 * heroAsset.height) / heroAsset.width);
} else if (config.images?.hero && !config.images.hero.endsWith('.svg') && Astro.site) {
  ogImage = new URL(config.images.hero, Astro.site).href;
}

// Category-aware structured data (rich results: type, stars, hours) — built from
// the same real facts shown on the page. See lib/structured-data.ts.
const jsonLd = buildJsonLd(config, { canonical, image: ogImage || undefined });
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {/* Unclaimed outreach demos stay out of the index so they can't outrank the
        prospect's real site. Flip outreach.published once they convert. */}
    {!config.outreach?.published && <meta name="robots" content="noindex, nofollow" />}

    <!-- Open Graph (link previews on social / messaging) -->
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:site_name" content={config.name} />
    <meta property="og:url" content={canonical} />
    {ogImage && (
      <Fragment>
        <meta property="og:image" content={ogImage} />
        {ogImageW > 0 && <meta property="og:image:width" content={String(ogImageW)} />}
        {ogImageH > 0 && <meta property="og:image:height" content={String(ogImageH)} />}
        <meta property="og:image:alt" content={config.images?.heroAlt ?? config.name} />
      </Fragment>
    )}

    <!-- Twitter / X card -->
    <meta name="twitter:card" content={ogImage ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}
    {ogImage && <meta name="twitter:image:alt" content={config.images?.heroAlt ?? config.name} />}

    <meta name="theme-color" content={ad.palette.brand} />

    <!-- Preload the display font's latin subset so the hero headline renders
         on the first paint rather than flashing unstyled (FOUT). The href is
         Vite-fingerprinted so it hits the browser cache reliably. Only emitted
         when a verified woff2 path resolves for this pairing. -->
    {displayFontPreloadHref && (
      <link
        rel="preload"
        as="font"
        type="font/woff2"
        href={displayFontPreloadHref}
        crossorigin
      />
    )}

    <!-- Per-business design tokens (full visual identity) -->
    <style is:inline set:html={tokenCss}></style>

    <!-- Reveal-animation guard: hide [data-reveal] content only while JS is
         running, so a blocked/slow reveal bundle can never leave the page blank.
         If reveal.ts hasn't initialized within 4s, unhide everything. -->
    <script is:inline>
      (function () {
        var el = document.documentElement;
        el.classList.add('js-reveal-ready');
        setTimeout(function () {
          if (!window.__revealReady) el.classList.remove('js-reveal-ready');
        }, 4000);
      })();
    </script>

    <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />

    <!-- Astro View Transitions: smooth page-to-page navigation (SPA-style) within
         the demo gallery. reveal.ts listens for astro:page-load to re-run
         intersection observers after each navigation. -->
    <ClientRouter />
  </head>
  <body data-archetype={ad.archetype}>
    <a href="#main" class="skip-nav">Skip to content</a>
    <slot />
    {!config.outreach?.published && <StickyMobileBar config={config} />}
    <script>
      import '../scripts/reveal.ts';
    </script>
    <script>
      import '../scripts/motion.ts';
    </script>
  </body>
</html>
