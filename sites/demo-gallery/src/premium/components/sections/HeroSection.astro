---
/**
 * HeroSection — the cold-link first impression. Three treatments:
 *   • 'fullbleed' — photo as a full-bleed background under a dark scrim, content
 *     overlaid in light text. Strongest visual presence.
 *   • 'split'     — content left, a tall photo box right.
 *   • 'editorial' — type-forward; big headline, no/secondary photo.
 * Falls back to 'editorial' automatically when there's no image.
 * Styled only against the --p-* token vocabulary so it re-themes per business.
 */
import type { SecHero, PremiumConfig } from '../../lib/premium-types';
import SiteImage from '../../../components/SiteImage.astro';

interface Props {
  data: SecHero;
  config: PremiumConfig;
}
const { data } = Astro.props;

const img = data.image;
// No image ⇒ editorial regardless of what was requested.
const variant: NonNullable<SecHero['variant']> = !img
  ? 'editorial'
  : data.variant ?? 'fullbleed';

const eyebrow = data.eyebrow;
const heading = data.heading;
const subheading = data.subheading;
const badges = data.badges?.filter(Boolean) ?? [];
const primaryCta = data.primaryCta;
const secondaryCta = data.secondaryCta;

const isFullbleed = variant === 'fullbleed' && !!img;
const isSplit = variant === 'split' && !!img;
const isEditorial = !isFullbleed && !isSplit;
---

<section
  class:list={['p-hero', `p-hero--${variant}`, { 'section--ink': isFullbleed }]}
>
  {isFullbleed && img && (
    <div class="p-hero__bg" aria-hidden="true">
      <SiteImage
        src={img.src}
        alt={img.alt ?? ''}
        objectPosition={img.focal}
        loading="eager"
        fetchpriority="high"
        sizes="100vw"
      />
      <div class="p-hero__scrim"></div>
    </div>
  )}

  <div class="container p-hero__inner">
    <div class="p-hero__content" data-reveal>
      {eyebrow && <p class="eyebrow">{eyebrow}</p>}
      <h1 class="p-hero__heading">{heading}</h1>
      {subheading && <p class="p-hero__sub">{subheading}</p>}

      {(primaryCta || secondaryCta) && (
        <div class="p-hero__actions">
          {primaryCta && (
            <a class="btn btn--primary btn--lg" href={primaryCta.href}>{primaryCta.label}</a>
          )}
          {secondaryCta && (
            <a
              class:list={['btn', 'btn--lg', isFullbleed ? 'btn--ghost-light' : 'btn--outline']}
              href={secondaryCta.href}
            >{secondaryCta.label}</a>
          )}
        </div>
      )}

      {badges.length > 0 && (
        <ul class="p-hero__badges tag-row" aria-label="At a glance">
          {badges.map((b) => (
            <li><span class="pill">{b}</span></li>
          ))}
        </ul>
      )}
    </div>

    {isSplit && img && (
      <div class="p-hero__figure" data-reveal data-reveal-delay="2">
        <div class="media">
          <SiteImage
            src={img.src}
            alt={img.alt ?? ''}
            objectPosition={img.focal}
            loading="eager"
            fetchpriority="high"
            sizes="(min-width: 820px) 48vw, 100vw"
          />
        </div>
      </div>
    )}

    {isEditorial && img && (
      <div class="p-hero__aside" data-reveal data-reveal-delay="2">
        <div class="media">
          <SiteImage
            src={img.src}
            alt={img.alt ?? ''}
            objectPosition={img.focal}
            loading="eager"
            sizes="(min-width: 820px) 38vw, 100vw"
          />
        </div>
      </div>
    )}
  </div>
</section>

<style>
  .p-hero {
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    min-height: clamp(70vh, 60vh + 8vw, 86vh);
    padding-block: clamp(4.5rem, 3.5rem + 6vw, 8.5rem);
    background: var(--p-paper);
  }

  /* ---- Full-bleed background photo + scrim ------------------------------- */
  .p-hero__bg { position: absolute; inset: 0; z-index: 0; }
  .p-hero__bg :global(img) {
    position: absolute; inset: 0;
    width: 100%; height: 100%; object-fit: cover;
  }
  .p-hero__scrim {
    position: absolute; inset: 0;
    background:
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--p-structure) 52%, transparent) 0%,
        color-mix(in srgb, var(--p-structure) 68%, transparent) 55%,
        color-mix(in srgb, var(--p-structure) 88%, transparent) 100%
      ),
      linear-gradient(
        90deg,
        color-mix(in srgb, var(--p-structure) 62%, transparent) 0%,
        color-mix(in srgb, var(--p-structure) 12%, transparent) 100%
      );
  }

  .p-hero__inner { position: relative; z-index: 1; width: 100%; }

  /* ---- Content -----------------------------------------------------------*/
  .p-hero__content { max-width: 46rem; }
  .p-hero__heading {
    font-size: var(--p-text-hero);
    margin-top: var(--p-space-4);
  }
  .p-hero__sub {
    margin-top: var(--p-space-6);
    font-size: var(--p-text-lg);
    color: var(--p-ink-soft);
    max-width: 52ch;
  }
  .p-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--p-space-4);
    margin-top: var(--p-space-8);
  }
  .p-hero__badges { margin-top: var(--p-space-8); }

  /* On the dark full-bleed band, lift text legibility off the photo. */
  .p-hero--fullbleed .p-hero__heading,
  .p-hero--fullbleed .p-hero__sub { color: #fff; }
  .p-hero--fullbleed .p-hero__heading { text-shadow: 0 2px 28px rgb(0 0 0 / 0.35); }
  .p-hero--fullbleed .p-hero__sub {
    color: var(--p-on-dark-soft);
    text-shadow: 0 1px 14px rgb(0 0 0 / 0.4);
  }
  .p-hero--fullbleed .pill {
    background: rgb(255 255 255 / 0.1);
    border-color: rgb(255 255 255 / 0.32);
    color: #fff;
    backdrop-filter: blur(6px);
  }

  /* ---- Split: content + tall figure -------------------------------------*/
  .p-hero--split .p-hero__inner {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: clamp(2.5rem, 1.5rem + 4vw, 5rem);
    align-items: center;
  }
  .p-hero--split .p-hero__figure .media { --ratio: 4 / 5; box-shadow: var(--p-shadow-lg); }

  /* ---- Editorial: type-forward, optional smaller aside photo ------------ */
  .p-hero--editorial .p-hero__heading { max-width: 18ch; }
  .p-hero--editorial .p-hero__inner:has(.p-hero__aside) {
    display: grid;
    grid-template-columns: 1.3fr 0.7fr;
    gap: clamp(2.5rem, 1.5rem + 4vw, 5rem);
    align-items: center;
  }
  .p-hero--editorial .p-hero__aside .media { --ratio: 3 / 4; box-shadow: var(--p-shadow-md); }

  @media (max-width: 820px) {
    .p-hero { min-height: auto; }
    .p-hero--split .p-hero__inner,
    .p-hero--editorial .p-hero__inner:has(.p-hero__aside) {
      grid-template-columns: 1fr;
    }
    .p-hero--split .p-hero__figure,
    .p-hero--editorial .p-hero__aside { margin-top: var(--p-space-8); }
    .p-hero--split .p-hero__figure .media { --ratio: 16 / 11; }
    .p-hero--editorial .p-hero__aside .media { --ratio: 16 / 10; }
  }
</style>
