---
/**
 * HeroSection — the cold-link first impression. Three treatments:
 *   • 'fullbleed' — photo as a full-bleed background under a dark scrim, content
 *     overlaid in light text. Strongest visual presence.
 *   • 'split'     — content left, a tall photo box right.
 *   • 'editorial' — type-forward; big headline, no/secondary photo.
 * Falls back to 'editorial' automatically when there's no image.
 * Styled only against the --p-* token vocabulary so it re-themes per business.
 */
import type { SecHero, PremiumConfig } from '../../lib/premium-types';
import SiteImage from '../../../components/SiteImage.astro';

interface Props {
  data: SecHero;
  config: PremiumConfig;
}
const { data, config } = Astro.props;

const img = data.image;
// Decorative category motif (a library SVG drawn in currentColor) for the
// photo-less editorial hero — a brand-tinted illustrative backdrop behind the
// type. Clearly NOT a photo. When absent we still show the monogram watermark.
const motif = data.motif;
// Oversized monogram watermark for the photo-less editorial hero — gives a
// deliberate, composed visual weight (brand-tinted, decorative) instead of a
// bare type block. First letter of the business name.
const monogram = (config?.name || '').trim().charAt(0).toUpperCase();
// No image ⇒ editorial regardless of what was requested.
const variant: NonNullable<SecHero['variant']> = !img
  ? 'editorial'
  : data.variant ?? 'fullbleed';

const eyebrow = data.eyebrow;
const heading = data.heading;
const subheading = data.subheading;
const badges = data.badges?.filter(Boolean) ?? [];
const primaryCta = data.primaryCta;
const secondaryCta = data.secondaryCta;

const isFullbleed = variant === 'fullbleed' && !!img;
const isSplit = variant === 'split' && !!img;
const isEditorial = !isFullbleed && !isSplit;
---

<section
  class:list={['p-hero', `p-hero--${variant}`, { 'section--ink': isFullbleed, 'p-hero--editorial-solo': isEditorial && !img }]}
>
  {isEditorial && !img && motif && (
    <div
      class="p-hero__motif"
      aria-hidden="true"
      style={`-webkit-mask-image:url("${motif}");mask-image:url("${motif}")`}
    ></div>
  )}

  {isEditorial && !img && !motif && monogram && (
    <div class="p-hero__wm" aria-hidden="true">
      <span class="p-hero__wm-mono">{monogram}</span>
    </div>
  )}

  {isFullbleed && img && (
    <div class="p-hero__bg" aria-hidden="true">
      <SiteImage
        src={img.src}
        alt={img.alt ?? ''}
        objectPosition={img.focal}
        loading="eager"
        fetchpriority="high"
        sizes="100vw"
      />
      <div class="p-hero__scrim"></div>
    </div>
  )}

  <div class="container p-hero__inner">
    {/* Hero content is NOT reveal-gated — it's the LCP/above-the-fold element and
        must paint immediately, never flash faded while JS settles. */}
    <div class="p-hero__content">
      {eyebrow && <p class="eyebrow">{eyebrow}</p>}
      <h1 class="p-hero__heading" transition:name="page-hero-heading">{heading}</h1>
      {subheading && <p class="p-hero__sub">{subheading}</p>}

      {(primaryCta || secondaryCta) && (
        <div class="p-hero__actions">
          {primaryCta && (
            <a class="btn btn--primary btn--lg" href={primaryCta.href}>{primaryCta.label}</a>
          )}
          {secondaryCta && (
            <a
              class:list={['btn', 'btn--lg', isFullbleed ? 'btn--ghost-light' : 'btn--outline']}
              href={secondaryCta.href}
            >{secondaryCta.label}</a>
          )}
        </div>
      )}

      {badges.length > 0 && (
        <ul class="p-hero__badges tag-row" aria-label="At a glance">
          {badges.map((b) => (
            <li><span class="pill">{b}</span></li>
          ))}
        </ul>
      )}
    </div>

    {isSplit && img && (
      <div class="p-hero__figure">
        <div class="media">
          <SiteImage
            src={img.src}
            alt={img.alt ?? ''}
            objectPosition={img.focal}
            loading="eager"
            fetchpriority="high"
            sizes="(min-width: 820px) 48vw, 100vw"
          />
        </div>
      </div>
    )}

    {isEditorial && img && (
      <div class="p-hero__aside">
        <div class="media">
          <SiteImage
            src={img.src}
            alt={img.alt ?? ''}
            objectPosition={img.focal}
            loading="eager"
            sizes="(min-width: 820px) 38vw, 100vw"
          />
        </div>
      </div>
    )}
  </div>
</section>

<style>
  .p-hero {
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    min-height: clamp(58vh, 50vh + 7vw, 78vh);
    padding-block: clamp(3.5rem, 2.8rem + 4.5vw, 7rem);
    background: var(--p-paper);
  }

  /* ---- Full-bleed background photo + scrim ------------------------------- */
  .p-hero__bg { position: absolute; inset: 0; z-index: 0; }
  .p-hero__bg :global(img) {
    position: absolute; inset: 0;
    width: 100%; height: 100%; object-fit: cover;
  }
  .p-hero__scrim {
    position: absolute; inset: 0;
    background:
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--p-structure) 52%, transparent) 0%,
        color-mix(in srgb, var(--p-structure) 68%, transparent) 55%,
        color-mix(in srgb, var(--p-structure) 88%, transparent) 100%
      ),
      linear-gradient(
        90deg,
        color-mix(in srgb, var(--p-structure) 62%, transparent) 0%,
        color-mix(in srgb, var(--p-structure) 12%, transparent) 100%
      );
  }

  .p-hero__inner { position: relative; z-index: 1; width: 100%; }

  /* ---- Content -----------------------------------------------------------*/
  .p-hero__content { max-width: min(46rem, 100%); min-width: 0; }
  .p-hero__heading {
    font-size: var(--p-text-hero);
    margin-top: var(--p-space-4);
    overflow-wrap: break-word;
    hyphens: auto;
  }
  .p-hero__sub {
    margin-top: var(--p-space-6);
    font-size: var(--p-text-lg);
    color: var(--p-ink-soft);
    max-width: min(52ch, 100%);
    overflow-wrap: break-word;
  }
  .p-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--p-space-4);
    margin-top: var(--p-space-8);
  }
  .p-hero__badges { margin-top: var(--p-space-8); }

  /* On the dark full-bleed band, lift text legibility off the photo. */
  .p-hero--fullbleed .p-hero__heading,
  .p-hero--fullbleed .p-hero__sub { color: #fff; }
  .p-hero--fullbleed .p-hero__heading { text-shadow: 0 2px 28px rgb(0 0 0 / 0.35); }
  .p-hero--fullbleed .p-hero__sub {
    color: var(--p-on-dark-soft);
    text-shadow: 0 1px 14px rgb(0 0 0 / 0.4);
  }
  .p-hero--fullbleed .pill {
    background: rgb(255 255 255 / 0.1);
    border-color: rgb(255 255 255 / 0.32);
    color: #fff;
    backdrop-filter: blur(6px);
  }

  /* ---- Split: content + tall figure -------------------------------------*/
  .p-hero--split .p-hero__inner {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: clamp(2.5rem, 1.5rem + 4vw, 5rem);
    align-items: center;
  }
  .p-hero--split .p-hero__figure .media { --ratio: 4 / 5; box-shadow: var(--p-shadow-lg); }

  /* ---- Editorial: type-forward, optional smaller aside photo ------------ */
  .p-hero--editorial .p-hero__heading { max-width: 18ch; }

  /* Photo-less editorial hero: a deliberate, composed treatment — a subtle
     brand-tinted gradient panel + an oversized monogram watermark behind the
     type — so a hero with no real photo still has visual weight (not a bare
     block). Token-driven + decorative (aria-hidden). */
  .p-hero--editorial-solo {
    background:
      radial-gradient(60rem 38rem at 88% -10%, color-mix(in srgb, var(--p-primary) 12%, transparent), transparent 60%),
      linear-gradient(180deg, var(--p-paper) 0%, var(--p-paper-deep) 100%);
  }
  /* Category motif backdrop — a brand-tinted illustrative panel (library SVG
     used as a mask, painted in --p-primary) anchored to the right, low opacity,
     behind the type. Clearly decorative, never reads as a photo. */
  .p-hero__motif {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background-color: var(--p-primary);
    opacity: 0.14;
    -webkit-mask-repeat: no-repeat;
    mask-repeat: no-repeat;
    -webkit-mask-position: right -6% center;
    mask-position: right -6% center;
    -webkit-mask-size: clamp(28rem, 22rem + 30vw, 58rem) auto;
    mask-size: clamp(28rem, 22rem + 30vw, 58rem) auto;
  }
  .p-hero__wm {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
    pointer-events: none;
    display: flex;
    align-items: center;
    justify-content: flex-end;
  }
  .p-hero__wm-mono {
    font-family: var(--p-font-display);
    font-weight: 800;
    font-size: clamp(20rem, 14rem + 28vw, 44rem);
    line-height: 0.7;
    letter-spacing: -0.06em;
    color: var(--p-primary);
    opacity: 0.06;
    transform: translateX(12%);
    user-select: none;
  }
  .p-hero--editorial-solo .p-hero__inner { position: relative; z-index: 1; }
  .p-hero--editorial .p-hero__inner:has(.p-hero__aside) {
    display: grid;
    grid-template-columns: 1.3fr 0.7fr;
    gap: clamp(2.5rem, 1.5rem + 4vw, 5rem);
    align-items: center;
  }
  .p-hero--editorial .p-hero__aside .media { --ratio: 3 / 4; box-shadow: var(--p-shadow-md); }

  @media (max-width: 820px) {
    .p-hero { min-height: auto; }
    .p-hero--split .p-hero__inner,
    .p-hero--editorial .p-hero__inner:has(.p-hero__aside) {
      grid-template-columns: 1fr;
    }
    .p-hero--split .p-hero__figure,
    .p-hero--editorial .p-hero__aside { margin-top: var(--p-space-8); }
    .p-hero--split .p-hero__figure .media { --ratio: 16 / 11; }
    .p-hero--editorial .p-hero__aside .media { --ratio: 16 / 10; }
  }
</style>
