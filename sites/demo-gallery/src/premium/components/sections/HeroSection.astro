---
/**
 * HeroSection — the cold-link first impression. Three treatments:
 *   • 'fullbleed' — photo as a full-bleed background under a dark scrim, content
 *     overlaid in light text. Strongest visual presence.
 *   • 'split'     — content left, a tall photo box right.
 *   • 'editorial' — type-forward; big headline, no/secondary photo.
 * Falls back to 'editorial' automatically when there's no image.
 * Styled only against the --p-* token vocabulary so it re-themes per business.
 */
import type { SecHero, PremiumConfig } from '../../lib/premium-types';
import SiteImage from '../../../components/SiteImage.astro';
import { hash, rangeInt, chance } from '../../../lib/seed';

interface Props {
  data: SecHero;
  config: PremiumConfig;
}
const { data, config } = Astro.props;

// Deterministic per-site signature so two photo heroes don't look stamped from
// one mold. Drives the scrim direction + a corner glow placement; stable per
// slug, so a re-run is identical but neighbours differ. Token-driven only.
const sig = hash((config?.slug ?? config?.name ?? 'flow') + ':hero');
const scrimDir = rangeInt(sig, 0, 2); // 0 bottom-up, 1 corner BL, 2 corner BR
const glowSide = chance(sig >> 3, 0.5) ? 'r' : 'l';
// Deterministic motif tilt (±12deg) so five same-category photo-less heroes stop
// looking stamped from one mold — each slug gets its own settled angle, stable on
// re-run. Reduced motion neutralizes it to 0 in CSS (the rest of the composition
// is unchanged), so the static title-card never tilts for motion-averse visitors.
const motifTilt = rangeInt(sig >> 7, -12, 12);

const img = data.image;
// Decorative category motif (a library SVG drawn in currentColor) for the
// photo-less editorial hero — a brand-tinted illustrative backdrop behind the
// type. Clearly NOT a photo. When absent we still show the monogram watermark.
const motif = data.motif;
// Oversized monogram watermark for the photo-less editorial hero — gives a
// deliberate, composed visual weight (brand-tinted, decorative) instead of a
// bare type block. First letter of the business name.
const monogram = (config?.name || '').trim().charAt(0).toUpperCase();
// No image ⇒ editorial regardless of what was requested.
const variant: NonNullable<SecHero['variant']> = !img
  ? 'editorial'
  : data.variant ?? 'fullbleed';

const eyebrow = data.eyebrow;
const heading = data.heading;
const subheading = data.subheading;
const badges = data.badges?.filter(Boolean) ?? [];
const primaryCta = data.primaryCta;
const secondaryCta = data.secondaryCta;

// Focal-point-aware scrim bias. The focal Y (0=top .. 100=bottom) tells us where
// the subject sits; we darken the OPPOSITE edge so the scrim protects text without
// muddying the subject. focal high (subject near top, small Y) → bias the darkening
// toward the bottom; focal low (subject near bottom) → bias toward the top.
// --scrim-bias is a 0..1 number (0 = darken bottom, 1 = darken top); 0.5 = neutral.
const focalY = (() => {
  const m = /(\d+(?:\.\d+)?)\s*%?\s*$/.exec((img?.focal ?? '').trim());
  const y = m ? Number(m[1]) : 50;
  return Number.isFinite(y) ? Math.min(100, Math.max(0, y)) : 50;
})();
const scrimBias = +(focalY / 100).toFixed(3);

const isFullbleed = variant === 'fullbleed' && !!img;
const isSplit = variant === 'split' && !!img;
const isEditorial = !isFullbleed && !isSplit;
// Photo-less editorial hero is a deliberate DARK "title-card": a brand-structured
// band with light text + layered glow, motif/monogram at real presence, and a
// hairline texture. This is what turns "where's the image?" into "designed this
// way on purpose" — it borrows the same dark-band confidence as the photo heroes
// and AVISP's hero, but built entirely from type + brand color, no photo.
const isDarkEditorial = isEditorial && !img;
// Photo-less editorial hero: when there's no aside photo, give the right zone
// real architecture — a brand-tinted "credential card" built from the badges +
// the lede — so the hero reads as a composed two-column layout (AVISP-caliber),
// not big type floating over emptiness. Only when we actually have badges.
const soloAside = isEditorial && !img && badges.length > 0;
// Full-bleed hero with real credentials: float a frosted "credential card" over
// the photo (badges become a glass overlay) for layered depth — so a photo hero
// reads as composed, not just a scrim + two buttons. Only when we have badges.
const glassCred = isFullbleed && badges.length > 0;
---

<section
  class:list={['p-hero', `p-hero--${variant}`, { 'section--ink': isFullbleed || isDarkEditorial, 'p-hero--editorial-solo': isDarkEditorial, 'p-hero--editorial-paired': soloAside, 'p-hero--has-glass': glassCred }]}
  data-scrim={scrimDir}
  data-glow={glowSide}
  style={isFullbleed ? `--scrim-bias:${scrimBias}` : undefined}
>
  {isDarkEditorial && (
    <>
      {/* Living aurora field — a slowly drifting brand-light canvas painted behind
          the title-card so the dark hero shimmers with depth instead of sitting
          static. JS-only enhancement: the canvas paints OVER the existing static
          gradient band (which is the reduced-motion / no-JS / no-WebGL fallback),
          so nothing is hidden waiting on it. Decorative. */}
      <canvas class="p-hero__aurora" data-hero-aurora aria-hidden="true"></canvas>
      <div class="p-hero__sweep" aria-hidden="true"></div>
      <div class="p-hero__texture" aria-hidden="true"></div>
    </>
  )}

  {isDarkEditorial && motif && (
    <div
      class="p-hero__motif"
      aria-hidden="true"
      style={`-webkit-mask-image:url("${motif}");mask-image:url("${motif}");--p-motif-tilt:${motifTilt}deg`}
    ></div>
  )}

  {isDarkEditorial && monogram && (
    <div class="p-hero__wm" aria-hidden="true">
      <span class="p-hero__wm-mono">{monogram}</span>
    </div>
  )}

  {isFullbleed && img && (
    <div class="p-hero__bg" aria-hidden="true">
      {/* Photo wrapper carries the cinematic entrance: a clip-path wipe reveals
          the image and a slow Ken-Burns drift gives it depth. Both are pure
          compositor transforms armed AFTER first paint (.hero-armed), so the
          photo is fully painted for LCP and only enhances on motion clients. */}
      <div class="p-hero__photo" data-hero-photo data-hero-parallax="bg">
        <SiteImage
          src={img.src}
          alt={img.alt ?? ''}
          objectPosition={img.focal}
          loading="eager"
          fetchpriority="high"
          sizes="100vw"
        />
      </div>
      <div class="p-hero__scrim"></div>
      <div class="p-hero__glow" aria-hidden="true"></div>
    </div>
  )}

  <div class="container p-hero__inner">
    {/* Hero content is NOT reveal-gated — it's the LCP/above-the-fold element and
        must paint immediately, never flash faded while JS settles. */}
    <div class="p-hero__content">
      {eyebrow && <p class="eyebrow" data-hero-stage="0">{eyebrow}</p>}
      {/* Clip-reveal headline: the text paints immediately (LCP-safe, never
          opacity-gated). On motion-capable clients an overflow-clip mask lets
          each word rise into place once .reveal-armed is set — pure transform,
          zero layout shift. Reduced motion shows the words instantly. */}
      <h1 class="p-hero__heading" transition:name="page-hero-heading">
        <span class="p-hero__heading-clip">{heading.split(/\s+/).map((w, i, arr) => (
          <><span class="p-hero__word" style={`--w:${i}`}>{w}</span>{i < arr.length - 1 ? ' ' : ''}</>
        ))}</span>
      </h1>
      {subheading && <p class="p-hero__sub" data-hero-stage="2">{subheading}</p>}

      {(primaryCta || secondaryCta) && (
        <div class="p-hero__actions" data-hero-stage="3">
          {primaryCta && (
            <a class="btn btn--primary btn--lg" href={primaryCta.href} data-magnetic>{primaryCta.label}</a>
          )}
          {secondaryCta && (
            <a
              class:list={['btn', 'btn--lg', (isFullbleed || isDarkEditorial) ? 'btn--ghost-light' : 'btn--outline']}
              href={secondaryCta.href}
            >{secondaryCta.label}</a>
          )}
        </div>
      )}

      {badges.length > 0 && !soloAside && !glassCred && (
        <ul class="p-hero__badges tag-row" data-hero-stage="4" aria-label="At a glance">
          {badges.map((b) => (
            <li><span class="pill">{b}</span></li>
          ))}
        </ul>
      )}

      {glassCred && (
        <aside class="p-hero__glass" data-reveal aria-label="At a glance">
          <p class="p-hero__glass-label">Why us</p>
          <ul class="p-hero__glass-list">
            {badges.map((b) => (
              <li class="p-hero__glass-item">{b}</li>
            ))}
          </ul>
        </aside>
      )}
    </div>

    {soloAside && (
      <aside class="p-hero__cred" aria-label="At a glance">
        <span class="p-hero__cred-rule" aria-hidden="true"></span>
        <p class="p-hero__cred-label">At a glance</p>
        <ul class="p-hero__cred-list">
          {badges.map((b) => (
            <li class="p-hero__cred-item">{b}</li>
          ))}
        </ul>
      </aside>
    )}

    {isSplit && img && (
      <div class="p-hero__figure" data-reveal="right" data-hero-parallax="figure">
        <span class="p-hero__figure-frame" aria-hidden="true"></span>
        <div class="media p-hero__photo" data-hero-photo>
          <SiteImage
            src={img.src}
            alt={img.alt ?? ''}
            objectPosition={img.focal}
            loading="eager"
            fetchpriority="high"
            sizes="(min-width: 820px) 48vw, 100vw"
          />
        </div>
      </div>
    )}

    {isEditorial && img && (
      <div class="p-hero__aside" data-hero-parallax="figure">
        <div class="media p-hero__photo" data-hero-photo>
          <SiteImage
            src={img.src}
            alt={img.alt ?? ''}
            objectPosition={img.focal}
            loading="eager"
            sizes="(min-width: 820px) 38vw, 100vw"
          />
        </div>
      </div>
    )}
  </div>
</section>

<style>
  .p-hero {
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    min-height: clamp(58vh, 50vh + 7vw, 78vh);
    padding-block: clamp(3.5rem, 2.8rem + 4.5vw, 7rem);
    background: var(--p-paper);
  }

  /* ---- Full-bleed background photo + scrim ------------------------------- */
  .p-hero__bg { position: absolute; inset: 0; z-index: 0; }
  .p-hero__bg :global(img) {
    position: absolute; inset: 0;
    width: 100%; height: 100%; object-fit: cover;
  }
  /* PHOTOGRAPHIC scrim — preserves the photo instead of a muddy single-color
     wash. A nearly-transparent top, a bottom-anchored darkening that protects
     the text zone, and a side gradient under the copy column only. The photo's
     midtones survive; legibility comes from where text actually sits. The
     darkening uses a near-black tint (not the full brand color) so the image
     reads as a photo, with just a whisper of brand tint layered on top.
     Direction varies per site via [data-scrim] for variety, and each variant
     carries its own tonal identity (warm navy / cool + accent / extra-warm).
     --scrim-bias (0..1, from the photo's focal Y) shifts the vertical anchor:
     focal high → darken the bottom; focal low → darken the top. */
  .p-hero__scrim {
    /* 0 = darken bottom, 1 = darken top; default neutral if no photo focal. */
    --scrim-bias: 0.5;
    /* Per-edge weights derived from the bias so the darkening tracks the subject. */
    --scrim-bottom: calc(0.30 + (1 - var(--scrim-bias)) * 0.44);
    --scrim-top: calc(0.18 + var(--scrim-bias) * 0.40);
    position: absolute; inset: 0;
    background:
      /* protect the copy column (left) */
      linear-gradient(90deg,
        rgb(8 12 20 / 0.62) 0%,
        rgb(8 12 20 / 0.30) 38%,
        rgb(8 12 20 / 0) 70%),
      /* bottom anchor (weighted toward a high focal subject) */
      linear-gradient(0deg,
        rgb(8 12 20 / var(--scrim-bottom)) 0%,
        rgb(8 12 20 / 0.14) 34%,
        rgb(8 12 20 / 0) 60%),
      /* top anchor (weighted toward a low focal subject) */
      linear-gradient(180deg,
        rgb(8 12 20 / var(--scrim-top)) 0%,
        rgb(8 12 20 / 0) 26%),
      /* warm-navy tonal identity: brand structure leaning cool/navy */
      linear-gradient(135deg,
        color-mix(in srgb, var(--p-structure) 30%, transparent) 0%,
        color-mix(in srgb, var(--p-structure) 8%, transparent) 60%,
        transparent 100%);
  }
  /* Variant B: cool + accent radial — a brand-accent pool warms one corner over a
     cooler base (good for centered/wide photos). Bias-weighted vertical anchor. */
  .p-hero[data-scrim='1'] .p-hero__scrim {
    background:
      linear-gradient(0deg,
        rgb(8 12 20 / var(--scrim-bottom)) 0%,
        rgb(8 12 20 / 0.30) 30%,
        rgb(8 12 20 / 0) 58%),
      linear-gradient(180deg,
        rgb(8 12 20 / var(--scrim-top)) 0%,
        rgb(8 12 20 / 0) 24%),
      linear-gradient(105deg,
        rgb(8 12 20 / 0.46) 0%,
        rgb(8 12 20 / 0) 52%),
      radial-gradient(120% 90% at 18% 100%,
        color-mix(in srgb, var(--p-accent) 26%, transparent), transparent 58%),
      radial-gradient(140% 100% at 82% 0%,
        color-mix(in srgb, var(--p-structure) 22%, transparent), transparent 62%);
  }
  /* Variant C: extra-warm, brand-led diagonal — the warmest, most editorial. */
  .p-hero[data-scrim='2'] .p-hero__scrim {
    background:
      linear-gradient(115deg,
        color-mix(in srgb, var(--p-primary) 54%, transparent) 0%,
        rgb(8 12 20 / 0.34) 30%,
        rgb(8 12 20 / 0) 66%),
      linear-gradient(0deg,
        rgb(8 12 20 / var(--scrim-bottom)) 0%,
        rgb(8 12 20 / 0) 46%),
      linear-gradient(180deg,
        rgb(8 12 20 / var(--scrim-top)) 0%,
        rgb(8 12 20 / 0) 24%),
      radial-gradient(90% 70% at 12% 88%,
        color-mix(in srgb, var(--p-primary) 22%, transparent), transparent 60%);
  }
  /* Signature corner glow — a soft brand-tinted pool that gives the frame a
     focal warmth (Stripe/AVISP feel). Decorative; side flips per [data-glow]. */
  .p-hero__glow {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(42rem 30rem at 88% 8%,
        color-mix(in srgb, var(--p-primary) 30%, transparent), transparent 60%);
    mix-blend-mode: screen;
    opacity: 0.5;
  }
  .p-hero[data-glow='l'] .p-hero__glow {
    background:
      radial-gradient(42rem 30rem at 8% 6%,
        color-mix(in srgb, var(--p-primary) 30%, transparent), transparent 60%);
  }

  .p-hero__inner { position: relative; z-index: 1; width: 100%; }

  /* ---- Content -----------------------------------------------------------*/
  /* Nudge the hero text in from the left by ~1/16 of the viewport (capped) so big
     headlines don't crowd the screen edge and read easier. This indents the TEXT
     block only — the header bar and any hero photo/full-bleed art are unaffected.
     box-sizing keeps it inside the column, so no horizontal overflow. */
  .p-hero__content { max-width: min(46rem, 100%); min-width: 0; padding-inline-start: clamp(1rem, 6.25vw, 6rem); }
  .p-hero__heading {
    font-size: var(--p-text-hero);
    margin-top: var(--p-space-4);
    overflow-wrap: break-word;
    hyphens: auto;
  }
  /* Clip-reveal: each word sits in an overflow-clipped line and rises into view.
     Text is fully painted by default (no opacity gate on the LCP element). The
     hidden-then-rise only engages once JS adds .reveal-armed on motion-capable
     clients, and uses transform + clip only → zero layout shift. */
  /* Words stay in normal inline flow (inline-block preserves the spaces between
     them) so the headline reads correctly with no JS / reduced motion. When
     armed, each word starts shifted down + transparent and eases up in stagger
     — transform/opacity only, so the line box never reflows (zero CLS). */
  .p-hero__heading-clip { display: inline; }
  .p-hero__word { display: inline-block; }
  /* Hidden start-state is gated behind .hero-armed (added by JS only AFTER the
     opaque first paint), never .reveal-armed — so the LCP heading is painted
     visible before any reveal arms. */
  .premium .p-hero.hero-armed .p-hero__word {
    transform: translateY(0.45em);
    opacity: 0;
    transition:
      transform 720ms cubic-bezier(0.22, 1, 0.36, 1),
      opacity 520ms ease;
    transition-delay: calc(var(--w) * 40ms + 80ms);
  }
  .premium .p-hero.hero-armed.is-hero-in .p-hero__word {
    transform: none;
    opacity: 1;
  }
  .p-hero__sub {
    margin-top: var(--p-space-6);
    font-size: var(--p-text-lg);
    color: var(--p-ink-soft);
    max-width: min(52ch, 100%);
    overflow-wrap: break-word;
  }
  .p-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--p-space-4);
    margin-top: var(--p-space-8);
  }
  .p-hero__badges { margin-top: var(--p-space-8); }

  /* On the dark full-bleed band, lift text legibility off the photo. */
  .p-hero--fullbleed .p-hero__heading,
  .p-hero--fullbleed .p-hero__sub { color: #fff; }
  .p-hero--fullbleed .p-hero__heading { text-shadow: 0 2px 28px rgb(0 0 0 / 0.35); }
  .p-hero--fullbleed .p-hero__sub {
    color: var(--p-on-dark-soft);
    text-shadow: 0 1px 14px rgb(0 0 0 / 0.4);
  }
  .p-hero--fullbleed .pill,
  .p-hero--editorial-solo .pill {
    background: rgb(255 255 255 / 0.1);
    border-color: rgb(255 255 255 / 0.32);
    color: #fff;
    backdrop-filter: blur(6px);
  }

  /* ---- Frosted credential card over the photo (layered depth) ------------ */
  .p-hero__glass {
    margin-top: var(--p-space-8);
    max-width: 30rem;
    padding: clamp(1.1rem, 0.9rem + 0.8vw, 1.5rem) clamp(1.25rem, 1rem + 1vw, 1.75rem);
    border-radius: var(--p-radius-lg);
    border: 1px solid rgb(255 255 255 / 0.22);
    background:
      linear-gradient(135deg, rgb(255 255 255 / 0.16), rgb(255 255 255 / 0.06));
    box-shadow:
      0 1px 0 rgb(255 255 255 / 0.25) inset,
      0 18px 44px rgb(8 12 20 / 0.34);
    backdrop-filter: blur(14px) saturate(1.1);
    -webkit-backdrop-filter: blur(14px) saturate(1.1);
  }
  .p-hero__glass-label {
    font-size: var(--p-text-xs);
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--p-primary) 40%, #fff);
    margin-bottom: var(--p-space-3);
  }
  .p-hero__glass-list { list-style: none; margin: 0; padding: 0; display: grid; gap: var(--p-space-3); }
  .p-hero__glass-item {
    position: relative;
    padding-inline-start: 1.5rem;
    color: #fff;
    font-weight: 600;
    line-height: 1.35;
    text-shadow: 0 1px 8px rgb(0 0 0 / 0.35);
  }
  .p-hero__glass-item::before {
    content: '';
    position: absolute;
    inset-inline-start: 0;
    top: 0.5em;
    width: 0.7rem; height: 0.7rem;
    border-radius: 50%;
    background: color-mix(in srgb, var(--p-primary) 55%, #fff);
    box-shadow: 0 0 0 4px color-mix(in srgb, var(--p-primary) 30%, transparent);
  }
  /* No backdrop-filter support → solid translucent fallback (still readable). */
  @supports not ((backdrop-filter: blur(1px)) or (-webkit-backdrop-filter: blur(1px))) {
    .p-hero__glass { background: rgb(12 18 28 / 0.66); }
  }

  /* ---- Split: content + tall figure -------------------------------------*/
  .p-hero--split .p-hero__inner {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: clamp(2.5rem, 1.5rem + 4vw, 5rem);
    align-items: center;
  }
  /* Split figure gets layered framing — an offset brand-tinted panel sits
     behind the photo, so the image reads as composed, not a bare rectangle. */
  .p-hero--split .p-hero__figure { position: relative; }
  .p-hero--split .p-hero__figure-frame {
    position: absolute;
    inset: 0;
    transform: translate(clamp(0.9rem, 0.6rem + 0.8vw, 1.4rem), clamp(0.9rem, 0.6rem + 0.8vw, 1.4rem));
    border-radius: var(--p-radius-lg);
    background:
      radial-gradient(28rem 22rem at 110% 110%, color-mix(in srgb, var(--p-primary) 22%, transparent), transparent 64%),
      var(--p-primary-tint);
    border: 1px solid color-mix(in srgb, var(--p-primary) 16%, var(--p-line));
    z-index: 0;
  }
  .p-hero--split .p-hero__figure .media {
    --ratio: 4 / 5;
    position: relative;
    z-index: 1;
    box-shadow: var(--p-shadow-lg);
  }

  /* ---- Editorial: type-forward, optional smaller aside photo ------------ */
  .p-hero--editorial .p-hero__heading { max-width: 18ch; }

  /* ---- Photo-less editorial hero = a DELIBERATE DARK TITLE-CARD ----------- */
  /* The fix for "reads as a missing image": instead of light type floating on a
     near-white gradient, the photo-less hero becomes a confident brand-structured
     dark band (same family as the photo heroes + AVISP's hero) with light text,
     layered brand glow, a hairline texture, an oversized brand monogram, and the
     category motif at real presence. Fully composed → reads as designed, not
     unfinished. Built only from type + brand color — no photo. Token-driven;
     if color-mix is unsupported the --p-structure base still gives a solid dark
     band (never a broken light block). */
  .p-hero--editorial-solo {
    background:
      radial-gradient(54rem 40rem at 82% -16%, color-mix(in srgb, var(--p-primary) 32%, transparent), transparent 56%),
      radial-gradient(46rem 34rem at 2% 112%, color-mix(in srgb, var(--p-accent) 20%, transparent), transparent 54%),
      radial-gradient(70rem 50rem at 50% 130%, color-mix(in srgb, var(--p-primary) 12%, transparent), transparent 60%),
      linear-gradient(165deg,
        color-mix(in srgb, var(--p-structure) 92%, #fff 8%) 0%,
        var(--p-structure) 52%,
        color-mix(in srgb, var(--p-structure) 88%, #000 12%) 100%);
  }
  /* Hairline diagonal-grid texture — gives the dark band branded richness (the
     "considered surface" look) without a photo. Very low contrast, decorative. */
  .p-hero__texture {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    opacity: 0.5;
    background-image:
      repeating-linear-gradient(
        115deg,
        color-mix(in srgb, var(--p-on-dark) 6%, transparent) 0 1px,
        transparent 1px 26px);
    -webkit-mask-image: linear-gradient(105deg, #000 0%, transparent 72%);
    mask-image: linear-gradient(105deg, #000 0%, transparent 72%);
  }
  /* Category motif — brand-tinted illustrative panel (library SVG used as a mask,
     painted brand-primary) anchored low-right, behind the type. Now at MEANINGFUL
     presence on the dark band (not a 6% ghost). Decorative, never a photo. */
  .p-hero__motif {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    /* Stronger brand-forward fill so the motif reads as a confident graphic, not
       a washed ghost. Adaptive opacity + blend (emitted from brand lightness in
       tokens.ts) keep it legible on both light and dark brands. */
    background-color: color-mix(in srgb, var(--p-primary) 78%, #fff);
    opacity: var(--p-motif-opacity, 0.34);
    mix-blend-mode: var(--p-motif-blend, screen);
    /* Deterministic per-slug tilt about the low-right anchor so siblings differ. */
    transform: rotate(var(--p-motif-tilt, 0deg));
    transform-origin: 88% 92%;
    -webkit-mask-repeat: no-repeat;
    mask-repeat: no-repeat;
    -webkit-mask-position: right -4% bottom -8%;
    mask-position: right -4% bottom -8%;
    -webkit-mask-size: clamp(26rem, 20rem + 28vw, 52rem) auto;
    mask-size: clamp(26rem, 20rem + 28vw, 52rem) auto;
  }
