---
/**
 * FeaturesSection — benefit/feature cards with small inline-SVG icons. Turns a
 * business's real highlights into a structured benefit band (instead of a flat
 * checklist). The icon set is defined IN this component (no external deps) and
 * drawn in currentColor so it inherits the brand tint; an unknown/absent keyword
 * falls back to the 'check' mark. Renders nothing with fewer than 2 items.
 * Tokens only; re-themes per brand.
 */
import type { SecFeatures, PremiumConfig, FeatureIcon } from '../../lib/premium-types';

interface Props {
  data: SecFeatures;
  config: PremiumConfig;
}
const { data } = Astro.props;

const items = (data.items ?? []).filter((it) => it && it.title);
if (items.length < 2) return null;

// Inline icon paths (24×24 viewBox, stroke = currentColor). Token-tinted by the
// .p-features__icon color rule. Keep keywords in sync with FeatureIcon.
const ICONS: Record<FeatureIcon, string> = {
  check: 'M20 6 9 17l-5-5',
  clock: 'M12 7v5l3 2 M12 21a9 9 0 1 0 0-18 9 9 0 0 0 0 18Z',
  shield: 'M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z',
  leaf: 'M11 20A7 7 0 0 1 4 13c0-5 5-9 16-9 0 11-4 16-9 16Z M4 20c2-4 5-7 9-9',
  wrench: 'M14.7 6.3a4 4 0 0 0-5.4 5.2l-6 6 2.9 2.9 6-6a4 4 0 0 0 5.2-5.4l-2.6 2.6-2.1-.5-.5-2.1Z',
  sparkle: 'M12 3v6 M12 15v6 M3 12h6 M15 12h6 M6.3 6.3l3 3 M14.7 14.7l3 3 M17.7 6.3l-3 3 M9.3 14.7l-3 3',
  'map-pin': 'M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z M12 12a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5Z',
  phone: 'M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3 19.5 19.5 0 0 1-6-6 19.8 19.8 0 0 1-3-8.6A2 2 0 0 1 4.1 2h3a2 2 0 0 1 2 1.7c.1 1 .4 1.9.7 2.8a2 2 0 0 1-.5 2.1L8.1 9.9a16 16 0 0 0 6 6l1.3-1.2a2 2 0 0 1 2.1-.5c.9.3 1.8.6 2.8.7a2 2 0 0 1 1.7 2Z',
};
const iconFor = (k?: FeatureIcon) => ICONS[k ?? 'check'] ?? ICONS.check;

// Bento layout: an asymmetric tile rhythm (see .bento--features in effects.css)
// kicks in for 3+ items where there's enough to compose a varied grid. Two or
// fewer falls back to the clean even grid so a sparse band never looks broken.
// The span pattern + grid-auto-flow:dense guarantees no holes at any count.
const useBento = items.length >= 3;
const cols = items.length % 3 === 0 || items.length > 4 ? 'grid-3' : 'grid-2';
// Tile indexes that get the wide "lead" treatment (must mirror the nth-child
// pattern in effects.css: 5n+1 and 5n+4) so they get the brand-tinted base.
const isLead = (i: number) => i % 5 === 0 || i % 5 === 3;
---

<section class="section p-features">
  <div class="container">
    {(data.eyebrow || data.heading || data.intro) && (
      <div class="section-head" data-reveal data-draw-underline>
        {data.eyebrow && <p class="eyebrow">{data.eyebrow}</p>}
        {data.heading && <h2>{data.heading}</h2>}
        {data.intro && <p>{data.intro}</p>}
      </div>
    )}

    <div class:list={['p-features__grid', useBento ? ['bento', 'bento--features'] : ['grid', cols]]}>
      {items.map((it, i) => (
        <article
          class:list={['card', 'card--accent', 'p-features__card', { 'is-bento-lead': useBento && isLead(i) }]}
          data-tilt-gloss
          data-reveal
          data-reveal-delay={((i % 3) + 1)}
        >
          <span class="p-features__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="24" height="24" fill="none"
              stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              {iconFor(it.icon).split(' M').map((d, k) => (
                <path d={k === 0 ? d : `M${d}`} />
              ))}
            </svg>
          </span>
          <h3 class="p-features__title">{it.title}</h3>
          <p class="p-features__body">{it.body}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .p-features__card {
    display: flex;
    flex-direction: column;
    gap: var(--p-space-3);
  }
  .p-features__icon {
    display: grid;
    place-items: center;
    width: 3rem;
    height: 3rem;
    margin-bottom: var(--p-space-1);
    border-radius: var(--p-radius-md);
    background: var(--p-primary-tint);
    color: var(--p-primary);
    border: 1px solid color-mix(in srgb, var(--p-primary) 16%, transparent);
    box-shadow: inset 0 1px 0 color-mix(in srgb, #fff 50%, transparent);
    transition: background-color 240ms ease, color 240ms ease, transform 320ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  /* The icon tile fills with brand on hover (mirrors .card-marker), so the whole
     family of cards shares one congruent hover language. */
  .p-features__title { font-size: var(--p-text-xl); letter-spacing: -0.015em; }
  .p-features__body { color: var(--p-ink-soft); font-size: var(--p-text-base); }
  @media (hover: hover) {
    .p-features__card:hover .p-features__icon {
      background: var(--p-primary); color: var(--p-primary-contrast); transform: translateY(-1px);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .p-features__icon { transition: none; }
    .p-features__card:hover .p-features__icon { transform: none; }
  }
</style>
