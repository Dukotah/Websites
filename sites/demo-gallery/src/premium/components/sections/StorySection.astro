---
/**
 * StorySection — the about/story band. Two-column: prose (+ optional checklist
 * of differentiators and a signature line) beside an image. With no image the
 * prose centers into a comfortable reading measure. Tokens only.
 */
import type { SecStory, PremiumConfig } from '../../lib/premium-types';
import SiteImage from '../../../components/SiteImage.astro';
import Marquee from '../Marquee.astro';

interface Props {
  data: SecStory;
  config: PremiumConfig;
}
const { data } = Astro.props;

const eyebrow = data.eyebrow;
const heading = data.heading;
const body = data.body?.filter(Boolean) ?? [];
const highlights = data.highlights?.filter(Boolean) ?? [];
const img = data.image;
const signature = data.signature;

const hasImage = !!img;
// Photo-less story with real differentiators (highlights): render the highlights
// as a designed brand-tinted panel beside the prose — an asymmetric two-column
// composition that holds the page without a photo (AVISP-caliber), instead of a
// single centered text column. Falls back to the centered measure when there are
// no highlights to fill the aside.
const soloPanel = !hasImage && highlights.length > 0;

// Sticky-scroll storytelling: when there's an image AND enough prose to scroll
// (2+ paragraphs), the figure pins in view while the narrative steps scroll past
// it (CSS position:sticky — no scroll-jacking; collapses to normal flow on
// mobile + reduced motion via effects.css). Reserves space via the grid → 0 CLS.
const sticky = hasImage && body.length >= 2;

// A credential strip beneath the story — derived from existing highlights (no
// schema change). Renders only when there are 4+ differentiators (enough to read
// as a moving strip rather than a thin row) AND the section has an image (so the
// inline checklist isn't the only place they appear). In that case the strip
// REPLACES the inline checklist so the highlights never read twice on one screen.
const useMarquee = hasImage && !soloPanel && highlights.length >= 4;
const credentials = highlights;
---

<section class:list={['section', 'p-story', { 'p-story--solo': !hasImage, 'p-story--panel': soloPanel, 'p-story--sticky': sticky }]}>
  <div class="container">
    <div class="p-story__grid">
      <div class="p-story__body" data-reveal={hasImage || soloPanel ? 'left' : ''}>
        {eyebrow && <p class="eyebrow">{eyebrow}</p>}
        <h2 class="p-story__heading">{heading}</h2>

        <div class:list={['p-story__prose', { 'p-story__steps': sticky }]} data-dropcap>
          {body.map((para, i) =>
            sticky ? (
              <p data-reveal data-reveal-delay={Math.min((i % 8) + 1, 8)}>{para}</p>
            ) : (
              <p>{para}</p>
            ),
          )}
        </div>

        {highlights.length > 0 && !soloPanel && !useMarquee && (
          <ul class="checklist p-story__highlights">
            {highlights.map((h) => <li>{h}</li>)}
          </ul>
        )}

        {signature && <p class="p-story__signature">{signature}</p>}
      </div>

      {hasImage && img && (
        <div class="p-story__figure" data-reveal="right" data-reveal-delay="2">
          <div class="media">
            <SiteImage
              src={img.src}
              alt={img.alt ?? ''}
              objectPosition={img.focal}
              sizes="(min-width: 820px) 44vw, 100vw"
            />
          </div>
        </div>
      )}

      {soloPanel && (
        <aside class="p-story__panel" data-reveal="right" data-reveal-delay="2">
          <span class="p-story__panel-rule" aria-hidden="true"></span>
          <p class="p-story__panel-label">What sets us apart</p>
          <ul class="checklist p-story__panel-list">
            {highlights.map((h) => <li>{h}</li>)}
          </ul>
        </aside>
      )}
    </div>

    {/* Credential strip — an infinite marquee of the differentiators, beneath the
        story. Derived from existing `highlights` (no schema change); REPLACES the
        inline checklist when present so they never read twice on one screen. */}
    {useMarquee && (
      <div class="p-story__credentials" data-reveal>
        <Marquee items={credentials} label="What sets us apart" />
      </div>
    )}
  </div>
</section>

<style>
  .p-story__grid {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: clamp(2.5rem, 1.5rem + 4vw, 5.5rem);
    align-items: center;
  }
  .p-story__heading {
    font-size: var(--p-text-3xl);
    margin-top: var(--p-space-3);
  }
  .p-story__prose {
    display: grid;
    gap: var(--p-space-4);
    margin-top: var(--p-space-6);
    color: var(--p-ink-soft);
    font-size: var(--p-text-lg);
    max-width: 60ch;
  }
  .p-story__highlights { margin-top: var(--p-space-8); }
  .p-story__highlights li { color: var(--p-ink); }

  .p-story__signature {
    margin-top: var(--p-space-8);
    font-family: var(--p-font-display);
    font-size: var(--p-text-xl);
    color: var(--p-ink-strong);
    letter-spacing: -0.01em;
  }

  .p-story__figure .media {
    --ratio: 4 / 5;
    box-shadow: var(--p-shadow-lg);
  }

  /* Photo-less story WITH a differentiator panel: asymmetric two-column — prose
     left, a designed brand-tinted highlight panel right. Holds the page without
     a photo. Overrides the centered-solo rules below. */
  .p-story--panel .p-story__grid {
    grid-template-columns: 1.15fr 0.85fr;
    align-items: start;
  }
  .p-story--panel .p-story__body {
    max-width: 56rem;
    margin-inline: 0;
    text-align: left;
  }
  .p-story--panel .eyebrow { justify-content: flex-start; }
  .p-story--panel .eyebrow::before { display: inline-block; }
  .p-story--panel .p-story__prose { margin-inline: 0; text-align: left; }
  .p-story__panel {
    position: relative;
    align-self: start;
    padding: clamp(1.75rem, 1.3rem + 1.8vw, 2.75rem);
    border: 1px solid var(--p-line);
    border-radius: var(--p-radius-lg);
    background:
      radial-gradient(34rem 24rem at 120% -20%, var(--p-primary-tint), transparent 62%),
      var(--p-surface);
    box-shadow: var(--p-shadow-md);
  }
  .p-story__panel-rule {
    position: absolute;
    inset-block: clamp(1.75rem, 1.3rem + 1.8vw, 2.75rem);
    inset-inline-start: 0;
    width: 3px;
    border-radius: 3px;
    background: linear-gradient(180deg, var(--p-primary), color-mix(in srgb, var(--p-primary) 35%, transparent));
  }
  .p-story__panel-label {
    font-size: var(--p-text-xs);
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--p-primary);
    margin-bottom: var(--p-space-4);
  }
  .p-story__panel-list li { color: var(--p-ink-strong); font-weight: 600; }

  /* No image, no panel: center the prose into a readable column. */
  .p-story--solo:not(.p-story--panel) .p-story__grid { grid-template-columns: 1fr; }
  .p-story--solo:not(.p-story--panel) .p-story__body {
    max-width: 46rem;
    margin-inline: auto;
    text-align: center;
  }
  .p-story--solo:not(.p-story--panel) .eyebrow { justify-content: center; }
  .p-story--solo:not(.p-story--panel) .eyebrow::before { display: none; }
  .p-story--solo:not(.p-story--panel) .p-story__prose {
    margin-inline: auto;
    text-align: left;
  }
  .p-story--solo:not(.p-story--panel) .p-story__highlights {
    max-width: 34rem;
    margin-inline: auto;
    text-align: left;
  }

  /* Credential marquee beneath the story — a hairline-topped strip. */
  .p-story__credentials {
    margin-top: clamp(2.5rem, 1.8rem + 2.5vw, 4rem);
    padding-top: var(--p-space-8);
    border-top: 1px solid var(--p-line);
  }

  @media (max-width: 820px) {
    .p-story__grid { grid-template-columns: 1fr; }
    .p-story--panel .p-story__grid { grid-template-columns: 1fr; }
    .p-story__figure { order: -1; }
    .p-story__figure .media { --ratio: 16 / 11; }
    .p-story--panel .p-story__panel { margin-top: var(--p-space-6); }
  }
</style>
