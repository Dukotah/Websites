---
/**
 * ServicesSection — eyebrow + heading + intro, then the offerings.
 *   • layout 'grid' (default) — a responsive card grid; each item a .card with
 *     an optional small image and a .pill badge.
 *   • layout 'rows' — alternating full-width feature rows (image one side,
 *     copy the other, flipping per index) for a richer, page-filling treatment
 *     like AVISP's services page.
 * Tokens only; re-themes per business.
 */
import type { SecServices, PremiumConfig } from '../../lib/premium-types';
import SiteImage from '../../../components/SiteImage.astro';

interface Props {
  data: SecServices;
  config: PremiumConfig;
}
const { data, config } = Astro.props;

// a11y: a service photo is a REAL content image — give it a meaningful, non-empty
// alt. Prefer the author's alt, else the service title, else the business name.
const svcAlt = (item: { title?: string; image?: { alt?: string } }) =>
  (item.image?.alt && item.image.alt.trim()) || item.title || `${config?.name ?? 'Our'} service`;

const eyebrow = data.eyebrow;
const heading = data.heading;
const intro = data.intro;
const items = data.items ?? [];
const layout: NonNullable<SecServices['layout']> = data.layout ?? 'grid';
const isRows = layout === 'rows';

// Pick a sensible grid density so cards fill the row without stranding one.
const cols = items.length % 3 === 0 || items.length > 4 ? 'grid-3' : 'grid-2';
// Bento rhythm for the grid layout with 3+ offerings (see .bento--services in
// effects.css). Dense flow guarantees no holes for any count. Cards WITH photos
// keep the even grid — a media tile spanning 2 cols/rows distorts the crop — so
// bento only applies when the grid is text-led (no item images).
const anyImage = items.some((it) => !!it.image);
const useBento = !isRows && items.length >= 3 && !anyImage;
const isLead = (i: number) => i % 7 === 0;

// In the grid layout, move the intro into a split section-head (heading left,
// lede right) so this section doesn't read as another centered eyebrow→grid
// stamp. Rows keep the simple stacked head (the rows themselves carry rhythm).
const splitHead = !isRows && !!intro;
---

<section class="section p-services">
  <div class="container">
    <div class:list={['section-head', { 'section-head--split': splitHead }]} data-reveal>
      <div class="p-services__head-main">
        {eyebrow && <p class="eyebrow">{eyebrow}</p>}
        <h2>{heading}</h2>
        {intro && !splitHead && <p>{intro}</p>}
      </div>
      {splitHead && <p class="section-head__lede">{intro}</p>}
    </div>

    {isRows ? (
      <div class="p-services__rows">
        {items.map((item, i) => (
          <article
            class:list={['p-services__row', { 'p-services__row--flip': i % 2 === 1 }]}
            data-reveal
          >
            <div class="p-services__row-body">
              <span class="kicker-num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
              {item.badge && <span class="pill pill--accent">{item.badge}</span>}
              <h3>{item.title}</h3>
              <p>{item.description}</p>
            </div>
            <div class="p-services__row-figure">
              {item.image ? (
                <div class="media">
                  <SiteImage
                    src={item.image.src}
                    alt={svcAlt(item)}
                    objectPosition={item.image.focal}
                    sizes="(min-width: 820px) 48vw, 100vw"
                  />
                </div>
              ) : (
                <div class="p-services__row-glyph" aria-hidden="true">
                  <span class="kicker-num">{String(i + 1).padStart(2, '0')}</span>
                </div>
              )}
            </div>
          </article>
        ))}
      </div>
    ) : (
      <div class:list={['p-services__cards', useBento ? ['bento', 'bento--services'] : ['grid', cols]]}>
        {items.map((item, i) => (
          <article
            class:list={['card', 'card--accent', 'p-services__card', { 'is-bento-lead': useBento && isLead(i) }]}
            data-tilt-gloss
            data-reveal
            data-reveal-delay={((i % 3) + 1)}
          >
            {item.image && (
              <div class="media p-services__card-media">
                <SiteImage
                  src={item.image.src}
                  alt={svcAlt(item)}
                  objectPosition={item.image.focal}
                  sizes="(min-width: 860px) 30vw, (min-width: 560px) 45vw, 100vw"
                />
              </div>
            )}
            <div class="p-services__card-top">
              <span class="card-marker p-services__card-num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
              {item.badge && <span class="pill pill--accent p-services__card-badge">{item.badge}</span>}
            </div>
            <h3 class="p-services__card-title">{item.title}</h3>
            <p class="p-services__card-copy">{item.description}</p>
          </article>
        ))}
      </div>
    )}
  </div>
</section>

<style>
  /* ---- Card grid ---------------------------------------------------------*/
  .p-services__card {
    display: flex;
    flex-direction: column;
    gap: var(--p-space-3);
  }
  .p-services__card-media {
    --ratio: 16 / 10;
    margin: calc(-1 * var(--p-space-8)) calc(-1 * var(--p-space-8)) var(--p-space-2);
    border-radius: var(--p-radius-lg) var(--p-radius-lg) 0 0;
  }
  /* Top row: the brand-tinted index marker (always congruent — no clip-art) and
     an optional badge, separated from the title so the card has real internal
     hierarchy instead of bold-title-over-gray-text. */
  .p-services__card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--p-space-3);
    margin-bottom: var(--p-space-1);
  }
  /* When a card has its own photo, the number is redundant with the imagery —
     drop it and let the badge sit alone. */
  .p-services__card-media ~ .p-services__card-top .p-services__card-num { display: none; }
  .p-services__card-badge { align-self: center; }
  .p-services__card-title { font-size: var(--p-text-xl); letter-spacing: -0.015em; }
  /* A short brand hairline under the title divides it from the copy — the small
     craft that separates "considered" from "filled-in box". */
  .p-services__card-title::after {
    content: ''; display: block;
    width: 1.75rem; height: 2px; margin-top: var(--p-space-3);
    background: var(--p-primary); border-radius: 2px; opacity: 0.55;
  }
  .p-services__card-copy { color: var(--p-ink-soft); font-size: var(--p-text-base); }

  /* ---- Alternating feature rows -----------------------------------------*/
  .p-services__rows {
    display: grid;
    gap: clamp(3rem, 2rem + 4vw, 5.5rem);
  }
  .p-services__row {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: clamp(2rem, 1.2rem + 3.5vw, 4.5rem);
    align-items: center;
  }
  .p-services__row--flip .p-services__row-body { order: 2; }
  .p-services__row--flip .p-services__row-figure { order: 1; }

  .p-services__row-body {
    display: grid;
    justify-items: start;
    gap: var(--p-space-3);
  }
  .p-services__row-body .kicker-num { margin-bottom: calc(-1 * var(--p-space-4)); }
  .p-services__row-body h3 { font-size: var(--p-text-2xl); }
  .p-services__row-body p {
    color: var(--p-ink-soft);
    font-size: var(--p-text-lg);
    max-width: 54ch;
  }

  .p-services__row-figure .media { --ratio: 4 / 3; box-shadow: var(--p-shadow-lg); }
  .p-services__row-glyph {
    display: grid;
    place-items: center;
    aspect-ratio: 4 / 3;
    border-radius: var(--p-radius-lg);
    background:
      radial-gradient(28rem 18rem at 70% 110%, var(--p-primary-tint), transparent 60%),
      var(--p-paper-deep);
    box-shadow: var(--p-shadow-sm);
  }
  .p-services__row-glyph .kicker-num { opacity: 0.4; }

  @media (max-width: 820px) {
    .p-services__row { grid-template-columns: 1fr; gap: var(--p-space-6); }
    .p-services__row--flip .p-services__row-body { order: 1; }
    .p-services__row--flip .p-services__row-figure { order: 2; }
    .p-services__row-figure .media { --ratio: 16 / 10; }
  }
</style>
