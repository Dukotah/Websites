---
/**
 * TeamSection — owner/founder/team bios. A card grid reusing .card + .media.
 * Members WITHOUT a photo render a brand-tinted monogram tile (never a blank
 * grey box), so the section is presentable whether or not we have headshots.
 * Author emits this ONLY when research carries real people — never fabricated.
 * Renders nothing when there are no members. Tokens only.
 */
import type { SecTeam, PremiumConfig } from '../../lib/premium-types';
import SiteImage from '../../../components/SiteImage.astro';

interface Props {
  data: SecTeam;
  config: PremiumConfig;
}
const { data } = Astro.props;

const members = (data.members ?? []).filter((m) => m && m.name);
if (members.length < 1) return null;

const monogram = (name: string) =>
  name.split(/\s+/).filter(Boolean).slice(0, 2).map((w) => w.charAt(0).toUpperCase()).join('');

// Match the services-grid density logic so cards fill the row. A lone member
// centers into a single comfortable card instead of stranding an empty column.
const solo = members.length === 1;
const cols = members.length % 3 === 0 || members.length > 4 ? 'grid-3' : 'grid-2';
---

<section class="section p-team">
  <div class="container">
    <div class:list={['section-head', { 'section-head--center': solo }]} data-reveal>
      {data.eyebrow && <p class="eyebrow">{data.eyebrow}</p>}
      <h2>{data.heading ?? 'Meet the team'}</h2>
    </div>

    <div class:list={['grid', cols, 'p-team__grid', { 'p-team__grid--solo': solo }]}>
      {members.map((m, i) => (
        <article class="card p-team__card" data-reveal data-reveal-delay={((i % 3) + 1)}>
          {m.image ? (
            <div class="media p-team__media">
              <SiteImage
                src={m.image.src}
                alt={m.image.alt ?? m.name}
                objectPosition={m.image.focal}
                sizes="(min-width: 860px) 30vw, (min-width: 560px) 45vw, 100vw"
              />
            </div>
          ) : (
            <div class="p-team__mono" aria-hidden="true" data-mono={monogram(m.name)}></div>
          )}
          <h3 class="p-team__name">{m.name}</h3>
          {m.role && <p class="p-team__role">{m.role}</p>}
          {m.bio && <p class="p-team__bio">{m.bio}</p>}
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .p-team__card {
    display: flex;
    flex-direction: column;
    gap: var(--p-space-2);
  }
  .p-team__media {
    --ratio: 1 / 1;
    margin: calc(-1 * var(--p-space-8)) calc(-1 * var(--p-space-8)) var(--p-space-4);
    border-radius: var(--p-radius-lg) var(--p-radius-lg) 0 0;
  }
  /* Photo-less fallback: a designed brand-tinted monogram tile (never a blank
     grey box). A soft diagonal brand wash + a fine inner ring + a centered
     monogram disc give it deliberate composition. */
  .p-team__mono {
    position: relative;
    display: grid;
    place-items: center;
    aspect-ratio: 1 / 1;
    margin: calc(-1 * var(--p-space-8)) calc(-1 * var(--p-space-8)) var(--p-space-4);
    border-radius: var(--p-radius-lg) var(--p-radius-lg) 0 0;
    background:
      radial-gradient(18rem 14rem at 25% 18%, color-mix(in srgb, var(--p-primary) 16%, transparent), transparent 60%),
      radial-gradient(22rem 18rem at 78% 108%, var(--p-primary-tint), transparent 62%),
      var(--p-paper-deep);
    overflow: hidden;
  }
  /* Centered monogram on a tinted disc — reads as a deliberate brand mark. */
  .p-team__mono::before {
    content: attr(data-mono);
    display: grid;
    place-items: center;
    width: clamp(4.5rem, 3.5rem + 6vw, 7rem);
    aspect-ratio: 1 / 1;
    border-radius: 50%;
    background: color-mix(in srgb, var(--p-surface) 70%, transparent);
    box-shadow: inset 0 0 0 1.5px color-mix(in srgb, var(--p-primary) 40%, transparent), var(--p-shadow-sm);
    font-family: var(--p-font-display);
    font-weight: 800;
    font-size: clamp(1.6rem, 1.1rem + 2vw, 2.4rem);
    letter-spacing: -0.03em;
    color: var(--p-primary);
  }
  .p-team__name { font-size: var(--p-text-xl); }
  .p-team__role {
    font-size: var(--p-text-sm);
    font-weight: 650;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--p-primary);
  }
  .p-team__bio { color: var(--p-ink-soft); font-size: var(--p-text-base); margin-top: var(--p-space-1); }

  /* Lone member: a single centered card (no stranded empty column). On wide
     screens it becomes a horizontal split — monogram/photo left, bio right —
     so one person still fills the band with a composed, intentional layout. */
  .p-team__grid--solo {
    grid-template-columns: 1fr;
    max-width: 46rem;
    margin-inline: auto;
  }
  @media (min-width: 620px) {
    .p-team__grid--solo .p-team__card {
      display: grid;
      grid-template-columns: 0.42fr 0.58fr;
      align-items: center;
      gap: var(--p-space-6);
      text-align: left;
    }
    .p-team__grid--solo .p-team__media,
    .p-team__grid--solo .p-team__mono {
      margin: calc(-1 * var(--p-space-8)) 0 calc(-1 * var(--p-space-8)) calc(-1 * var(--p-space-8));
      border-radius: var(--p-radius-lg) 0 0 var(--p-radius-lg);
      height: 100%;
    }
  }
</style>
