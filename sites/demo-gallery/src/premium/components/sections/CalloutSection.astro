---
/**
 * CalloutSection — a brand-tinted "differentiator" band used when a site is too
 * thin for a full stat row (1–2 real stats) but has real highlights worth a
 * deliberate mid-page beat. Type-forward + a brand motif backdrop; photo-free by
 * design, so it never demands imagery and never renders a blank panel. Tokens
 * only; re-themes per business.
 */
import type { SecCallout, PremiumConfig } from '../../lib/premium-types';

interface Props {
  data: SecCallout;
  config: PremiumConfig;
}
const { data } = Astro.props;

const eyebrow = data.eyebrow;
const heading = data.heading;
const body = data.body;
const points = (data.points ?? []).filter(Boolean).slice(0, 4);
const cta = data.primaryCta;
---

<section class="section p-callout">
  <div class="container">
    <div class="p-callout__panel" data-reveal>
      <div class="p-callout__motif" aria-hidden="true"></div>
      <div class="p-callout__body">
        {eyebrow && <p class="eyebrow">{eyebrow}</p>}
        <h2 class="p-callout__heading">{heading}</h2>
        {body && <p class="p-callout__lead">{body}</p>}

        {points.length > 0 && (
          <ul class="checklist p-callout__points">
            {points.map((p) => <li>{p}</li>)}
          </ul>
        )}

        {cta && (
          <div class="p-callout__actions">
            <a class="btn btn--primary btn--lg" href={cta.href}>{cta.label}</a>
          </div>
        )}
      </div>
    </div>
  </div>
</section>

<style>
  .p-callout__panel {
    position: relative;
    overflow: hidden;
    border-radius: var(--p-radius-lg);
    border: 1px solid var(--p-line);
    background:
      radial-gradient(46rem 30rem at 100% -20%, var(--p-primary-tint), transparent 62%),
      var(--p-surface);
    padding: clamp(2.25rem, 1.6rem + 3vw, 4.5rem);
  }
  /* Decorative brand stripe down the leading edge so the panel reads as a
     designed band, not a card. */
  .p-callout__motif {
    position: absolute;
    inset-block: 0;
    inset-inline-start: 0;
    width: clamp(0.4rem, 0.2rem + 0.6vw, 0.7rem);
    background: linear-gradient(180deg, var(--p-primary), color-mix(in srgb, var(--p-primary) 40%, transparent));
  }
  .p-callout__body { position: relative; max-width: 52rem; }
  .p-callout__heading {
    font-size: var(--p-text-3xl);
    margin-top: var(--p-space-3);
  }
  .p-callout__lead {
    margin-top: var(--p-space-4);
    font-size: var(--p-text-lg);
    color: var(--p-ink-soft);
    max-width: 56ch;
  }
  .p-callout__points {
    margin-top: var(--p-space-8);
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--p-space-3) var(--p-space-8);
  }
  .p-callout__points li { color: var(--p-ink); }
  .p-callout__actions { margin-top: var(--p-space-8); }

  @media (max-width: 640px) {
    .p-callout__points { grid-template-columns: 1fr; }
  }
</style>
