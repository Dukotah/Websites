---
/**
 * PremiumBase — the AVISP-caliber layout shell for multi-page agent-authored
 * demos. Forked from layouts/BaseLayout.astro: it KEEPS the factory brand engine
 * (resolveArtDirection -> artDirectionToCss seeds the per-prospect --brand/--text/
 * --font-* tokens that premium.css consumes) and all the SEO/OG/JSON-LD/font
 * plumbing, but loads the PREMIUM design system instead of the legacy one, adds
 * Astro View Transitions (ClientRouter) for SPA-smooth page swaps across the
 * multi-page site, and a self-contained scroll-reveal that re-inits after every
 * transition. Every page wraps its content in <PremiumBase> and the body lives in
 * a `.premium` subtree so the premium tokens/components apply cleanly.
 */
import '../styles/premium.css';
import '../../lib/font-faces';
import { ClientRouter } from 'astro:transitions';
import { getImage } from 'astro:assets';
import { resolveArtDirection, inferCategory } from '../../lib/art-direction';
import { artDirectionToCss } from '../../lib/tokens';
import { resolveAsset } from '../../lib/assets';
import { buildJsonLd } from '../../lib/structured-data';
import { categoryLabelFor } from '../../lib/labels';
import { getDisplayFontPreloadHref } from '../../lib/fonts';
import PremiumHeader from '../components/PremiumHeader.astro';
import PremiumFooter from '../components/PremiumFooter.astro';
import StickyContactBar from '../components/StickyContactBar.astro';
import type { PremiumConfig } from '../lib/premium-types';

interface Props {
  config: PremiumConfig;
  /** Which page of the multi-page site this is — drives nav active state. */
  page?: string;
  /** Page <title>; defaults to the SEO title for the home page. */
  title?: string;
  description?: string;
  /** Per-page social-share image override (else the home hero). */
  ogImage?: string;
}

const { config, page = 'home' } = Astro.props;
const description = Astro.props.description ?? config.seoDescription;

// Structural shell variant (see PremiumLayout). Sanitized to the known set so a
// stray value can never emit an unknown class; default 'classic' renders exactly
// as before (existing data files carry no `layout`, so they're untouched).
const LAYOUTS = ['classic', 'editorial', 'sidebar'] as const;
const layout = (LAYOUTS as readonly string[]).includes((config as any).layout)
  ? ((config as any).layout as (typeof LAYOUTS)[number])
  : 'classic';

const categoryLabel = config.categoryLabel ?? categoryLabelFor(inferCategory(config as any));
const baseTitle =
  categoryLabel && config.area
    ? `${config.name} — ${categoryLabel} in ${config.area}`
    : config.area
      ? `${config.name} — ${config.area}`
      : config.name;
// Home uses the SEO title; interior pages prefix the page label.
const pageLabel = Astro.props.title;
const fullTitle = pageLabel ? `${pageLabel} | ${config.name}` : baseTitle;

// Per-business visual identity (palette + type pairing) → token block.
// Map the v2 `brand` the agent pinned (color + fontId) onto the fields the
// factory art-direction engine reads (theme.brand drives the palette via
// palette.ts; artDirection.fontId picks the pairing — an unknown id safely
// falls back to a category-seeded font). Omitting `brand` lets the engine
// derive a palette/font from the business name + category.
const adInput = {
  ...config,
  theme: config.brand?.color ? { brand: config.brand.color } : (config as any).theme,
  artDirection: config.brand?.fontId ? { fontId: config.brand.fontId } : (config as any).artDirection,
};
const ad = resolveArtDirection(adInput as any);
const tokenCss = artDirectionToCss(ad);
const displayFontPreloadHref = getDisplayFontPreloadHref(ad.fontId);

const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : Astro.url.pathname;

// Social-share image: the home hero rendered to a 1200w JPEG for link previews.
const heroAsset = resolveAsset(config.images?.hero);
let ogImage = Astro.props.ogImage ?? '';
let ogImageW = 0;
let ogImageH = 0;
if (!ogImage && heroAsset) {
  const built = await getImage({ src: heroAsset, width: 1200, format: 'jpeg', quality: 80 });
  ogImage = Astro.site ? new URL(built.src, Astro.site).href : built.src;
  ogImageW = 1200;
  ogImageH = Math.round((1200 * heroAsset.height) / heroAsset.width);
} else if (!ogImage && config.images?.hero && !config.images.hero.endsWith('.svg') && Astro.site) {
  ogImage = new URL(config.images.hero, Astro.site).href;
}

const jsonLd = buildJsonLd(config as any, { canonical, image: ogImage || undefined });
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {!config.outreach?.published && <meta name="robots" content="noindex, nofollow" />}
    <ClientRouter />

    <!-- Open Graph + Twitter (link previews) -->
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:site_name" content={config.name} />
    <meta property="og:url" content={canonical} />
    {ogImage && (
      <Fragment>
        <meta property="og:image" content={ogImage} />
        {ogImageW > 0 && <meta property="og:image:width" content={String(ogImageW)} />}
        {ogImageH > 0 && <meta property="og:image:height" content={String(ogImageH)} />}
        <meta property="og:image:alt" content={config.images?.heroAlt ?? config.name} />
      </Fragment>
    )}
    <meta name="twitter:card" content={ogImage ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}

    <meta name="theme-color" content={ad.palette.brand} />
    {displayFontPreloadHref && (
      <link rel="preload" as="font" type="font/woff2" href={displayFontPreloadHref} crossorigin />
    )}

    <!-- Per-business design tokens (palette + type) consumed by premium.css -->
    <style is:inline set:html={tokenCss}></style>
    <noscript><style>.premium [data-reveal]{opacity:1!important;transform:none!important}</style></noscript>

    <!-- Structural LAYOUT variants. Opt-in via config.layout; 'classic' emits no
         rules here so existing sites are byte-for-byte unchanged. Pure CSS over
         the existing markup (wrapper class + header/main/footer), so section
         components are untouched. Both variants degrade to the centered stack on
         smaller screens. -->
    <style is:global>
      /* ── editorial: asymmetric magazine column ──────────────────────────── */
      .premium.layout-editorial .container {
        width: auto;
        max-width: 62rem;
        margin-inline: auto;
      }
      .premium.layout-editorial main {
        position: relative;
      }
      /* Slightly taller section rhythm reinforces the unhurried editorial feel. */
      .premium.layout-editorial .section {
        padding-block: clamp(4.5rem, 3.4rem + 4.2vw, 8rem);
      }
      @media (min-width: 1080px) {
        /* Left-biased measure with a generous right rail = magazine cadence. */
        .premium.layout-editorial .container {
          margin-inline-start: clamp(4rem, 14vw, 14rem);
          margin-inline-end: clamp(2rem, 6vw, 6rem);
        }
        /* A thin brand-tinted rule runs down the left rail — editorial signature.
           Decorative + token-driven; pointer-events off so it never intercepts. */
        .premium.layout-editorial main::before {
          content: '';
          position: absolute;
          top: 0;
          bottom: 0;
          left: clamp(2rem, 9vw, 9rem);
          width: 1px;
          background: linear-gradient(
            to bottom,
            transparent,
            color-mix(in srgb, var(--p-primary) 30%, var(--p-line)),
            transparent
          );
          pointer-events: none;
        }
      }

      /* ── sidebar: fixed vertical nav rail beside scrolling content ───────── */
      @media (min-width: 1100px) {
        .premium.layout-sidebar {
          display: grid;
          grid-template-columns: 16rem minmax(0, 1fr);
          grid-template-areas:
            'nav main'
            'nav foot';
          align-items: start;
        }
        .premium.layout-sidebar > .p-hdr {
          grid-area: nav;
          position: sticky;
          top: 0;
          height: 100vh;
          border-bottom: 0;
          border-inline-end: 1px solid var(--p-line);
        }
        .premium.layout-sidebar > .p-hdr .p-hdr__inner {
          flex-direction: column;
          align-items: flex-start;
          height: 100%;
          width: 100%;
          padding-block: var(--p-space-8);
          gap: var(--p-space-6);
        }
        .premium.layout-sidebar > .p-hdr .p-hdr__nav {
          flex-direction: column;
          align-items: flex-start;
          margin: 0;
          gap: 0.15rem;
          width: 100%;
        }
        .premium.layout-sidebar > .p-hdr .p-hdr__nav a {
          width: 100%;
        }
        /* Push the CTA to the bottom of the rail. */
        .premium.layout-sidebar > .p-hdr .p-hdr__actions {
          margin: auto 0 0 0;
          flex-direction: column;
          align-items: flex-start;
          width: 100%;
        }
        .premium.layout-sidebar > main {
          grid-area: main;
        }
        .premium.layout-sidebar > footer {
          grid-area: foot;
        }
      }
    </style>

    <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <div class:list={['premium', `layout-${layout}`]}>
      <a class="skip-link" href="#main">Skip to main content</a>
      <PremiumHeader config={config} page={page} />
      <main id="main" transition:name="page-main">
        <slot />
      </main>
      <PremiumFooter config={config} />
      <StickyContactBar config={config} />
    </div>

    <script>
      // Scroll-reveal: add .is-visible as [data-reveal] enters the viewport.
      // Re-inits on first load AND after every View-Transition navigation.
      // Content is VISIBLE by default; we ARM the opacity:0 starting state
      // (.reveal-armed) just-in-time, and ONLY on motion-capable clients — so a
      // reduced-motion or no-JS visitor never sees a faded/blank section.
      function initReveal() {
        const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (reduce) return;
        const root = document.querySelector('.premium');
        root?.classList.add('reveal-armed');

        // Hero word-reveal: the heading is painted FULLY OPAQUE first (the
        // hidden start-state is gated behind .hero-armed, NOT .reveal-armed),
        // so the LCP element is never invisible. We then set the hidden state,
        // force a reflow to commit that paint, and add .is-hero-in on the next
        // frame so the words ease up. Pure transform/opacity → zero CLS, and
        // LCP is captured on the opaque first paint.
        const hero = document.querySelector<HTMLElement>('.premium .p-hero');
        if (hero) {
          requestAnimationFrame(() => {
            hero.classList.add('hero-armed');
            void hero.offsetWidth; // flush the hidden start-state to a paint
            requestAnimationFrame(() => hero.classList.add('is-hero-in'));
          });
        }

        const els = document.querySelectorAll('.premium [data-reveal]:not(.is-visible)');
        if (els.length) {
          const io = new IntersectionObserver(
            (entries) => {
              for (const e of entries) {
                if (e.isIntersecting) {
                  e.target.classList.add('is-visible');
                  io.unobserve(e.target);
                }
              }
            },
            { threshold: 0.12, rootMargin: '0px 0px -40px 0px' },
          );
          els.forEach((el) => io.observe(el));
        }

        // Defer the non-critical interaction JS (count-up rAF loop + magnetic
        // CTA wiring) to main-thread idle so it lands OUTSIDE the load/TBT
        // window. The count-up animation on above-the-fold stats was adding
        // ~200ms TBT on heavier pages (designer-smiles: 0 → 218ms); pushing it
        // past TTI restores TBT≈0 with no visible change (the count still fires
        // the moment its stat is in view, just armed a beat later).
        const w = window as Window & { requestIdleCallback?: (cb: () => void, o?: { timeout?: number }) => number };
        const idle = (cb: () => void) =>
          w.requestIdleCallback ? w.requestIdleCallback(cb, { timeout: 600 }) : window.setTimeout(cb, 1);
        idle(() => { initCountUp(root); initMagnetic(reduce); });
      }

      // Count-up: animate [data-countup] numbers from 0 → value on first view.
      // Splits a leading number off any prefix/suffix ("4.9★", "$2k+", "1,200")
      // so units/symbols are preserved. Tiny, dependency-free, IO-gated.
      function initCountUp(root: Element | null) {
        if (typeof IntersectionObserver === 'undefined') return;
        const els = (root ?? document).querySelectorAll<HTMLElement>('[data-countup]:not(.is-counted)');
        if (!els.length) return;
        const run = (el: HTMLElement) => {
          el.classList.add('is-counted');
          const raw = el.textContent || '';
          const m = raw.match(/^(\D*)(\d[\d,]*\.?\d*)(.*)$/s);
          if (!m) return;
          const pre = m[1], numStr = m[2].replace(/,/g, ''), suf = m[3];
          const target = parseFloat(numStr);
          if (!isFinite(target)) return;
          const dec = numStr.includes('.') ? (numStr.split('.')[1]?.length ?? 0) : 0;
          const commas = m[2].includes(',');
          const fmt = (v: number) => dec ? v.toFixed(dec) : (commas ? Math.round(v).toLocaleString() : String(Math.round(v)));
          const dur = 1300, start = performance.now();
          const ease = (t: number) => 1 - Math.pow(1 - t, 3);
          const frame = (now: number) => {
            const p = Math.min((now - start) / dur, 1);
            el.textContent = pre + fmt(target * ease(p)) + suf;
            if (p < 1) requestAnimationFrame(frame);
            else el.textContent = raw;
          };
          requestAnimationFrame(frame);
        };
        const io = new IntersectionObserver((entries) => {
          for (const e of entries) if (e.isIntersecting) { run(e.target as HTMLElement); io.unobserve(e.target); }
        }, { threshold: 0.3, rootMargin: '0px 0px -40px 0px' });
        els.forEach((el) => io.observe(el));
      }

      // Magnetic CTA: the primary hero button drifts a few px toward the cursor
      // and springs back. Hover-capable + fine-pointer only; cleaned up between
      // page swaps. Compositor-only transform; never runs under reduced motion.
      let magneticCleanup: (() => void) | null = null;
      function initMagnetic(reduce: boolean) {
        if (magneticCleanup) { magneticCleanup(); magneticCleanup = null; }
        if (reduce) return;
        if (!window.matchMedia('(hover: hover) and (pointer: fine)').matches) return;
        const btns = Array.from(document.querySelectorAll<HTMLElement>('.premium [data-magnetic]'));
        if (!btns.length) return;
        const handlers: Array<[HTMLElement, (ev: PointerEvent) => void, () => void]> = [];
        for (const btn of btns) {
          const move = (ev: PointerEvent) => {
            const r = btn.getBoundingClientRect();
            const dx = (ev.clientX - (r.left + r.width / 2)) / r.width;
            const dy = (ev.clientY - (r.top + r.height / 2)) / r.height;
            btn.style.transform = `translate(${(dx * 7).toFixed(2)}px, ${(dy * 7).toFixed(2)}px)`;
          };
          const leave = () => { btn.style.transform = ''; };
          btn.addEventListener('pointermove', move);
          btn.addEventListener('pointerleave', leave);
          handlers.push([btn, move, leave]);
        }
        magneticCleanup = () => {
          for (const [btn, move, leave] of handlers) {
            btn.removeEventListener('pointermove', move);
            btn.removeEventListener('pointerleave', leave);
            btn.style.transform = '';
          }
        };
      }
      document.addEventListener('astro:before-swap', () => { if (magneticCleanup) { magneticCleanup(); magneticCleanup = null; } });
      document.addEventListener('astro:page-load', initReveal);
    </script>

    <!-- Cinematic hero + smooth-scroll choreography. Self-contained, reduced-motion
         + no-WebGL + View-Transition safe (own teardown). Bundled by Astro. -->
    <script>
      import '../scripts/hero-cinematic';
    </script>

    <!-- Section motion: 3D card tilt, dark-band mouse spotlight, self-drawing
         accents. Self-contained, reduced-motion + fine-pointer gated, own teardown. -->
    <script>
      import '../scripts/effects';
    </script>
  </body>
</html>
