---
// Split hero: text on a solid brand panel beside a full-height photo.
// A structurally different silhouette from the full-bleed `Hero.astro`.
import type { ProspectConfig } from '../types';
const { config } = Astro.props as { config: ProspectConfig };
const telHref = `tel:${config.contact.phone.replace(/[^+\d]/g, '')}`;
const { images } = config;
---

<section class="splitHero" id="top">
  <div class="splitHero__panel">
    <p class="splitHero__eyebrow">{[config.established, config.area].filter(Boolean).join(' · ')}</p>
    <h1 class="splitHero__title">{config.hero.heading}</h1>
    <p class="splitHero__sub">{config.hero.subheading}</p>
    <div class="splitHero__actions">
      <a href={config.hero.ctaHref} class="btn">{config.hero.ctaText}</a>
      <a href={telHref} class="splitHero__phone">{config.contact.phone}</a>
    </div>
    <ul class="splitHero__highlights">
      {config.highlights.map((h) => <li>{h}</li>)}
    </ul>
  </div>
  <div class="splitHero__media">
    <img
      src={images.hero}
      alt={images.heroAlt}
      onerror={`this.onerror=null;this.src='${images.placeholder}'`}
      fetchpriority="high"
    />
  </div>
</section>

<style>
  .splitHero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: min(82vh, 720px);
  }
  .splitHero__panel {
    background: var(--brand-dark);
    color: #fff;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: clamp(2.5rem, 6vw, 5rem);
  }
  .splitHero__eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.2em;
    font-size: 0.74rem;
    font-weight: 700;
    color: color-mix(in srgb, var(--brand) 70%, #fff);
    margin-bottom: 1.25rem;
  }
  .splitHero__title {
    color: #fff;
    margin-bottom: 1.25rem;
  }
  .splitHero__sub {
    font-size: clamp(1.02rem, 1.6vw, 1.22rem);
    color: rgba(255, 255, 255, 0.88);
    max-width: 46ch;
    margin-bottom: 1.9rem;
  }
  .splitHero__actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem 1.5rem;
  }
  .splitHero__phone {
    color: #fff;
    font-weight: 600;
    border-bottom: 1px solid rgba(255, 255, 255, 0.5);
    padding-bottom: 2px;
  }
  .splitHero__phone:hover { text-decoration: none; border-color: #fff; }
  .splitHero__highlights {
    list-style: none;
    margin: 2.25rem 0 0;
    padding: 1.5rem 0 0;
    border-top: 1px solid rgba(255, 255, 255, 0.22);
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem 1.75rem;
    font-size: 0.82rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.82);
  }
  .splitHero__media {
    background: var(--brand-dark);
  }
  .splitHero__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  @media (max-width: 820px) {
    .splitHero {
      grid-template-columns: 1fr;
    }
    .splitHero__media {
      order: -1;
      min-height: 42vh;
    }
  }
</style>
