---
/**
 * SpecStrip — bold KPI / credentials strip for utility archetype pages.
 *
 * Renders big number+label blocks on a brand or deep band. Ideal for towing
 * response time, license number, coverage radius, satisfaction guarantee,
 * years in business, or any operational credential that closes the sale fast.
 *
 * Props mirror the SectionEnvelope contract + an items array that shares the
 * same shape as the stats section so data can be reused across both.
 *
 * Reduced-motion safe: transitions are all CSS-token-driven; the global hard
 * block in global.css disables them under prefers-reduced-motion.
 */
import type { SectionEnvelope } from '../../types';

interface SpecItem {
  /** The big display value — number, label, or short phrase. e.g. "45 min", "A+" */
  value: string;
  /** Short uppercase label below the value. e.g. "Response Time" */
  label: string;
  /** Optional icon character or short emoji-free symbol. e.g. "★" or "✔" */
  icon?: string;
}

interface Props extends SectionEnvelope {
  items: SpecItem[];
}

const {
  items = [],
  eyebrow,
  heading,
  intro,
  tone = 'brand',
  align = 'center',
} = Astro.props as Props;
---

{items.length > 0 && (
  <section class="section spec-strip" data-tone={tone} id="spec-strip">
    <div class="container">

      {(eyebrow || heading || intro) && (
        <div
          class:list={['spec-strip__head', align === 'center' && 'spec-strip__head--center']}
          data-reveal
        >
          {eyebrow && <p class="eyebrow">{eyebrow}</p>}
          {heading && <h2 class="spec-strip__heading">{heading}</h2>}
          {intro   && <p  class="spec-strip__intro">{intro}</p>}
        </div>
      )}

      <ul class="spec-strip__grid" role="list" data-reveal-stagger>
        {items.map(({ value, label, icon }) => (
          <li class="spec-item">
            {icon && (
              <span class="spec-item__icon" aria-hidden="true">{icon}</span>
            )}
            <strong class="spec-item__value">{value}</strong>
            <span  class="spec-item__label">{label}</span>
          </li>
        ))}
      </ul>

    </div>
  </section>
)}

<style>
  /* ── Band surface ─────────────────────────────────────────────────────── */
  .spec-strip {
    padding-block: calc(var(--section-pad) * 0.65);
    /* top+bottom rule gives the band a structural, "stamped" feel */
    border-top:    3px solid rgba(0, 0, 0, 0.18);
    border-bottom: 3px solid rgba(0, 0, 0, 0.18);
  }

  .container {
    max-width: var(--maxw);
    margin-inline: auto;
    padding-inline: var(--gutter);
  }

  /* ── Optional header block ──────────────────────────────────────────── */
  .spec-strip__head {
    margin-bottom: calc(var(--section-pad) * 0.45);
    max-width: 56ch;
  }
  .spec-strip__head--center {
    text-align: center;
    margin-inline: auto;
  }

  .spec-strip__heading {
    font-family: var(--font-display);
    font-size: var(--step-3);
    font-weight: var(--fw-display);
    letter-spacing: var(--tracking-display);
    line-height: var(--leading-display);
    /* In [data-tone="brand"/"deep"] contexts the color is set via tone rules below */
    margin: 0 0 0.4em;
  }

  .spec-strip__intro {
    font-size: var(--step-0);
    line-height: var(--leading-body);
    margin: 0;
    opacity: 0.88;
  }

  /* ── Grid of KPI blocks ─────────────────────────────────────────────── */
  .spec-strip__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    /* At least 2 wide on mobile, expand to however many items fit */
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 160px), 1fr));
    gap: 0;
    /* Hard vertical dividers give the "operational dashboard" look */
    border-left: 2px solid rgba(255, 255, 255, 0.18);
  }

  /* ── Single KPI block ───────────────────────────────────────────────── */
  .spec-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 1.75rem 1.5rem;
    border-right: 2px solid rgba(255, 255, 255, 0.18);
    position: relative;
    /* Subtle hover highlight without transform (safe for reduced-motion) */
    transition: background var(--motion-fade) var(--motion-ease);
  }

  .spec-item:hover {
    background: rgba(255, 255, 255, 0.07);
  }

  /* Icon: large enough to read, muted so the number stays dominant */
  .spec-item__icon {
    display: block;
    font-size: var(--step-1);
    line-height: 1;
    margin-bottom: 0.4rem;
    opacity: 0.75;
  }

  /* The BIG value — this is the whole point of the strip */
  .spec-item__value {
    display: block;
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 5vw + 1rem, 3.6rem);
    font-weight: var(--fw-display);
    letter-spacing: -0.02em;
    line-height: 1;
    /* Inherits from tone surface — see tone rules below */
  }

  /* Short uppercase credential label */
  .spec-item__label {
    display: block;
    margin-top: 0.45rem;
    font-family: var(--font-body);
    font-size: var(--step--1);
    font-weight: var(--fw-bold);
    letter-spacing: var(--tracking-eyebrow);
    text-transform: uppercase;
    opacity: 0.78;
    line-height: 1.3;
  }

  /* ── Tone surfaces ──────────────────────────────────────────────────── */

  /* Brand band (default for this component) */
  .spec-strip[data-tone="brand"] {
    background: var(--brand);
    color: var(--brand-contrast);
  }
  .spec-strip[data-tone="brand"] .spec-strip__heading {
    color: var(--brand-contrast);
  }
  .spec-strip[data-tone="brand"] .eyebrow {
    color: var(--accent);
  }
  .spec-strip[data-tone="brand"] .spec-strip__grid {
    border-left-color: rgba(255, 255, 255, 0.2);
  }
  .spec-strip[data-tone="brand"] .spec-item {
    border-right-color: rgba(255, 255, 255, 0.2);
  }

  /* Deep (dark) band */
  .spec-strip[data-tone="deep"] {
    background: var(--bg-deep);
    color: var(--text-on-dark);
  }
  .spec-strip[data-tone="deep"] .spec-strip__heading {
    color: var(--text-on-dark);
  }
  .spec-strip[data-tone="deep"] .eyebrow {
    color: var(--accent);
  }
  .spec-strip[data-tone="deep"] .spec-strip__grid {
    border-left-color: rgba(255, 255, 255, 0.12);
  }
  .spec-strip[data-tone="deep"] .spec-item {
    border-right-color: rgba(255, 255, 255, 0.12);
  }
  .spec-strip[data-tone="deep"] .spec-item__value {
    color: var(--text-on-dark);
  }

  /* Alt band (lighter alternative, keeps brand accent on the value) */
  .spec-strip[data-tone="alt"] {
    background: var(--bg-alt);
    color: var(--text);
  }
  .spec-strip[data-tone="alt"] .spec-strip__heading { color: var(--text); }
  .spec-strip[data-tone="alt"] .spec-item__value    { color: var(--brand); }
  .spec-strip[data-tone="alt"] .spec-strip__grid  {
    border-left-color: var(--border);
  }
  .spec-strip[data-tone="alt"] .spec-item {
    border-right-color: var(--border);
  }
  .spec-strip[data-tone="alt"] .spec-item:hover {
    background: color-mix(in srgb, var(--brand) 5%, var(--bg-alt));
  }

  /* Default (page bg) */
  .spec-strip[data-tone="default"] {
    background: var(--bg);
    color: var(--text);
  }
  .spec-strip[data-tone="default"] .spec-item__value { color: var(--brand); }
  .spec-strip[data-tone="default"] .spec-strip__grid  {
    border-left-color: var(--border);
  }
  .spec-strip[data-tone="default"] .spec-item {
    border-right-color: var(--border);
  }
  .spec-strip[data-tone="default"] .spec-item:hover {
    background: var(--bg-alt);
  }

  /* ── Responsive ─────────────────────────────────────────────────────── */
  @media (max-width: 540px) {
    .spec-strip__grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .spec-item {
      padding: 1.25rem 1rem;
    }
  }

  @media (max-width: 340px) {
    .spec-strip__grid {
      grid-template-columns: 1fr;
    }
    .spec-strip__grid,
    .spec-item {
      border-left:  none;
      border-right: none;
      border-bottom: 1px solid rgba(255, 255, 255, 0.18);
    }
    .spec-item:last-child {
      border-bottom: none;
    }
  }
</style>
