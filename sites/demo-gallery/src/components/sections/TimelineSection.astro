---
/**
 * TimelineSection — refined vertical/numbered chapter timeline.
 * --accent markers (dot + spine). Numbered chapter counter as a typographic
 * divider beside each entry (Zorah / Awwwards numbered-section pattern).
 * Header via SectionHead. Mobile-first, accessible, no client JS.
 */
import SectionHead from './SectionHead.astro';
import type { SectionEnvelope } from '../../types';

interface TimelineItem {
  year?: string;
  title: string;
  body?: string;
}

interface Props extends SectionEnvelope {
  items: TimelineItem[];
  index?: number;
}

const {
  items,
  eyebrow,
  heading,
  intro,
  tone = 'default',
  align = 'left',
  index,
} = Astro.props as Props;
---

<section class="section timeline-section" data-tone={tone}>
  <div class="container">
    <SectionHead {index} {eyebrow} {heading} {intro} {align} />

    {items.length > 0 && (
      <ol class="tl" aria-label={heading ?? 'Timeline'}>
        {items.map((item, i) => (
          <li class="tl__item" data-reveal data-reveal-order={i}>
            {/* Left column: chapter number + spine */}
            <div class="tl__track" aria-hidden="true">
              <span class="tl__num">{String(i + 1).padStart(2, '0')}</span>
              <span class="tl__dot"></span>
              {/* spine drawn via CSS border on the track column */}
            </div>

            {/* Right column: content */}
            <div class="tl__body">
              {item.year && (
                <span class="tl__year">{item.year}</span>
              )}
              <h3 class="tl__title">{item.title}</h3>
              {item.body && (
                <p class="tl__text">{item.body}</p>
              )}
            </div>
          </li>
        ))}
      </ol>
    )}
  </div>
</section>

<style>
  /* ── Shell ──────────────────────────────────────────────────────────────── */
  .timeline-section {
    padding-block: var(--section-pad);
    background: var(--bg);
    color: var(--text);
  }
  .container {
    max-width: var(--maxw);
    margin-inline: auto;
    padding-inline: var(--gutter);
  }

  /* ── Timeline list ─────────────────────────────────────────────────────── */
  .tl {
    list-style: none;
    margin: 0;
    padding: 0;
    /* constrain the timeline to a comfortable reading width + the track col */
    max-width: min(100%, 720px);
  }

  /* ── Each item: two-column grid (track | content) ─────────────────────── */
  .tl__item {
    display: grid;
    grid-template-columns: 3.5rem 1fr;
    column-gap: clamp(1.25rem, 3vw, 2rem);
    padding-bottom: clamp(2rem, 5vw, 3.5rem);
    position: relative;
  }
  .tl__item:last-child {
    padding-bottom: 0;
  }

  /* ── Track column: chapter number above, dot + spine below ─────────────── */
  .tl__track {
    display: flex;
    flex-direction: column;
    align-items: center;
    /* spine: a border on the track column stretching past the dot */
    border-inline-end: 1px solid color-mix(in srgb, var(--accent) 28%, var(--border));
    /* fade the spine out on the last item */
    position: relative;
  }
  .tl__item:last-child .tl__track {
    border-inline-end: none;
  }

  /* Chapter number — small tracked label, --accent, top of track */
  .tl__num {
    font-family: var(--font-body);
    font-size: var(--step--1);
    font-weight: var(--fw-bold);
    letter-spacing: var(--tracking-eyebrow);
    color: var(--accent);
    font-variant-numeric: tabular-nums;
    line-height: 1;
    /* align it flush to the spine */
    margin-inline-end: calc(-1 * 0.5em);
    padding-bottom: 0.75rem;
  }

  /* Accent dot — sits on the spine line, centered */
  .tl__dot {
    display: block;
    width: 0.65rem;
    height: 0.65rem;
    border-radius: var(--radius-pill);
    background: var(--accent);
    /* nudge slightly to sit ON the spine (the border is on the right edge of track) */
    margin-inline-end: calc(-0.325rem - 0.5px);
    flex-shrink: 0;
    /* ring around the dot */
    box-shadow:
      0 0 0 3px color-mix(in srgb, var(--accent) 18%, transparent),
      0 0 0 1px var(--bg);
  }

  /* ── Content column ────────────────────────────────────────────────────── */
  .tl__body {
    padding-top: 0;
    /* slight upward alignment so the title sits flush with the dot */
    padding-block-start: 0.05rem;
  }

  .tl__year {
    display: inline-block;
    font-family: var(--font-body);
    font-size: var(--step--1);
    font-weight: var(--fw-bold);
    letter-spacing: var(--tracking-eyebrow);
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 0.35rem;
    line-height: 1;
  }

  .tl__title {
    font-family: var(--font-display);
    font-size: var(--step-2);
    font-weight: var(--fw-display);
    letter-spacing: var(--tracking-display);
    line-height: var(--leading-display);
    color: var(--text);
    margin: 0 0 0.55rem;
    text-wrap: balance;
  }

  .tl__text {
    font-family: var(--font-body);
    font-size: var(--step-0);
    line-height: var(--leading-body);
    color: var(--text-muted);
    margin: 0;
    max-width: 58ch;
  }

  /* ── Tone overrides ─────────────────────────────────────────────────────── */
  [data-tone='alt'] {
    background: var(--bg-alt);
  }

  [data-tone='deep'] {
    background: var(--bg-deep);
    color: var(--text-on-dark);
  }
  [data-tone='deep'] .tl__track {
    border-color: color-mix(in srgb, var(--accent) 35%, transparent);
  }
  [data-tone='deep'] .tl__dot {
    box-shadow:
      0 0 0 3px color-mix(in srgb, var(--accent) 22%, transparent),
      0 0 0 1px var(--bg-deep);
  }
  [data-tone='deep'] .tl__title {
    color: var(--text-on-dark);
  }
  [data-tone='deep'] .tl__year {
    color: color-mix(in srgb, var(--text-on-dark) 60%, transparent);
  }
  [data-tone='deep'] .tl__text {
    color: color-mix(in srgb, var(--text-on-dark) 72%, transparent);
  }

  [data-tone='brand'] {
    background: var(--brand);
    color: var(--brand-contrast);
  }
  [data-tone='brand'] .tl__num {
    color: var(--brand-contrast);
    opacity: 0.7;
  }
  [data-tone='brand'] .tl__dot {
    background: var(--brand-contrast);
    box-shadow:
      0 0 0 3px color-mix(in srgb, var(--brand-contrast) 22%, transparent),
      0 0 0 1px var(--brand);
  }
  [data-tone='brand'] .tl__track {
    border-color: color-mix(in srgb, var(--brand-contrast) 25%, transparent);
  }
  [data-tone='brand'] .tl__title {
    color: var(--brand-contrast);
  }
  [data-tone='brand'] .tl__year {
    color: color-mix(in srgb, var(--brand-contrast) 70%, transparent);
  }
  [data-tone='brand'] .tl__text {
    color: color-mix(in srgb, var(--brand-contrast) 80%, transparent);
  }

  /* ── Mobile: tighten the track column ──────────────────────────────────── */
  @media (max-width: 480px) {
    .tl {
      max-width: 100%;
    }
    .tl__item {
      grid-template-columns: 2.5rem 1fr;
      column-gap: 1rem;
    }
    .tl__num {
      font-size: 0.65rem;
    }
  }
</style>
