---
/**
 * TestimonialsSpotlight — single oversized pull-quote spotlight.
 * Award-site silhouette: one hero quote in display type with a large decorative
 * opening mark, author + source in tracked small-caps beneath. Remaining items
 * surface as a slim secondary attribution row — not a second card grid.
 * Drop-in variant: identical props to TestimonialsSection.
 */
import SectionHead from './SectionHead.astro';
import type { Section } from '../../types';

type Props = Extract<Section, { type: 'testimonials' }> & { index?: number };

const {
  eyebrow = 'In their words',
  heading,
  intro,
  tone = 'default',
  align = 'left',
  items = [],
  index,
} = Astro.props as Props;

/* Pick the longest quote as the spotlight — feels most intentional at scale. */
const sorted = [...items].sort((a, b) => b.quote.length - a.quote.length);
const [spotlight, ...secondary] = sorted;
---

{items.length > 0 && (
  <section class="section tmsl" data-tone={tone}>
    <div class="container">
      <SectionHead {index} {eyebrow} {heading} {intro} {align} />

      {/* ── Spotlight quote ─────────────────────────────────────────── */}
      <figure class="tmsl__spotlight" data-reveal>
        <blockquote class="tmsl__blockquote">
          <p class="tmsl__pull">{spotlight.quote}</p>
        </blockquote>
        <figcaption class="tmsl__caption">
          <span class="tmsl__author">{spotlight.author}</span>
          {spotlight.source && (
            <span class="tmsl__source">{spotlight.source}</span>
          )}
        </figcaption>
      </figure>

      {/* ── Secondary attributions ──────────────────────────────────── */}
      {secondary.length > 0 && (
        <ol class="tmsl__secondary" role="list" data-reveal data-reveal-stagger>
          {secondary.map((item) => (
            <li class="tmsl__secondary-item">
              <p class="tmsl__secondary-quote">{item.quote}</p>
              <p class="tmsl__secondary-attr">
                <span class="tmsl__author tmsl__author--sm">{item.author}</span>
                {item.source && (
                  <span class="tmsl__source">{item.source}</span>
                )}
              </p>
            </li>
          ))}
        </ol>
      )}
    </div>
  </section>
)}

<style>
  /* ── Section shell ──────────────────────────────────────────────────── */
  .tmsl {
    padding-block: var(--section-pad);
    background: var(--bg);
    color: var(--text);
  }
  .tmsl[data-tone='alt']   { background: var(--bg-alt); }
  .tmsl[data-tone='deep']  { background: var(--bg-deep);  color: var(--text-on-dark); }
  .tmsl[data-tone='brand'] { background: var(--brand);    color: var(--brand-contrast); }

  .container {
    max-width: var(--maxw);
    margin-inline: auto;
    padding-inline: var(--gutter);
  }

  /* ── Spotlight figure ───────────────────────────────────────────────── */
  .tmsl__spotlight {
    margin: 0;
    /* Generous vertical breathing room — this is the editorial moment. */
    padding-block: clamp(3rem, 8vw, 6rem);
    /* Centre the whole spotlight on wider viewports. */
    max-width: 78ch;
    margin-inline: auto;
    text-align: center;
  }

  /* ── Oversized pull quote ───────────────────────────────────────────── */
  .tmsl__blockquote {
    margin: 0 0 clamp(1.25rem, 3vw, 2rem);
    position: relative;
  }

  /* Decorative opening mark — large, brand-tinted, aria-ignored. */
  .tmsl__blockquote::before {
    content: '\201C';
    display: block;
    font-family: var(--font-display);
    font-size: clamp(4rem, 12vw, 9rem);
    font-style: normal;
    font-weight: var(--fw-display);
    line-height: 0.8;
    color: var(--brand);
    opacity: 0.25;
    margin-bottom: 0.2em;
    /* Slight negative margin so the mark feels attached to the text above. */
    margin-top: -0.1em;
  }
  .tmsl[data-tone='deep']  .tmsl__blockquote::before,
  .tmsl[data-tone='brand'] .tmsl__blockquote::before {
    color: currentColor;
    opacity: 0.3;
  }

  .tmsl__pull {
    font-family: var(--font-display);
    font-size: clamp(var(--step-2), 4vw, var(--step-4));
    font-style: italic;
    font-weight: var(--fw-display);
    line-height: 1.18;
    letter-spacing: var(--tracking-display);
    color: var(--text);
    text-wrap: balance;
    margin: 0;
  }
  .tmsl[data-tone='deep']  .tmsl__pull { color: var(--text-on-dark); }
  .tmsl[data-tone='brand'] .tmsl__pull { color: var(--brand-contrast); }

  /* ── Attribution below spotlight ───────────────────────────────────── */
  .tmsl__caption {
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  /* Shared small-caps author style — used at two sizes. */
  .tmsl__author {
    font-family: var(--font-body);
    font-size: var(--step-0);
    font-weight: var(--fw-bold);
    letter-spacing: var(--tracking-eyebrow);
    text-transform: uppercase;
    font-variant-caps: all-small-caps;
    color: var(--text);
  }
  .tmsl[data-tone='deep']  .tmsl__author { color: var(--text-on-dark); }
  .tmsl[data-tone='brand'] .tmsl__author { color: var(--brand-contrast); }

  .tmsl__author--sm {
    font-size: var(--step--1);
  }

  .tmsl__source {
    font-family: var(--font-body);
    font-size: var(--step--1);
    letter-spacing: var(--tracking-eyebrow);
    text-transform: uppercase;
    font-variant-caps: all-small-caps;
    color: var(--text-muted);
  }
  .tmsl__source::before {
    content: '\2014\00a0';
    opacity: 0.5;
  }
  .tmsl[data-tone='deep']  .tmsl__source,
  .tmsl[data-tone='brand'] .tmsl__source {
    color: inherit;
    opacity: 0.65;
  }

  /* ── Divider between spotlight and secondary row ────────────────────── */
  .tmsl__secondary {
    list-style: none;
    margin: 0;
    padding: 0;
    border-top: var(--border-weight) solid var(--border);
    /* Secondary row is slim — a hint, not a section of its own. */
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
  }
  .tmsl[data-tone='deep']  .tmsl__secondary,
  .tmsl[data-tone='brand'] .tmsl__secondary {
    border-top-color: color-mix(in srgb, currentColor 18%, transparent);
  }

  .tmsl__secondary-item {
    border-bottom: var(--border-weight) solid var(--border);
    padding-block: clamp(1rem, 2.5vw, 1.5rem);
  }
  .tmsl[data-tone='deep']  .tmsl__secondary-item,
  .tmsl[data-tone='brand'] .tmsl__secondary-item {
    border-bottom-color: color-mix(in srgb, currentColor 18%, transparent);
  }

  .tmsl__secondary-quote {
    font-family: var(--font-body);
    font-size: var(--step-0);
    font-style: italic;
    color: var(--text-muted);
    line-height: var(--leading-body);
    margin: 0 0 0.5rem;
    /* Clamp to two lines — secondary items are citations, not features. */
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .tmsl[data-tone='deep']  .tmsl__secondary-quote,
  .tmsl[data-tone='brand'] .tmsl__secondary-quote {
    color: color-mix(in srgb, currentColor 65%, transparent);
  }

  .tmsl__secondary-attr {
    display: flex;
    align-items: baseline;
    gap: 0.4rem;
    flex-wrap: wrap;
    margin: 0;
  }

  /* ── Wide: secondary items lay out side-by-side (up to 3 columns) ──── */
  @media (min-width: 40rem) {
    .tmsl__secondary {
      grid-template-columns: repeat(auto-fill, minmax(22ch, 1fr));
    }
    .tmsl__secondary-item {
      border-right: var(--border-weight) solid var(--border);
      padding-inline: clamp(1rem, 2vw, 1.75rem);
    }
    .tmsl__secondary-item:first-child {
      padding-inline-start: 0;
    }
    .tmsl[data-tone='deep']  .tmsl__secondary-item,
    .tmsl[data-tone='brand'] .tmsl__secondary-item {
      border-right-color: color-mix(in srgb, currentColor 18%, transparent);
    }
  }

  @media (min-width: 64rem) {
    .tmsl__pull {
      font-size: var(--step-5);
    }
  }

  /* ── Reduced-motion: drop entrance animations ───────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    [data-reveal],
    [data-reveal-stagger] > * {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
  }
</style>
