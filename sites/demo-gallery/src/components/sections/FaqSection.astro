---
/**
 * FaqSection — editorial Q/A without accordion clutter.
 * Award pattern: accordion-less layout with hairline dividers, sticky header,
 * Q in display type, A in body with generous leading. Trades/salon/winery teardowns
 * all prefer clear typographic hierarchy over interactive disclosure.
 */
import SectionHead from './SectionHead.astro';
import type { Section } from '../../types';

type Props = Extract<Section, { type: 'faq' }> & { index?: number };

const {
  eyebrow = 'Good to know',
  heading = 'Common questions',
  intro,
  tone = 'default',
  align = 'left',
  items = [],
  index,
} = Astro.props as Props;
---

<section class="section faq" data-tone={tone}>
  <div class="container">
    <div class="faq__layout">

      {/* Sticky header col — 38% */}
      <div class="faq__aside">
        <SectionHead {index} {eyebrow} {heading} {intro} {align} />
      </div>

      {/* Q/A list col — 62% */}
      {items.length > 0 && (
        <dl class="faq__list" role="list">
          {items.map((item, i) => (
            <div class="faq__row" data-reveal data-reveal-stagger data-reveal-order={i}>
              <dt class="faq__q">{item.q}</dt>
              <dd class="faq__a">{item.a}</dd>
            </div>
          ))}
        </dl>
      )}

    </div>
  </div>
</section>

<style>
  /* ── Section shell ── */
  .faq {
    padding-block: var(--section-pad);
    background: var(--bg);
    color: var(--text);
  }
  .faq[data-tone='alt']   { background: var(--bg-alt); }
  .faq[data-tone='deep']  { background: var(--bg-deep); color: var(--text-on-dark); }
  .faq[data-tone='brand'] { background: var(--brand);   color: var(--brand-contrast); }

  .container {
    max-width: var(--maxw);
    margin-inline: auto;
    padding-inline: var(--gutter);
  }

  /* ── 38 / 62 asymmetric layout ── */
  .faq__layout {
    display: grid;
    grid-template-columns: 38fr 62fr;
    gap: clamp(3rem, 6vw, 6rem);
    align-items: start;
  }

  .faq__aside {
    position: sticky;
    top: clamp(3rem, 8vw, 5rem);
  }

  /* ── Q/A list ── */
  .faq__list {
    margin: 0;
    padding: 0;
  }

  .faq__row {
    border-top: var(--border-weight) solid var(--border);
    padding-block: clamp(1.4rem, 2.5vw, 2rem);
  }

  /* Last item gets a closing hairline */
  .faq__row:last-child {
    border-bottom: var(--border-weight) solid var(--border);
  }

  /* On dark/brand tones the hairlines are pale */
  .faq[data-tone='deep']  .faq__row,
  .faq[data-tone='brand'] .faq__row {
    border-color: color-mix(in srgb, currentColor 20%, transparent);
  }

  /* Question — display face, step-1, tight leading */
  .faq__q {
    font-family: var(--font-display);
    font-size: var(--step-1);
    font-weight: var(--fw-display);
    letter-spacing: var(--tracking-display);
    line-height: var(--leading-display);
    color: var(--text);
    margin: 0 0 0.7rem;
    text-wrap: balance;
  }

  .faq[data-tone='deep']  .faq__q { color: var(--text-on-dark); }
  .faq[data-tone='brand'] .faq__q { color: var(--brand-contrast); }

  /* Answer — body face, generous leading, muted */
  .faq__a {
    font-size: var(--step-0);
    line-height: var(--leading-body);
    color: var(--text-muted);
    margin: 0;
    max-width: 64ch;
  }

  .faq[data-tone='deep']  .faq__a,
  .faq[data-tone='brand'] .faq__a {
    color: color-mix(in srgb, currentColor 75%, transparent);
  }

  /* ── Responsive: stack on narrow viewports ── */
  @media (max-width: 720px) {
    .faq__layout {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .faq__aside {
      position: static;
    }
  }
</style>
