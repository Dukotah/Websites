---
/**
 * GallerySection — premium editorial masonry gallery.
 *
 * Design decisions from award teardowns (award-teardowns.json):
 *
 * LAYOUT — not a uniform grid.  Images are assigned to one of four
 * repeating "panel groups" that alternate across the tile stream:
 *   Group A (wide-narrow)   : 1 landscape hero (2/3) + 1 portrait (1/3)
 *   Group B (stacked right) : 2 stacked landscapes right, 1 tall portrait left
 *   Group C (three-col)     : portrait (1fr) · landscape (2fr) · portrait (1fr)
 *   Group D (reversed B)    : 1 tall portrait right, 2 stacked landscapes left
 * Each group is a CSS Grid island — tiles are never forcibly equal.
 *
 * HOVER — the image itself scales (1.04) inside overflow:hidden; the
 * container never moves.  No lift, no shadow change, no overlay.
 * This is the gallery-quality hover from every editorial site studied.
 * Reduced-motion: transform skipped entirely.
 *
 * CAPTIONS — frosted-glass bar that slides up from behind the image on
 * hover.  Off-screen at rest (transform: translateY(100%)).  Italicised
 * body type, small-caps attribution line if present.  Invisible to
 * reduced-motion users (caption rendered as plain text below instead).
 *
 * DATA-FRAME — every figure carries data-frame so global frame tokens
 * (treatment.css) compose on top of our rules.
 *
 * TONE — default / alt / deep / brand honored via [data-tone].
 *
 * Props:
 *   images   { src, alt, caption? }[]   — the photo stream
 *   eyebrow? heading? intro?            — passed to SectionHead
 *   tone?    align?                     — section-level
 *   index?                              — chapter number from SectionRenderer
 */

import type { SectionEnvelope } from '../../types';
import SectionHead from './SectionHead.astro';
import SiteImage from '../SiteImage.astro';

interface GalleryImage {
  src: string;
  alt: string;
  caption?: string;
}

interface Props extends SectionEnvelope {
  images: GalleryImage[];
  index?: number;
  /** Photo treatment from artDirection config — applies to all gallery cells. */
  photoTreatment?: 'duotone' | 'natural' | 'muted';
  /** Film-grain texture from artDirection config — adds [data-grain] to cells. */
  photoGrain?: boolean;
}

const {
  images = [],
  eyebrow,
  heading,
  intro,
  tone = 'default',
  align = 'center',
  index,
  photoTreatment = 'natural',
  photoGrain = false,
} = Astro.props as Props;

// Derive treatment classes/attrs for .gallery__thumb wrappers
const thumbDuotone = photoTreatment === 'duotone';
const thumbMuted   = photoTreatment === 'muted';

/**
 * Assign each image a "slot" within its repeating group.
 * Groups cycle A → B → C → D → A → …
 * Each group has a fixed number of images; within the group each image
 * gets a data-span attribute the CSS grid reads.
 *
 * Group A (2 images): hero-wide + portrait-narrow
 * Group B (3 images): tall-portrait-left + two-stacked-right (2 images)
 * Group C (3 images): portrait + wide-center + portrait
 * Group D (3 images): two-stacked-left + tall-portrait-right
 * Single leftover images fill a full-row span.
 */
type GroupId = 'a' | 'b' | 'c' | 'd';

interface SlottedImage extends GalleryImage {
  group: GroupId;
  slot: number;     // 0-based slot within its group
  groupSize: number;
}

function slotImages(imgs: GalleryImage[]): SlottedImage[] {
  const groupSizes: Record<GroupId, number> = { a: 2, b: 3, c: 3, d: 3 };
  const groupOrder: GroupId[] = ['a', 'b', 'c', 'd'];
  const result: SlottedImage[] = [];
  let i = 0;
  let g = 0;
  while (i < imgs.length) {
    const group = groupOrder[g % groupOrder.length] as GroupId;
    const size = groupSizes[group];
    const remaining = imgs.length - i;
    if (remaining < size) {
      // Fill the rest as solo full-spans
      for (; i < imgs.length; i++) {
        result.push({ ...imgs[i], group: 'a', slot: 0, groupSize: 1 });
      }
      break;
    }
    for (let s = 0; s < size; s++, i++) {
      result.push({ ...imgs[i], group, slot: s, groupSize: size });
    }
    g++;
  }
  return result;
}

const slotted = slotImages(images);

// Build groups for rendering (group consecutive same-group items together)
interface RenderGroup {
  id: GroupId;
  items: SlottedImage[];
}

function buildRenderGroups(slottedImgs: SlottedImage[]): RenderGroup[] {
  const groups: RenderGroup[] = [];
  let current: RenderGroup | null = null;
  for (const img of slottedImgs) {
    if (!current || current.items[0].group !== img.group || img.slot === 0) {
      if (current) groups.push(current);
      current = { id: img.group, items: [img] };
    } else {
      current.items.push(img);
    }
  }
  if (current) groups.push(current);
  return groups;
}

const renderGroups = buildRenderGroups(slotted);
---

{images.length > 0 && (
  <section class="section gallery" data-tone={tone}>
    <div class="container">
      <SectionHead
        index={index}
        eyebrow={eyebrow}
        heading={heading}
        intro={intro}
        align={align}
      />

      <div class="gallery__stream">
        {renderGroups.map((grp) => (
          <div class={`gallery__group gallery__group--${grp.id}`} data-reveal data-reveal-stagger>
            {grp.items.map((img, si) => (
              <figure
                class={`gallery__cell gallery__cell--${grp.id}${si}`}
                data-frame
              >
                <div
                  class={[
                    'gallery__thumb',
                    thumbDuotone ? 'img-duotone' : '',
                  ].filter(Boolean).join(' ')}
                  data-treat={thumbMuted ? 'grade' : undefined}
                  data-grain={photoGrain ? '' : undefined}
                >
                  <SiteImage
                    src={img.src}
                    alt={img.alt}
                    class="gallery__img"
                    sizes="(min-width: 768px) 50vw, 100vw"
                  />
                  {thumbDuotone && photoGrain && (
                    <span class="grain-layer" aria-hidden="true"></span>
                  )}
                  {img.caption && (
                    <figcaption class="gallery__cap" aria-hidden="true">
                      <span class="gallery__cap-text">{img.caption}</span>
                    </figcaption>
                  )}
                </div>
                {img.caption && (
                  <p class="gallery__cap-fallback">{img.caption}</p>
                )}
              </figure>
            ))}
          </div>
        ))}
      </div>
    </div>
  </section>
)}

<style>
  /* ─── Shell ────────────────────────────────────────────────────────────────── */
  .gallery {
    padding-block: var(--section-pad);
  }

  .container {
    max-width: var(--maxw);
    margin-inline: auto;
    padding-inline: var(--gutter);
  }

  /* ─── Stream wrapper ────────────────────────────────────────────────────────── */
  .gallery__stream {
    display: flex;
    flex-direction: column;
    gap: clamp(0.75rem, 1.5vw, 1.25rem);
  }

  /* ─── Group grids ─────────────────────────────────────────────────────────── */

  /*
   * All groups stack to a single column on mobile; the editorial grid
   * kicks in from 640 px upward.
   */
  .gallery__group {
    display: grid;
    gap: clamp(0.75rem, 1.5vw, 1.25rem);
    grid-template-columns: 1fr;
  }

  /* GROUP A  — 1 wide-landscape (60%) + 1 portrait (40%) ─────────────────── */
  @media (min-width: 640px) {
    .gallery__group--a {
      grid-template-columns: 3fr 2fr;
    }
    .gallery__cell--a0 { aspect-ratio: 4 / 3; }
    .gallery__cell--a1 { aspect-ratio: 2 / 3; }
  }

  /* GROUP B  — 1 tall portrait (left) + 2 stacked landscapes (right) ──────── */
  @media (min-width: 640px) {
    .gallery__group--b {
      grid-template-columns: 2fr 3fr;
      grid-template-rows: 1fr 1fr;
    }
    .gallery__cell--b0 {
      grid-row: 1 / 3;
      aspect-ratio: 2 / 3;
    }
    .gallery__cell--b1,
    .gallery__cell--b2 {
      aspect-ratio: 16 / 9;
    }
  }

  /* GROUP C  — portrait · wide · portrait  (1fr 2fr 1fr) ─────────────────── */
  @media (min-width: 768px) {
    .gallery__group--c {
      grid-template-columns: 1fr 2fr 1fr;
    }
    .gallery__cell--c0 { aspect-ratio: 3 / 4; }
    .gallery__cell--c1 { aspect-ratio: 16 / 10; }
    .gallery__cell--c2 { aspect-ratio: 3 / 4; }
  }
  /* On narrower screens group C falls back to two columns */
  @media (min-width: 640px) and (max-width: 767px) {
    .gallery__group--c {
      grid-template-columns: 1fr 1fr;
    }
    .gallery__cell--c2 {
      grid-column: 1 / -1;
      aspect-ratio: 16 / 9;
    }
  }

  /* GROUP D  — 2 stacked landscapes (left) + 1 tall portrait (right) ──────── */
  @media (min-width: 640px) {
    .gallery__group--d {
      grid-template-columns: 3fr 2fr;
      grid-template-rows: 1fr 1fr;
    }
    .gallery__cell--d0,
    .gallery__cell--d1 {
      aspect-ratio: 16 / 9;
    }
    .gallery__cell--d2 {
      grid-column: 2;
      grid-row: 1 / 3;
      aspect-ratio: 2 / 3;
    }
  }

  /* ─── Cell ─────────────────────────────────────────────────────────────── */
  .gallery__cell {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-lg);
    background: var(--surface);
    /* Clip the image during zoom without a visible border */
  }

  /* ─── Thumb wrapper + image ─────────────────────────────────────────────── */
  .gallery__thumb {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
  }

  .gallery__img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    /* Will transition on non-reduced-motion — see below */
    transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  /* ─── Hover: image crop-zoom only ──────────────────────────────────────── */
  @media (prefers-reduced-motion: no-preference) {
    .gallery__cell:hover .gallery__img {
      transform: scale(1.04);
    }
  }

  /* ─── Caption: frosted bar slides up on hover ─────────────────────────── */
  .gallery__cap {
    position: absolute;
    inset-inline: 0;
    bottom: 0;
    padding: 0.75rem 1rem 0.85rem;
    background: color-mix(in srgb, var(--bg-deep) 80%, transparent);
    /* stylelint-disable-next-line property-no-unknown */
    -webkit-backdrop-filter: blur(10px) saturate(1.4);
    backdrop-filter: blur(10px) saturate(1.4);
    transform: translateY(100%);
    transition:
      transform 0.4s cubic-bezier(0.22, 1, 0.36, 1),
      opacity 0.4s ease;
    opacity: 0;
  }

  .gallery__cell:hover .gallery__cap,
  .gallery__cell:focus-within .gallery__cap {
    transform: translateY(0);
    opacity: 1;
  }

  /* Reduced-motion: no slide, caption visible as static bar */
  @media (prefers-reduced-motion: reduce) {
    .gallery__cap {
      transform: none;
      opacity: 1;
      position: static;
      background: var(--surface);
      backdrop-filter: none;
      -webkit-backdrop-filter: none;
    }
    /* Hide the duplicate fallback paragraph in reduced-motion since cap is visible */
    .gallery__cap-fallback { display: none; }
  }

  .gallery__cap-text {
    display: block;
    font-family: var(--font-body);
    font-size: var(--step--1);
    font-style: italic;
    color: var(--text-on-dark);
    line-height: var(--leading-body);
    letter-spacing: 0.01em;
  }

  /* ─── Accessibility fallback caption (screen-reader + no-hover) ─────────── */
  /*
   * The frosted bar is aria-hidden; this paragraph is visually hidden at rest
   * but remains in the a11y tree. Hidden visually on motion-ok + non-reduced
   * devices where the hover cap suffices.
  */
  .gallery__cap-fallback {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
  }

  /* On touch devices we reveal captions as a plain bar below the image */
  @media (hover: none) {
    .gallery__cap {
      position: static;
      transform: none;
      opacity: 1;
      backdrop-filter: none;
      -webkit-backdrop-filter: none;
      background: var(--surface);
      border-top: var(--border-weight) solid var(--border);
      padding: 0.55rem 0.85rem 0.65rem;
    }
    .gallery__cap-text {
      color: var(--text-muted);
    }
    .gallery__cap-fallback { display: none; }
  }

  /* ─── Mobile: all cells are natural aspect-ratio images ────────────────── */
  @media (max-width: 639px) {
    .gallery__cell {
      aspect-ratio: unset;
    }
    .gallery__thumb {
      height: auto;
    }
    .gallery__img {
      height: auto;
    }
  }

  /* ─── Tone overrides ─────────────────────────────────────────────────────── */
  [data-tone='alt'] { background: var(--bg-alt); }

  [data-tone='deep'] {
    background: var(--bg-deep);
    color: var(--text-on-dark);
  }
  [data-tone='deep'] .gallery__cell {
    background: var(--surface-2);
  }
  [data-tone='deep'] .gallery__cap-text {
    color: var(--text-on-dark);
  }

  [data-tone='brand'] {
    background: var(--brand);
    color: var(--brand-contrast);
  }
  [data-tone='brand'] .gallery__cell {
    background: color-mix(in srgb, var(--brand-dark) 60%, transparent);
  }
</style>
