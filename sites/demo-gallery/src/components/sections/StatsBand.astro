---
/**
 * StatsBand — bold horizontal KPI band (variant-1 of stats).
 *
 * Deliberately different silhouette from StatsSection: stats sit in a single
 * row separated by thin vertical DIVIDER RULES (border-inline-start on each
 * cell except the first). Oversized display numerals (clamped up to ~--step-6)
 * are the hero, stacked above small uppercase tracked labels. 2-up on mobile,
 * up to 4-across on desktop. Tone-aware; entrance via data-reveal + stagger.
 *
 * Props: identical to StatsSection (items, eyebrow, heading, intro, tone,
 * align, index) — drop-in swappable by the variant selector.
 */
import SectionHead from './SectionHead.astro';
import type { Section } from '../../types';

type Props = Extract<Section, { type: 'stats' }> & { index?: number };

const {
  eyebrow,
  heading,
  intro,
  tone = 'default',
  align = 'left',
  items = [],
  index,
} = Astro.props as Props;
---

{items.length > 0 && (
  <section class="section stats-band" data-tone={tone}>
    <div class="container">
      <SectionHead {index} {eyebrow} {heading} {intro} {align} />

      <div class="band__rail" role="list" data-reveal data-reveal-stagger>
        {items.map((item, i) => (
          <div
            class="band__cell"
            role="listitem"
            data-reveal
            data-reveal-order={i}
          >
            <div
              class="band__value"
              aria-label={`${item.value} — ${item.label}`}
            >
              {item.value}
            </div>
            <div class="band__label" aria-hidden="true">{item.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>
)}

<style>
  /* ── Shell ──────────────────────────────────────────────────────────────── */
  .stats-band {
    padding-block: var(--section-pad);
    background: var(--bg);
    color: var(--text);
  }

  .container {
    max-width: var(--maxw);
    margin-inline: auto;
    padding-inline: var(--gutter);
  }

  /* ── Rail: 2-up mobile → 4-across desktop, single horizontal strip ─────── */
  .band__rail {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    border-top: var(--border-weight) solid var(--border);
    border-bottom: var(--border-weight) solid var(--border);
  }

  @media (min-width: 640px) {
    .band__rail {
      grid-template-columns: repeat(auto-fit, minmax(min(100%, 10rem), 1fr));
    }
  }

  /* ── Cell ───────────────────────────────────────────────────────────────── */
  .band__cell {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    gap: 0.5rem;
    padding-block: clamp(2rem, 5vw, 3.5rem);
    padding-inline: clamp(1rem, 3vw, 2rem);
    /* vertical divider rule on every cell except the first */
    border-inline-start: var(--border-weight) solid var(--border);
  }

  /* Remove divider from the first cell in each row */
  .band__cell:first-child {
    border-inline-start: none;
  }

  /* On 2-column mobile the 3rd item starts a new row — clear its left border */
  @media (max-width: 639px) {
    .band__cell:nth-child(2n+1) {
      border-inline-start: none;
    }
    /* Row separator between the two rows in mobile 2-column layout */
    .band__cell:nth-child(1),
    .band__cell:nth-child(2) {
      border-bottom: var(--border-weight) solid var(--border);
    }
  }

  /* ── Numeral — the hero ─────────────────────────────────────────────────── */
  .band__value {
    font-family: var(--font-display);
    font-size: clamp(var(--step-4), 7vw, var(--step-6));
    font-weight: var(--fw-display);
    line-height: 1;
    letter-spacing: var(--tracking-display);
    font-variant-numeric: tabular-nums;
    color: var(--brand);
  }

  /* ── Label ──────────────────────────────────────────────────────────────── */
  .band__label {
    font-family: var(--font-body);
    font-size: var(--step--1);
    font-weight: var(--fw-bold);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-muted);
    line-height: 1.3;
    max-width: 18ch;
  }

  /* ── Tone: alt ──────────────────────────────────────────────────────────── */
  [data-tone='alt'] {
    background: var(--bg-alt);
  }

  /* ── Tone: deep ─────────────────────────────────────────────────────────── */
  [data-tone='deep'] {
    background: var(--bg-deep);
    color: var(--text-on-dark);
  }
  [data-tone='deep'] .band__rail {
    border-color: color-mix(in srgb, var(--text-on-dark) 18%, transparent);
  }
  [data-tone='deep'] .band__cell {
    border-color: color-mix(in srgb, var(--text-on-dark) 18%, transparent);
  }
  [data-tone='deep'] .band__value {
    color: var(--text-on-dark);
  }
  [data-tone='deep'] .band__label {
    color: color-mix(in srgb, var(--text-on-dark) 60%, transparent);
  }

  /* ── Tone: brand ────────────────────────────────────────────────────────── */
  [data-tone='brand'] {
    background: var(--brand);
    color: var(--brand-contrast);
  }
  [data-tone='brand'] .band__rail {
    border-color: color-mix(in srgb, var(--brand-contrast) 25%, transparent);
  }
  [data-tone='brand'] .band__cell {
    border-color: color-mix(in srgb, var(--brand-contrast) 25%, transparent);
  }
  [data-tone='brand'] .band__value {
    color: var(--brand-contrast);
  }
  [data-tone='brand'] .band__label {
    color: color-mix(in srgb, var(--brand-contrast) 70%, transparent);
  }

  /* ── Reduced motion ─────────────────────────────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    [data-reveal],
    [data-reveal-stagger] {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
  }
</style>
