---
/**
 * BeforeAfter — elegant paired/slider before-and-after images.
 * Award patterns applied:
 *   - Single pair: full-width CSS clip-path slider with drag handle (--brand grip)
 *   - Multiple pairs: 60/40-biased grid with the first pair larger
 *   - Before/After badges: small-caps pill tokens, brand vs surface
 *   - Caption: bottom gradient overlay, text-on-dark
 *   - SectionHead for header; index forwarded
 *   - Pure CSS layout + minimal JS for clip-path drive; no external lib
 *   - [data-frame] on image wrappers; [data-reveal] on figures
 */
import SectionHead from './SectionHead.astro';
import type { Section } from '../../types';

type Props = Extract<Section, { type: 'before-after' }> & { index?: number };

const {
  pairs = [],
  eyebrow,
  heading,
  intro,
  tone = 'default',
  align = 'center',
  index,
} = Astro.props as Props;

const single = pairs.length === 1;
---

<section class="section ba" data-tone={tone} id="before-after">
  <div class="container">

    {(eyebrow || heading || intro) && (
      <SectionHead {index} {eyebrow} {heading} {intro} {align} />
    )}

    {pairs.length > 0 && (
      <div class={`ba__grid${single ? ' ba__grid--single' : ''}`}>
        {pairs.map(({ before, after, label }, i) => (
          <figure
            class="ba-pair"
            data-reveal
            data-reveal-order={i}
            aria-label={label ?? `Before and after comparison ${i + 1}`}
          >

            {/* After image — base layer, full bleed */}
            <div class="ba-after" data-frame>
              <img
                src={after}
                alt={label ? `${label} — after` : `After image ${i + 1}`}
                class="ba-img"
                loading="lazy"
                decoding="async"
              />
            </div>

            {/* Before image — clipped to left of --split */}
            <div class="ba-before" data-frame>
              <img
                src={before}
                alt={label ? `${label} — before` : `Before image ${i + 1}`}
                class="ba-img"
                loading="lazy"
                decoding="async"
              />
            </div>

            {/* Labels: small-caps pills */}
            <span class="ba-badge ba-badge--before" aria-hidden="true">Before</span>
            <span class="ba-badge ba-badge--after"  aria-hidden="true">After</span>

            {/* Vertical drag-line + circular grip */}
            <div class="ba-handle" aria-hidden="true">
              <span class="ba-handle__line"></span>
              <span class="ba-handle__grip">
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
                  <path d="M6 3.5 2.5 9 6 14.5M12 3.5 15.5 9 12 14.5"
                        stroke="currentColor" stroke-width="1.75"
                        stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
              <span class="ba-handle__line"></span>
            </div>

            {/* Invisible range input — drives --split via JS; keyboard accessible */}
            <input
              type="range"
              class="ba-slider"
              min="0"
              max="100"
              value="50"
              aria-label={label ? `Adjust ${label} comparison` : `Adjust comparison ${i + 1}`}
            />

            {/* Caption — bottom gradient overlay */}
            {label && <figcaption class="ba-caption">{label}</figcaption>}

          </figure>
        ))}
      </div>
    )}

  </div>
</section>

{/* Minimal JS: drives --split custom prop from the range input. */}
<script>
  function initBA() {
    document.querySelectorAll<HTMLElement>('.ba-pair').forEach((pair) => {
      const slider = pair.querySelector<HTMLInputElement>('.ba-slider');
      if (!slider) return;
      const sync = () => pair.style.setProperty('--split', `${slider.value}%`);
      slider.addEventListener('input', sync);
      sync(); // set initial 50%
    });
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initBA);
  } else {
    initBA();
  }
</script>

<style>
  /* ── Section shell ── */
  .ba {
    padding-block: var(--section-pad);
    background: var(--bg);
    color: var(--text);
  }
  .ba[data-tone='alt']   { background: var(--bg-alt); }
  .ba[data-tone='deep']  { background: var(--bg-deep); color: var(--text-on-dark); }
  .ba[data-tone='brand'] { background: var(--brand);   color: var(--brand-contrast); }

  .container {
    max-width: var(--maxw);
    margin-inline: auto;
    padding-inline: var(--gutter);
  }

  /* ── Grid: single = full-width; multiple = first item spans 2 cols if space ── */
  .ba__grid {
    display: grid;
    gap: var(--grid-gap);
    grid-template-columns: repeat(auto-fit, minmax(min(380px, 100%), 1fr));
  }

  /* Single-pair: give it a sensible max-width so it doesn't stretch silly wide */
  .ba__grid--single {
    grid-template-columns: 1fr;
    max-width: 840px;
    margin-inline: auto;
  }

  /* ── Pair figure ── */
  .ba-pair {
    --split: 50%;
    position: relative;
    margin: 0;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
    background: var(--surface-2);
    cursor: col-resize;
    user-select: none;
    -webkit-user-select: none;
  }

  /* ── After: full-size base layer ── */
  .ba-after {
    position: absolute;
    inset: 0;
    border-radius: 0;
  }

  /* ── Before: clipped to left portion via --split ── */
  .ba-before {
    position: absolute;
    inset: 0;
    clip-path: inset(0 calc(100% - var(--split)) 0 0);
    border-radius: 0;
  }

  .ba-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* ── Before/After label badges ── */
  .ba-badge {
    position: absolute;
    top: 0.8rem;
    font-family: var(--font-body);
    font-size: var(--step--1);
    font-weight: var(--fw-bold);
    letter-spacing: var(--tracking-eyebrow);
    text-transform: uppercase;
    padding: 0.22em 0.7em;
    border-radius: var(--radius-pill);
    pointer-events: none;
    z-index: 4;
    line-height: 1.4;
  }

  .ba-badge--before {
    left: 0.8rem;
    background: var(--brand);
    color: var(--brand-contrast);
  }

  .ba-badge--after {
    right: 0.8rem;
    background: var(--surface);
    color: var(--text);
    border: var(--border-weight) solid var(--border);
  }

  /* ── Drag-line handle ── */
  .ba-handle {
    position: absolute;
    top: 0;
    bottom: 0;
    left: var(--split);
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    pointer-events: none;
    z-index: 3;
  }

  .ba-handle__line {
    flex: 1;
    width: 2px;
    background: rgba(255, 255, 255, 0.9);
  }

  .ba-handle__grip {
    flex-shrink: 0;
    width: 2.6rem;
    height: 2.6rem;
    border-radius: var(--radius-pill);
    background: var(--brand);
    color: var(--brand-contrast);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: var(--shadow-md);
    border: 2px solid rgba(255, 255, 255, 0.55);
    transition: transform var(--motion-fade) var(--motion-ease), box-shadow var(--motion-fade) var(--motion-ease);
  }

  .ba-pair:hover .ba-handle__grip {
    transform: scale(1.08);
    box-shadow: var(--shadow-lg);
  }

  /* ── Range input: transparent overlay, drives interaction ── */
  .ba-slider {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    cursor: col-resize;
    z-index: 5;
    margin: 0;
    /* Remove native browser thumb styling to keep the cursor experience clean */
    -webkit-appearance: none;
    appearance: none;
    background: transparent;
  }

  /* Accessible focus ring on the pair figure, not the invisible input */
  .ba-slider:focus-visible {
    outline: none;
  }
  .ba-pair:has(.ba-slider:focus-visible) {
    outline: 3px solid var(--ring);
    outline-offset: 3px;
  }

  /* ── Caption: bottom gradient overlay ── */
  .ba-caption {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: linear-gradient(
      to top,
      color-mix(in srgb, var(--bg-deep) 72%, transparent) 0%,
      transparent 100%
    );
    color: var(--text-on-dark);
    font-size: var(--step--1);
    font-weight: var(--fw-bold);
    letter-spacing: var(--tracking-eyebrow);
    text-transform: uppercase;
    padding: 2rem 1rem 0.85rem;
    text-align: center;
    pointer-events: none;
    z-index: 4;
  }

  /* ── Mobile: tighter aspect ratio ── */
  @media (max-width: 480px) {
    .ba-pair { aspect-ratio: 3 / 2; }
  }
</style>
