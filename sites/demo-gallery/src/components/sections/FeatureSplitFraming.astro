---
/**
 * FeatureSplitFraming — 2-up card grid variant of FeatureSplit.
 *
 * Deliberately different silhouette from FeatureSplit's alternating full-bleed
 * editorial rows. Each feature becomes a framed card: a wide image band at the
 * top (16/10 aspect, overflow:hidden, crop-zoom on hover) with heading + body
 * below. Soft shadow lifts to deeper shadow on hover. Rounded corners via
 * --radius-lg. One column on mobile, two on desktop.
 *
 * Drop-in swappable with FeatureSplit — identical props interface.
 * Spec §6 type: 'feature-split-framing'. No client JS. [data-reveal] entrances.
 */
import SectionHead from './SectionHead.astro';
import SiteImage from '../SiteImage.astro';
import type { SectionEnvelope } from '../../types';

interface SplitRow {
  heading: string;
  body: string;
  image?: string;
  imageAlt?: string;
}

interface Props extends SectionEnvelope {
  rows: SplitRow[];
  index?: number;
}

const {
  rows = [],
  eyebrow,
  heading,
  intro,
  tone = 'default',
  align = 'left',
  index,
} = Astro.props as Props;
---

{rows.length > 0 && (
  <section class="section fsf" data-tone={tone}>
    <div class="container">

      <SectionHead {index} {eyebrow} heading={heading} {intro} {align} />

      <div class="fsf__grid" data-reveal data-reveal-stagger>
        {rows.map((row) => {
          const hasImg = Boolean(row.image);
          return (
            <article class={`fsf__card${!hasImg ? ' fsf__card--no-img' : ''}`} data-reveal aria-label={row.heading}>

              {/* ── Image band ─────────────────────────────────────── */}
              <div class="fsf__media">
                {hasImg ? (
                  <SiteImage
                    src={row.image}
                    alt={row.imageAlt ?? row.heading}
                    class="fsf__img"
                    sizes="(min-width: 768px) 50vw, 100vw"
                  />
                ) : (
                  <div class="fsf__placeholder" aria-hidden="true">
                    <span class="fsf__placeholder-glyph">
                      {row.heading.charAt(0)}
                    </span>
                  </div>
                )}
              </div>

              {/* ── Copy area ──────────────────────────────────────── */}
              <div class="fsf__copy">
                <h3 class="fsf__heading">{row.heading}</h3>
                <p class="fsf__body">{row.body}</p>
              </div>

            </article>
          );
        })}
      </div>

    </div>
  </section>
)}

<style>
  /* ── Shell ────────────────────────────────────────────────────────────────── */
  .fsf {
    padding-block: var(--section-pad);
  }

  .container {
    max-width: var(--maxw);
    margin-inline: auto;
    padding-inline: var(--gutter);
  }

  /* ── Card grid — mobile-first ─────────────────────────────────────────────── */
  .fsf__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(1.5rem, 3vw, 2.5rem);
  }

  @media (min-width: 680px) {
    .fsf__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* ── Card ─────────────────────────────────────────────────────────────────── */
  .fsf__card {
    display: flex;
    flex-direction: column;
    background: var(--surface);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-2);
    border: var(--border-weight) solid var(--border);
    transition:
      box-shadow 320ms var(--ease-out-3),
      transform 320ms var(--ease-out-3);
  }

  .fsf__card:hover {
    box-shadow: var(--shadow-4);
    transform: translateY(-3px);
  }

  /* ── Image band ───────────────────────────────────────────────────────────── */
  .fsf__media {
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: color-mix(in srgb, var(--brand) 8%, var(--surface-2));
    flex-shrink: 0;
  }

  .fsf__img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transition: transform 480ms var(--ease-out-3);
  }

  .fsf__card:hover .fsf__img {
    transform: scale(1.05);
  }

  /* Placeholder for cards with no image */
  .fsf__placeholder {
    width: 100%;
    height: 100%;
    display: grid;
    place-items: center;
    background: color-mix(in srgb, var(--brand) 8%, var(--surface-2));
    border-bottom: calc(var(--border-weight) * 3) solid var(--brand);
  }

  .fsf__placeholder-glyph {
    font-family: var(--font-display);
    font-weight: var(--fw-display);
    font-size: clamp(3rem, 10vw, 7rem);
    line-height: 1;
    color: color-mix(in srgb, var(--brand) 22%, transparent);
    user-select: none;
  }

  /* ── Copy area ────────────────────────────────────────────────────────────── */
  .fsf__copy {
    padding: clamp(1.25rem, 3vw, 2rem);
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    flex: 1;
  }

  .fsf__heading {
    font-family: var(--font-display);
    font-weight: var(--fw-display);
    font-size: clamp(var(--step-1), 2.5vw, var(--step-3));
    letter-spacing: var(--tracking-display);
    line-height: 1.15;
    color: var(--text);
    margin: 0;
    text-wrap: balance;
  }

  .fsf__body {
    font-size: var(--step--1);
    line-height: var(--leading-body);
    color: var(--text-muted);
    margin: 0;
  }

  /* ── Tone overrides ───────────────────────────────────────────────────────── */
  [data-tone='alt']  { background: var(--bg-alt); }
  [data-tone='deep'] { background: var(--bg-deep); color: var(--text-on-dark); }
  [data-tone='brand']{ background: var(--brand); color: var(--brand-contrast); }

  [data-tone='alt']  .fsf__card { background: var(--surface); }

  [data-tone='deep'] .fsf__card {
    background: color-mix(in srgb, var(--text-on-dark) 6%, var(--bg-deep));
    border-color: color-mix(in srgb, var(--text-on-dark) 14%, transparent);
  }
  [data-tone='deep'] .fsf__heading { color: var(--text-on-dark); }
  [data-tone='deep'] .fsf__body    { color: color-mix(in srgb, var(--text-on-dark) 72%, transparent); }
  [data-tone='deep'] .fsf__placeholder {
    background: color-mix(in srgb, var(--text-on-dark) 8%, var(--bg-deep));
    border-bottom-color: color-mix(in srgb, var(--text-on-dark) 30%, transparent);
  }

  [data-tone='brand'] .fsf__card {
    background: color-mix(in srgb, var(--brand-contrast) 9%, var(--brand));
    border-color: color-mix(in srgb, var(--brand-contrast) 18%, transparent);
  }
  [data-tone='brand'] .fsf__heading { color: var(--brand-contrast); }
  [data-tone='brand'] .fsf__body    { color: color-mix(in srgb, var(--brand-contrast) 80%, transparent); }
  [data-tone='brand'] .fsf__placeholder {
    background: color-mix(in srgb, var(--brand-contrast) 8%, var(--brand));
    border-bottom-color: color-mix(in srgb, var(--brand-contrast) 30%, transparent);
  }

  /* ── Entrance animation ───────────────────────────────────────────────────── */
  /*
   * [data-reveal] starts at opacity:0 — the global reveal JS transitions it in.
   * We must not fight that with our own opacity here; card hover uses transform
   * only. Reduced-motion collapses all transitions + the hover lift.
   */
  @media (prefers-reduced-motion: reduce) {
    .fsf__card,
    .fsf__img {
      transition: none;
    }
    .fsf__card:hover {
      transform: none;
    }
    .fsf__card:hover .fsf__img {
      transform: none;
    }
  }
</style>
