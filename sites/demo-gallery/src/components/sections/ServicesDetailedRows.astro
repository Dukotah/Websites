---
/**
 * ServicesDetailedRows — services as an editorial numbered-row list (variant 1).
 *
 * A deliberately different silhouette from the ServicesDetailed card grid:
 * full-width rows divided by hairline rules, each led by a large display
 * numeral. Reads as a premium "index" / table-of-contents and looks intentional
 * whether or not services carry photos (an optional thumbnail rides the right
 * rail when present). Same props as ServicesDetailed so it's drop-in swappable
 * by the variant selector.
 *
 * • Token-driven; tone-aware (default / alt / deep / brand).
 * • data-reveal-stagger entrance; reduced-motion safe.
 * • Header delegated to SectionHead (chapter index support).
 */
import type { Tone, Align } from '../../types';
import SectionHead from './SectionHead.astro';

interface ServiceItem {
  title: string;
  description: string;
  image?: string;
  icon?: string;
}

interface Props {
  items: ServiceItem[];
  eyebrow?: string;
  heading?: string;
  intro?: string;
  tone?: Tone;
  align?: Align;
  phone?: string;
  envelope?: string;
  index?: number;
}

const {
  items = [],
  eyebrow = 'What we do',
  heading,
  intro,
  tone = 'default',
  align = 'left',
  phone,
  envelope,
  index,
} = Astro.props as Props;

const ctaHref = phone
  ? `tel:${phone.replace(/[^+\d]/g, '')}`
  : envelope
  ? `mailto:${envelope}`
  : '#contact';
---

{items.length > 0 && (
  <section class="section svcrows" data-tone={tone} id="services-detailed">
    <div class="container">
      <SectionHead {index} {eyebrow} {heading} {intro} {align} />

      <ol class="svcrows__list" data-reveal data-reveal-stagger>
        {items.map((item, i) => (
          <li class="svcrow">
            <a class="svcrow__link" href={ctaHref} aria-label={`${item.title} — ask about this`}>
              <span class="svcrow__num" aria-hidden="true">
                {String(i + 1).padStart(2, '0')}
              </span>

              {item.image && (
                <span class="svcrow__media" data-frame>
                  <img
                    src={item.image}
                    alt={item.title}
                    loading="lazy"
                    decoding="async"
                    width="240"
                    height="160"
                  />
                </span>
              )}

              <span class="svcrow__body">
                <span class="svcrow__title">{item.title}</span>
                <span class="svcrow__desc">{item.description}</span>
              </span>

              <span class="svcrow__cue" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" focusable="false">
                  <path
                    d="M5 12h14m-6-6 6 6-6 6"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
              </span>
            </a>
          </li>
        ))}
      </ol>
    </div>
  </section>
)}

<style>
  .svcrows {
    padding-block: var(--section-pad);
  }

  .container {
    max-width: var(--maxw);
    margin-inline: auto;
    padding-inline: var(--gutter);
  }

  .svcrows__list {
    list-style: none;
    margin: 0;
    padding: 0;
    border-top: var(--border-weight, 1px) solid var(--border);
  }

  .svcrow {
    border-bottom: var(--border-weight, 1px) solid var(--border);
  }

  /* Whole row is one click target → calm hover state, no card chrome. */
  .svcrow__link {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    column-gap: clamp(1rem, 3vw, 2.5rem);
    padding-block: clamp(1.25rem, 3vw, 2.1rem);
    text-decoration: none;
    color: inherit;
    transition: background 240ms var(--motion-ease, var(--ease-out-3));
  }

  /* Pull the hover tint slightly into the gutter so it reads as a full band. */
  .svcrow__link:hover {
    background: color-mix(in srgb, var(--brand) 6%, transparent);
    box-shadow:
      0 0 0 clamp(0.6rem, 1.4vw, 1.1rem) color-mix(in srgb, var(--brand) 6%, transparent);
  }

  .svcrow__num {
    font-family: var(--font-display);
    font-size: var(--step-2);
    font-weight: var(--fw-display);
    line-height: 1;
    letter-spacing: var(--tracking-display, -0.02em);
    color: color-mix(in srgb, var(--brand) 55%, var(--text-muted));
    font-variant-numeric: tabular-nums;
    min-width: 2.2ch;
  }

  .svcrow__media {
    display: none;
    overflow: hidden;
    border-radius: var(--radius);
    aspect-ratio: 3 / 2;
    width: clamp(120px, 14vw, 168px);
    background: color-mix(in srgb, var(--brand) 12%, var(--surface));
  }

  .svcrow__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 540ms var(--ease-out-3, var(--motion-ease));
  }

  .svcrow__link:hover .svcrow__media img {
    transform: scale(1.05);
  }

  @media (min-width: 720px) {
    .svcrow__media {
      display: block;
    }
  }

  .svcrow__body {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    min-width: 0;
  }

  .svcrow__title {
    font-family: var(--font-display);
    font-size: var(--step-2);
    font-weight: var(--fw-display);
    letter-spacing: var(--tracking-display, -0.02em);
    line-height: 1.12;
    color: var(--text);
    text-wrap: balance;
  }

  .svcrow__desc {
    font-size: var(--step-0);
    color: var(--text-muted);
    line-height: var(--leading-body);
    max-width: 60ch;
  }

  .svcrow__cue {
    display: grid;
    place-items: center;
    width: 2.75rem;
    height: 2.75rem;
    border-radius: var(--radius-pill, 999px);
    border: var(--border-weight, 1px) solid var(--border);
    color: var(--brand);
    flex-shrink: 0;
    transition:
      transform 240ms var(--ease-out-3, var(--motion-ease)),
      border-color 240ms var(--ease-out-3, var(--motion-ease)),
      background 240ms var(--ease-out-3, var(--motion-ease));
  }

  .svcrow__cue svg {
    width: 1.15rem;
    height: 1.15rem;
  }

  .svcrow__link:hover .svcrow__cue {
    background: var(--brand);
    border-color: var(--brand);
    color: var(--brand-contrast);
    transform: translateX(3px);
  }

  @media (prefers-reduced-motion: reduce) {
    .svcrow__link,
    .svcrow__media img,
    .svcrow__cue {
      transition: none;
    }
    .svcrow__link:hover .svcrow__media img {
      transform: none;
    }
  }

  /* ── Tone variants ───────────────────────────────────────────────────── */
  [data-tone='alt'] {
    background: var(--bg-alt);
  }

  [data-tone='deep'] {
    background: var(--bg-deep);
    color: var(--text-on-dark);
  }
  [data-tone='deep'] .svcrows__list,
  [data-tone='deep'] .svcrow {
    border-color: color-mix(in srgb, var(--text-on-dark) 16%, transparent);
  }
  [data-tone='deep'] .svcrow__title {
    color: var(--text-on-dark);
  }
  [data-tone='deep'] .svcrow__desc {
    color: color-mix(in srgb, var(--text-on-dark) 72%, transparent);
  }
  [data-tone='deep'] .svcrow__cue {
    border-color: color-mix(in srgb, var(--text-on-dark) 28%, transparent);
  }

  [data-tone='brand'] {
    background: var(--brand);
    color: var(--brand-contrast);
  }
  [data-tone='brand'] .svcrows__list,
  [data-tone='brand'] .svcrow {
    border-color: color-mix(in srgb, var(--brand-contrast) 22%, transparent);
  }
  [data-tone='brand'] .svcrow__num {
    color: color-mix(in srgb, var(--brand-contrast) 70%, transparent);
  }
  [data-tone='brand'] .svcrow__title {
    color: var(--brand-contrast);
  }
  [data-tone='brand'] .svcrow__desc {
    color: color-mix(in srgb, var(--brand-contrast) 80%, transparent);
  }
  [data-tone='brand'] .svcrow__link:hover {
    background: color-mix(in srgb, var(--brand-contrast) 10%, transparent);
    box-shadow: 0 0 0 clamp(0.6rem, 1.4vw, 1.1rem)
      color-mix(in srgb, var(--brand-contrast) 10%, transparent);
  }
  [data-tone='brand'] .svcrow__cue {
    border-color: color-mix(in srgb, var(--brand-contrast) 40%, transparent);
    color: var(--brand-contrast);
  }
  [data-tone='brand'] .svcrow__link:hover .svcrow__cue {
    background: var(--brand-contrast);
    color: var(--brand);
  }
</style>
