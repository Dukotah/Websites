---
import type { Section } from '../../types';

// Ported sections
import StatsSection from './StatsSection.astro';
import TestimonialsSection from './TestimonialsSection.astro';
import FaqSection from './FaqSection.astro';
import ListSection from './ListSection.astro';
import CtaSection from './CtaSection.astro';

// Rich sections
import GallerySection from './GallerySection.astro';
import FeatureSplit from './FeatureSplit.astro';
import TimelineSection from './TimelineSection.astro';
import MenuSection from './MenuSection.astro';
import TeamSection from './TeamSection.astro';
import MapSection from './MapSection.astro';
import PressSection from './PressSection.astro';
import BigQuoteSection from './BigQuoteSection.astro';
import ServicesDetailed from './ServicesDetailed.astro';
import ServicesDetailedRows from './ServicesDetailedRows.astro';
import ServiceAreaSection from './ServiceAreaSection.astro';
import HoursContactSection from './HoursContactSection.astro';
import ProcessSection from './ProcessSection.astro';
import LogosStrip from './LogosStrip.astro';
import BeforeAfter from './BeforeAfter.astro';
import FeatureGrid from './FeatureGrid.astro';
import EditorialFeature from './EditorialFeature.astro';
import SpecStrip from './SpecStrip.astro';

// Section-variant alternates (chosen per slug by lib/variants.ts).
import GalleryUniform from './GalleryUniform.astro';
import GalleryFilmstrip from './GalleryFilmstrip.astro';
import TestimonialsSpotlight from './TestimonialsSpotlight.astro';
import FeatureSplitFraming from './FeatureSplitFraming.astro';
import FeatureGridBordered from './FeatureGridBordered.astro';
import StatsBand from './StatsBand.astro';
import StatsInline from './StatsInline.astro';
import ServicesDetailedBento from './ServicesDetailedBento.astro';
import CtaPanel from './CtaPanel.astro';

interface Props {
  sections: Section[];
}

const { sections = [] } = Astro.props as Props;

// Numbered "chapter" content sections (award pattern). Accent/utility bands
// (stats, cta, map, hours, press, logos, spec-strip…) are intentionally NOT
// numbered so the chapters read as the narrative spine.
const MAJOR = new Set([
  'services-detailed', 'feature-split', 'gallery', 'timeline', 'menu',
  'team', 'process', 'editorial-feature', 'faq', 'list', 'before-after',
]);
let chapter = 0;

// Variant pools: a section type can render in several layouts; compose.ts picks
// the index per slug (lib/variants.ts) so same-category sites diverge. Keep each
// array length-aligned with SECTION_VARIANTS; out-of-range wraps via modulo.
const SERVICES_DETAILED = [ServicesDetailed, ServicesDetailedRows, ServicesDetailedBento];
const GALLERY = [GallerySection, GalleryUniform, GalleryFilmstrip];
const TESTIMONIALS = [TestimonialsSection, TestimonialsSpotlight];
const FEATURE_SPLIT = [FeatureSplit, FeatureSplitFraming];
const FEATURE_GRID = [FeatureGrid, FeatureGridBordered];
const STATS = [StatsSection, StatsBand, StatsInline];
const CTA = [CtaSection, CtaPanel];

/** Pick a variant component for a section, wrapping the index safely. */
function variantOf<T>(pool: T[], variant?: number): T {
  return pool[((variant ?? 0) % pool.length + pool.length) % pool.length];
}
---

{
  sections.map((section) => {
    const index = MAJOR.has(section.type) ? ++chapter : undefined;
    switch (section.type) {
      case 'stats': {
        const C = variantOf(STATS, section.variant);
        return <C {...section} index={index} />;
      }
      case 'testimonials': {
        const C = variantOf(TESTIMONIALS, section.variant);
        return <C {...section} index={index} />;
      }
      case 'faq':
        return <FaqSection {...section} index={index} />;
      case 'list':
        return <ListSection {...section} index={index} />;
      case 'cta': {
        const C = variantOf(CTA, section.variant);
        return <C {...section} index={index} />;
      }
      case 'gallery': {
        const C = variantOf(GALLERY, section.variant);
        return <C {...section} index={index} />;
      }
      case 'feature-split': {
        const C = variantOf(FEATURE_SPLIT, section.variant);
        return <C {...section} index={index} />;
      }
      case 'timeline':
        return <TimelineSection {...section} index={index} />;
      case 'menu':
        return <MenuSection {...section} index={index} />;
      case 'team':
        return <TeamSection {...section} index={index} />;
      case 'map':
        return <MapSection {...section} index={index} />;
      case 'press':
        return <PressSection {...section} index={index} />;
      case 'bigquote':
        return <BigQuoteSection {...section} index={index} />;
      case 'services-detailed': {
        const Svc = variantOf(SERVICES_DETAILED, section.variant);
        return <Svc {...section} index={index} />;
      }
      case 'service-area':
        return <ServiceAreaSection {...section} index={index} />;
      case 'hours-contact':
        return <HoursContactSection {...section} index={index} />;
      case 'process':
        return <ProcessSection {...section} index={index} />;
      case 'logos':
        return <LogosStrip {...section} index={index} />;
      case 'before-after':
        return <BeforeAfter {...section} index={index} />;
      case 'feature-grid': {
        const C = variantOf(FEATURE_GRID, section.variant);
        return <C {...section} index={index} />;
      }
      case 'editorial-feature':
        return <EditorialFeature {...section} index={index} />;
      case 'spec-strip':
        return <SpecStrip {...section} index={index} />;
      default:
        return null;
    }
  })
}
