---
/**
 * MenuSection — priced/grouped menu list (cafe, winery, etc.).
 * Spec §6: type 'menu'. No client JS. Elegant dotted-leader pricing rows.
 */
import type { SectionEnvelope } from '../../types';

interface MenuItem {
  name: string;
  price?: string;
  note?: string;
}

interface MenuGroup {
  title: string;
  items: MenuItem[];
}

interface Props extends SectionEnvelope {
  groups: MenuGroup[];
}

const {
  groups,
  eyebrow,
  heading,
  intro,
  tone = 'default',
  align = 'center',
} = Astro.props as Props;
---

<section class="section menu-section" data-tone={tone}>
  <div class="container">
    {(eyebrow || heading || intro) && (
      <header class={`section-header section-header--${align}`} data-reveal>
        {eyebrow && <p class="eyebrow">{eyebrow}</p>}
        {heading && <h2 class="menu-section__heading">{heading}</h2>}
        {intro && <p class="menu-section__intro">{intro}</p>}
      </header>
    )}

    <div class="menu-groups">
      {groups.map((group, gi) => (
        <div class="menu-group" data-reveal data-reveal-order={gi}>
          <h3 class="menu-group__title">{group.title}</h3>
          <ul class="menu-list">
            {group.items.map((item) => (
              <li class="menu-item">
                <span class="menu-item__name">{item.name}</span>
                {item.price && (
                  <span class="menu-item__price">{item.price}</span>
                )}
                {item.note && (
                  <span class="menu-item__note">{item.note}</span>
                )}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .menu-section {
    padding-block: var(--section-pad);
  }

  .container {
    max-width: var(--maxw);
    margin-inline: auto;
    padding-inline: var(--gutter);
  }

  .section-header {
    margin-bottom: 3rem;
  }
  .section-header--center {
    text-align: center;
    max-width: 52ch;
    margin-inline: auto;
  }
  .section-header--left {
    text-align: left;
    max-width: 52ch;
  }

  .eyebrow {
    font-family: var(--font-body);
    font-size: var(--step--1);
    font-weight: var(--fw-bold);
    letter-spacing: var(--tracking-eyebrow);
    text-transform: uppercase;
    color: var(--brand);
    margin: 0 0 0.5rem;
  }

  .menu-section__heading {
    font-family: var(--font-display);
    font-size: var(--step-3);
    font-weight: var(--fw-display);
    letter-spacing: var(--tracking-display);
    line-height: var(--leading-display);
    color: var(--text);
    margin: 0 0 0.75rem;
  }

  .menu-section__intro {
    font-size: var(--step-0);
    color: var(--text-muted);
    line-height: var(--leading-body);
    margin: 0;
  }

  /* Menu groups layout ------------------------------------------------------- */
  .menu-groups {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  @media (min-width: 768px) {
    .menu-groups {
      /* Up to 2-col when there are multiple groups */
      grid-template-columns: repeat(auto-fit, minmax(min(100%, 28rem), 1fr));
    }
  }

  .menu-group {
    background: var(--surface);
    border-radius: var(--radius-lg);
    padding: 2rem 2rem 1.75rem;
    box-shadow: var(--shadow-sm);
    border: var(--border-weight) solid var(--border);
  }

  .menu-group__title {
    font-family: var(--font-display);
    font-size: var(--step-1);
    font-weight: var(--fw-display);
    letter-spacing: var(--tracking-display);
    color: var(--text);
    margin: 0 0 1.25rem;
    padding-bottom: 0.75rem;
    border-bottom: calc(var(--border-weight) * 2) solid var(--brand);
    display: inline-block;
  }

  .menu-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  /* Dotted-leader row: name stretches, price at end */
  .menu-item {
    display: grid;
    /* name | dots | price */
    grid-template-columns: auto 1fr auto;
    grid-template-rows: auto auto;
    align-items: baseline;
    column-gap: 0.4rem;
    padding: 0.65rem 0;
    border-bottom: var(--border-weight) solid var(--border);
  }

  .menu-item:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .menu-item__name {
    font-size: var(--step-0);
    font-weight: var(--fw-bold);
    color: var(--text);
    grid-column: 1;
    grid-row: 1;
  }

  /* Dotted leader — pseudo-element on the grid cell after name */
  .menu-item::after {
    content: '';
    grid-column: 2;
    grid-row: 1;
    align-self: end;
    border-bottom: 1px dotted var(--border);
    margin-bottom: 0.35em;
  }

  .menu-item__price {
    font-family: var(--font-display);
    font-size: var(--step-0);
    font-weight: var(--fw-display);
    color: var(--brand);
    grid-column: 3;
    grid-row: 1;
    white-space: nowrap;
  }

  .menu-item__note {
    font-size: var(--step--1);
    color: var(--text-muted);
    font-style: italic;
    line-height: var(--leading-body);
    grid-column: 1 / -1;
    grid-row: 2;
    padding-top: 0.2rem;
  }

  /* Tone overrides ---------------------------------------------------------- */
  [data-tone='alt'] {
    background: var(--bg-alt);
  }
  [data-tone='alt'] .menu-group {
    background: var(--surface-2);
  }
  [data-tone='deep'] {
    background: var(--bg-deep);
  }
  [data-tone='deep'] .menu-section__heading {
    color: var(--text-on-dark);
  }
  [data-tone='deep'] .menu-section__intro {
    color: color-mix(in srgb, var(--text-on-dark) 75%, transparent);
  }
  [data-tone='deep'] .eyebrow {
    color: var(--accent);
  }
  [data-tone='deep'] .menu-group {
    background: color-mix(in srgb, var(--bg-deep) 70%, var(--surface) 30%);
    border-color: color-mix(in srgb, var(--text-on-dark) 12%, transparent);
  }
  [data-tone='deep'] .menu-group__title,
  [data-tone='deep'] .menu-item__name {
    color: var(--text-on-dark);
  }
  [data-tone='deep'] .menu-item__note {
    color: color-mix(in srgb, var(--text-on-dark) 65%, transparent);
  }
  [data-tone='deep'] .menu-item {
    border-bottom-color: color-mix(in srgb, var(--text-on-dark) 12%, transparent);
  }
  [data-tone='brand'] {
    background: var(--brand);
  }
  [data-tone='brand'] .menu-section__heading {
    color: var(--brand-contrast);
  }
  [data-tone='brand'] .menu-section__intro {
    color: color-mix(in srgb, var(--brand-contrast) 80%, transparent);
  }
  [data-tone='brand'] .eyebrow {
    color: var(--brand-contrast);
    opacity: 0.7;
  }
  [data-tone='brand'] .menu-group {
    background: color-mix(in srgb, var(--brand) 60%, white 40%);
    border-color: color-mix(in srgb, var(--brand-contrast) 20%, transparent);
  }
  [data-tone='brand'] .menu-group__title,
  [data-tone='brand'] .menu-item__name {
    color: var(--brand-contrast);
  }
  [data-tone='brand'] .menu-group__title {
    border-bottom-color: var(--brand-contrast);
  }
  [data-tone='brand'] .menu-item__price {
    color: var(--brand-contrast);
  }
</style>
