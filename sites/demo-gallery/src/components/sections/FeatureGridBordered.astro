---
/**
 * FeatureGridBordered — spec-sheet / table variant of FeatureGrid (variant 1).
 *
 * Items sit in a connected grid divided by hairline rules — cells share edges
 * exactly like a technical spec sheet (no gaps, no card shadows). Each cell
 * carries a zero-padded monospace index (or a brand tick when no icon is
 * supplied), the label in display type, and the optional note in muted text.
 * 2 columns on mobile → 3 at mid → 4 at wide.
 *
 * Border model: every cell draws only border-inline-start + border-block-start
 * so edges are never doubled. The outer frame is closed with a matching
 * border-inline-end + border-block-end on the grid wrapper itself.
 *
 * Identical props to FeatureGrid v0 — drop-in swappable via the variant
 * selector. Token-driven; tone-aware (default / alt / deep / brand).
 * data-reveal entrance; reduced-motion safe.
 */
import SectionHead from './SectionHead.astro';
import type { SectionEnvelope } from '../../types';

interface Item {
  label: string;
  note?: string;
  icon?: string;
}

interface Props extends SectionEnvelope {
  items: Item[];
  index?: number;
}

const {
  items = [],
  eyebrow,
  heading,
  intro,
  tone = 'default',
  align = 'left',
  index,
} = Astro.props as Props;
---

{items.length > 0 && (
  <section class="section fgb" data-tone={tone}>
    <div class="container">

      <SectionHead {index} {eyebrow} {heading} {intro} {align} />

      <ul class="fgb__grid" role="list" data-reveal data-reveal-stagger>
        {items.map((item, i) => (
          <li class="fgb__cell">
            <span class="fgb__marker" aria-hidden="true">
              {item.icon
                ? <span class="fgb__icon" set:html={item.icon} />
                : <span class="fgb__index">{String(i + 1).padStart(2, '0')}</span>
              }
            </span>
            <h3 class="fgb__label">{item.label}</h3>
            {item.note && <p class="fgb__note">{item.note}</p>}
          </li>
        ))}
      </ul>

    </div>
  </section>
)}

<style>
  /* ── Layout ────────────────────────────────────────────────────── */
  .fgb {
    padding-block: var(--section-pad);
  }

  .container {
    max-width: var(--maxw);
    margin-inline: auto;
    padding-inline: var(--gutter);
  }

  /* ── Grid — shared-edge border model ───────────────────────────── */
  /*
   * The grid itself carries the outer right + bottom edges of the frame.
   * Each cell draws only its left + top edge, so no border ever doubles.
   * Result: one clean 1px hairline between every pair of cells and around
   * the whole grid, with zero gap.
   */
  .fgb__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    /* Close the outer frame on the right and bottom */
    border-inline-end: var(--border-weight, 1px) solid var(--border);
    border-block-end: var(--border-weight, 1px) solid var(--border);
  }

  @media (min-width: 640px) {
    .fgb__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .fgb__grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  /* ── Cell ──────────────────────────────────────────────────────── */
  .fgb__cell {
    /* Each cell supplies its own top + left edge — never right/bottom */
    border-inline-start: var(--border-weight, 1px) solid var(--border);
    border-block-start: var(--border-weight, 1px) solid var(--border);
    padding: clamp(1.25rem, 3vw, 1.75rem) clamp(1rem, 2.5vw, 1.5rem);
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    /* Subtle hover tint — no box-shadow, no lift, stay in-plane */
    transition: background 200ms var(--ease-out-3, ease);
  }

  .fgb__cell:hover {
    background: color-mix(in srgb, var(--brand) 5%, transparent);
  }

  /* ── Marker: monospace index or svg icon ───────────────────────── */
  .fgb__marker {
    display: flex;
    align-items: center;
    margin-bottom: 0.55rem;
  }

  .fgb__index {
    font-family: var(--font-body);
    font-size: var(--step--1);
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.06em;
    color: var(--brand);
    line-height: 1;
    /* Monospace feel even on proportional fonts */
    font-feature-settings: "tnum";
  }

  .fgb__icon {
    display: inline-flex;
    width: 1.2rem;
    height: 1.2rem;
    color: var(--brand);
  }

  .fgb__icon :global(svg) {
    width: 100%;
    height: 100%;
    stroke-width: 1.75;
  }

  /* ── Text ──────────────────────────────────────────────────────── */
  .fgb__label {
    font-family: var(--font-display);
    font-size: var(--step-1);
    font-weight: var(--fw-display);
    letter-spacing: var(--tracking-display, -0.02em);
    color: var(--text);
    line-height: 1.15;
    margin: 0;
    text-wrap: balance;
  }

  .fgb__note {
    font-size: var(--step--1);
    color: var(--text-muted);
    line-height: var(--leading-body);
    margin: 0;
  }

  /* ── Reduced-motion ────────────────────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .fgb__cell {
      transition: none;
    }
  }

  /* ── Tone variants ─────────────────────────────────────────────── */
  [data-tone='alt'] {
    background: var(--bg-alt);
  }

  [data-tone='deep'] {
    background: var(--bg-deep);
    color: var(--text-on-dark);
  }
  [data-tone='deep'] .fgb__grid {
    border-color: color-mix(in srgb, var(--text-on-dark) 14%, transparent);
  }
  [data-tone='deep'] .fgb__cell {
    border-color: color-mix(in srgb, var(--text-on-dark) 14%, transparent);
  }
  [data-tone='deep'] .fgb__cell:hover {
    background: color-mix(in srgb, var(--text-on-dark) 6%, transparent);
  }
  [data-tone='deep'] .fgb__label {
    color: var(--text-on-dark);
  }
  [data-tone='deep'] .fgb__note {
    color: color-mix(in srgb, var(--text-on-dark) 65%, transparent);
  }

  [data-tone='brand'] {
    background: var(--brand);
    color: var(--brand-contrast);
  }
  [data-tone='brand'] .fgb__grid {
    border-color: color-mix(in srgb, var(--brand-contrast) 22%, transparent);
  }
  [data-tone='brand'] .fgb__cell {
    border-color: color-mix(in srgb, var(--brand-contrast) 22%, transparent);
  }
  [data-tone='brand'] .fgb__cell:hover {
    background: color-mix(in srgb, var(--brand-contrast) 8%, transparent);
  }
  [data-tone='brand'] .fgb__index,
  [data-tone='brand'] .fgb__icon {
    color: color-mix(in srgb, var(--brand-contrast) 80%, transparent);
  }
  [data-tone='brand'] .fgb__label {
    color: var(--brand-contrast);
  }
  [data-tone='brand'] .fgb__note {
    color: color-mix(in srgb, var(--brand-contrast) 72%, transparent);
  }
</style>
