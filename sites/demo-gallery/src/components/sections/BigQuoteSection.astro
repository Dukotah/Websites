---
/**
 * BigQuoteSection — dark "atmosphere" palate-cleanser.
 *
 * Award pattern (winery/editorial teardown §5 "Dark atmosphere section"):
 *   – Full-width --bg-deep section, --text-on-dark foreground.
 *   – One oversized italic display pull-quote at --step-4/5.
 *   – Thin --accent horizontal rules above and below the figure.
 *   – Subtle film-grain overlay via [data-grain] on the section wrapper.
 *   – Radial brand-glow at near-zero opacity for warmth without flatness.
 *   – Optional SectionHead for eyebrow/heading/intro (rarely needed for this
 *     palate-cleanser role, but honoured when provided).
 */
import SectionHead from './SectionHead.astro';
import type { Tone, Align } from '../../types';

interface Props {
  quote: string;
  author?: string;
  source?: string;
  eyebrow?: string;
  heading?: string;
  intro?: string;
  tone?: Tone;
  align?: Align;
  index?: number;
}

const {
  quote,
  author,
  source,
  eyebrow,
  heading,
  intro,
  tone = 'deep',
  align = 'center',
  index,
} = Astro.props;

const hasHead = eyebrow || heading || intro;
---

<section class="section bqs" data-tone={tone} data-grain id="bigquote">
  <!-- Ambient glow — purely decorative -->
  <div class="bqs__glow" aria-hidden="true"></div>

  <div class="container">

    {hasHead && (
      <SectionHead
        index={index}
        eyebrow={eyebrow}
        heading={heading}
        intro={intro}
        align={align}
      />
    )}

    <figure class="bqs__figure" data-reveal>

      <!-- Thin accent rule above -->
      <div class="bqs__rule" aria-hidden="true"></div>

      <blockquote class="bqs__quote" cite={source}>
        <!-- Aria-hidden decorative opening glyph (large typographic ornament) -->
        <span class="bqs__glyph" aria-hidden="true">&ldquo;</span>
        <p>{quote}<span class="bqs__glyph-close" aria-hidden="true">&rdquo;</span></p>
      </blockquote>

      <!-- Thin accent rule below -->
      <div class="bqs__rule" aria-hidden="true"></div>

      {(author || source) && (
        <figcaption class="bqs__attribution">
          {author && (
            <span class="bqs__author">{author}</span>
          )}
          {source && (
            <cite class="bqs__source">{source}</cite>
          )}
        </figcaption>
      )}

    </figure>
  </div>
</section>

<style>
  /* ── Wrapper ────────────────────────────────────────────────────────────── */
  .bqs {
    padding-block: var(--section-pad);
    text-align: center;
    position: relative;
    overflow: hidden;
    /* [data-grain] from treatment.css adds the feTurbulence noise overlay
       as a ::after; it sits above the glow but below text (z-index 3). */
  }

  /* Force deep-tone colours — this component is always dark */
  .bqs[data-tone="deep"],
  .bqs {
    background: var(--bg-deep);
    color: var(--text-on-dark);
  }

  /* ── Ambient radial glow ────────────────────────────────────────────────── */
  .bqs__glow {
    position: absolute;
    inset: 0;
    /* Warm brand glow at the centre — stays below grain layer */
    background: radial-gradient(
      ellipse 70% 55% at 50% 50%,
      color-mix(in srgb, var(--brand) 22%, transparent) 0%,
      transparent 68%
    );
    opacity: 0.18;
    pointer-events: none;
    z-index: 0;
  }

  /* ── Container ──────────────────────────────────────────────────────────── */
  .container {
    max-width: var(--maxw);
    margin-inline: auto;
    padding-inline: var(--gutter);
    position: relative;
    z-index: 1; /* sits above glow + grain overlay */
  }

  /* ── Figure ─────────────────────────────────────────────────────────────── */
  .bqs__figure {
    margin: 0 auto;
    max-width: 42ch;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: clamp(1.25rem, 3vw, 2rem);
  }

  /* ── Accent rules ───────────────────────────────────────────────────────── */
  .bqs__rule {
    width: clamp(3rem, 10vw, 6rem);
    height: 1px;
    background: var(--accent);
    opacity: 0.75;
    flex-shrink: 0;
  }

  /* ── Decorative quotation glyph ─────────────────────────────────────────── */
  .bqs__glyph {
    display: block;
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(4rem, 12vw, 7.5rem);
    line-height: 0.6;
    color: var(--accent);
    opacity: 0.35;
    user-select: none;
    /* Pull glyph up so quote text nestles beneath it */
    margin-bottom: -0.25em;
  }

  .bqs__glyph-close {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 0.7em;
    line-height: 0;
    vertical-align: -0.15em;
    color: var(--accent);
    opacity: 0.35;
    margin-left: 0.1em;
    user-select: none;
  }

  /* ── Blockquote / pull-quote text ───────────────────────────────────────── */
  .bqs__quote {
    margin: 0;
  }

  .bqs__quote p {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: var(--fw-display);
    /* --step-4 fluid; clamp up to --step-5 on wide viewports */
    font-size: clamp(var(--step-3), 4.5vw, var(--step-5));
    line-height: var(--leading-display);
    letter-spacing: var(--tracking-display);
    color: var(--text-on-dark);
    margin: 0;
    text-wrap: balance;
  }

  /* ── Attribution ────────────────────────────────────────────────────────── */
  .bqs__attribution {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.3rem;
    font-style: normal;
  }

  .bqs__author {
    font-family: var(--font-body);
    font-weight: var(--fw-bold);
    font-size: var(--step--1);
    text-transform: uppercase;
    letter-spacing: var(--tracking-eyebrow);
    color: var(--text-on-dark);
    opacity: 0.9;
  }

  .bqs__source {
    font-family: var(--font-body);
    font-size: var(--step--1);
    font-style: italic;
    color: var(--text-on-dark);
    opacity: 0.55;
  }

  /* ── Tone variants: alt/brand fall back gracefully but look best on deep ── */
  [data-tone="default"] .bqs__quote p,
  [data-tone="alt"] .bqs__quote p {
    color: var(--text);
  }
  [data-tone="default"] .bqs__author,
  [data-tone="alt"] .bqs__author {
    color: var(--text-muted);
    opacity: 1;
  }
  [data-tone="default"] .bqs__source,
  [data-tone="alt"] .bqs__source {
    color: var(--text-muted);
    opacity: 1;
  }
  [data-tone="brand"] .bqs__quote p {
    color: var(--brand-contrast);
  }

  /* ── Responsive ─────────────────────────────────────────────────────────── */
  @media (max-width: 600px) {
    .bqs__figure {
      max-width: 36ch;
    }
  }
</style>
