---
/**
 * HoursContactSection — refined hours table + contact details + CTA combo.
 *
 * Award pattern: utility bands should feel like editorial decisions, not
 * afterthoughts. 65/35 asymmetric split (copy left, hours card right).
 * Hours rendered as a clean DL table with a fine rule separating rows.
 * Phone number treated as a display-scale typographic moment.
 * CTA pill anchored below phone. All token-driven; tone variants respected.
 *
 * Prop shape matches the 'hours-contact' member of the Section union (types.ts).
 */
import type { BusinessHours, SectionEnvelope } from '../../types';

interface Props extends SectionEnvelope {
  hours: BusinessHours[];
  phone?: string;
  cta?: { text: string; href: string };
  /** Chapter index from SectionRenderer — accepted but not rendered (utility band). */
  index?: number;
}

const {
  hours,
  phone,
  cta,
  eyebrow,
  heading,
  intro,
  tone = 'alt',
  align = 'left',
  index: _index,
} = Astro.props as Props;

const telHref = phone ? `tel:${phone.replace(/\D/g, '')}` : undefined;
const isCentered = align === 'center';
---

<section class="section hc" data-tone={tone} id="hours-contact">
  <div class="container">
    <div class={`hc__layout${isCentered ? ' hc__layout--center' : ''}`}>

      <!-- ── Left: editorial copy + contact ── -->
      <div class="hc__lead" data-reveal>

        {eyebrow && (
          <p class="hc__eyebrow">{eyebrow}</p>
        )}

        {heading && (
          <h2 class="hc__heading">{heading}</h2>
        )}

        {intro && (
          <p class="hc__intro">{intro}</p>
        )}

        {telHref && phone && (
          <a class="hc__phone" href={telHref} aria-label={`Call us at ${phone}`}>
            {phone}
          </a>
        )}

        {cta && (
          <a class="hc__cta" href={cta.href}>
            {cta.text}
            <svg class="hc__cta-arrow" viewBox="0 0 20 20" fill="none" aria-hidden="true" focusable="false">
              <path d="M4 10h12m-5-5 5 5-5 5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        )}

      </div>

      <!-- ── Right: hours card ── -->
      {hours.length > 0 && (
        <div class="hc__hours-wrap" data-reveal>
          <div class="hc__card">
            <p class="hc__card-label">Hours</p>
            <dl class="hc__table">
              {hours.map(({ day, hours: h }) => (
                <div class="hc__row">
                  <dt class="hc__day">{day}</dt>
                  <dd class="hc__val">{h}</dd>
                </div>
              ))}
            </dl>
          </div>
        </div>
      )}

    </div>
  </div>
</section>

<style>
  /* ── Section padding ── */
  .hc {
    padding-block: var(--section-pad);
  }

  /* ── Two-column 65 / 35 layout ── */
  .hc__layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: start;
  }

  /* Override: wider left column for editorial asymmetry */
  @media (min-width: 720px) {
    .hc__layout {
      /* 60 / 40 split — NOT 50/50 */
      grid-template-columns: 3fr 2fr;
    }
  }

  .hc__layout--center {
    text-align: center;
    justify-items: center;
  }

  /* ── Eyebrow ── */
  .hc__eyebrow {
    font-family: var(--font-body);
    font-size: var(--step--1);
    font-weight: var(--fw-bold);
    letter-spacing: var(--tracking-eyebrow);
    text-transform: uppercase;
    color: var(--brand);
    margin: 0 0 0.6rem;
  }

  /* ── Heading ── */
  .hc__heading {
    font-family: var(--font-display);
    font-size: clamp(var(--step-2), 2.8vw + 0.4rem, var(--step-4));
    font-weight: var(--fw-display);
    letter-spacing: var(--tracking-display);
    line-height: var(--leading-display);
    color: var(--text);
    margin: 0 0 0.45em;
    text-wrap: balance;
  }

  /* ── Intro ── */
  .hc__intro {
    font-size: var(--step-0);
    color: var(--text-muted);
    line-height: var(--leading-body);
    margin: 0 0 1.5rem;
    max-width: 46ch;
  }
  .hc__layout--center .hc__intro {
    margin-inline: auto;
  }

  /* ── Phone: display-scale typographic moment ── */
  .hc__phone {
    display: block;
    font-family: var(--font-display);
    font-size: clamp(var(--step-2), 3vw, var(--step-3));
    font-weight: var(--fw-display);
    letter-spacing: var(--tracking-display);
    line-height: 1.1;
    color: var(--brand);
    text-decoration: none;
    margin-bottom: 1.5rem;
    transition: color var(--motion-fade) var(--motion-ease);
  }
  .hc__phone:hover,
  .hc__phone:focus-visible {
    color: var(--accent);
    text-decoration: none;
    outline: 2px solid var(--ring);
    outline-offset: 3px;
    border-radius: 2px;
  }

  /* ── CTA link ── */
  .hc__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.75em 1.5em;
    font-family: var(--font-body);
    font-weight: var(--fw-bold);
    font-size: var(--step-0);
    text-decoration: none;
    background: var(--brand);
    color: var(--brand-contrast);
    border-radius: var(--radius-pill);
    box-shadow: var(--shadow-sm);
    transition:
      background-color var(--motion-fade) var(--motion-ease),
      box-shadow var(--motion-fade) var(--motion-ease),
      transform var(--motion-fade) var(--motion-ease);
  }
  .hc__cta:hover,
  .hc__cta:focus-visible {
    background: var(--brand-dark);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
    text-decoration: none;
    outline: 2px solid var(--ring);
    outline-offset: 3px;
  }

  .hc__cta-arrow {
    width: 1em;
    height: 1em;
    flex-shrink: 0;
    transition: transform var(--motion-fade) var(--motion-ease);
  }
  .hc__cta:hover .hc__cta-arrow {
    transform: translateX(3px);
  }

  /* ── Hours card ── */
  .hc__hours-wrap {
    /* Allows the card to sit flush at the top of its column */
    width: 100%;
  }

  .hc__card {
    background: var(--surface);
    border: var(--border-weight) solid var(--border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
    padding: clamp(1.25rem, 3vw, 2rem);
    /* Top accent stripe instead of a title-bar heavyweight treatment */
    border-top: 3px solid var(--brand);
  }

  .hc__card-label {
    font-family: var(--font-body);
    font-size: var(--step--1);
    font-weight: var(--fw-bold);
    letter-spacing: var(--tracking-eyebrow);
    text-transform: uppercase;
    color: var(--brand);
    margin: 0 0 1rem;
  }

  /* ── Hours table (DL) ── */
  .hc__table {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin: 0;
    padding: 0;
  }

  .hc__row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    padding: 0.55em 0;
    border-bottom: var(--border-weight) solid var(--border);
  }
  .hc__row:last-child {
    border-bottom: none;
  }

  .hc__day {
    font-family: var(--font-body);
    font-weight: var(--fw-bold);
    font-size: var(--step--1);
    color: var(--text);
    /* dt resets */
    margin: 0;
    min-width: 5rem;
  }

  .hc__val {
    font-family: var(--font-body);
    font-size: var(--step--1);
    color: var(--text-muted);
    /* dd reset */
    margin: 0;
    text-align: right;
  }

  /* ── Tone overrides ── */
  [data-tone="deep"] .hc__eyebrow {
    color: var(--accent);
  }
  [data-tone="deep"] .hc__heading {
    color: var(--text-on-dark);
  }
  [data-tone="deep"] .hc__intro {
    color: var(--text-on-dark);
    opacity: 0.75;
  }
  [data-tone="deep"] .hc__phone {
    color: var(--accent);
  }
  [data-tone="deep"] .hc__card {
    background: color-mix(in srgb, var(--text-on-dark) 8%, transparent);
    border-color: color-mix(in srgb, var(--text-on-dark) 18%, transparent);
  }
  [data-tone="deep"] .hc__card-label {
    color: var(--accent);
  }
  [data-tone="deep"] .hc__day {
    color: var(--text-on-dark);
  }
  [data-tone="deep"] .hc__val {
    color: var(--text-on-dark);
    opacity: 0.65;
  }
  [data-tone="deep"] .hc__row {
    border-bottom-color: color-mix(in srgb, var(--text-on-dark) 14%, transparent);
  }

  [data-tone="brand"] .hc__eyebrow {
    color: var(--brand-contrast);
    opacity: 0.75;
  }
  [data-tone="brand"] .hc__heading,
  [data-tone="brand"] .hc__intro {
    color: var(--brand-contrast);
  }
  [data-tone="brand"] .hc__phone {
    color: var(--brand-contrast);
  }
  [data-tone="brand"] .hc__cta {
    background: var(--brand-contrast);
    color: var(--brand);
  }
  [data-tone="brand"] .hc__cta:hover {
    background: color-mix(in srgb, var(--brand-contrast) 90%, var(--brand));
  }
  [data-tone="brand"] .hc__card {
    background: color-mix(in srgb, var(--brand-contrast) 12%, transparent);
    border-color: color-mix(in srgb, var(--brand-contrast) 25%, transparent);
  }
  [data-tone="brand"] .hc__card-label {
    color: var(--brand-contrast);
    opacity: 0.8;
  }
  [data-tone="brand"] .hc__day {
    color: var(--brand-contrast);
  }
  [data-tone="brand"] .hc__val {
    color: var(--brand-contrast);
    opacity: 0.65;
  }
  [data-tone="brand"] .hc__row {
    border-bottom-color: color-mix(in srgb, var(--brand-contrast) 20%, transparent);
  }

  /* ── Mobile ── */
  @media (max-width: 719px) {
    .hc__layout {
      grid-template-columns: 1fr;
    }
    .hc__phone {
      font-size: var(--step-2);
    }
  }
</style>
