---
/**
 * ListSection — tidy grouped columns with notes.
 * Award pattern (cafe/salon teardowns): service/menu list as editorial element.
 * Group title with accent rule, items as stacked rows, name + note on same line,
 * hairline separators, no icon clutter. Generous inter-group spacing.
 */
import SectionHead from './SectionHead.astro';
import type { Section } from '../../types';

type Props = Extract<Section, { type: 'list' }> & { index?: number };

const {
  eyebrow,
  heading,
  intro,
  tone = 'default',
  align = 'left',
  groups = [],
  index,
} = Astro.props as Props;
---

<section class="section lst" data-tone={tone}>
  <div class="container">

    {(eyebrow || heading || intro) && (
      <SectionHead {index} {eyebrow} {heading} {intro} {align} />
    )}

    {groups.length > 0 && (
      <div class="lst__groups">
        {groups.map((group, gi) => (
          <div class="lst__group" data-reveal data-reveal-order={gi}>

            {/* Group heading — small accent rule below */}
            <h3 class="lst__title">{group.title}</h3>

            <ul class="lst__items" role="list">
              {group.items.map((item) => (
                <li class="lst__item">
                  <span class="lst__name">{item.name}</span>
                  {item.note && (
                    <span class="lst__note">{item.note}</span>
                  )}
                </li>
              ))}
            </ul>

          </div>
        ))}
      </div>
    )}

  </div>
</section>

<style>
  /* ── Section shell ── */
  .lst {
    padding-block: var(--section-pad);
    background: var(--bg);
    color: var(--text);
  }
  .lst[data-tone='alt']   { background: var(--bg-alt); }
  .lst[data-tone='deep']  { background: var(--bg-deep); color: var(--text-on-dark); }
  .lst[data-tone='brand'] { background: var(--brand);   color: var(--brand-contrast); }

  .container {
    max-width: var(--maxw);
    margin-inline: auto;
    padding-inline: var(--gutter);
  }

  /* ── Multi-column group grid ── */
  .lst__groups {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 280px), 1fr));
    gap: clamp(2.5rem, 5vw, 4rem) var(--grid-gap);
  }

  /* ── Group block ── */
  .lst__title {
    font-family: var(--font-display);
    font-size: var(--step-1);
    font-weight: var(--fw-display);
    letter-spacing: var(--tracking-display);
    color: var(--text);
    margin: 0 0 0.9rem;
    padding-bottom: 0.65rem;
    /* Thin accent rule below the group title — editorial menu pattern */
    border-bottom: 2px solid var(--accent);
    text-wrap: balance;
  }

  .lst[data-tone='deep']  .lst__title,
  .lst[data-tone='brand'] .lst__title { color: currentColor; }

  /* ── Item list ── */
  .lst__items {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .lst__item {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    padding-block: 0.6rem;
    /* Hairline dotted separator — cafe/menu teardown pattern */
    border-bottom: 1px solid var(--border);
    font-size: var(--step-0);
  }

  /* Remove bottom border on last item so it doesn't double with group spacing */
  .lst__item:last-child {
    border-bottom: none;
  }

  .lst[data-tone='deep']  .lst__item,
  .lst[data-tone='brand'] .lst__item {
    border-bottom-color: color-mix(in srgb, currentColor 18%, transparent);
  }

  /* Item name — bold, left */
  .lst__name {
    font-weight: var(--fw-bold);
    color: var(--text);
    line-height: var(--leading-body);
  }

  .lst[data-tone='deep']  .lst__name,
  .lst[data-tone='brand'] .lst__name { color: currentColor; }

  /* Note — muted, right-aligned, small, flex: none to prevent wrapping */
  .lst__note {
    flex: 0 0 auto;
    font-size: var(--step--1);
    color: var(--text-muted);
    text-align: right;
    line-height: var(--leading-body);
    /* Soft italics for a menu/note feel */
    font-style: italic;
  }

  .lst[data-tone='deep']  .lst__note,
  .lst[data-tone='brand'] .lst__note {
    color: color-mix(in srgb, currentColor 65%, transparent);
    font-style: italic;
  }
</style>
