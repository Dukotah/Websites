---
/**
 * ServicesDetailedBento — services as an asymmetric bento grid (variant 2).
 *
 * The FIRST item is a large feature cell spanning 2 columns × 2 rows; the
 * remaining items fill smaller cells of mixed sizes — an editorial "bento box"
 * that reads as intentional whether a service carries a photo or not.
 *
 * • Photo cells: overflow:hidden, subtle crop-zoom on hover.
 * • Photoless cells: tinted surface + large watermark index number.
 * • Degrades to a single column on mobile; 2-col at ≥ 640 px; full bento ≥ 900 px.
 * • Token-driven; tone-aware (default / alt / deep / brand).
 * • data-reveal / data-reveal-stagger entrance; reduced-motion safe.
 * • Header delegated to SectionHead (chapter index support).
 */
import type { Tone, Align } from '../../types';
import SectionHead from './SectionHead.astro';
import SiteImage from '../SiteImage.astro';

interface ServiceItem {
  title: string;
  description: string;
  image?: string;
  icon?: string;
}

interface Props {
  items: ServiceItem[];
  eyebrow?: string;
  heading?: string;
  intro?: string;
  tone?: Tone;
  align?: Align;
  phone?: string;
  envelope?: string;
  /** Chapter index forwarded from SectionRenderer */
  index?: number;
}

const {
  items = [],
  eyebrow = 'What we do',
  heading,
  intro,
  tone = 'default',
  align = 'left',
  phone,
  envelope,
  index,
} = Astro.props as Props;

const ctaHref = phone
  ? `tel:${phone.replace(/[^+\d]/g, '')}`
  : envelope
  ? `mailto:${envelope}`
  : '#contact';
---

{items.length > 0 && (
  <section class="section bento" data-tone={tone} id="services-detailed">
    <div class="container">

      <SectionHead {index} {eyebrow} {heading} {intro} {align} />

      <div class="bento__grid" data-reveal data-reveal-stagger>
        {items.map((item, i) => (
          <article
            class={`bento-cell${i === 0 ? ' bento-cell--feature' : ''}${item.image ? ' bento-cell--photo' : ' bento-cell--num'}`}
            data-reveal-order={i}
          >
            {/* ── Image layer ─────────────────────────────────────── */}
            {item.image && (
              <div class="bento-cell__media">
                <SiteImage
                  src={item.image}
                  alt={item.title}
                  sizes="(min-width: 900px) 50vw, 100vw"
                />
              </div>
            )}

            {/* ── Watermark number (photoless cells) ──────────────── */}
            {!item.image && (
              <span class="bento-cell__watermark" aria-hidden="true">
                {String(i + 1).padStart(2, '0')}
              </span>
            )}

            {/* ── Content overlay / body ──────────────────────────── */}
            <div class={`bento-cell__body${item.image ? ' bento-cell__body--overlay' : ''}`}>
              {!item.image && (
                <span class="bento-cell__index" aria-hidden="true">
                  {String(i + 1).padStart(2, '0')}
                </span>
              )}
              <h3 class="bento-cell__title">{item.title}</h3>
              <p class="bento-cell__desc">{item.description}</p>
              <a href={ctaHref} class="bento-cell__link" aria-label={`${item.title} — ask about this`}>
                Ask about this
                <svg viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false">
                  <path
                    d="M5 12h14m-6-6 6 6-6 6"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
              </a>
            </div>
          </article>
        ))}
      </div>

    </div>
  </section>
)}

<style>
  /* ── Section shell ───────────────────────────────────────────────────── */
  .bento {
    padding-block: var(--section-pad);
  }

  .container {
    max-width: var(--maxw);
    margin-inline: auto;
    padding-inline: var(--gutter);
  }

  /* ── Bento grid ──────────────────────────────────────────────────────── */
  /*
   * Mobile: single column stack — every cell full-width, min-height to give
   * the feature cell more presence.
   *
   * ≥ 640 px: two columns, feature cell spans both (still 2 rows on feature).
   *
   * ≥ 900 px: full asymmetric bento — 3 columns where col 1-2 are equal and
   * col 3 is slightly wider; feature cell locks to [1/3, 1/3] (rows 1-2).
   * Remaining cells fill in naturally; CSS auto-placement handles mixed sizes
   * for 3-6 items without extra JS.
   */

  .bento__grid {
    display: grid;
    gap: clamp(0.75rem, 1.5vw, 1.25rem);
    grid-template-columns: 1fr;
  }

  @media (min-width: 640px) {
    .bento__grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .bento-cell--feature {
      grid-column: 1 / -1; /* span both columns at 2-col breakpoint */
    }
  }

  @media (min-width: 900px) {
    .bento__grid {
      grid-template-columns: repeat(3, 1fr);
      grid-auto-rows: minmax(260px, auto);
    }

    /* Feature cell: top-left, 2 cols × 2 rows */
    .bento-cell--feature {
      grid-column: 1 / 3;
      grid-row: 1 / 3;
    }
  }

  /* ── Cell base ───────────────────────────────────────────────────────── */
  .bento-cell {
    position: relative;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    border-radius: var(--radius-lg);
    background: var(--surface);
    border: var(--border-weight, 1px) solid var(--border);
    box-shadow: var(--shadow-2);
    min-height: 220px;
    transition:
      transform 260ms var(--motion-ease, var(--ease-out-3)),
      box-shadow 260ms var(--motion-ease, var(--ease-out-3));
    will-change: transform;
  }

  .bento-cell--feature {
    min-height: 320px;
  }

  @media (min-width: 900px) {
    .bento-cell--feature {
      min-height: 0; /* grid-auto-rows handles it */
    }
  }

  .bento-cell:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-4);
  }

  /* ── Photo cell ──────────────────────────────────────────────────────── */
  .bento-cell--photo {
    border-color: transparent;
  }

  .bento-cell--photo:hover {
    border-color: color-mix(in srgb, var(--brand) 30%, transparent);
  }

  .bento-cell__media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .bento-cell__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 560ms var(--ease-out-3, var(--motion-ease));
  }

  .bento-cell--photo:hover .bento-cell__media img {
    transform: scale(1.06);
  }

  /* Dark scrim so text is always legible over photos */
  .bento-cell--photo::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      to top,
      color-mix(in srgb, var(--bg-deep, #0a0a0a) 78%, transparent) 0%,
      color-mix(in srgb, var(--bg-deep, #0a0a0a) 28%, transparent) 55%,
      transparent 100%
    );
    pointer-events: none;
  }

  /* ── Numbered / photoless cell ───────────────────────────────────────── */
  .bento-cell--num {
    background: color-mix(in srgb, var(--brand) 7%, var(--surface-2, var(--surface)));
    border-color: color-mix(in srgb, var(--brand) 18%, var(--border));
    border-top: 3px solid var(--brand);
  }

  .bento-cell--num:hover {
    background: color-mix(in srgb, var(--brand) 11%, var(--surface-2, var(--surface)));
    border-color: color-mix(in srgb, var(--brand) 36%, var(--border));
    border-top-color: var(--brand);
  }

  /* Large background watermark — zero layout contribution */
  .bento-cell__watermark {
    position: absolute;
    inset-block-end: -0.15em;
    inset-inline-end: 0.5rem;
    font-family: var(--font-display);
    font-size: clamp(4rem, 10vw, 7rem);
    font-weight: var(--fw-display);
    line-height: 1;
    color: color-mix(in srgb, var(--brand) 10%, transparent);
    pointer-events: none;
    user-select: none;
    z-index: 0;
  }

  /* ── Cell body ───────────────────────────────────────────────────────── */
  .bento-cell__body {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    flex: 1;
    padding: clamp(1.25rem, 3vw, 1.75rem);
    gap: 0;
    margin-top: auto; /* push to bottom so short cells breathe at top */
  }

  /* Photo overlay: body anchored to bottom of cell */
  .bento-cell__body--overlay {
    justify-content: flex-end;
    background: transparent;
  }

  /* Visible inline index above title (photoless cells only) */
  .bento-cell__index {
    display: block;
    font-family: var(--font-display);
    font-size: var(--step-1);
    font-weight: var(--fw-display);
    line-height: 1;
    letter-spacing: var(--tracking-display, -0.02em);
    color: var(--brand);
    margin-bottom: 0.5rem;
    position: relative;
    z-index: 1;
  }

  .bento-cell__title {
    font-family: var(--font-display);
    font-size: var(--step-1);
    font-weight: var(--fw-display);
    letter-spacing: var(--tracking-display, -0.02em);
    line-height: 1.15;
    color: var(--text);
    margin: 0 0 0.45rem;
    text-wrap: balance;
  }

  /* Feature cell gets a larger title */
  .bento-cell--feature .bento-cell__title {
    font-size: var(--step-3);
  }

  /* Photo overlays: invert text color for legibility */
  .bento-cell--photo .bento-cell__title {
    color: var(--text-on-dark, #fff);
  }

  .bento-cell__desc {
    font-size: var(--step-0);
    color: var(--text-muted);
    line-height: var(--leading-body);
    margin: 0 0 1.1rem;
    flex: 1;
    max-width: 52ch;
  }

  .bento-cell--photo .bento-cell__desc {
    color: color-mix(in srgb, var(--text-on-dark, #fff) 80%, transparent);
  }

  .bento-cell__link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-family: var(--font-body);
    font-size: var(--step--1);
    font-weight: var(--fw-display);
    letter-spacing: 0.01em;
    color: var(--brand);
    text-decoration: none;
    margin-top: auto;
    align-self: flex-start;
  }

  .bento-cell--photo .bento-cell__link {
    color: var(--text-on-dark, #fff);
  }

  .bento-cell__link svg {
    width: 1em;
    height: 1em;
    flex-shrink: 0;
    transition: transform 220ms var(--ease-out-3, var(--motion-ease));
  }

  .bento-cell:hover .bento-cell__link svg {
    transform: translateX(4px);
  }

  /* ── Reduced-motion ──────────────────────────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .bento-cell,
    .bento-cell__media img,
    .bento-cell__link svg {
      transition: none;
    }

    .bento-cell:hover {
      transform: none;
    }

    .bento-cell--photo:hover .bento-cell__media img {
      transform: none;
    }

    .bento-cell:hover .bento-cell__link svg {
      transform: none;
    }
  }

  /* ── Tone variants ───────────────────────────────────────────────────── */
  [data-tone='alt'] {
    background: var(--bg-alt);
  }

  [data-tone='deep'] {
    background: var(--bg-deep);
    color: var(--text-on-dark);
  }

  [data-tone='deep'] .bento-cell--num {
    background: color-mix(in srgb, var(--brand) 12%, var(--surface-2, #1a1a1a));
    border-color: color-mix(in srgb, var(--text-on-dark) 16%, transparent);
    border-top-color: var(--brand);
  }

  [data-tone='deep'] .bento-cell--num:hover {
    background: color-mix(in srgb, var(--brand) 18%, var(--surface-2, #1a1a1a));
    border-color: color-mix(in srgb, var(--text-on-dark) 26%, transparent);
  }

  [data-tone='deep'] .bento-cell__title {
    color: var(--text-on-dark);
  }

  [data-tone='deep'] .bento-cell__desc {
    color: color-mix(in srgb, var(--text-on-dark) 72%, transparent);
  }

  [data-tone='deep'] .bento-cell__watermark {
    color: color-mix(in srgb, var(--text-on-dark) 6%, transparent);
  }

  [data-tone='brand'] {
    background: var(--brand);
    color: var(--brand-contrast);
  }

  [data-tone='brand'] .bento-cell--num {
    background: color-mix(in srgb, var(--brand-dark) 40%, var(--surface));
    border-color: color-mix(in srgb, var(--brand-contrast) 20%, transparent);
    border-top-color: var(--brand-contrast);
  }

  [data-tone='brand'] .bento-cell__index {
    color: color-mix(in srgb, var(--brand-contrast) 70%, transparent);
  }

  [data-tone='brand'] .bento-cell__title {
    color: var(--brand-contrast);
  }

  [data-tone='brand'] .bento-cell__desc {
    color: color-mix(in srgb, var(--brand-contrast) 80%, transparent);
  }

  [data-tone='brand'] .bento-cell__link {
    color: var(--brand-contrast);
  }

  [data-tone='brand'] .bento-cell__watermark {
    color: color-mix(in srgb, var(--brand-contrast) 8%, transparent);
  }
</style>
