---
/**
 * GalleryUniform — calm, grid-disciplined gallery variant.
 *
 * A deliberately different silhouette from GallerySection's editorial masonry:
 * equal square-ish tiles in a responsive auto-fill grid (240 px min column),
 * consistent tight gap, each tile a crop-zoom on hover.  Quieter, more
 * catalogue-like — suits product shots, team grids, or any set where visual
 * equality matters more than drama.
 *
 * LAYOUT — repeat(auto-fill, minmax(min(100%, 240px), 1fr)).
 *   Desktop: 1/1 aspect-ratio tiles.
 *   Mobile:  4/3 tiles (a touch of landscape breathing room on small screens).
 *
 * HOVER — image scales (1.04) inside overflow:hidden; container is static.
 *   Same editorial hover as GallerySection — no lift, no shadow change.
 *   Reduced-motion: transform skipped entirely.
 *
 * CAPTIONS — identical frosted-glass bar slides up from behind the image on
 *   hover.  Reduced-motion: rendered as static bar.  Touch: plain bar below.
 *   aria-hidden on the overlay; accessible text lives in a visually-hidden
 *   fallback paragraph (screen-reader + no-hover devices).
 *
 * DATA-REVEAL — data-reveal-stagger on the grid wrapper; individual cells
 *   inherit entrance animation from global JS.
 *
 * TONE — default / alt / deep / brand honored via [data-tone].
 *
 * Props: identical to GallerySection (drop-in swappable by variant selector).
 *   images   { src, alt, caption? }[]   — the photo stream
 *   eyebrow? heading? intro?            — passed to SectionHead
 *   tone?    align?                     — section-level
 *   index?                              — chapter number from SectionRenderer
 */

import type { SectionEnvelope } from '../../types';
import SectionHead from './SectionHead.astro';
import SiteImage from '../SiteImage.astro';

interface GalleryImage {
  src: string;
  alt: string;
  caption?: string;
  /** Per-image focal point as a CSS object-position string ("X% Y%"). */
  focal?: string;
}

interface Props extends SectionEnvelope {
  images: GalleryImage[];
  index?: number;
}

const {
  images = [],
  eyebrow,
  heading,
  intro,
  tone = 'default',
  align = 'center',
  index,
} = Astro.props as Props;
---

{images.length > 0 && (
  <section class="section gu" data-tone={tone}>
    <div class="container">
      <SectionHead
        index={index}
        eyebrow={eyebrow}
        heading={heading}
        intro={intro}
        align={align}
      />

      <div class="gu__grid" data-reveal data-reveal-stagger>
        {images.map((img) => (
          <figure class="gu__cell" data-frame aria-label={img.alt}>
            <div class="gu__thumb">
              <SiteImage
                src={img.src}
                alt={img.alt}
                class="gu__img"
                objectPosition={img.focal ?? 'center'}
                sizes="(min-width: 768px) 33vw, (min-width: 480px) 50vw, 100vw"
              />
              {img.caption && (
                <figcaption class="gu__cap" aria-hidden="true">
                  <span class="gu__cap-text">{img.caption}</span>
                </figcaption>
              )}
            </div>
            {img.caption && (
              <p class="gu__cap-fallback">{img.caption}</p>
            )}
          </figure>
        ))}
      </div>
    </div>
  </section>
)}

<style>
  /* ─── Shell ────────────────────────────────────────────────────────────────── */
  .gu {
    padding-block: var(--section-pad);
  }

  .container {
    max-width: var(--maxw);
    margin-inline: auto;
    padding-inline: var(--gutter);
  }

  /* ─── Uniform grid ──────────────────────────────────────────────────────────
   * auto-fill so column count adapts to available width with no media queries.
   * min(100%, 240px) prevents a single column from exceeding full width on very
   * narrow viewports.
   */
  .gu__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 240px), 1fr));
    gap: clamp(0.5rem, 1.25vw, 0.875rem);
  }

  /* ─── Cell ──────────────────────────────────────────────────────────────────
   * Mobile: 4/3 — a bit of landscape air on small screens.
   * Desktop (≥ 640 px): true 1/1 square tiles.
   */
  .gu__cell {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    border-radius: var(--radius-lg);
    background: var(--surface);
    margin: 0; /* reset user-agent figure margin */
  }

  @media (min-width: 640px) {
    .gu__cell {
      aspect-ratio: 1 / 1;
    }
  }

  /* ─── Thumb wrapper + image ─────────────────────────────────────────────── */
  .gu__thumb {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
  }

  .gu__img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  /* ─── Hover: image crop-zoom only ──────────────────────────────────────── */
  @media (prefers-reduced-motion: no-preference) {
    .gu__cell:hover .gu__img {
      transform: scale(1.04);
    }
  }

  /* ─── Caption: frosted bar slides up on hover ─────────────────────────── */
  .gu__cap {
    position: absolute;
    inset-inline: 0;
    bottom: 0;
    padding: 0.75rem 1rem 0.85rem;
    background: color-mix(in srgb, var(--bg-deep) 80%, transparent);
    /* stylelint-disable-next-line property-no-unknown */
    -webkit-backdrop-filter: blur(10px) saturate(1.4);
    backdrop-filter: blur(10px) saturate(1.4);
    transform: translateY(100%);
    transition:
      transform 0.4s cubic-bezier(0.22, 1, 0.36, 1),
      opacity 0.4s ease;
    opacity: 0;
  }

  .gu__cell:hover .gu__cap,
  .gu__cell:focus-within .gu__cap {
    transform: translateY(0);
    opacity: 1;
  }

  /* Reduced-motion: no slide, caption visible as static bar */
  @media (prefers-reduced-motion: reduce) {
    .gu__cap {
      transform: none;
      opacity: 1;
      position: static;
      background: var(--surface);
      backdrop-filter: none;
      -webkit-backdrop-filter: none;
    }
    /* Hide duplicate fallback since cap is now visible */
    .gu__cap-fallback { display: none; }
  }

  .gu__cap-text {
    display: block;
    font-family: var(--font-body);
    font-size: var(--step--1);
    font-style: italic;
    color: var(--text-on-dark);
    line-height: var(--leading-body);
    letter-spacing: 0.01em;
  }

  /* ─── Accessibility fallback caption (screen-reader + no-hover) ─────────── */
  .gu__cap-fallback {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
  }

  /* Touch devices: plain bar below the image */
  @media (hover: none) {
    .gu__cap {
      position: static;
      transform: none;
      opacity: 1;
      backdrop-filter: none;
      -webkit-backdrop-filter: none;
      background: var(--surface);
      border-top: var(--border-weight) solid var(--border);
      padding: 0.55rem 0.85rem 0.65rem;
    }
    .gu__cap-text {
      color: var(--text-muted);
    }
    .gu__cap-fallback { display: none; }
  }

  /* ─── Tone overrides ─────────────────────────────────────────────────────── */
  [data-tone='alt'] { background: var(--bg-alt); }

  [data-tone='deep'] {
    background: var(--bg-deep);
    color: var(--text-on-dark);
  }
  [data-tone='deep'] .gu__cell {
    background: var(--surface-2);
  }
  [data-tone='deep'] .gu__cap-text {
    color: var(--text-on-dark);
  }

  [data-tone='brand'] {
    background: var(--brand);
    color: var(--brand-contrast);
  }
  [data-tone='brand'] .gu__cell {
    background: color-mix(in srgb, var(--brand-dark) 60%, transparent);
  }
</style>
