---
/**
 * CtaSection — confident contained CTA band.
 *
 * Award pattern: a single focused ask, generous inset, high-contrast surface,
 * heading + body + one primary button. No clutter. The button never shouts on
 * the brand tone — it inverts to create a contained call-to-action that feels
 * considered rather than desperate.
 *
 * Prop shape matches the 'cta' member of the Section union (types.ts).
 */
import type { Section } from '../../types';

type Props = Extract<Section, { type: 'cta' }> & { index?: number };

const {
  heading,
  text,
  buttonText,
  buttonHref = '#contact',
  tone = 'brand',
  align = 'left',
  // index accepted for SectionRenderer parity; intentionally not rendered
  // (utility bands don't use chapter numbering per spec)
  index: _index,
} = Astro.props as Props;

const isCentered = align === 'center';
---

<section class="section cta-band" data-tone={tone}>
  <div class="container">
    <div class={`cta-band__inner${isCentered ? ' cta-band__inner--center' : ''}`}>

      <div class="cta-band__copy" data-reveal>
        <h2 class="cta-band__heading">{heading}</h2>
        {text && <p class="cta-band__text">{text}</p>}
      </div>

      {buttonText && (
        <div class="cta-band__action" data-reveal>
          <a href={buttonHref} class="cta-band__btn">
            {buttonText}
            <svg class="cta-band__arrow" viewBox="0 0 20 20" fill="none" aria-hidden="true" focusable="false">
              <path d="M4 10h12m-5-5 5 5-5 5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
      )}

    </div>
  </div>
</section>

<style>
  /* ── Base section padding ── */
  .cta-band {
    padding-block: clamp(3rem, 7vw, 5.5rem);
  }

  /* ── Inner layout: asymmetric 65/35 on wide; stacks on narrow ── */
  .cta-band__inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: clamp(1.5rem, 4vw, 3rem);
    /* 65 % copy / 35 % action split — not 50/50 */
    --cta-copy-basis: clamp(260px, 62%, 700px);
  }
  .cta-band__inner--center {
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .cta-band__copy {
    flex: 1 1 var(--cta-copy-basis);
    min-width: 220px;
  }

  .cta-band__action {
    flex: 0 0 auto;
    /* On centered layout, action falls naturally below copy */
  }

  /* ── Heading ── */
  .cta-band__heading {
    font-family: var(--font-display);
    font-size: clamp(var(--step-2), 3vw + 0.5rem, var(--step-4));
    font-weight: var(--fw-display);
    letter-spacing: var(--tracking-display);
    line-height: var(--leading-display);
    margin: 0 0 0.45em;
    text-wrap: balance;
    /* Inherits color from tone context (brand-contrast, text-on-dark, etc.) */
    color: currentColor;
  }

  /* ── Support text ── */
  .cta-band__text {
    font-size: var(--step-0);
    line-height: var(--leading-body);
    margin: 0;
    /* Slight opacity so heading stays dominant */
    opacity: 0.88;
    color: currentColor;
    max-width: 54ch;
  }
  .cta-band__inner--center .cta-band__text {
    margin-inline: auto;
  }

  /* ── CTA button: inverted surface so it reads as a distinct contained element ── */
  .cta-band__btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-body);
    font-weight: var(--fw-bold);
    font-size: var(--step-0);
    letter-spacing: 0.01em;
    text-decoration: none;
    padding: 0.85em 1.6em;
    border-radius: var(--radius-pill);
    white-space: nowrap;
    transition:
      transform var(--motion-fade) var(--motion-ease),
      box-shadow var(--motion-fade) var(--motion-ease),
      background-color var(--motion-fade) var(--motion-ease);
    /* Default (brand tone): white button on brand background */
    background: var(--brand-contrast);
    color: var(--brand);
    box-shadow: var(--shadow-sm);
  }
  .cta-band__btn:hover,
  .cta-band__btn:focus-visible {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
    text-decoration: none;
    outline: 2px solid var(--ring);
    outline-offset: 3px;
  }

  .cta-band__arrow {
    width: 1.1em;
    height: 1.1em;
    flex-shrink: 0;
    transition: transform var(--motion-fade) var(--motion-ease);
  }
  .cta-band__btn:hover .cta-band__arrow {
    transform: translateX(3px);
  }

  /* ── Tone overrides ── */

  /* default: brand bg on a default section */
  [data-tone="default"] .cta-band__btn {
    background: var(--brand);
    color: var(--brand-contrast);
    box-shadow: var(--shadow-sm);
  }
  [data-tone="default"] .cta-band__btn:hover {
    background: var(--brand-dark);
  }

  /* alt: same as default */
  [data-tone="alt"] .cta-band__btn {
    background: var(--brand);
    color: var(--brand-contrast);
  }
  [data-tone="alt"] .cta-band__btn:hover {
    background: var(--brand-dark);
  }

  /* deep: white button on dark background */
  [data-tone="deep"] .cta-band__btn {
    background: var(--text-on-dark);
    color: var(--bg-deep);
  }
  [data-tone="deep"] .cta-band__btn:hover {
    background: var(--accent);
    color: var(--accent-contrast);
  }

  /* brand (default): brand-contrast button on brand background */
  [data-tone="brand"] .cta-band__heading,
  [data-tone="brand"] .cta-band__text {
    color: var(--brand-contrast);
  }
  [data-tone="brand"] .cta-band__btn {
    background: var(--brand-contrast);
    color: var(--brand);
  }
  [data-tone="brand"] .cta-band__btn:hover {
    background: color-mix(in srgb, var(--brand-contrast) 92%, var(--brand));
  }

  /* ── Mobile ── */
  @media (max-width: 600px) {
    .cta-band__inner {
      flex-direction: column;
      align-items: flex-start;
    }
    .cta-band__inner--center {
      align-items: center;
    }
    .cta-band__btn {
      width: 100%;
      justify-content: center;
    }
    .cta-band__inner--center .cta-band__btn {
      width: auto;
    }
  }
</style>
