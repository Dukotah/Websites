---
/**
 * FeatureGrid — refined highlight cards (icon / label / note).
 * Award pattern: Son Daven "amenity icon-grid with editorial framing" —
 * no visible card borders, generous padding, Open Props shadow on hover only,
 * brand-accented icon container, left-border accent rule on hover.
 * Header via SectionHead. Tone-aware.
 */
import SectionHead from './SectionHead.astro';
import type { SectionEnvelope } from '../../types';

interface Item {
  label: string;
  note?: string;
  icon?: string;
}

interface Props extends SectionEnvelope {
  items: Item[];
  index?: number;
}

const {
  items = [],
  eyebrow,
  heading,
  intro,
  tone = 'default',
  align = 'left',
  index,
} = Astro.props as Props;
---

{items.length > 0 && (
  <section class="section fg" data-tone={tone}>
    <div class="container">

      <SectionHead {index} {eyebrow} {heading} {intro} {align} />

      <ul class="fg__grid" role="list">
        {items.slice(0, 6).map((item, i) => (
          <li class="fg__card" data-reveal data-reveal-order={i}>
            {item.icon && (
              <span class="fg__icon-wrap" aria-hidden="true">
                <span class="fg__icon" set:html={item.icon} />
              </span>
            )}
            <h3 class="fg__label">{item.label}</h3>
            {item.note && <p class="fg__note">{item.note}</p>}
          </li>
        ))}
      </ul>

    </div>
  </section>
)}

<style>
  /* ── Layout ────────────────────────────────────────────────── */
  .fg { padding-block: var(--section-pad); }

  .container {
    max-width: var(--maxw);
    margin-inline: auto;
    padding-inline: var(--gutter);
  }

  /* ── Card grid ─────────────────────────────────────────────── */
  .fg__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--grid-gap);
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 220px), 1fr));
  }

  /*
   * Award pattern: editorial amenity tile.
   * Cards start borderless — separation comes from generous padding + surface bg.
   * On hover the Open Props shadow (--shadow-4) lifts the card and a 2px brand
   * left-border rule paints in, signalling interactivity without the generic
   * "rounded card with box-shadow at rest" template tell.
   */
  .fg__card {
    background: var(--surface);
    border-radius: var(--radius-lg);
    padding: 1.75rem 1.6rem 1.8rem;
    border-left: 2px solid transparent;
    transition:
      box-shadow var(--motion-fade) var(--motion-ease),
      border-color var(--motion-fade) var(--motion-ease),
      transform var(--motion-fade) var(--motion-ease);
  }

  .fg__card:hover {
    box-shadow: var(--shadow-4);
    border-left-color: var(--brand);
    transform: translateY(-4px);
  }

  /* ── Icon ──────────────────────────────────────────────────── */
  .fg__icon-wrap {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    background: color-mix(in srgb, var(--brand) 10%, var(--surface));
    border-radius: var(--radius);
    margin-bottom: 1rem;
    transition: background var(--motion-fade) var(--motion-ease);
  }

  .fg__card:hover .fg__icon-wrap {
    background: color-mix(in srgb, var(--brand) 18%, var(--surface));
  }

  .fg__icon {
    display: inline-flex;
    width: 1.35rem;
    height: 1.35rem;
    color: var(--brand);
  }

  .fg__icon :global(svg) {
    width: 100%;
    height: 100%;
    stroke-width: 1.75;
  }

  /* ── Text ──────────────────────────────────────────────────── */
  .fg__label {
    font-family: var(--font-display);
    font-size: var(--step-1);
    font-weight: var(--fw-display);
    color: var(--text);
    margin: 0 0 0.4rem;
    line-height: 1.2;
    text-wrap: balance;
  }

  .fg__note {
    font-size: var(--step--1);
    color: var(--text-muted);
    line-height: var(--leading-body);
    margin: 0;
  }

  /* ── Tone variants ─────────────────────────────────────────── */
  [data-tone='alt'] { background: var(--bg-alt); }

  [data-tone='deep'] {
    background: var(--bg-deep);
    color: var(--text-on-dark);
  }
  [data-tone='deep'] .fg__label  { color: var(--text-on-dark); }
  [data-tone='deep'] .fg__note   { color: color-mix(in srgb, var(--text-on-dark) 65%, transparent); }
  [data-tone='deep'] .fg__card   {
    background: var(--surface-2);
    border-left-color: transparent;
  }
  [data-tone='deep'] .fg__card:hover {
    border-left-color: var(--accent);
    box-shadow: var(--shadow-4);
  }
  [data-tone='deep'] .fg__icon-wrap {
    background: color-mix(in srgb, var(--brand) 20%, var(--surface-2));
  }

  [data-tone='brand'] {
    background: var(--brand);
    color: var(--brand-contrast);
  }
  [data-tone='brand'] .fg__label { color: var(--brand-contrast); }
  [data-tone='brand'] .fg__note  {
    color: color-mix(in srgb, var(--brand-contrast) 75%, transparent);
  }
  [data-tone='brand'] .fg__card {
    background: color-mix(in srgb, var(--brand-contrast) 10%, transparent);
    border-left-color: transparent;
  }
  [data-tone='brand'] .fg__card:hover {
    border-left-color: var(--brand-contrast);
    box-shadow: var(--shadow-3);
  }
  [data-tone='brand'] .fg__icon-wrap {
    background: color-mix(in srgb, var(--brand-contrast) 15%, transparent);
  }
  [data-tone='brand'] .fg__icon { color: var(--brand-contrast); }
</style>
