---
/**
 * FaqAccordion — bordered-accordion variant of FaqSection (faq variant 1).
 *
 * Layout: centered section head, then a single column of bordered <details>
 * items. Each row is self-contained: question in display type on the <summary>
 * with a rotating + → × brand-colored indicator, answer reveals underneath in
 * body type. On viewports ≥ 900 px the accordion splits into two balanced
 * columns (CodeStitch "double accordion" silhouette).
 *
 * Key differences from FaqSection v0 (the sticky two-column split):
 *   - Interactive disclosure — items are collapsed by default (screen-reader +
 *     keyboard accessible via native <details>/<summary>)
 *   - Indicator rotates on open (CSS-only, no JS needed)
 *   - Two-column layout on wide viewports vs. one-wide-column fixed split
 *   - Center-aligned header vs. sticky aside
 *
 * Identical props to FaqSection — drop-in via the variant selector.
 * Token-driven; tone-aware (default / alt / deep / brand).
 * data-reveal entrance; prefers-reduced-motion safe.
 */
import SectionHead from './SectionHead.astro';
import type { Section } from '../../types';

type Props = Extract<Section, { type: 'faq' }> & { index?: number };

const {
  eyebrow = 'Good to know',
  heading = 'Common questions',
  intro,
  tone = 'default',
  align = 'center',
  items = [],
  index,
} = Astro.props as Props;

// Split items into two balanced columns for the wide layout.
// Left col gets the first ceil(n/2) items; right col gets the rest.
const mid = Math.ceil(items.length / 2);
const leftItems = items.slice(0, mid);
const rightItems = items.slice(mid);
---

<section class="section faqa" data-tone={tone}>
  <div class="container">

    <SectionHead {index} {eyebrow} {heading} {intro} align={align} />

    {items.length > 0 && (
      <div class="faqa__cols" data-reveal data-reveal-stagger>

        {/* Left column */}
        <div class="faqa__col">
          {leftItems.map((item, i) => (
            <details class="faqa__item" data-reveal-order={i}>
              <summary class="faqa__summary">
                <span class="faqa__q">{item.q}</span>
                <span class="faqa__indicator" aria-hidden="true">
                  <svg class="faqa__icon" viewBox="0 0 20 20" fill="none" focusable="false">
                    <line x1="10" y1="4" x2="10" y2="16" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
                    <line x1="4"  y1="10" x2="16" y2="10" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" class="faqa__crossbar"/>
                  </svg>
                </span>
              </summary>
              <div class="faqa__body">
                <p class="faqa__a">{item.a}</p>
              </div>
            </details>
          ))}
        </div>

        {/* Right column — only rendered when there are items for it */}
        {rightItems.length > 0 && (
          <div class="faqa__col">
            {rightItems.map((item, i) => (
              <details class="faqa__item" data-reveal-order={mid + i}>
                <summary class="faqa__summary">
                  <span class="faqa__q">{item.q}</span>
                  <span class="faqa__indicator" aria-hidden="true">
                    <svg class="faqa__icon" viewBox="0 0 20 20" fill="none" focusable="false">
                      <line x1="10" y1="4" x2="10" y2="16" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
                      <line x1="4"  y1="10" x2="16" y2="10" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" class="faqa__crossbar"/>
                    </svg>
                  </span>
                </summary>
                <div class="faqa__body">
                  <p class="faqa__a">{item.a}</p>
                </div>
              </details>
            ))}
          </div>
        )}

      </div>
    )}

  </div>
</section>

<style>
  /* ── Section shell ──────────────────────────────────────────────────── */
  .faqa {
    padding-block: var(--section-pad);
    background: var(--bg);
    color: var(--text);
  }
  .faqa[data-tone='alt']   { background: var(--bg-alt); }
  .faqa[data-tone='deep']  { background: var(--bg-deep);  color: var(--text-on-dark); }
  .faqa[data-tone='brand'] { background: var(--brand);    color: var(--brand-contrast); }

  .container {
    max-width: var(--maxw);
    margin-inline: auto;
    padding-inline: var(--gutter);
  }

  /* ── Two-column wrapper ─────────────────────────────────────────────── */
  .faqa__cols {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0; /* columns share the top border of their first item */
  }

  @media (min-width: 900px) {
    .faqa__cols {
      grid-template-columns: 1fr 1fr;
      column-gap: clamp(2rem, 4vw, 4rem);
    }
  }

  /* ── Individual accordion item ──────────────────────────────────────── */
  .faqa__item {
    border-top: var(--border-weight, 1px) solid var(--border);
  }

  .faqa__item:last-child {
    border-bottom: var(--border-weight, 1px) solid var(--border);
  }

  /* Tone: hairlines on dark/brand backgrounds */
  .faqa[data-tone='deep']  .faqa__item,
  .faqa[data-tone='brand'] .faqa__item {
    border-color: color-mix(in srgb, currentColor 20%, transparent);
  }

  /* ── Summary (clickable row) ────────────────────────────────────────── */
  /* Remove default <summary> disclosure triangle across all browsers */
  .faqa__summary {
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-block: clamp(1.1rem, 2.2vw, 1.6rem);
    cursor: pointer;
    /* Reset default browser focus ring; we add our own below */
    outline: none;
  }

  /* Webkit hides the marker with ::-webkit-details-marker */
  .faqa__summary::-webkit-details-marker { display: none; }

  .faqa__summary:focus-visible {
    outline: 2px solid var(--brand);
    outline-offset: 2px;
    border-radius: 2px;
  }
  .faqa[data-tone='deep']  .faqa__summary:focus-visible,
  .faqa[data-tone='brand'] .faqa__summary:focus-visible {
    outline-color: currentColor;
  }

  /* Question text */
  .faqa__q {
    font-family: var(--font-display);
    font-size: var(--step-1);
    font-weight: var(--fw-display);
    letter-spacing: var(--tracking-display);
    line-height: var(--leading-display);
    text-wrap: balance;
    flex: 1;
  }

  /* ── Indicator icon: + collapses into × when open ───────────────────── */
  .faqa__indicator {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.75rem;
    height: 1.75rem;
    color: var(--brand);
    transition: color 180ms var(--ease-out-3, ease);
  }

  .faqa[data-tone='deep']  .faqa__indicator { color: var(--text-on-dark); }
  .faqa[data-tone='brand'] .faqa__indicator { color: var(--brand-contrast); }

  .faqa__icon {
    width: 100%;
    height: 100%;
    overflow: visible;
  }

  /* The vertical bar (part of +) rotates to become the second arm of × */
  .faqa__crossbar {
    transition: transform 240ms var(--ease-out-3, ease);
    transform-origin: center;
  }

  /* When <details> is open: rotate the crossbar 90° → turns + into × shape */
  .faqa__item[open] .faqa__crossbar {
    transform: rotate(90deg);
  }

  /* Hint on hover: slightly lift the indicator */
  .faqa__summary:hover .faqa__indicator {
    transform: scale(1.1);
  }

  /* ── Answer body ─────────────────────────────────────────────────────── */
  .faqa__body {
    padding-block-end: clamp(1.1rem, 2.2vw, 1.6rem);
    padding-inline-end: 2.5rem; /* keep text clear of the indicator column */
  }

  .faqa__a {
    font-size: var(--step-0);
    line-height: var(--leading-body);
    color: var(--text-muted);
    margin: 0;
    max-width: 64ch;
  }

  .faqa[data-tone='deep']  .faqa__a,
  .faqa[data-tone='brand'] .faqa__a {
    color: color-mix(in srgb, currentColor 75%, transparent);
  }

  /* ── Reduced-motion: disable icon transition + data-reveal animations ─ */
  @media (prefers-reduced-motion: reduce) {
    .faqa__crossbar {
      transition: none;
    }
    .faqa__summary:hover .faqa__indicator {
      transform: none;
    }
    [data-reveal],
    [data-reveal-stagger] > * {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
  }
</style>
