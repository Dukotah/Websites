---
/**
 * GalleryFilmstrip — horizontal scroll-snap filmstrip gallery (variant 2).
 *
 * A deliberately distinct silhouette from the masonry (v0) and uniform grid
 * (v1): a single horizontal row of consistent landscape tiles that scroll
 * snap into place with CSS only.  The rightmost tile always peeks at the
 * edge to signal that more images exist offscreen — achieved by sizing each
 * tile to calc(55vw - var(--gutter)) on mobile and a fixed rem width on
 * wider viewports, leaving a deliberate partial tile visible.
 *
 * LAYOUT — a single-row flex container with:
 *   scroll-snap-type: x mandatory
 *   overflow-x: scroll
 *   Each tile: scroll-snap-align: start; flex: 0 0 <tile-width>; aspect-ratio 16/10.
 *
 * HOVER — same editorial crop-zoom (scale 1.04) as the siblings.
 *   Reduced-motion: transform skipped entirely.
 *
 * CAPTIONS — identical frosted-glass bar slides up from behind on hover.
 *   Reduced-motion: rendered as static bar.
 *   Touch: plain bar below the tile.
 *
 * SCROLLBAR — visually hidden (scrollbar-width: none + ::-webkit-scrollbar)
 *   so the peeking tile is the only scroll affordance.  Keyboard / A11y:
 *   the strip is focusable and scroll-navigable via arrow keys on the track.
 *
 * TONE — default / alt / deep / brand honored via [data-tone].
 *
 * Props: identical to GallerySection / GalleryUniform (drop-in swappable).
 *   images   { src, alt, caption? }[]   — the photo stream
 *   eyebrow? heading? intro?            — passed to SectionHead
 *   tone?    align?                     — section-level
 *   index?                              — chapter number from SectionRenderer
 */

import type { SectionEnvelope } from '../../types';
import SectionHead from './SectionHead.astro';
import SiteImage from '../SiteImage.astro';

interface GalleryImage {
  src: string;
  alt: string;
  caption?: string;
}

interface Props extends SectionEnvelope {
  images: GalleryImage[];
  index?: number;
}

const {
  images = [],
  eyebrow,
  heading,
  intro,
  tone = 'default',
  align = 'center',
  index,
} = Astro.props as Props;
---

{images.length > 0 && (
  <section class="section gf" data-tone={tone}>
    <div class="container">
      <SectionHead
        index={index}
        eyebrow={eyebrow}
        heading={heading}
        intro={intro}
        align={align}
      />

      <div class="gf__track" data-reveal aria-label="Photo filmstrip, scroll to see more">
        {images.map((img) => (
          <figure class="gf__tile" data-frame aria-label={img.alt}>
            <div class="gf__thumb">
              <SiteImage
                src={img.src}
                alt={img.alt}
                class="gf__img"
                sizes="(min-width: 768px) 30vw, 55vw"
              />
              {img.caption && (
                <figcaption class="gf__cap" aria-hidden="true">
                  <span class="gf__cap-text">{img.caption}</span>
                </figcaption>
              )}
            </div>
            {img.caption && (
              <p class="gf__cap-fallback">{img.caption}</p>
            )}
          </figure>
        ))}
      </div>
    </div>
  </section>
)}

<style>
  /* ─── Shell ────────────────────────────────────────────────────────────────── */
  .gf {
    padding-block: var(--section-pad);
    /* Overflow visible beyond the container so the peeking tile bleeds
       to the right edge; the container only controls the left inset. */
    overflow: hidden;
  }

  .container {
    max-width: var(--maxw);
    margin-inline: auto;
    padding-inline: var(--gutter);
  }

  /* ─── Filmstrip track ───────────────────────────────────────────────────────
   * overflow-x: scroll on the track itself (not the section) so the left
   * inset is respected while tiles bleed right past the maxw boundary.
   * Negative right margin lets the last tile peek past the container edge.
   */
  .gf__track {
    display: flex;
    flex-direction: row;
    gap: clamp(0.625rem, 1.25vw, 1rem);
    overflow-x: scroll;
    overflow-y: visible;
    scroll-snap-type: x mandatory;
    /* Smooth momentum scrolling on iOS */
    -webkit-overflow-scrolling: touch;
    /* Pull the track to the right edge of the viewport, past the container */
    margin-inline-end: calc(-1 * var(--gutter));
    padding-inline-end: var(--gutter);
    /* Hide the scrollbar visually; track still scrollable via pointer/touch/keyboard */
    scrollbar-width: none;
  }

  .gf__track::-webkit-scrollbar {
    display: none;
  }

  /* ─── Tile sizing — peeking design ─────────────────────────────────────────
   * Mobile: each tile is ~82vw so the next tile peeks ~10vw at the right.
   * Tablet+: fixed rem width (24rem) so ~3.5 tiles are visible at 1024 px.
   * Desktop: 28rem so ~4 tiles at 1400 px with a deliberate half-tile peek.
   */
  .gf__tile {
    flex: 0 0 calc(82vw - var(--gutter));
    /* consistent landscape aspect — 16/10 sits between widescreen and classic */
    aspect-ratio: 16 / 10;
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-lg);
    background: var(--surface);
    scroll-snap-align: start;
    margin: 0; /* reset user-agent figure margin */
  }

  @media (min-width: 600px) {
    .gf__tile {
      flex: 0 0 24rem;
    }
  }

  @media (min-width: 1024px) {
    .gf__tile {
      flex: 0 0 28rem;
    }
  }

  /* ─── Thumb wrapper + image ─────────────────────────────────────────────── */
  .gf__thumb {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
  }

  .gf__img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  /* ─── Hover: image crop-zoom only ──────────────────────────────────────── */
  @media (prefers-reduced-motion: no-preference) {
    .gf__tile:hover .gf__img {
      transform: scale(1.04);
    }
  }

  /* ─── Caption: frosted bar slides up on hover ─────────────────────────── */
  .gf__cap {
    position: absolute;
    inset-inline: 0;
    bottom: 0;
    padding: 0.75rem 1rem 0.85rem;
    background: color-mix(in srgb, var(--bg-deep) 80%, transparent);
    /* stylelint-disable-next-line property-no-unknown */
    -webkit-backdrop-filter: blur(10px) saturate(1.4);
    backdrop-filter: blur(10px) saturate(1.4);
    transform: translateY(100%);
    transition:
      transform 0.4s cubic-bezier(0.22, 1, 0.36, 1),
      opacity 0.4s ease;
    opacity: 0;
  }

  .gf__tile:hover .gf__cap,
  .gf__tile:focus-within .gf__cap {
    transform: translateY(0);
    opacity: 1;
  }

  /* Reduced-motion: no slide, caption visible as static bar */
  @media (prefers-reduced-motion: reduce) {
    .gf__cap {
      transform: none;
      opacity: 1;
      position: static;
      background: var(--surface);
      backdrop-filter: none;
      -webkit-backdrop-filter: none;
    }
    /* Hide duplicate fallback since cap is now visible */
    .gf__cap-fallback { display: none; }
    /* Tiles become height: auto when cap is static so they don't clip it */
    .gf__tile {
      height: auto;
      aspect-ratio: unset;
    }
    .gf__thumb {
      aspect-ratio: 16 / 10;
      height: auto;
    }
  }

  .gf__cap-text {
    display: block;
    font-family: var(--font-body);
    font-size: var(--step--1);
    font-style: italic;
    color: var(--text-on-dark);
    line-height: 1.45;
    letter-spacing: 0.01em;
  }

  /* ─── Accessibility fallback caption (screen-reader + no-hover) ─────────── */
  .gf__cap-fallback {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
  }

  /* Touch devices: plain bar below the tile */
  @media (hover: none) {
    .gf__cap {
      position: static;
      transform: none;
      opacity: 1;
      backdrop-filter: none;
      -webkit-backdrop-filter: none;
      background: var(--surface);
      border-top: var(--border-weight) solid var(--border);
      padding: 0.55rem 0.85rem 0.65rem;
    }
    .gf__cap-text {
      color: var(--text-muted);
    }
    .gf__cap-fallback { display: none; }
    /* Allow tile height to grow to accommodate the caption below */
    .gf__tile {
      height: auto;
      aspect-ratio: unset;
    }
    .gf__thumb {
      aspect-ratio: 16 / 10;
    }
  }

  /* ─── Tone overrides ─────────────────────────────────────────────────────── */
  [data-tone='alt'] { background: var(--bg-alt); }

  [data-tone='deep'] {
    background: var(--bg-deep);
    color: var(--text-on-dark);
  }
  [data-tone='deep'] .gf__tile {
    background: var(--surface-2);
  }
  [data-tone='deep'] .gf__cap-text {
    color: var(--text-on-dark);
  }

  [data-tone='brand'] {
    background: var(--brand);
    color: var(--brand-contrast);
  }
  [data-tone='brand'] .gf__tile {
    background: color-mix(in srgb, var(--brand) 60%, transparent);
  }
</style>
