---
/**
 * ServicesDetailed — bear-flag-quality service grid: a photo (or branded
 * placeholder) per card, title, description, and a "request this" link.
 * Spec §6: type 'services-detailed'. Token-driven for per-business identity.
 */
import type { Tone, Align } from '../../types';

interface ServiceItem {
  title: string;
  description: string;
  /** Real photo for this service (public path). Falls back to a branded card. */
  image?: string;
  icon?: string;
}

interface Props {
  items: ServiceItem[];
  eyebrow?: string;
  heading?: string;
  intro?: string;
  tone?: Tone;
  align?: Align;
  /** phone for the per-card CTA link */
  phone?: string;
}

const {
  items = [],
  eyebrow = 'What we do',
  heading,
  intro,
  tone = 'default',
  align = 'left',
  phone,
} = Astro.props as Props;

const telHref = phone ? `tel:${phone.replace(/[^+\d]/g, '')}` : '#contact';
---

{items.length > 0 && (
  <section class="section svc" data-tone={tone} id="services-detailed">
    <div class="container">
      {(eyebrow || heading || intro) && (
        <div class={`svc__head${align === 'center' ? ' svc__head--center' : ''}`} data-reveal>
          {eyebrow && <p class="eyebrow">{eyebrow}</p>}
          {heading && <h2 class="svc__heading">{heading}</h2>}
          {intro && <p class="svc__intro">{intro}</p>}
        </div>
      )}

      <div class="svc__grid">
        {items.map((item, i) => (
          <article class="svc-card" data-reveal data-reveal-order={i}>
            <div class="svc-card__media" data-frame>
              {item.image ? (
                <img src={item.image} alt={item.title} loading="lazy" decoding="async" />
              ) : (
                <span class="svc-card__ph" aria-hidden="true">
                  {item.title.charAt(0)}
                </span>
              )}
            </div>
            <div class="svc-card__body">
              <h3 class="svc-card__title">{item.title}</h3>
              <p class="svc-card__desc">{item.description}</p>
              <a href={telHref} class="svc-card__link">
                Ask about this
                <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <path d="M5 12h14m-6-6 6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
)}

<style>
  .svc { padding-block: var(--section-pad); }
  .container { max-width: var(--maxw); margin-inline: auto; padding-inline: var(--gutter); }
  .svc__head { margin-bottom: 2.5rem; max-width: 56ch; }
  .svc__head--center { text-align: center; margin-inline: auto; }
  .eyebrow {
    font-family: var(--font-body);
    font-size: var(--step--1);
    font-weight: var(--fw-bold);
    letter-spacing: var(--tracking-eyebrow);
    text-transform: uppercase;
    color: var(--brand);
    margin: 0 0 0.5rem;
  }
  .svc__heading {
    font-family: var(--font-display);
    font-size: var(--step-3);
    font-weight: var(--fw-display);
    letter-spacing: var(--tracking-display);
    line-height: var(--leading-display);
    color: var(--text);
    margin: 0 0 0.6rem;
  }
  .svc__intro { font-size: var(--step-0); color: var(--text-muted); line-height: var(--leading-body); margin: 0; }

  .svc__grid {
    display: grid;
    gap: var(--grid-gap);
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 280px), 1fr));
  }
  .svc-card {
    display: flex;
    flex-direction: column;
    background: var(--surface);
    border: var(--border-weight) solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    transition: transform var(--motion-fade) var(--motion-ease), box-shadow var(--motion-fade) var(--motion-ease), border-color var(--motion-fade) var(--motion-ease);
  }
  .svc-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
    border-color: color-mix(in srgb, var(--brand) 35%, var(--border));
  }
  .svc-card__media {
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: linear-gradient(135deg, color-mix(in srgb, var(--brand) 18%, var(--surface)), color-mix(in srgb, var(--brand) 4%, var(--surface)));
    display: grid;
    place-items: center;
  }
  .svc-card__media img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s var(--motion-ease); }
  .svc-card:hover .svc-card__media img { transform: scale(1.05); }
  .svc-card__ph {
    font-family: var(--font-display);
    font-size: var(--step-5);
    font-weight: var(--fw-display);
    color: color-mix(in srgb, var(--brand) 55%, transparent);
  }
  .svc-card__body { padding: 1.3rem 1.4rem 1.5rem; display: flex; flex-direction: column; flex: 1; }
  .svc-card__title { font-family: var(--font-display); font-size: var(--step-1); font-weight: var(--fw-display); color: var(--text); margin: 0 0 0.4rem; line-height: 1.2; }
  .svc-card__desc { font-size: var(--step--1); color: var(--text-muted); line-height: var(--leading-body); margin: 0 0 1.1rem; flex: 1; }
  .svc-card__link { display: inline-flex; align-items: center; gap: 0.4rem; font-family: var(--font-body); font-weight: var(--fw-bold); font-size: var(--step--1); color: var(--brand); }
  .svc-card__link svg { width: 1.05em; height: 1.05em; transition: transform var(--motion-fade) var(--motion-ease); }
  .svc-card__link:hover { text-decoration: none; }
  .svc-card:hover .svc-card__link svg { transform: translateX(3px); }

  [data-tone='alt'] { background: var(--bg-alt); }
  [data-tone='deep'] { background: var(--bg-deep); color: var(--text-on-dark); }
  [data-tone='deep'] .svc__heading, [data-tone='deep'] .svc-card__title { color: var(--text-on-dark); }
  [data-tone='deep'] .svc-card { background: var(--surface-2); border-color: color-mix(in srgb, var(--text-on-dark) 16%, transparent); }
</style>
