---
import type { Tone, Align } from '../../types';

interface ServiceItem {
  title: string;
  description: string;
  /** Optional inline SVG string or a named icon key (see ICON_MAP below). */
  icon?: string;
}

interface Props {
  items: ServiceItem[];
  eyebrow?: string;
  heading?: string;
  intro?: string;
  tone?: Tone;
  align?: Align;
}

const {
  items,
  eyebrow = 'Our Services',
  heading,
  intro,
  tone = 'default',
  align = 'left',
} = Astro.props;

/**
 * Minimal named-icon set — callers can pass a named key or raw inline SVG.
 * All paths use currentColor so they inherit the token-driven color.
 * Stroke-based icons at 24×24 with 2px stroke and round caps.
 */
const ICON_MAP: Record<string, string> = {
  wrench: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>`,
  truck: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="1" y="3" width="15" height="13" rx="1"/><path d="M16 8h4l3 5v3h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>`,
  scissors: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="6" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><line x1="20" y1="4" x2="8.12" y2="15.88"/><line x1="14.47" y1="14.48" x2="20" y2="20"/><line x1="8.12" y1="8.12" x2="12" y2="12"/></svg>`,
  leaf: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10z"/><path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/></svg>`,
  droplet: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"/></svg>`,
  star: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>`,
  shield: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
  clock: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
  phone: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>`,
  check: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>`,
};

/**
 * Resolve icon: named key → SVG string; raw SVG → pass through; else → null.
 */
function resolveIcon(icon?: string): string | null {
  if (!icon) return null;
  // Named key match
  if (ICON_MAP[icon]) return ICON_MAP[icon];
  // Looks like inline SVG already
  if (icon.trimStart().startsWith('<')) return icon;
  return null;
}
---

<section class="section" data-tone={tone} id="services-detailed">
  <div class="container">

    {(eyebrow || heading || intro) && (
      <div class={`section-header${align === 'center' ? ' section-header--center' : ''}`} data-reveal>
        {eyebrow && <span class="eyebrow">{eyebrow}</span>}
        {heading && <h2>{heading}</h2>}
        {intro && <p class="intro">{intro}</p>}
      </div>
    )}

    <ul class="svc-grid" aria-label="Services" data-reveal-stagger>
      {items.map((item) => {
        const svgIcon = resolveIcon(item.icon);
        return (
          <li class="svc-card">
            {svgIcon && (
              <div class="svc-card__icon" aria-hidden="true" set:html={svgIcon} />
            )}
            <div class="svc-card__body">
              <h3 class="svc-card__title">{item.title}</h3>
              <p class="svc-card__desc">{item.description}</p>
            </div>
          </li>
        );
      })}
    </ul>

  </div>
</section>

<style>
  .svc-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 300px), 1fr));
    gap: var(--grid-gap);
  }

  /* Rich card */
  .svc-card {
    background: var(--surface);
    border: var(--border-weight) solid var(--border);
    border-radius: var(--radius-lg);
    padding: clamp(1.25rem, 3vw, 2rem);
    display: flex;
    flex-direction: column;
    gap: 1rem;
    box-shadow: var(--shadow-sm);
    transition:
      box-shadow var(--motion-fade) var(--motion-ease),
      transform var(--motion-fade) var(--motion-ease);
    position: relative;
    overflow: hidden;
  }

  /* Left accent bar — a small brand flourish */
  .svc-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 3px;
    height: 100%;
    background: var(--brand);
    border-radius: var(--radius) 0 0 var(--radius);
    opacity: 0;
    transition: opacity var(--motion-fade) var(--motion-ease);
  }

  .svc-card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-3px);
  }

  .svc-card:hover::before {
    opacity: 1;
  }

  /* Icon container */
  .svc-card__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    background: var(--bg-alt);
    border-radius: var(--radius);
    color: var(--brand);
    flex-shrink: 0;
    transition: background var(--motion-fade) var(--motion-ease),
                color var(--motion-fade) var(--motion-ease);
  }

  .svc-card:hover .svc-card__icon {
    background: var(--brand);
    color: var(--brand-contrast);
  }

  .svc-card__icon :global(svg) {
    width: 1.4rem;
    height: 1.4rem;
    display: block;
  }

  /* Body */
  .svc-card__body {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
  }

  .svc-card__title {
    font-size: var(--step-1);
    font-family: var(--font-display);
    font-weight: var(--fw-display);
    line-height: var(--leading-display);
    color: var(--text);
    margin: 0;
  }

  .svc-card__desc {
    font-size: var(--step-0);
    color: var(--text-muted);
    line-height: var(--leading-body);
    margin: 0;
  }

  /* ── Tone adaptations ────────────────────────────────────────────────── */
  [data-tone="alt"] .svc-card {
    background: var(--surface);
  }

  [data-tone="deep"] .svc-card,
  [data-tone="brand"] .svc-card {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(255, 255, 255, 0.12);
  }

  [data-tone="deep"] .svc-card__title,
  [data-tone="brand"] .svc-card__title {
    color: var(--text-on-dark);
  }

  [data-tone="deep"] .svc-card__desc,
  [data-tone="brand"] .svc-card__desc {
    color: var(--text-on-dark);
    opacity: 0.75;
  }

  [data-tone="deep"] .svc-card__icon,
  [data-tone="brand"] .svc-card__icon {
    background: rgba(255, 255, 255, 0.1);
    color: var(--accent);
  }

  [data-tone="deep"] .svc-card:hover .svc-card__icon,
  [data-tone="brand"] .svc-card:hover .svc-card__icon {
    background: var(--accent);
    color: var(--accent-contrast);
  }

  [data-tone="deep"] .svc-card::before,
  [data-tone="brand"] .svc-card::before {
    background: var(--accent);
  }
</style>
