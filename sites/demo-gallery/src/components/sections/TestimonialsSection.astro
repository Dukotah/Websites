---
/**
 * TestimonialsSection — editorial pull-quote stack.
 * Award pattern: stacked large italic serif quotes, tracked small-caps attribution.
 * NO star ratings. NO sliding carousel. Confidence, not insecurity.
 * Spec: type 'testimonials'. Union prop shape preserved + index from SectionRenderer.
 */
import SectionHead from './SectionHead.astro';
import type { Section } from '../../types';

type Props = Extract<Section, { type: 'testimonials' }> & { index?: number };

const {
  eyebrow = 'In their words',
  heading,
  intro,
  tone = 'default',
  align = 'left',
  items = [],
  index,
} = Astro.props as Props;
---

{items.length > 0 && (
  <section class="section tms" data-tone={tone}>
    <div class="container">
      <SectionHead {index} {eyebrow} {heading} {intro} {align} />

      <ol class="tms__stack" role="list">
        {items.map((item, i) => (
          <li class="tms__item" data-reveal data-reveal-order={i}>
            <figure class="tms__figure">
              <blockquote class="tms__quote">
                <p>{item.quote}</p>
              </blockquote>
              <figcaption class="tms__attribution">
                <span class="tms__author">{item.author}</span>
                {item.source && (
                  <span class="tms__source">{item.source}</span>
                )}
              </figcaption>
            </figure>
            {i < items.length - 1 && <hr class="tms__rule" aria-hidden="true" />}
          </li>
        ))}
      </ol>
    </div>
  </section>
)}

<style>
  /* ── Section shell ──────────────────────────────────────────────────── */
  .tms {
    padding-block: var(--section-pad);
    background: var(--bg);
    color: var(--text);
  }
  .tms[data-tone='alt']   { background: var(--bg-alt); }
  .tms[data-tone='deep']  { background: var(--bg-deep); color: var(--text-on-dark); }
  .tms[data-tone='brand'] { background: var(--brand);   color: var(--brand-contrast); }

  .container {
    max-width: var(--maxw);
    margin-inline: auto;
    padding-inline: var(--gutter);
  }

  /* ── Quote stack ────────────────────────────────────────────────────── */
  .tms__stack {
    list-style: none;
    margin: 0;
    padding: 0;
    /* Generous max-width keeps long quotes readable — editorial column width. */
    max-width: 72ch;
  }

  .tms__item {
    /* No card. No border. The quote stands on its own. */
  }

  /* ── Pull quote ─────────────────────────────────────────────────────── */
  .tms__figure {
    margin: 0;
    padding-block: clamp(2.25rem, 5vw, 3.5rem);
  }

  .tms__quote {
    margin: 0 0 1.25rem;
  }

  .tms__quote p {
    font-family: var(--font-display);
    font-size: var(--step-2);
    font-style: italic;
    font-weight: var(--fw-display);
    line-height: var(--leading-display);
    color: var(--text);
    /* text-wrap: balance on headings — quoted text benefits from the same. */
    text-wrap: balance;
    margin: 0;
    /* Opening mark rendered as pseudo — not cluttering the DOM. */
    position: relative;
    padding-left: 1.6rem;
  }

  .tms__quote p::before {
    content: '\201C';
    position: absolute;
    left: 0;
    top: -0.08em;
    font-family: var(--font-display);
    font-size: 2.4em;
    line-height: 1;
    color: var(--brand);
    opacity: 0.4;
    font-style: normal;
  }

  /* Deep / brand tones: quote text inverts. */
  .tms[data-tone='deep']  .tms__quote p { color: var(--text-on-dark); }
  .tms[data-tone='brand'] .tms__quote p { color: var(--brand-contrast); }

  /* ── Attribution — tracked small-caps ──────────────────────────────── */
  .tms__attribution {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    flex-wrap: wrap;
  }

  .tms__author {
    font-family: var(--font-body);
    font-size: var(--step--1);
    font-weight: var(--fw-bold);
    letter-spacing: var(--tracking-eyebrow);
    text-transform: uppercase;
    /* True small-caps where the font supports it. */
    font-variant-caps: all-small-caps;
    color: var(--text);
  }
  .tms[data-tone='deep']  .tms__author { color: var(--text-on-dark); }
  .tms[data-tone='brand'] .tms__author { color: var(--brand-contrast); }

  .tms__source {
    font-family: var(--font-body);
    font-size: var(--step--1);
    letter-spacing: var(--tracking-eyebrow);
    text-transform: uppercase;
    font-variant-caps: all-small-caps;
    color: var(--text-muted);
    /* Em dash separator — cleaner than bullet. */
  }
  .tms__source::before {
    content: '\2014\00a0';
    opacity: 0.5;
  }
  .tms[data-tone='deep']  .tms__source,
  .tms[data-tone='brand'] .tms__source {
    color: inherit;
    opacity: 0.7;
  }

  /* ── Divider between quotes ─────────────────────────────────────────── */
  .tms__rule {
    border: none;
    border-top: var(--border-weight) solid var(--border);
    margin: 0;
  }
  .tms[data-tone='deep']  .tms__rule,
  .tms[data-tone='brand'] .tms__rule {
    border-top-color: color-mix(in srgb, currentColor 18%, transparent);
  }

  /* ── Wide layout: open the quote column on generous viewports ───────── */
  @media (min-width: 64rem) {
    .tms__stack {
      max-width: 66ch;
    }
    .tms__quote p {
      font-size: var(--step-3);
      padding-left: 2rem;
    }
  }
</style>
