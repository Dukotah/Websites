---
import type { Section } from '../../types';

type Props = Extract<Section, { type: 'testimonials' }>;

const {
  eyebrow = 'In their words',
  heading = 'What people say',
  intro,
  tone = 'default',
  align = 'left',
  items = [],
} = Astro.props as Props;
---

<section class="section" data-tone={tone}>
  <div class="container">
    {(eyebrow || heading || intro) && (
      <div class="testimonials__head" data-align={align}>
        {eyebrow && <p class="eyebrow">{eyebrow}</p>}
        {heading && <h2>{heading}</h2>}
        {intro && <p class="testimonials__intro">{intro}</p>}
      </div>
    )}

    <div class="testimonials__grid">
      {
        items.map((item, i) => (
          <figure class="testimonial" data-reveal data-reveal-order={i}>
            <blockquote>{item.quote}</blockquote>
            <figcaption>
              <span class="testimonial__author">{item.author}</span>
              {item.source && <span class="testimonial__source"> · {item.source}</span>}
            </figcaption>
          </figure>
        ))
      }
    </div>
  </div>
</section>

<style>
  .section[data-tone='default'] {
    background: var(--bg);
    color: var(--text);
  }
  .section[data-tone='alt'] {
    background: var(--bg-alt);
    color: var(--text);
  }
  .section[data-tone='deep'] {
    background: var(--bg-deep);
    color: var(--text-on-dark);
  }
  .section[data-tone='brand'] {
    background: var(--brand);
    color: var(--brand-contrast);
  }

  .testimonials__head {
    margin-bottom: var(--section-pad);
    max-width: 50ch;
  }
  .testimonials__head[data-align='center'] {
    text-align: center;
    margin-left: auto;
    margin-right: auto;
  }

  .testimonials__intro {
    color: var(--text-muted);
    font-size: var(--step-0);
    margin: 0.5rem 0 0;
  }
  .section[data-tone='deep'] .testimonials__intro,
  .section[data-tone='brand'] .testimonials__intro {
    color: inherit;
    opacity: 0.9;
  }

  .testimonials__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--grid-gap);
  }

  .testimonial {
    margin: 0;
    background: var(--surface);
    border: var(--border-weight) solid var(--border);
    border-radius: var(--radius-lg);
    padding: var(--section-pad);
    box-shadow: var(--shadow-sm);
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .section[data-tone='alt'] .testimonial {
    background: var(--surface-2);
  }
  .section[data-tone='deep'] .testimonial,
  .section[data-tone='brand'] .testimonial {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.2);
  }

  .testimonial blockquote {
    margin: 0;
    font-size: var(--step-0);
    line-height: var(--leading-body);
    color: currentColor;
    font-family: var(--font-body);
  }

  .testimonial figcaption {
    font-size: var(--step--1);
    color: var(--text-muted);
    margin-top: auto;
  }
  .section[data-tone='deep'] .testimonial figcaption,
  .section[data-tone='brand'] .testimonial figcaption {
    color: inherit;
    opacity: 0.85;
  }

  .testimonial__author {
    font-weight: var(--fw-bold);
    color: var(--text);
  }
  .section[data-tone='deep'] .testimonial__author,
  .section[data-tone='brand'] .testimonial__author {
    color: currentColor;
  }

  .testimonial__source {
    color: var(--text-muted);
  }
  .section[data-tone='deep'] .testimonial__source,
  .section[data-tone='brand'] .testimonial__source {
    color: inherit;
    opacity: 0.75;
  }
</style>
