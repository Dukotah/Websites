---
/**
 * ServiceAreaSection — elegant chip cloud + optional note.
 * Tear-down pattern: trades "Location/Service Area" section — pill grid with
 * accent border, hover fill, very-low-opacity map-texture background.
 * Header via SectionHead. Tone-aware.
 */
import SectionHead from './SectionHead.astro';
import type { SectionEnvelope } from '../../types';

interface Props extends SectionEnvelope {
  areas: string[];
  note?: string;
  index?: number;
}

const {
  areas = [],
  note,
  eyebrow = 'Service area',
  heading,
  intro,
  tone = 'alt',
  align = 'left',
  index,
} = Astro.props as Props;
---

{areas.length > 0 && (
  <section class="section area" data-tone={tone}>
    <div class="container">

      <SectionHead {index} {eyebrow} {heading} {intro} {align} />

      <ul class="area__chips" data-reveal data-reveal-stagger>
        {areas.map((a) => (
          <li class="area__chip">{a}</li>
        ))}
      </ul>

      {note && (
        <p class="area__note" data-reveal>{note}</p>
      )}

    </div>
  </section>
)}

<style>
  /* ── Layout ────────────────────────────────────────────────── */
  .area { padding-block: var(--section-pad); }

  .container {
    max-width: var(--maxw);
    margin-inline: auto;
    padding-inline: var(--gutter);
  }

  /* ── Chip cloud ────────────────────────────────────────────── */
  .area__chips {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem 0.65rem;
  }

  /*
   * Award pattern: pill chips with accent border that fill --accent on hover.
   * The hover fill + text invert is the "premium pill grid" from trades teardown.
   */
  .area__chip {
    font-family: var(--font-body);
    font-size: var(--step--1);
    font-weight: var(--fw-bold);
    letter-spacing: 0.02em;
    color: var(--text);
    background: var(--surface);
    border: var(--border-weight) solid color-mix(in srgb, var(--accent) 55%, var(--border));
    border-radius: var(--radius-pill);
    padding: 0.45rem 1.05rem;
    box-shadow: var(--shadow-1);
    transition:
      background var(--motion-fade) var(--motion-ease),
      color var(--motion-fade) var(--motion-ease),
      border-color var(--motion-fade) var(--motion-ease),
      box-shadow var(--motion-fade) var(--motion-ease),
      transform var(--motion-fade) var(--motion-ease);
    cursor: default;
  }

  .area__chip:hover {
    background: var(--accent);
    color: var(--accent-contrast);
    border-color: var(--accent);
    box-shadow: var(--shadow-3);
    transform: translateY(-2px);
  }

  /* ── Note ──────────────────────────────────────────────────── */
  .area__note {
    margin-block-start: 1.75rem;
    font-size: var(--step--1);
    color: var(--text-muted);
    line-height: var(--leading-body);
    max-width: 60ch;
  }

  /* ── Tone variants ─────────────────────────────────────────── */
  [data-tone='default'] { background: var(--bg); }
  [data-tone='alt']     { background: var(--bg-alt); }

  [data-tone='deep'] {
    background: var(--bg-deep);
    color: var(--text-on-dark);
  }
  [data-tone='deep'] .area__note {
    color: color-mix(in srgb, var(--text-on-dark) 65%, transparent);
  }
  [data-tone='deep'] .area__chip {
    background: var(--surface-2);
    color: var(--text-on-dark);
    border-color: color-mix(in srgb, var(--accent) 40%, transparent);
  }
  [data-tone='deep'] .area__chip:hover {
    background: var(--accent);
    color: var(--accent-contrast);
    border-color: var(--accent);
  }

  [data-tone='brand'] {
    background: var(--brand);
    color: var(--brand-contrast);
  }
  [data-tone='brand'] .area__note {
    color: color-mix(in srgb, var(--brand-contrast) 75%, transparent);
  }
  [data-tone='brand'] .area__chip {
    background: color-mix(in srgb, var(--brand-contrast) 12%, transparent);
    color: var(--brand-contrast);
    border-color: color-mix(in srgb, var(--brand-contrast) 35%, transparent);
  }
  [data-tone='brand'] .area__chip:hover {
    background: var(--brand-contrast);
    color: var(--brand);
    border-color: var(--brand-contrast);
  }
</style>
