---
/**
 * SectionHead — the shared editorial section header used by every rich section.
 * Award-site pattern: a numbered "chapter" (01, 02…) as a typographic divider in
 * the accent color, a tracked small-caps eyebrow, an oversized display heading,
 * and an optional intro. Token-driven; archetype CSS can restyle it (e.g.
 * editorial = asymmetric two-column).
 *
 * Props:
 *   index?   running chapter number from SectionRenderer (omit → no number)
 *   eyebrow? heading? intro?  the header text
 *   align?   'left' | 'center'
 */
interface Props {
  index?: number;
  eyebrow?: string;
  heading?: string;
  intro?: string;
  align?: 'left' | 'center';
}
const { index, eyebrow, heading, intro, align = 'left' } = Astro.props as Props;
const chapter = typeof index === 'number' ? String(index).padStart(2, '0') : '';
const hasContent = eyebrow || heading || intro || chapter;
---

{hasContent && (
  <header class={`sec-head sec-head--${align}`} data-reveal>
    {(chapter || eyebrow) && (
      <p class="sec-head__eyebrow">
        {chapter && <span class="sec-head__num">{chapter}</span>}
        {eyebrow && <span class="sec-head__label">{eyebrow}</span>}
      </p>
    )}
    {heading && <h2 class="sec-head__heading">{heading}</h2>}
    {intro && <p class="sec-head__intro">{intro}</p>}
  </header>
)}

<style>
  .sec-head {
    margin-bottom: clamp(2rem, 4vw, 3.25rem);
    max-width: 60ch;
  }
  .sec-head--center {
    text-align: center;
    margin-inline: auto;
    max-width: 52ch;
  }
  .sec-head__eyebrow {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    margin: 0 0 0.9rem;
    font-family: var(--font-body);
    font-size: var(--step--1);
    font-weight: var(--fw-bold);
    letter-spacing: var(--tracking-eyebrow);
    text-transform: uppercase;
    color: var(--text-muted);
  }
  .sec-head--center .sec-head__eyebrow {
    justify-content: center;
  }
  .sec-head__num {
    color: var(--accent);
    font-variant-numeric: tabular-nums;
  }
  .sec-head__num::after {
    content: '';
    display: inline-block;
    width: 1.4rem;
    height: 1px;
    margin-left: 0.7rem;
    vertical-align: middle;
    background: color-mix(in srgb, var(--accent) 60%, transparent);
  }
  .sec-head__label {
    color: var(--brand);
  }
  .sec-head__heading {
    font-family: var(--font-display);
    font-size: var(--step-4);
    font-weight: var(--fw-display);
    letter-spacing: var(--tracking-display);
    line-height: var(--leading-display);
    color: var(--text);
    margin: 0 0 0.6rem;
    text-wrap: balance;
  }
  .sec-head__intro {
    font-size: var(--step-1);
    color: var(--text-muted);
    line-height: var(--leading-body);
    margin: 0;
  }
  /* On dark sections the header inverts. */
  :global([data-tone='deep']) .sec-head__heading { color: var(--text-on-dark); }
  :global([data-tone='deep']) .sec-head__label { color: var(--text-on-dark); }
  :global([data-tone='brand']) .sec-head__heading,
  :global([data-tone='brand']) .sec-head__label { color: var(--brand-contrast); }
</style>
