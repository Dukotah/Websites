---
/**
 * EditorialFeature — signature full-bleed editorial spread.
 *
 * Alternating rows: large portrait image one side, short poetic copy + a
 * folio index number the other. Image side flips left/right each row.
 * Spec §6 type: 'editorial-feature'. Token-driven. [data-reveal] for
 * scroll-entrance. No client JS, no external images fetched at build.
 *
 * Props shape mirrors FeatureSplit for data-source compatibility:
 *   rows: { heading, body, image?, imageAlt? }[]
 * Plus the shared SectionEnvelope (eyebrow, heading, intro, tone, align).
 */
import type { SectionEnvelope } from '../../types';

interface EditorialRow {
  heading: string;
  body: string;
  image?: string;
  imageAlt?: string;
}

interface Props extends SectionEnvelope {
  rows: EditorialRow[];
}

const {
  rows = [],
  eyebrow,
  heading,
  intro,
  tone = 'default',
  align = 'left',
} = Astro.props as Props;

// Pad the index number with a leading zero — e.g. "01", "02" — editorial folio style.
function fmtIndex(n: number): string {
  return String(n + 1).padStart(2, '0');
}
---

{rows.length > 0 && (
  <section class="section ef" data-tone={tone}>
    <div class="ef__container">

      {(eyebrow || heading || intro) && (
        <header class={`ef__header${align === 'center' ? ' ef__header--center' : ''}`} data-reveal>
          {eyebrow && <p class="ef__eyebrow">{eyebrow}</p>}
          {heading && <h2 class="ef__section-heading">{heading}</h2>}
          {intro && <p class="ef__section-intro">{intro}</p>}
          <!-- Hairline beneath the header block -->
          <hr class="ef__rule" aria-hidden="true" />
        </header>
      )}

      <div class="ef__rows">
        {rows.map((row, i) => {
          const isEven = i % 2 === 0; /* even → image-left, odd → image-right */
          const hasImage = Boolean(row.image);
          return (
            <article
              class={`ef__row ef__row--${isEven ? 'img-left' : 'img-right'}`}
              aria-label={row.heading}
            >
              {/* ── Image panel ─────────────────────────────────────────── */}
              <div class="ef__media-col" data-reveal data-reveal-order={0}>
                {hasImage ? (
                  <figure class="ef__figure" data-frame="editorial">
                    <img
                      src={row.image}
                      alt={row.imageAlt ?? row.heading}
                      loading="lazy"
                      decoding="async"
                      class="ef__img"
                    />
                  </figure>
                ) : (
                  /* Branded placeholder panel when no photo is available */
                  <div class="ef__placeholder" aria-hidden="true">
                    <span class="ef__placeholder-glyph">{row.heading.charAt(0)}</span>
                  </div>
                )}
              </div>

              {/* ── Copy panel ──────────────────────────────────────────── */}
              <div class="ef__copy-col" data-reveal data-reveal-order={1}>
                <span class="ef__index" aria-hidden="true">{fmtIndex(i)}</span>
                <hr class="ef__copy-rule" aria-hidden="true" />
                <h3 class="ef__heading">{row.heading}</h3>
                <p class="ef__body">{row.body}</p>
              </div>
            </article>
          );
        })}
      </div>

    </div>
  </section>
)}

<style>
  /* ── Section shell ───────────────────────────────────────────────────────── */
  .ef {
    padding-block: var(--section-pad);
    /* No background override — inherits from [data-tone] in global.css */
  }

  /* Full-width container: bleeds wider than the standard --maxw column so the
     image panels can touch the viewport edge on large screens. */
  .ef__container {
    width: 100%;
    max-width: var(--maxw);
    margin-inline: auto;
    padding-inline: var(--gutter);
  }

  /* ── Section header ──────────────────────────────────────────────────────── */
  .ef__header {
    margin-bottom: clamp(3rem, 7vw, 6rem);
    max-width: 70ch;
  }

  .ef__header--center {
    text-align: center;
    margin-inline: auto;
    max-width: 46ch;
  }

  .ef__eyebrow {
    font-family: var(--font-body);
    font-size: var(--step--1);
    font-weight: var(--fw-body);
    letter-spacing: calc(var(--tracking-eyebrow) + 0.04em);
    text-transform: uppercase;
    color: var(--text-muted);
    margin: 0 0 1.25rem;
  }

  [data-tone="deep"] .ef__eyebrow,
  [data-tone="brand"] .ef__eyebrow {
    color: color-mix(in srgb, var(--text-on-dark) 65%, transparent);
  }

  .ef__section-heading {
    font-family: var(--font-display);
    font-weight: var(--fw-display);
    font-size: clamp(var(--step-3), 4.5vw, var(--step-5));
    letter-spacing: var(--tracking-display);
    line-height: var(--leading-display);
    color: var(--text);
    margin: 0 0 1rem;
  }

  [data-tone="deep"] .ef__section-heading {
    color: var(--text-on-dark);
  }

  .ef__section-intro {
    font-size: var(--step-0);
    color: var(--text-muted);
    line-height: var(--leading-body);
    margin: 0;
  }

  [data-tone="deep"] .ef__section-intro {
    color: color-mix(in srgb, var(--text-on-dark) 75%, transparent);
  }

  /* Hairline rule beneath the header */
  .ef__rule {
    border: none;
    border-top: var(--border-weight) solid var(--border);
    margin: clamp(1.5rem, 3vw, 2.5rem) 0 0;
  }

  [data-tone="deep"] .ef__rule {
    border-top-color: color-mix(in srgb, var(--text-on-dark) 18%, transparent);
  }

  /* ── Row stack ───────────────────────────────────────────────────────────── */
  .ef__rows {
    display: flex;
    flex-direction: column;
    /* Each row is separated by a hairline rule rendered via padding + border */
  }

  /* ── Individual row ──────────────────────────────────────────────────────── */
  .ef__row {
    display: grid;
    grid-template-columns: 1.15fr 1fr;
    gap: clamp(3rem, 6vw, 7rem);
    align-items: center;
    padding-block: clamp(3rem, 7vw, 6rem);
    border-top: var(--border-weight) solid var(--border);
  }

  [data-tone="deep"] .ef__row {
    border-top-color: color-mix(in srgb, var(--text-on-dark) 12%, transparent);
  }

  /* First row: no top border (header hairline already above it) */
  .ef__row:first-child {
    border-top: none;
    padding-top: 0;
  }

  /* Image-right rows: swap column order visually */
  .ef__row--img-right {
    grid-template-columns: 1fr 1.15fr;
  }

  .ef__row--img-right .ef__media-col {
    order: 2;
  }

  .ef__row--img-right .ef__copy-col {
    order: 1;
  }

  /* ── Image panel ─────────────────────────────────────────────────────────── */
  .ef__media-col {
    position: relative;
  }

  /* figure gets [data-frame="editorial"] from global.css:
     border-radius: var(--radius); border-bottom: border-weight solid border */
  .ef__figure {
    margin: 0;
    overflow: hidden;
    aspect-ratio: 3 / 4; /* portrait — signature editorial proportion */
    width: 100%;
    border-radius: var(--radius);
    border-bottom: calc(var(--border-weight) * 3) solid var(--brand);
  }

  .ef__img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
    transition: transform calc(var(--motion-fade) * 2) var(--motion-ease);
  }

  .ef__figure:hover .ef__img {
    transform: scale(1.03);
  }

  /* Branded placeholder when no image is available */
  .ef__placeholder {
    aspect-ratio: 3 / 4;
    display: grid;
    place-items: center;
    background: color-mix(in srgb, var(--brand) 10%, var(--surface));
    border-radius: var(--radius);
    border-bottom: calc(var(--border-weight) * 3) solid var(--brand);
    overflow: hidden;
  }

  .ef__placeholder-glyph {
    font-family: var(--font-display);
    font-weight: var(--fw-display);
    font-size: clamp(5rem, 18vw, 14rem);
    line-height: 1;
    color: color-mix(in srgb, var(--brand) 30%, transparent);
    user-select: none;
  }

  /* ── Copy panel ──────────────────────────────────────────────────────────── */
  .ef__copy-col {
    padding-block: 0.5rem;
  }

  /* Folio index — oversized faded numeral, editorial signature */
  .ef__index {
    display: block;
    font-family: var(--font-display);
    font-weight: var(--fw-display);
    font-size: clamp(var(--step-4), 7vw, var(--step-6));
    line-height: 1;
    color: var(--brand);
    opacity: 0.15;
    letter-spacing: -0.04em;
    margin-bottom: -0.1em; /* optical tuck — the rule sits just below it */
    user-select: none;
  }

  [data-tone="deep"] .ef__index {
    color: var(--text-on-dark);
    opacity: 0.12;
  }

  /* Hairline rule between the index number and the heading */
  .ef__copy-rule {
    border: none;
    border-top: var(--border-weight) solid var(--border);
    margin: 0.75rem 0 1.25rem;
    width: 3rem;
    transition: width var(--motion-fade) var(--motion-ease);
  }

  [data-tone="deep"] .ef__copy-rule {
    border-top-color: color-mix(in srgb, var(--text-on-dark) 25%, transparent);
  }

  /* Hover: extend the rule to reinforce the interaction */
  .ef__row:hover .ef__copy-rule {
    width: 5rem;
  }

  /* Row heading */
  .ef__heading {
    font-family: var(--font-display);
    font-weight: var(--fw-display);
    font-size: clamp(var(--step-2), 3.5vw, var(--step-4));
    letter-spacing: var(--tracking-display);
    line-height: var(--leading-display);
    color: var(--text);
    margin: 0 0 1rem;
  }

  [data-tone="deep"] .ef__heading {
    color: var(--text-on-dark);
  }

  /* Body copy — deliberately short and poetic (short-form editorial prose) */
  .ef__body {
    font-size: var(--step-0);
    line-height: var(--leading-body);
    color: var(--text-muted);
    margin: 0;
    max-width: 44ch; /* intentionally narrow: editorial voice, not a wall of text */
  }

  [data-tone="deep"] .ef__body {
    color: color-mix(in srgb, var(--text-on-dark) 70%, transparent);
  }

  /* ── Tone overrides ──────────────────────────────────────────────────────── */
  [data-tone="alt"] { background: var(--bg-alt); }
  [data-tone="deep"] { background: var(--bg-deep); color: var(--text-on-dark); }
  [data-tone="brand"] { background: var(--brand); color: var(--brand-contrast); }

  [data-tone="brand"] .ef__eyebrow { color: color-mix(in srgb, var(--brand-contrast) 65%, transparent); }
  [data-tone="brand"] .ef__section-heading,
  [data-tone="brand"] .ef__heading { color: var(--brand-contrast); }
  [data-tone="brand"] .ef__section-intro,
  [data-tone="brand"] .ef__body { color: color-mix(in srgb, var(--brand-contrast) 80%, transparent); }
  [data-tone="brand"] .ef__rule,
  [data-tone="brand"] .ef__row,
  [data-tone="brand"] .ef__copy-rule { border-color: color-mix(in srgb, var(--brand-contrast) 20%, transparent); }
  [data-tone="brand"] .ef__index { color: var(--brand-contrast); opacity: 0.2; }

  /* ── Responsive ──────────────────────────────────────────────────────────── */

  /* Tablet: narrow the gap, keep two columns */
  @media (max-width: 900px) {
    .ef__row,
    .ef__row--img-right {
      grid-template-columns: 1fr 1fr;
      gap: clamp(2rem, 4vw, 3rem);
    }
  }

  /* Mobile: single column, image above copy, flip ordering reset */
  @media (max-width: 620px) {
    .ef__row,
    .ef__row--img-right {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    /* Restore natural DOM order (image col, then copy col) on mobile */
    .ef__row--img-right .ef__media-col { order: 0; }
    .ef__row--img-right .ef__copy-col  { order: 1; }

    /* Portrait image at mobile: use landscape ratio to save vertical space */
    .ef__figure,
    .ef__placeholder {
      aspect-ratio: 4 / 3;
    }

    /* Shrink the folio index on small screens */
    .ef__index {
      font-size: var(--step-4);
    }
  }
</style>
