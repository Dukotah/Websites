---
/**
 * EditorialFeature — AWARD-LEVEL signature editorial spreads.
 *
 * The winery/resort editorial pattern: portrait 3:4 image on the wider (60%)
 * column, short poetic copy on the narrower (40%) column with an oversized
 * ghost folio number as typographic anchor. Image side alternates each row.
 * Generous section-level vertical rhythm (≥7vw between rows). Image wrapped
 * in .u-offset-frame + [data-frame="editorial"] for depth and the brand-
 * bottom accent mark. SectionHead handles the optional envelope header.
 *
 * Spec §6 type: 'editorial-feature'. No client JS. [data-reveal] for scroll
 * entrances. Mirrors FeatureSplit props for data-source compatibility.
 */
import SectionHead from './SectionHead.astro';
import type { SectionEnvelope } from '../../types';

interface EditorialRow {
  heading: string;
  body: string;
  image?: string;
  imageAlt?: string;
}

interface Props extends SectionEnvelope {
  rows: EditorialRow[];
  index?: number;
}

const {
  rows = [],
  eyebrow,
  heading,
  intro,
  tone = 'default',
  align = 'left',
  index,
} = Astro.props as Props;

function fmtFolio(n: number): string {
  return String(n + 1).padStart(2, '0');
}
---

{rows.length > 0 && (
  <section class="section ef" data-tone={tone}>
    <div class="container">

      <SectionHead {index} {eyebrow} {heading} {intro} {align} />

      <div class="ef__rows">
        {rows.map((row, i) => {
          const isEven  = i % 2 === 0; /* even → image-left, odd → image-right */
          const hasImg  = Boolean(row.image);
          return (
            <article
              class={`ef__row${isEven ? ' ef__row--img-left' : ' ef__row--img-right'}${!hasImg ? ' ef__row--no-img' : ''}`}
              aria-label={row.heading}
            >

              {/* ── Image column ─────────────────────────────────── */}
              <div class="ef__media-col" data-reveal data-reveal-order={0}>
                {hasImg ? (
                  <div class="u-offset-frame">
                    <figure
                      class="ef__figure"
                      data-frame="editorial"
                      data-treat="grade"
                    >
                      <img
                        src={row.image}
                        alt={row.imageAlt ?? row.heading}
                        loading="lazy"
                        decoding="async"
                        class="ef__img"
                      />
                    </figure>
                  </div>
                ) : (
                  <div class="ef__placeholder" aria-hidden="true">
                    <span class="ef__placeholder-glyph">
                      {row.heading.charAt(0)}
                    </span>
                  </div>
                )}
              </div>

              {/* ── Copy column ──────────────────────────────────── */}
              <div class="ef__copy-col" data-reveal data-reveal-order={1}>
                <div class="ef__copy-inner">
                  {/* Oversized ghost folio — the signature editorial anchor */}
                  <span class="ef__folio" aria-hidden="true">{fmtFolio(i)}</span>
                  <hr class="ef__copy-rule" aria-hidden="true" />
                  <h3 class="ef__row-heading">{row.heading}</h3>
                  <p class="ef__row-body">{row.body}</p>
                </div>
              </div>

            </article>
          );
        })}
      </div>

    </div>
  </section>
)}

<style>
  /* ── Shell ────────────────────────────────────────────────────────────────── */
  .ef {
    padding-block: var(--section-pad);
  }

  .container {
    max-width: var(--maxw);
    margin-inline: auto;
    padding-inline: var(--gutter);
  }

  /* ── Row stack ────────────────────────────────────────────────────────────── */
  .ef__rows {
    display: flex;
    flex-direction: column;
  }

  /* ── Individual row ───────────────────────────────────────────────────────── */
  /*
   * 60/40 split: the image column takes 3fr (≈60%), the copy column 2fr (≈40%).
   * Row gap is intentionally wide — editorial sites live or die by breathing room.
   * Vertical row spacing is generous: 7–9vw between rows (section-level rhythm).
   */
  .ef__row {
    display: grid;
    grid-template-columns: 3fr 2fr; /* 60/40 — image left by default */
    gap: clamp(3rem, 6vw, 7rem);
    align-items: center;
    padding-block: clamp(4rem, 8vw, 7rem);
    border-top: var(--border-weight) solid var(--border);
  }

  /* First row: no top border */
  .ef__row:first-child {
    border-top: none;
    padding-top: 0;
  }

  /* Image-right: swap column proportions so copy is still the narrower (40%) */
  .ef__row--img-right {
    grid-template-columns: 2fr 3fr; /* copy 40%, image 60% */
  }

  /* Visual order control */
  .ef__row--img-left  .ef__media-col { order: 0; }
  .ef__row--img-left  .ef__copy-col  { order: 1; }
  .ef__row--img-right .ef__media-col { order: 1; }
  .ef__row--img-right .ef__copy-col  { order: 0; }

  /* ── Image column ─────────────────────────────────────────────────────────── */
  .ef__media-col {
    position: relative;
  }

  /* Portrait 3:4 — the editorial magazine proportion (winery/resort signature) */
  .ef__figure {
    margin: 0;
    aspect-ratio: 3 / 4;
    overflow: hidden;
    border-radius: var(--radius);
    /* Brand accent mark at the base — the EditorialFeature visual signature */
    border-bottom: calc(var(--border-weight) * 4) solid var(--brand);
    /* Open Props shadow for real depth */
    box-shadow: var(--shadow-5);
  }

  .ef__img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 25%;
    transition: transform calc(var(--motion-fade) * 2.5) var(--motion-ease);
  }

  .ef__row:hover .ef__img {
    transform: scale(1.03);
  }

  /* Branded placeholder when no photo supplied */
  .ef__placeholder {
    aspect-ratio: 3 / 4;
    display: grid;
    place-items: center;
    background: color-mix(in srgb, var(--brand) 10%, var(--surface));
    border-radius: var(--radius);
    border-bottom: calc(var(--border-weight) * 4) solid var(--brand);
    overflow: hidden;
  }

  .ef__placeholder-glyph {
    font-family: var(--font-display);
    font-weight: var(--fw-display);
    font-size: clamp(5rem, 18vw, 14rem);
    line-height: 1;
    color: color-mix(in srgb, var(--brand) 28%, transparent);
    user-select: none;
  }

  /* ── Copy column ──────────────────────────────────────────────────────────── */
  /*
   * The "generous inset" — inner padding pulls the copy away from the image edge,
   * creating the feel of a column-within-a-column (Jordan Winery / Resplendent
   * Ceylon teardown pattern: min 10vw feel from the edge).
   */
  .ef__copy-col {
    display: flex;
    align-items: center;
  }

  .ef__copy-inner {
    width: 100%;
  }

  /* img-left → copy is right col; pad left (away from image) */
  .ef__row--img-left .ef__copy-inner {
    padding-inline-start: clamp(1.5rem, 5vw, 4rem);
  }

  /* img-right → copy is left col; pad right (away from image) */
  .ef__row--img-right .ef__copy-inner {
    padding-inline-end: clamp(1.5rem, 5vw, 4rem);
  }

  /* ── Folio number ─────────────────────────────────────────────────────────── */
  /*
   * Oversized ghost numeral — the editorial site signature move.
   * Very large, very faint, optically tucked into the rule below it.
   * Seen at Zorah Wines, Jordan Winery, Olivier Bernstein.
   */
  .ef__folio {
    display: block;
    font-family: var(--font-display);
    font-weight: var(--fw-display);
    font-size: clamp(var(--step-4), 9vw, var(--step-6));
    line-height: 1;
    color: var(--brand);
    opacity: 0.12;
    letter-spacing: -0.05em;
    /* Optical tuck: the rule appears to emerge from the base of the numeral */
    margin-bottom: -0.15em;
    user-select: none;
  }

  /* Hairline rule between folio and heading — extends on hover for tactile feel */
  .ef__copy-rule {
    border: none;
    border-top: var(--border-weight) solid var(--border);
    margin: 0.8rem 0 1.4rem;
    width: 3rem;
    transition: width var(--motion-fade) var(--motion-ease);
  }

  .ef__row:hover .ef__copy-rule {
    width: 5.5rem;
  }

  /* ── Row heading (large display, per-row) ─────────────────────────────────── */
  /*
   * Deliberately narrow max-width forces the 2–3 word per line cascade —
   * the premium winery/editorial move (teardown: "never let a headline run
   * full-column width — it reads as template-generated").
   */
  .ef__row-heading {
    font-family: var(--font-display);
    font-weight: var(--fw-display);
    font-size: clamp(var(--step-2), 3.5vw, var(--step-4));
    letter-spacing: var(--tracking-display);
    line-height: var(--leading-display);
    color: var(--text);
    margin: 0 0 1rem;
    text-wrap: balance;
    max-width: 14ch;
  }

  /* ── Row body copy ────────────────────────────────────────────────────────── */
  /* Short and poetic — editorial voice, not a wall of text */
  .ef__row-body {
    font-size: var(--step-0);
    line-height: var(--leading-body);
    color: var(--text-muted);
    margin: 0;
    max-width: 40ch;
  }

  /* ── Tone overrides ───────────────────────────────────────────────────────── */
  [data-tone='alt']   { background: var(--bg-alt); }
  [data-tone='deep']  { background: var(--bg-deep); color: var(--text-on-dark); }
  [data-tone='brand'] { background: var(--brand);   color: var(--brand-contrast); }

  [data-tone='deep'] .ef__row           { border-top-color: color-mix(in srgb, var(--text-on-dark) 12%, transparent); }
  [data-tone='deep'] .ef__row-heading   { color: var(--text-on-dark); }
  [data-tone='deep'] .ef__row-body      { color: color-mix(in srgb, var(--text-on-dark) 70%, transparent); }
  [data-tone='deep'] .ef__folio         { color: var(--text-on-dark); opacity: 0.10; }
  [data-tone='deep'] .ef__copy-rule     { border-top-color: color-mix(in srgb, var(--text-on-dark) 22%, transparent); }
  [data-tone='deep'] .ef__figure        { border-bottom-color: color-mix(in srgb, var(--brand) 80%, var(--text-on-dark)); }

  [data-tone='brand'] .ef__row          { border-top-color: color-mix(in srgb, var(--brand-contrast) 18%, transparent); }
  [data-tone='brand'] .ef__row-heading  { color: var(--brand-contrast); }
  [data-tone='brand'] .ef__row-body     { color: color-mix(in srgb, var(--brand-contrast) 80%, transparent); }
  [data-tone='brand'] .ef__folio        { color: var(--brand-contrast); opacity: 0.18; }
  [data-tone='brand'] .ef__copy-rule    { border-top-color: color-mix(in srgb, var(--brand-contrast) 22%, transparent); }
  [data-tone='brand'] .ef__figure       { border-bottom-color: var(--brand-contrast); }

  /* ── Responsive ───────────────────────────────────────────────────────────── */

  /* Tablet: keep two-column but ease the gap and reduce inset */
  @media (max-width: 900px) {
    .ef__row,
    .ef__row--img-right {
      grid-template-columns: 1fr 1fr;
      gap: clamp(2rem, 4vw, 3.5rem);
    }

    .ef__row--img-left .ef__copy-inner  { padding-inline-start: clamp(0.75rem, 2.5vw, 2rem); }
    .ef__row--img-right .ef__copy-inner { padding-inline-end:   clamp(0.75rem, 2.5vw, 2rem); }
  }

  /* Mobile: single column, image above copy, landscape to save height */
  @media (max-width: 620px) {
    .ef__row,
    .ef__row--img-right {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    /* Restore natural DOM order on mobile */
    .ef__row--img-right .ef__media-col { order: 0; }
    .ef__row--img-right .ef__copy-col  { order: 1; }

    /* Collapse inset on single column */
    .ef__row--img-left  .ef__copy-inner,
    .ef__row--img-right .ef__copy-inner {
      padding-inline: 0;
    }

    /* Landscape ratio on mobile — save vertical space */
    .ef__figure,
    .ef__placeholder { aspect-ratio: 4 / 3; }

    .ef__folio { font-size: var(--step-4); }
  }
</style>
