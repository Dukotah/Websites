---
/**
 * FeatureSplit — AWARD-LEVEL signature alternating editorial rows.
 *
 * Pattern: 60/40 image↔copy alternation (never 50/50), generous inset on the
 * copy side (clamp 8–10vw feel), large per-row display heading, optional folio
 * number, image wrapped in .u-offset-frame + [data-frame] for Open Props depth.
 * Image side alternates each row (even→image-left, odd→image-right).
 *
 * Spec §6 type: 'feature-split'. No client JS. [data-reveal] for scroll
 * entrances (handled globally). SectionHead for the optional envelope header.
 */
import SectionHead from './SectionHead.astro';
import SiteImage from '../SiteImage.astro';
import type { SectionEnvelope } from '../../types';

interface SplitRow {
  heading: string;
  body: string;
  image?: string;
  imageAlt?: string;
}

interface Props extends SectionEnvelope {
  rows: SplitRow[];
  index?: number;
}

const {
  rows = [],
  eyebrow,
  heading,
  intro,
  tone = 'default',
  align = 'left',
  index,
} = Astro.props as Props;

function fmtFolio(n: number): string {
  return String(n + 1).padStart(2, '0');
}
---

{rows.length > 0 && (
  <section class="section fs" data-tone={tone}>
    <div class="container">

      <SectionHead {index} {eyebrow} {heading} {intro} {align} />

      <div class="fs__rows">
        {rows.map((row, i) => {
          const isEven = i % 2 === 0; /* even → image left, odd → image right */
          const hasImg = Boolean(row.image);
          return (
            <article
              class={`fs__row${isEven ? ' fs__row--img-left' : ' fs__row--img-right'}${!hasImg ? ' fs__row--no-img' : ''}`}
              aria-label={row.heading}
            >

              {/* ── Image column ─────────────────────────────────── */}
              <div class="fs__media-col" data-reveal data-reveal-order={0}>
                {hasImg ? (
                  <div class="u-offset-frame">
                    <figure
                      class="fs__figure"
                      data-frame="editorial"
                      data-treat="grade"
                    >
                      <SiteImage
                        src={row.image}
                        alt={row.imageAlt ?? row.heading}
                        class="fs__img"
                        sizes="(min-width: 768px) 60vw, 100vw"
                      />
                    </figure>
                  </div>
                ) : (
                  <div class="fs__placeholder" aria-hidden="true">
                    <span class="fs__placeholder-glyph">
                      {row.heading.charAt(0)}
                    </span>
                  </div>
                )}
              </div>

              {/* ── Copy column ──────────────────────────────────── */}
              <div class="fs__copy-col" data-reveal data-reveal-order={1}>
                <div class="fs__copy-inner">
                  <span class="fs__folio" aria-hidden="true">{fmtFolio(i)}</span>
                  <hr class="fs__copy-rule" aria-hidden="true" />
                  <h3 class="fs__row-heading">{row.heading}</h3>
                  <p class="fs__row-body">{row.body}</p>
                </div>
              </div>

            </article>
          );
        })}
      </div>

    </div>
  </section>
)}

<style>
  /* ── Shell ────────────────────────────────────────────────────────────────── */
  .fs {
    padding-block: var(--section-pad);
  }

  .container {
    max-width: var(--maxw);
    margin-inline: auto;
    padding-inline: var(--gutter);
  }

  /* ── Row stack ────────────────────────────────────────────────────────────── */
  .fs__rows {
    display: flex;
    flex-direction: column;
  }

  /* ── Individual row ───────────────────────────────────────────────────────── */
  /*
   * The 60/40 split: image gets 3fr (60%), copy gets 2fr (40%).
   * Generous copy inset achieved via padding-inline on fs__copy-inner.
   * Row gap is wide enough to feel editorial (not a card grid).
   */
  .fs__row {
    display: grid;
    grid-template-columns: 3fr 2fr; /* 60 / 40 — image left by default */
    gap: clamp(2.5rem, 5vw, 5rem);
    align-items: center;
    padding-block: clamp(3rem, 7vw, 6rem);
    border-top: var(--border-weight) solid var(--border);
  }

  /* First row: no top border — the SectionHead rule (or clean entry) above it */
  .fs__row:first-child {
    border-top: none;
    padding-top: 0;
  }

  /* Image-right: copy col 1 (3fr), media col 2 (2fr) ... wait, for img-right the
     copy should be the wider 60%. Swap: copy 3fr, image 2fr. */
  .fs__row--img-right {
    grid-template-columns: 2fr 3fr; /* copy 40%, image 60% */
  }

  /* Reorder: on img-right rows the media col renders second in DOM, visual order
     is already correct (copy left, image right) — no order swap needed. */
  .fs__row--img-left  .fs__media-col { order: 0; }
  .fs__row--img-left  .fs__copy-col  { order: 1; }
  .fs__row--img-right .fs__media-col { order: 1; }
  .fs__row--img-right .fs__copy-col  { order: 0; }

  /* ── Image column ─────────────────────────────────────────────────────────── */
  .fs__media-col {
    /* Overflow visible so .u-offset-frame slab peeks out */
    position: relative;
  }

  /* The figure itself — landscape 4:3 for feature rows */
  .fs__figure {
    margin: 0;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    border-radius: var(--radius);
    /* Open Props shadow for depth */
    box-shadow: var(--shadow-4);
  }

  .fs__img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transition: transform calc(var(--motion-fade) * 2) var(--motion-ease);
  }

  .fs__row:hover .fs__img {
    transform: scale(1.04);
  }

  /* Branded placeholder when no photo supplied */
  .fs__placeholder {
    aspect-ratio: 4 / 3;
    display: grid;
    place-items: center;
    background: color-mix(in srgb, var(--brand) 8%, var(--surface));
    border-radius: var(--radius);
    border-bottom: calc(var(--border-weight) * 3) solid var(--brand);
    overflow: hidden;
  }

  .fs__placeholder-glyph {
    font-family: var(--font-display);
    font-weight: var(--fw-display);
    font-size: clamp(4rem, 16vw, 12rem);
    line-height: 1;
    color: color-mix(in srgb, var(--brand) 25%, transparent);
    user-select: none;
  }

  /* ── Copy column ──────────────────────────────────────────────────────────── */
  /*
   * The generous inset: padding-inline on the inner div (not the grid column)
   * creates the "column within a column" feel from the Jordan Winery teardown.
   * On img-left rows the copy is on the right — pad the left edge.
   * On img-right rows the copy is on the left — pad the right edge.
   */
  .fs__copy-col {
    display: flex;
    align-items: center;
  }

  .fs__copy-inner {
    width: 100%;
  }

  /* Inset: image-left → copy is right col, pad inward from image edge */
  .fs__row--img-left .fs__copy-inner {
    padding-inline-start: clamp(1rem, 4vw, 3rem);
  }

  /* Inset: image-right → copy is left col, pad inward from image edge */
  .fs__row--img-right .fs__copy-inner {
    padding-inline-end: clamp(1rem, 4vw, 3rem);
  }

  /* ── Folio number ─────────────────────────────────────────────────────────── */
  .fs__folio {
    display: block;
    font-family: var(--font-display);
    font-weight: var(--fw-display);
    font-size: clamp(var(--step-4), 8vw, var(--step-6));
    line-height: 1;
    color: var(--brand);
    opacity: 0.13;
    letter-spacing: -0.04em;
    margin-bottom: -0.1em; /* optical tuck into the rule below */
    user-select: none;
  }

  /* Hairline rule between folio and heading */
  .fs__copy-rule {
    border: none;
    border-top: var(--border-weight) solid var(--border);
    margin: 0.65rem 0 1.1rem;
    width: 2.75rem;
    transition: width var(--motion-fade) var(--motion-ease);
  }

  .fs__row:hover .fs__copy-rule {
    width: 4.5rem;
  }

  /* ── Row heading (large display, per-row) ─────────────────────────────────── */
  .fs__row-heading {
    font-family: var(--font-display);
    font-weight: var(--fw-display);
    font-size: clamp(var(--step-2), 3.5vw, var(--step-4));
    letter-spacing: var(--tracking-display);
    line-height: var(--leading-display);
    color: var(--text);
    margin: 0 0 0.9rem;
    text-wrap: balance;
    max-width: 16ch; /* deliberate narrow rag — premium editorial move */
  }

  /* ── Row body copy ────────────────────────────────────────────────────────── */
  .fs__row-body {
    font-size: var(--step-0);
    line-height: var(--leading-body);
    color: var(--text-muted);
    margin: 0;
    max-width: 44ch; /* intentionally narrow editorial voice */
  }

  /* ── Tone overrides ───────────────────────────────────────────────────────── */
  [data-tone='alt']  { background: var(--bg-alt); }
  [data-tone='deep'] { background: var(--bg-deep); color: var(--text-on-dark); }
  [data-tone='brand']{ background: var(--brand);  color: var(--brand-contrast); }

  [data-tone='deep'] .fs__row          { border-top-color: color-mix(in srgb, var(--text-on-dark) 12%, transparent); }
  [data-tone='deep'] .fs__row-heading  { color: var(--text-on-dark); }
  [data-tone='deep'] .fs__row-body     { color: color-mix(in srgb, var(--text-on-dark) 72%, transparent); }
  [data-tone='deep'] .fs__folio        { color: var(--text-on-dark); opacity: 0.10; }
  [data-tone='deep'] .fs__copy-rule    { border-top-color: color-mix(in srgb, var(--text-on-dark) 22%, transparent); }

  [data-tone='brand'] .fs__row         { border-top-color: color-mix(in srgb, var(--brand-contrast) 18%, transparent); }
  [data-tone='brand'] .fs__row-heading { color: var(--brand-contrast); }
  [data-tone='brand'] .fs__row-body    { color: color-mix(in srgb, var(--brand-contrast) 80%, transparent); }
  [data-tone='brand'] .fs__folio       { color: var(--brand-contrast); opacity: 0.18; }
  [data-tone='brand'] .fs__copy-rule   { border-top-color: color-mix(in srgb, var(--brand-contrast) 22%, transparent); }

  /* ── Responsive ───────────────────────────────────────────────────────────── */

  /* Tablet: keep two columns but tighten gap and equalize a bit */
  @media (max-width: 960px) {
    .fs__row,
    .fs__row--img-right {
      grid-template-columns: 1fr 1fr;
      gap: clamp(2rem, 4vw, 3rem);
    }

    .fs__row--img-left .fs__copy-inner  { padding-inline-start: clamp(0.5rem, 2vw, 1.5rem); }
    .fs__row--img-right .fs__copy-inner { padding-inline-end:   clamp(0.5rem, 2vw, 1.5rem); }
  }

  /* Mobile: single column, image stacks above copy, folio shrinks */
  @media (max-width: 620px) {
    .fs__row,
    .fs__row--img-right {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    /* Restore natural DOM order: media first, copy second */
    .fs__row--img-right .fs__media-col { order: 0; }
    .fs__row--img-right .fs__copy-col  { order: 1; }

    /* Inset collapses on single-column */
    .fs__row--img-left  .fs__copy-inner,
    .fs__row--img-right .fs__copy-inner {
      padding-inline: 0;
    }

    .fs__folio { font-size: var(--step-3); }

    /* Landscape on mobile to save height */
    .fs__figure,
    .fs__placeholder { aspect-ratio: 4 / 3; }
  }
</style>
