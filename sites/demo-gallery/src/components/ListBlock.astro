---
const {
  eyebrow = '',
  heading = '',
  intro = '',
  groups = [],
} = Astro.props as {
  eyebrow?: string;
  heading?: string;
  intro?: string;
  groups: { title: string; items: { name: string; note?: string }[] }[];
};
---

<section class="section section--alt">
  <div class="container">
    <div class="lb__head">
      {eyebrow && <p class="eyebrow">{eyebrow}</p>}
      {heading && <h2>{heading}</h2>}
      {intro && <p class="lb__intro">{intro}</p>}
    </div>
    <div class="lb__groups">
      {
        groups.map((g) => (
          <div class="lb__group">
            <h3 class="lb__title">{g.title}</h3>
            <ul>
              {g.items.map((it) => (
                <li>
                  <span class="lb__name">{it.name}</span>
                  {it.note && <span class="lb__note">{it.note}</span>}
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .lb__head {
    max-width: 50ch;
    margin-bottom: 2.5rem;
  }
  .lb__intro {
    color: var(--text-muted);
    font-size: 1.08rem;
  }
  .lb__groups {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 2rem 3rem;
  }
  .lb__title {
    font-family: var(--serif);
    color: var(--brand-dark);
    padding-bottom: 0.6rem;
    border-bottom: 2px solid var(--brand);
    margin-bottom: 0.75rem;
  }
  .lb__group ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .lb__group li {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.5rem 0;
    border-bottom: 1px dotted var(--border);
  }
  .lb__name {
    font-weight: 600;
    color: var(--text);
  }
  .lb__note {
    color: var(--text-muted);
    font-size: 0.92rem;
    text-align: right;
  }
</style>
