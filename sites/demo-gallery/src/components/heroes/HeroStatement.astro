---
/**
 * HeroStatement — huge display type + single keyline + ghost CTA. Minimal.
 *
 * Award patterns applied:
 * - Winery heroPatterns[3] (chapter/narrative opener): dark bg, manifesto in
 *   tracked small-caps, parallax peels to reveal photo — adapted as a
 *   light/dark hybrid with the "statement" register.
 * - Trades heroPatterns[3]: "EDITORIAL FULL-WIDTH HERO with tall type and a
 *   thin horizontal rule" — 1px rule, single accent word, trust bar below rule.
 * - Marina/Cafe antiGeneric: whitespace as color; nothing between keyline and CTA.
 *
 * Structure: eyebrow → thick keyline → oversized H1 → thin full-width rule →
 * ghost CTA + phone → highlights strip. Photo (optional) as right-side inset
 * with offset/overlap accent, keeping the left column clean.
 */
import type { ProspectConfig } from '../../types';
import SiteImage from '../SiteImage.astro';
import TrustBadge from '../TrustBadge.astro';
import AccentMark from '../AccentMark.astro';
const { config } = Astro.props as { config: ProspectConfig };

const { hero, images, contact, highlights = [], established, area, artDirection, rating } = config;
const telHref = `tel:${contact.phone.replace(/[^+\d]/g, '')}`;
const eyebrow = [established, area].filter(Boolean).join(' · ');
const badgeYear = (established || '').toString().replace(/^est\.?\s*/i, '');
const trustLine = highlights[0] ?? '';
const hasPhoto = Boolean(images?.hero);

// Art-direction photo treatment
const treatment = artDirection?.photoTreatment ?? 'natural';
const useGrain  = artDirection?.photoGrain ?? false;
const photoClass = [
  'stmt-hero__photo',
  treatment === 'duotone' ? 'img-duotone' : '',
].filter(Boolean).join(' ');
const photoTreat = treatment === 'muted' ? 'grade' : undefined;

// Hand-drawn accent on a key heading word (premium "agency vs template" tell).
// Gated by artDirection.accentMark; wraps the 2nd word (or last when < 2 words).
const accentMark = artDirection?.accentMark ?? 'none';
const headWords = hero.heading.trim().split(/\s+/);
const accentIdx = headWords.length >= 2 ? 1 : 0;
const useAccent = accentMark !== 'none' && headWords.length > 0;
---

<section class="stmt-hero" id="top" aria-label="Hero">

  <!-- ① Gradient-mesh background (subtle, light) -->
  <div class="stmt-hero__bg" aria-hidden="true"></div>

  <!-- ② Optional photo inset (right side, offset frame, parallax) -->
  {hasPhoto && (
    <div class="stmt-hero__photo-wrap" aria-hidden="true">
      <!-- Offset accent rectangle behind the photo -->
      <div class="stmt-hero__photo-accent" aria-hidden="true"></div>
      <div
        class={photoClass}
        data-parallax
        data-parallax-speed="0.2"
        data-parallax-axis="y"
        data-treat={photoTreat}
        data-grain={useGrain ? '' : undefined}
      >
        <SiteImage
          src={images.hero}
          alt={images.heroAlt}
          placeholder={images.placeholder}
          sizes="(min-width: 880px) 45vw, 100vw"
          loading="eager"
          fetchpriority="high"
        />
        {treatment === 'duotone' && useGrain && (
          <span class="grain-layer" aria-hidden="true"></span>
        )}
      </div>
      <!-- Trust badge on photo inset (glassmorphism) -->
      <div class="stmt-hero__badge-wrap" data-reveal data-reveal-order="0">
        <TrustBadge
          year={badgeYear || undefined}
          rating={rating?.value}
          reviewCount={rating?.count}
          highlight={trustLine || undefined}
          position="bottom-right"
        />
      </div>
    </div>
  )}

  <!-- ③ Content — left-anchored, reserved right for photo when present -->
  <div
    class="container stmt-hero__inner"
    data-has-photo={hasPhoto ? 'true' : undefined}
  >

    <!-- Eyebrow: accent rule + tracked caps (HeroCinematic idiom) -->
    {eyebrow && (
      <p class="stmt-hero__eyebrow" data-reveal data-reveal-order="1">{eyebrow}</p>
    )}

    <!-- Primary keyline: thick, brand-gradient, short (the award "single keyline" move) -->
    <div class="stmt-hero__keyline" aria-hidden="true" data-reveal data-reveal-order="2"></div>

    <!-- Oversized display headline — the defining gesture; max-width forces cascade -->
    <h1 class="stmt-hero__title" data-reveal data-reveal-order="3">
      {useAccent ? (
        <>
          {accentIdx > 0 && headWords.slice(0, accentIdx).join(' ')}{accentIdx > 0 ? ' ' : ''}
          <span class="stmt-hero__accent-wrap">
            {headWords[accentIdx]}
            <AccentMark type={accentMark as 'underline' | 'circle' | 'arrow'} delay="0.4s" />
          </span>
          {accentIdx < headWords.length - 1 ? ' ' + headWords.slice(accentIdx + 1).join(' ') : ''}
        </>
      ) : (
        hero.heading
      )}
    </h1>

    <!-- Secondary thin full-width rule: palette cleanser before CTAs -->
    <div class="stmt-hero__rule" aria-hidden="true" data-reveal data-reveal-order="4"></div>

    <!-- Footer row: sub + CTAs. Generous gap, flex-wrap for mobile. -->
    <div class="stmt-hero__foot" data-reveal data-reveal-order="5">
      {hero.subheading && (
        <p class="stmt-hero__sub">{hero.subheading}</p>
      )}
      <div class="stmt-hero__actions">
        <!-- Ghost CTA — award pattern for statement/minimal heroes -->
        <a href={hero.ctaHref} class="stmt-hero__cta-ghost">{hero.ctaText}</a>
        {contact.phone && (
          <a href={telHref} class="stmt-hero__phone">
            <svg class="stmt-hero__phone-icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M6.62 10.79a15.05 15.05 0 006.59 6.59l2.2-2.2a1 1 0 011.01-.24 11.47 11.47 0 003.58.57 1 1 0 011 1V20a1 1 0 01-1 1A17 17 0 013 4a1 1 0 011-1h3.5a1 1 0 011 1c0 1.25.2 2.45.57 3.58a1 1 0 01-.25 1.01l-2.2 2.2z" fill="currentColor"/>
            </svg>
            {contact.phone}
          </a>
        )}
      </div>
    </div>

    <!-- Inline trust badge fallback when no photo present -->
    {!hasPhoto && (
      <div class="stmt-hero__badge-inline" data-reveal data-reveal-order="6">
        <TrustBadge
          year={badgeYear || undefined}
          rating={rating?.value}
          reviewCount={rating?.count}
          highlight={trustLine || undefined}
          position="bottom-right"
        />
      </div>
    )}

    <!-- Highlights strip -->
    {highlights.length > 0 && (
      <ul class="stmt-hero__highlights" data-reveal data-reveal-order="7" aria-label="Key highlights">
        {highlights.map((h: string) => <li>{h}</li>)}
      </ul>
    )}

  </div>
</section>

<style>
  /* ── Shell ─────────────────────────────────────────────────────────────── */
  .stmt-hero {
    position: relative;
    isolation: isolate;
    background: var(--bg);
    color: var(--text);
    min-height: min(86vh, 780px);
    display: flex;
    flex-direction: column;
    justify-content: center;
    overflow: hidden;
  }

  /* ── ① Gradient-mesh background (very subtle — statement hero is minimal) ─ */
  .stmt-hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    background:
      radial-gradient(
        ellipse 55% 50% at 108% 108%,
        color-mix(in srgb, var(--brand) 8%, transparent) 0%,
        transparent 62%
      ),
      radial-gradient(
        ellipse 40% 35% at -5% -5%,
        color-mix(in srgb, var(--accent) 6%, transparent) 0%,
        transparent 58%
      );
    pointer-events: none;
  }

  /* ── ② Photo inset (right column, offset frame) ─────────────────────────── */
  .stmt-hero__photo-wrap {
    position: absolute;
    top: 7%;
    right: -1.5%;
    width: clamp(220px, 34vw, 500px);
    height: 78%;
    z-index: 1;
  }

  /* Offset accent rectangle behind the photo — brand tint, peeks out */
  .stmt-hero__photo-accent {
    position: absolute;
    inset: 8% -7% -8% 8%;
    background: color-mix(in srgb, var(--brand) 10%, var(--bg-alt, var(--surface)));
    border-radius: var(--radius-lg);
    z-index: 0;
  }

  /* Photo container — parallax target */
  .stmt-hero__photo {
    position: absolute;
    inset: 0;
    z-index: 1;
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-lg);
    will-change: transform;
  }
  .stmt-hero__photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  @media (prefers-reduced-motion: reduce) {
    .stmt-hero__photo { will-change: auto; }
  }

  /* Trust badge wrapper — bottom-left of photo, bleeds beyond frame edge */
  .stmt-hero__badge-wrap {
    position: absolute;
    bottom: -1.25rem;
    left: -1.75rem;
    z-index: 2;
  }

  /* Inline trust badge — no-photo fallback, sits below the CTA row */
  .stmt-hero__badge-inline {
    margin-top: 2.25rem;
    display: inline-block;
  }

  /* ── ③ Content layer ────────────────────────────────────────────────────── */
  .stmt-hero__inner {
    position: relative;
    z-index: 2;
    padding-block: clamp(4.5rem, 12vw, 9rem);
  }

  /* Reserve right column for photo when present */
  .stmt-hero__inner[data-has-photo] {
    padding-inline-end: clamp(230px, 38vw, 540px);
  }

  /* Eyebrow: accent rule + tracked caps */
  .stmt-hero__eyebrow {
    display: block;
    font-family: var(--font-body);
    font-size: var(--step--1);
    font-weight: var(--fw-bold);
    letter-spacing: var(--tracking-eyebrow);
    text-transform: uppercase;
    color: var(--text-muted);
    margin: 0 0 1.6rem;
  }
  .stmt-hero__eyebrow::before {
    content: '';
    display: inline-block;
    width: 1.6rem;
    height: 2px;
    margin-right: 0.6rem;
    vertical-align: middle;
    background: var(--accent);
  }

  /* Primary keyline (thick, brand gradient, short — "the single keyline") */
  .stmt-hero__keyline {
    height: 3px;
    background: linear-gradient(
      90deg,
      var(--brand) 0%,
      color-mix(in srgb, var(--brand) 15%, transparent) 100%
    );
    border: none;
    margin: 0 0 1.75rem;
    width: clamp(3.5rem, 8vw, 7rem);
    border-radius: var(--radius-pill);
  }

  /* Oversized headline — the defining gesture; max-width forces cascade */
  .stmt-hero__title {
    font-family: var(--font-display);
    font-weight: var(--fw-display);
    font-size: clamp(3.2rem, 9vw, 8rem);
    line-height: var(--leading-display);
    letter-spacing: var(--tracking-display);
    color: var(--text);
    margin: 0;
    /* Max-width forces 2–3 word cascade (award anti-generic pattern) */
    max-width: 14ch;
    text-wrap: balance;
  }

  /* Accent-word container — relative + inline-block so the absolute AccentMark
     positions against the word (per AccentMark's contract). */
  .stmt-hero__accent-wrap {
    position: relative;
    display: inline-block;
  }

  /* Secondary thin full-width rule — minimal, the "single keyline" award move */
  .stmt-hero__rule {
    height: 1px;
    background: var(--border);
    border: none;
    margin: 1.75rem 0 2.5rem;
    width: 100%;
  }

  /* Footer row: sub + CTAs */
  .stmt-hero__foot {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-start;
    gap: 1.5rem 3rem;
  }

  .stmt-hero__sub {
    font-size: clamp(1rem, 1.8vw, 1.2rem);
    line-height: var(--leading-body);
    color: var(--text-muted);
    max-width: 52ch;
    margin: 0;
    flex: 1 1 280px;
  }

  /* CTA cluster */
  .stmt-hero__actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem 1.5rem;
    flex-shrink: 0;
    padding-top: 0.1rem;
  }

  /* Ghost/outline CTA — award pattern: "no filled button in the hero" */
  .stmt-hero__cta-ghost {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-body);
    font-weight: var(--fw-bold);
    font-size: var(--step-0);
    color: var(--text);
    text-decoration: none;
    border: var(--border-weight) solid var(--border);
    padding: 0.75em 1.6em;
    border-radius: var(--radius);
    transition:
      border-color var(--motion-fade) var(--motion-ease),
      background var(--motion-fade) var(--motion-ease),
      color var(--motion-fade) var(--motion-ease);
  }
  .stmt-hero__cta-ghost:hover {
    border-color: var(--brand);
    background: var(--brand);
    color: var(--brand-contrast);
    text-decoration: none;
  }
  .stmt-hero__cta-ghost:focus-visible {
    outline: 2px solid var(--ring);
    outline-offset: 3px;
  }

  /* Phone link */
  .stmt-hero__phone {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    color: var(--text);
    font-family: var(--font-body);
    font-weight: var(--fw-bold);
    font-size: var(--step-0);
    text-decoration: none;
    border-bottom: var(--border-weight) solid var(--border);
    padding-bottom: 2px;
    transition:
      border-color var(--motion-fade) var(--motion-ease),
      color var(--motion-fade) var(--motion-ease);
  }
  .stmt-hero__phone:hover {
    text-decoration: none;
    border-color: var(--brand);
    color: var(--brand);
  }
  .stmt-hero__phone:focus-visible {
    outline: 2px solid var(--ring);
    outline-offset: 3px;
    border-radius: 2px;
  }
  .stmt-hero__phone-icon {
    width: 1.05em;
    height: 1.05em;
    flex-shrink: 0;
  }

  /* Highlights strip */
  .stmt-hero__highlights {
    list-style: none;
    margin: 2.75rem 0 0;
    padding: 1.5rem 0 0;
    border-top: var(--border-weight) solid var(--border);
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 2.5rem;
    font-family: var(--font-body);
    font-size: var(--step--1);
    font-weight: var(--fw-bold);
    letter-spacing: var(--tracking-eyebrow);
    text-transform: uppercase;
    color: var(--text-muted);
  }

  /* ── Mobile ─────────────────────────────────────────────────────────────── */
  @media (max-width: 900px) {
    .stmt-hero__photo-wrap { display: none; }
    .stmt-hero__inner[data-has-photo] { padding-inline-end: var(--gutter); }
  }
  @media (max-width: 640px) {
    .stmt-hero__title {
      font-size: clamp(2.6rem, 11vw, 4rem);
      max-width: none;
    }
    .stmt-hero__foot { flex-direction: column; gap: 1.25rem; }
  }

  /* ── Archetype tweaks ──────────────────────────────────────────────────── */
  [data-archetype="editorial"] .stmt-hero__keyline {
    border-radius: 0;
  }
  [data-archetype="magazine"] .stmt-hero__title {
    font-size: clamp(3.8rem, 10vw, 10rem);
    letter-spacing: -0.04em;
  }
  [data-archetype="classic"] .stmt-hero {
    background: var(--bg-alt, var(--surface));
  }
</style>
