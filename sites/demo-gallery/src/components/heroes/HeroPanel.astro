---
/**
 * HeroPanel — solid --brand-dark panel with oversized type, a layered
 * gradient-mesh, an offset geometric accent shape, and a floating trust badge.
 * No photo required; looks distinct per business via tokens alone.
 * Spec §7: "panel" variant.
 */
import type { ProspectConfig } from '../../types';
const { config } = Astro.props as { config: ProspectConfig };

const { hero, images, contact, highlights = [], established, area } = config;
const telHref = `tel:${contact.phone.replace(/[^+\d]/g, '')}`;
const eyebrow = [established, area].filter(Boolean).join(' · ');
const badgeYear = (established || '').toString().replace(/^est\.?\s*/i, '');
const trustLine = highlights[0] ?? '';
---

<section class="panel-hero" id="top" data-tone="deep">

  <!-- ① Gradient-mesh background layer -->
  <div class="panel-hero__bg" aria-hidden="true"></div>

  <!-- ② Large rotated geometric accent (top-right) -->
  <div class="panel-hero__geo panel-hero__geo--main" aria-hidden="true"></div>

  <!-- ③ Smaller circle accent (bottom-left) -->
  <div class="panel-hero__geo panel-hero__geo--circle" aria-hidden="true"></div>

  <!-- ④ Horizontal brand keyline (design gesture) -->
  <div class="panel-hero__keyline" aria-hidden="true"></div>

  <!-- ⑤ Content -->
  <div class="container panel-hero__inner">

    <!-- Trust badge -->
    {(badgeYear || trustLine) && (
      <div class="panel-hero__badge" data-reveal data-reveal-order="0" aria-label="Trust signal">
        {badgeYear && <strong class="panel-hero__badge-year">{badgeYear}</strong>}
        <span class="panel-hero__badge-label">{badgeYear ? 'Est.' : trustLine}</span>
        {badgeYear && trustLine && <span class="panel-hero__badge-trust">{trustLine}</span>}
      </div>
    )}

    {eyebrow && (
      <p class="panel-hero__eyebrow" data-reveal data-reveal-order="1">{eyebrow}</p>
    )}

    <h1 class="panel-hero__title" data-reveal data-reveal-order="2">
      {hero.heading}
    </h1>

    {hero.subheading && (
      <p class="panel-hero__sub" data-reveal data-reveal-order="3">
        {hero.subheading}
      </p>
    )}

    <!-- CTA cluster -->
    <div class="panel-hero__actions" data-reveal data-reveal-order="4">
      <a href={hero.ctaHref} class="btn btn--contrast panel-hero__cta">{hero.ctaText}</a>
      {contact.phone && (
        <a href={telHref} class="panel-hero__phone">
          <svg class="panel-hero__phone-icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M6.62 10.79a15.05 15.05 0 006.59 6.59l2.2-2.2a1 1 0 011.01-.24 11.47 11.47 0 003.58.57 1 1 0 011 1V20a1 1 0 01-1 1A17 17 0 013 4a1 1 0 011-1h3.5a1 1 0 011 1c0 1.25.2 2.45.57 3.58a1 1 0 01-.25 1.01l-2.2 2.2z" fill="currentColor"/>
          </svg>
          {contact.phone}
        </a>
      )}
    </div>

    <!-- Highlights strip -->
    {highlights.length > 0 && (
      <ul class="panel-hero__highlights" data-reveal data-reveal-order="5">
        {highlights.map((h: string) => <li>{h}</li>)}
      </ul>
    )}

  </div>
</section>

<style>
  /* ── Shell ───────────────────────────────────────────────────────────────── */
  .panel-hero {
    position: relative;
    isolation: isolate;
    min-height: min(88vh, 800px);
    display: flex;
    flex-direction: column;
    justify-content: center;
    background: var(--bg-deep);
    color: var(--text-on-dark);
    overflow: hidden;
  }

  /* ── ① Gradient-mesh ─────────────────────────────────────────────────────── */
  .panel-hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    background:
      radial-gradient(
        ellipse 85% 65% at 100% 115%,
        color-mix(in srgb, var(--brand) 22%, transparent) 0%,
        transparent 65%
      ),
      radial-gradient(
        ellipse 60% 50% at -10% -5%,
        color-mix(in srgb, var(--accent) 16%, transparent) 0%,
        transparent 60%
      ),
      var(--bg-deep);
    pointer-events: none;
  }

  /* ── ② Rotated square accent (top-right) ────────────────────────────────── */
  .panel-hero__geo--main {
    position: absolute;
    top: -14%;
    right: -8%;
    width: clamp(280px, 40vw, 580px);
    aspect-ratio: 1 / 1;
    border-radius: var(--radius-lg);
    border: 2px solid color-mix(in srgb, var(--brand) 28%, transparent);
    background: color-mix(in srgb, var(--brand) 6%, transparent);
    transform: rotate(20deg);
    z-index: 1;
    pointer-events: none;
  }

  /* ── ③ Solid circle accent (bottom-left) ────────────────────────────────── */
  .panel-hero__geo--circle {
    position: absolute;
    bottom: -18%;
    left: -12%;
    width: clamp(200px, 28vw, 420px);
    aspect-ratio: 1 / 1;
    border-radius: 50%;
    border: 2px solid color-mix(in srgb, var(--accent) 22%, transparent);
    background: color-mix(in srgb, var(--accent) 5%, transparent);
    z-index: 1;
    pointer-events: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .panel-hero__geo--main,
    .panel-hero__geo--circle { display: none; }
  }

  /* ── ④ Brand keyline ─────────────────────────────────────────────────────── */
  .panel-hero__keyline {
    position: absolute;
    left: var(--gutter);
    right: var(--gutter);
    top: 0;
    height: 3px;
    background: linear-gradient(
      90deg,
      var(--brand) 0%,
      color-mix(in srgb, var(--brand) 30%, transparent) 100%
    );
    z-index: 2;
  }

  /* ── ⑤ Content ───────────────────────────────────────────────────────────── */
  .panel-hero__inner {
    position: relative;
    z-index: 3;
    padding-block: clamp(3.5rem, 10vw, 6.5rem);
    max-width: 820px;
  }

  /* Trust badge */
  .panel-hero__badge {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.1rem;
    background: var(--brand);
    color: var(--brand-contrast);
    border-radius: var(--radius);
    padding: 0.75rem 1rem;
    min-width: 68px;
    box-shadow: var(--shadow-lg);
    text-align: center;
    margin-bottom: 1.75rem;
    /* slight left-bleed so it reads as a distinct element */
    position: relative;
    left: -0.25rem;
  }
  .panel-hero__badge-year {
    font-family: var(--font-display);
    font-size: var(--step-2);
    font-weight: var(--fw-display);
    line-height: 1;
  }
  .panel-hero__badge-label {
    font-size: var(--step--1);
    font-weight: var(--fw-bold);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    opacity: 0.85;
  }
  .panel-hero__badge-trust {
    font-size: 0.62rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    opacity: 0.75;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 110px;
  }

  /* Eyebrow */
  .panel-hero__eyebrow {
    font-family: var(--font-body);
    font-size: var(--step--1);
    font-weight: var(--fw-bold);
    letter-spacing: var(--tracking-eyebrow);
    text-transform: uppercase;
    color: var(--brand);
    margin-bottom: 1.1rem;
  }

  /* Oversized headline */
  .panel-hero__title {
    font-family: var(--font-display);
    font-weight: var(--fw-display);
    font-size: clamp(2.8rem, 7vw, 6.2rem);
    line-height: var(--leading-display);
    letter-spacing: var(--tracking-display);
    color: var(--text-on-dark);
    margin-bottom: 1.1rem;
    overflow-wrap: break-word;
    hyphens: auto;
  }

  .panel-hero__sub {
    font-size: clamp(1.05rem, 1.9vw, 1.28rem);
    line-height: var(--leading-body);
    color: color-mix(in srgb, var(--text-on-dark) 84%, transparent);
    max-width: 54ch;
    margin-bottom: 2rem;
  }

  /* CTA cluster */
  .panel-hero__actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem 1.75rem;
  }

  .btn--contrast {
    background: var(--brand);
    color: var(--brand-contrast);
    border-color: var(--brand);
    box-shadow: 0 4px 18px color-mix(in srgb, var(--brand) 40%, transparent);
  }
  .btn--contrast:hover,
  .btn--contrast:focus-visible {
    background: var(--brand-dark);
    border-color: var(--brand-dark);
  }

  .panel-hero__phone {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    color: var(--text-on-dark);
    font-weight: var(--fw-bold);
    font-size: var(--step-0);
    text-decoration: none;
    border-bottom: var(--border-weight) solid
      color-mix(in srgb, var(--text-on-dark) 42%, transparent);
    padding-bottom: 2px;
    transition: border-color var(--motion-fade) var(--motion-ease);
  }
  .panel-hero__phone:hover {
    text-decoration: none;
    border-color: var(--text-on-dark);
  }
  .panel-hero__phone:focus-visible {
    outline: 2px solid var(--ring);
    outline-offset: 3px;
    border-radius: 2px;
  }
  .panel-hero__phone-icon {
    width: 1.05em;
    height: 1.05em;
    flex-shrink: 0;
  }

  /* Highlights strip */
  .panel-hero__highlights {
    list-style: none;
    margin: 2.5rem 0 0;
    padding: 1.5rem 0 0;
    border-top: var(--border-weight) solid
      color-mix(in srgb, var(--text-on-dark) 16%, transparent);
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 2rem;
    font-family: var(--font-body);
    font-size: var(--step--1);
    letter-spacing: var(--tracking-eyebrow);
    text-transform: uppercase;
    color: color-mix(in srgb, var(--text-on-dark) 74%, transparent);
    font-weight: var(--fw-bold);
  }

  /* ── Mobile ──────────────────────────────────────────────────────────────── */
  @media (max-width: 640px) {
    .panel-hero__title { font-size: clamp(2.2rem, 9vw, 3.4rem); }
    .panel-hero__geo--main {
      width: 58vw;
      right: -20%;
      top: -6%;
    }
    .panel-hero__geo--circle {
      width: 40vw;
      bottom: -12%;
      left: -15%;
    }
    .panel-hero__badge { left: 0; }
  }

  /* ── Archetype tweaks ────────────────────────────────────────────────────── */
  [data-archetype="utility"] .panel-hero__keyline {
    height: 4px;
  }
  [data-archetype="editorial"] .panel-hero__geo--main {
    transform: rotate(0deg);
    border-radius: 0;
    border-width: 1px;
  }
  [data-archetype="classic"] .panel-hero__title {
    font-size: clamp(3rem, 7.5vw, 6.5rem);
  }
</style>
