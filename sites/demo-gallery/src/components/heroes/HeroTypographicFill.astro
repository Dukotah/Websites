---
/**
 * HeroTypographicFill — the "type IS the hero" variant. A single oversized
 * display headline fills the viewport; no photo. This is the dominant
 * premium-agency move on 2025–2026 award sites and the strongest antidote to
 * the stock-photo-hero template tell — so it's the right pick when a prospect
 * has NO real photo (a stretched flat stock image is the loudest slop signal).
 *
 * Pure type + tokens, so it inherits the per-business display font and palette
 * and looks distinct per site. No image dependency → always safe in any pool.
 */
import type { ProspectConfig } from '../../types';
const { config } = Astro.props as { config: ProspectConfig };

const { hero, contact, highlights = [], established, area } = config;
const telHref = `tel:${contact.phone.replace(/[^+\d]/g, '')}`;
const eyebrow = [established, area].filter(Boolean).join(' · ');
---

<section class="tf-hero" id="top" aria-label="Hero">
  <div class="tf-hero__bg" aria-hidden="true"></div>

  <div class="container tf-hero__inner">
    {eyebrow && <p class="tf-hero__eyebrow" data-reveal data-reveal-order="0">{eyebrow}</p>}

    <h1 class="tf-hero__title" data-reveal data-reveal-order="1">{hero.heading}</h1>

    {hero.subheading && (
      <p class="tf-hero__sub" data-reveal data-reveal-order="2">{hero.subheading}</p>
    )}

    <div class="tf-hero__actions" data-reveal data-reveal-order="3">
      <a href={hero.ctaHref} class="tf-hero__cta">{hero.ctaText}</a>
      {contact.phone && (
        <a href={telHref} class="tf-hero__phone">
          <svg class="tf-hero__phone-icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M6.62 10.79a15.05 15.05 0 006.59 6.59l2.2-2.2a1 1 0 011.01-.24 11.47 11.47 0 003.58.57 1 1 0 011 1V20a1 1 0 01-1 1A17 17 0 013 4a1 1 0 011-1h3.5a1 1 0 011 1c0 1.25.2 2.45.57 3.58a1 1 0 01-.25 1.01l-2.2 2.2z" fill="currentColor"/>
          </svg>
          {contact.phone}
        </a>
      )}
    </div>

    {highlights.length > 0 && (
      <ul class="tf-hero__highlights" data-reveal data-reveal-order="4" aria-label="Key highlights">
        {highlights.map((h: string) => <li>{h}</li>)}
      </ul>
    )}
  </div>
</section>

<style>
  .tf-hero {
    position: relative;
    isolation: isolate;
    background: var(--bg);
    color: var(--text);
    min-height: min(90vh, 820px);
    display: flex;
    flex-direction: column;
    justify-content: center;
    overflow: hidden;
  }

  /* Faint twin-corner brand mesh — keeps a pure-type hero from feeling empty. */
  .tf-hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background:
      radial-gradient(ellipse 60% 55% at 100% 0%,
        color-mix(in srgb, var(--brand) 10%, transparent) 0%, transparent 60%),
      radial-gradient(ellipse 50% 45% at 0% 100%,
        color-mix(in srgb, var(--accent) 8%, transparent) 0%, transparent 58%);
  }

  .tf-hero__inner {
    position: relative;
    z-index: 1;
    max-width: var(--maxw);
    margin-inline: auto;
    padding-inline: var(--gutter);
    padding-block: clamp(4.5rem, 12vw, 9rem);
  }

  .tf-hero__eyebrow {
    font-family: var(--font-body);
    font-size: var(--step--1);
    font-weight: var(--fw-bold);
    letter-spacing: var(--tracking-eyebrow);
    text-transform: uppercase;
    color: var(--text-muted);
    margin: 0 0 1.4rem;
  }
  .tf-hero__eyebrow::before {
    content: '';
    display: inline-block;
    width: 1.8rem;
    height: 2px;
    margin-right: 0.7rem;
    vertical-align: middle;
    background: var(--accent);
  }

  /* The defining gesture: viewport-scale display type. */
  .tf-hero__title {
    font-family: var(--font-display);
    font-weight: var(--fw-display);
    font-size: clamp(3rem, 11vw, 8.5rem);
    line-height: 0.98;
    letter-spacing: -0.02em;
    color: var(--text);
    margin: 0;
    max-width: 18ch;
    text-wrap: balance;
  }

  .tf-hero__sub {
    font-size: clamp(1.05rem, 2vw, 1.35rem);
    line-height: var(--leading-body);
    color: var(--text-muted);
    max-width: 54ch;
    margin: 1.75rem 0 0;
  }

  .tf-hero__actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem 1.75rem;
    margin-top: 2.5rem;
  }

  /* Filled brand CTA — a type hero can carry a confident solid button. */
  .tf-hero__cta {
    display: inline-flex;
    align-items: center;
    background: var(--brand);
    color: var(--brand-contrast);
    font-family: var(--font-body);
    font-weight: var(--fw-bold);
    font-size: var(--step-0);
    text-decoration: none;
    padding: 0.8em 1.8em;
    border-radius: var(--radius);
    box-shadow: var(--shadow-sm);
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }
  .tf-hero__cta:hover {
    text-decoration: none;
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }
  .tf-hero__cta:focus-visible {
    outline: 2px solid var(--ring);
    outline-offset: 3px;
  }

  .tf-hero__phone {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    color: var(--text);
    font-family: var(--font-body);
    font-weight: var(--fw-bold);
    font-size: var(--step-0);
    text-decoration: none;
    border-bottom: var(--border-weight) solid var(--border);
    padding-bottom: 2px;
    transition: border-color var(--motion-fade) var(--motion-ease), color var(--motion-fade) var(--motion-ease);
  }
  .tf-hero__phone:hover {
    text-decoration: none;
    border-color: var(--brand);
    color: var(--brand);
  }
  .tf-hero__phone:focus-visible {
    outline: 2px solid var(--ring);
    outline-offset: 3px;
    border-radius: 2px;
  }
  .tf-hero__phone-icon {
    width: 1.05em;
    height: 1.05em;
    flex-shrink: 0;
  }

  .tf-hero__highlights {
    list-style: none;
    margin: 2.75rem 0 0;
    padding: 1.5rem 0 0;
    border-top: var(--border-weight) solid var(--border);
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 2.5rem;
    font-family: var(--font-body);
    font-size: var(--step--1);
    font-weight: var(--fw-bold);
    letter-spacing: var(--tracking-eyebrow);
    text-transform: uppercase;
    color: var(--text-muted);
  }

  @media (max-width: 640px) {
    .tf-hero__title {
      font-size: clamp(2.6rem, 13vw, 4.2rem);
      max-width: none;
    }
    .tf-hero__actions {
      flex-direction: column;
      align-items: flex-start;
      gap: 1.1rem;
    }
  }

  /* Archetype flavor: editorial/magazine push the type even bigger + tighter. */
  [data-archetype="magazine"] .tf-hero__title,
  [data-archetype="editorial"] .tf-hero__title {
    font-size: clamp(3.4rem, 13vw, 10rem);
    letter-spacing: -0.04em;
  }
</style>
