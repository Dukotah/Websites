---
/**
 * HeroEditorial — oversized typographic hero. The headline overflows toward
 * one edge, image reveals beneath on scroll (data-parallax). Inspired by the
 * BRAND Napa / Post Familiar / winery oversized-type pattern:
 *
 *   "Oversized typographic hero: the estate name or a single evocative phrase
 *    rendered at 12–18vw … positioned to overflow the viewport edge on one
 *    side. A secondary image fades in on scroll beneath the text."
 *
 * Award patterns applied:
 * - Winery heroPatterns[2]: 12–18vw type, overflow one edge, image reveals under text
 * - Salon heroPatterns[1]: "Oversized stacked headline over a muted-overlay image"
 * - Eyebrow accent rule (HeroCinematic idiom), badge, parallax via data-parallax
 */
import type { ProspectConfig } from '../../types';
const { config } = Astro.props as { config: ProspectConfig };

const { hero, images, contact, highlights = [], established, area } = config;
const telHref = `tel:${contact.phone.replace(/[^+\d]/g, '')}`;
const eyebrow = [established, area].filter(Boolean).join('  ·  ');
const hasPhoto = Boolean(images?.hero);
const badgeYear = (established || '').toString().replace(/^est\.?\s*/i, '');
const trustLine = highlights[0] ?? '';
---

<section
  class="ed-hero"
  id="top"
  data-has-photo={hasPhoto ? 'true' : undefined}
  aria-label="Hero"
>

  <!-- ① Photo — parallax target, reveals "beneath" the oversized type on scroll -->
  {hasPhoto && (
    <div class="ed-hero__media" aria-hidden="true" data-parallax data-parallax-speed="0.35">
      <img
        src={images.hero}
        alt={images.heroAlt}
        onerror={`this.onerror=null;this.src='${images.placeholder}'`}
        fetchpriority="high"
        decoding="async"
      />
    </div>
  )}

  <!-- ② Gradient-mesh overlay -->
  <div class="ed-hero__mesh" aria-hidden="true"></div>

  <!-- ③ Legibility scrim: heavier at base, lighter center so type breathes -->
  <div class="ed-hero__scrim" aria-hidden="true"></div>

  <!-- ④ Trust badge — anchored top-right so it doesn't compete with the
       overflowing type (bottom-left is where the type bleeds) -->
  {(badgeYear || trustLine) && (
    <div class="ed-hero__badge" data-reveal data-reveal-order="0" aria-label="Trust signal">
      {badgeYear && <strong class="ed-hero__badge-year">{badgeYear}</strong>}
      <span class="ed-hero__badge-label">{badgeYear ? 'Est.' : trustLine}</span>
      {badgeYear && trustLine && <span class="ed-hero__badge-trust">{trustLine}</span>}
    </div>
  )}

  <!-- ⑤ Content — left-aligned, type overflows right edge at large sizes -->
  <div class="ed-hero__inner">

    <div class="ed-hero__copy" data-reveal data-reveal-order="1">

      {eyebrow && (
        <p class="ed-hero__eyebrow">{eyebrow}</p>
      )}

      <!-- The oversized headline — intentionally wide, overflows viewport edge -->
      <h1 class="ed-hero__title">{hero.heading}</h1>

      <!-- Accent mid-rule below headline: short brand bar, left-anchored -->
      <div class="ed-hero__rule" aria-hidden="true"></div>

      {hero.subheading && (
        <p class="ed-hero__sub">{hero.subheading}</p>
      )}

      <!-- Ghost CTA + phone — award pattern for editorial heroes -->
      <div class="ed-hero__actions">
        <a href={hero.ctaHref} class="ed-hero__cta-ghost">{hero.ctaText}</a>
        {contact.phone && (
          <a href={telHref} class="ed-hero__phone">
            <svg class="ed-hero__phone-icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M6.62 10.79a15.05 15.05 0 006.59 6.59l2.2-2.2a1 1 0 011.01-.24 11.47 11.47 0 003.58.57 1 1 0 011 1V20a1 1 0 01-1 1A17 17 0 013 4a1 1 0 011-1h3.5a1 1 0 011 1c0 1.25.2 2.45.57 3.58a1 1 0 01-.25 1.01l-2.2 2.2z" fill="currentColor"/>
            </svg>
            {contact.phone}
          </a>
        )}
      </div>
    </div>

  </div>

  <!-- ⑥ Highlights ticker bar — pinned bottom, backdrop-blur -->
  {highlights.length > 0 && (
    <ul class="ed-hero__highlights" aria-label="Key highlights" data-reveal data-reveal-order="2">
      {highlights.map((h: string) => <li>{h}</li>)}
    </ul>
  )}

</section>

<style>
  /* ── Shell ─────────────────────────────────────────────────────────────── */
  .ed-hero {
    position: relative;
    isolation: isolate;
    min-height: min(96vh, 920px);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;   /* copy sits lower, photo "above" reveals on scroll */
    background: var(--bg-deep);
    color: var(--text-on-dark);
    overflow: hidden;
  }

  /* ── ① Photo layer ──────────────────────────────────────────────────────── */
  .ed-hero__media {
    position: absolute;
    inset: -14% 0;          /* generous bleed so parallax never shows gaps */
    z-index: 0;
    will-change: transform;
  }
  .ed-hero__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
    display: block;
  }
  @media (prefers-reduced-motion: reduce) {
    .ed-hero__media { inset: 0; will-change: auto; }
  }

  /* ── ② Gradient-mesh ────────────────────────────────────────────────────── */
  .ed-hero__mesh {
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      radial-gradient(
        ellipse 75% 50% at 0% 10%,
        color-mix(in srgb, var(--brand) 26%, transparent) 0%,
        transparent 62%
      ),
      radial-gradient(
        ellipse 50% 40% at 95% 92%,
        color-mix(in srgb, var(--accent) 16%, transparent) 0%,
        transparent 58%
      );
    pointer-events: none;
  }

  /* ── ③ Legibility scrim ─────────────────────────────────────────────────── */
  /* Heavier at the bottom-left where copy sits; fades up/right.
     Award pattern: transparent center → darker edges preserves photo detail. */
  .ed-hero__scrim {
    position: absolute;
    inset: 0;
    z-index: 2;
    background:
      linear-gradient(
        160deg,
        transparent 30%,
        color-mix(in srgb, var(--bg-deep) 65%, transparent) 100%
      ),
      linear-gradient(
        180deg,
        transparent 40%,
        color-mix(in srgb, var(--bg-deep) 78%, transparent) 100%
      );
    pointer-events: none;
  }
  :not([data-has-photo]) .ed-hero__scrim {
    background: color-mix(in srgb, var(--bg-deep) 82%, transparent);
  }

  /* ── ④ Trust badge (top-right, out of the type flow) ───────────────────── */
  .ed-hero__badge {
    position: absolute;
    top: clamp(1.5rem, 4vw, 3rem);
    right: clamp(1.5rem, 4vw, 3.5rem);
    z-index: 5;
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.1rem;
    background: var(--brand);
    color: var(--brand-contrast);
    border-radius: var(--radius);
    padding: 0.85rem 1.1rem;
    min-width: 72px;
    box-shadow: var(--shadow-lg);
    text-align: center;
  }
  .ed-hero__badge-year {
    font-family: var(--font-display);
    font-size: var(--step-2);
    font-weight: var(--fw-display);
    line-height: 1;
  }
  .ed-hero__badge-label {
    font-size: var(--step--1);
    font-weight: var(--fw-bold);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    opacity: 0.85;
  }
  .ed-hero__badge-trust {
    font-size: 0.62rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    opacity: 0.75;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 110px;
  }

  /* ── ⑤ Content layer ────────────────────────────────────────────────────── */
  .ed-hero__inner {
    position: relative;
    z-index: 3;
    width: 100%;
    max-width: var(--maxw);
    /* align to gutter — NOT a constrained container, title overflows right */
    padding-inline-start: var(--gutter);
    padding-inline-end: 0;           /* intentional: title overflows right edge */
    padding-block-end: clamp(3rem, 7vw, 5.5rem);
    margin-inline: auto;
  }

  .ed-hero__copy {
    /* width is intentionally wider than the safe zone to enable the overflow */
    max-width: none;
  }

  /* Eyebrow: accent rule + tracked caps */
  .ed-hero__eyebrow {
    display: block;
    font-family: var(--font-body);
    font-size: var(--step--1);
    font-weight: var(--fw-bold);
    letter-spacing: var(--tracking-eyebrow);
    text-transform: uppercase;
    color: color-mix(in srgb, var(--text-on-dark) 72%, transparent);
    margin: 0 0 1.1rem;
  }
  .ed-hero__eyebrow::before {
    content: '';
    display: inline-block;
    width: 1.6rem;
    height: 2px;
    margin-right: 0.6rem;
    vertical-align: middle;
    background: var(--accent);
  }

  /* Oversized headline — key pattern: overflows the viewport edge on one side.
     No max-width constraint. Fluid size from --step-4 → viewport-scale. */
  .ed-hero__title {
    font-family: var(--font-display);
    font-weight: var(--fw-display);
    /* Intentionally large — goes beyond container on wide viewports */
    font-size: clamp(3rem, 9vw, 8.5rem);
    line-height: var(--leading-display);
    letter-spacing: var(--tracking-display);
    color: var(--text-on-dark);
    margin: 0;
    text-shadow: 0 2px 48px color-mix(in srgb, var(--bg-deep) 45%, transparent);
    /* Allow the overflow to the right — the award move */
    white-space: nowrap;
    overflow: visible;
  }

  /* Accent mid-rule below headline: left-anchored, short brand bar */
  .ed-hero__rule {
    width: clamp(3rem, 6vw, 5rem);
    height: 3px;
    background: var(--accent);
    margin: 1.4rem 0 1.6rem;
    border-radius: var(--radius-pill);
  }
  :not([data-has-photo]) .ed-hero__rule {
    background: color-mix(in srgb, var(--brand) 70%, #fff 30%);
  }

  /* Subheading — constrained width so it doesn't run to the edge */
  .ed-hero__sub {
    font-family: var(--font-body);
    font-size: var(--step-1);
    line-height: var(--leading-body);
    color: color-mix(in srgb, var(--text-on-dark) 82%, transparent);
    max-width: 50ch;
    margin: 0 0 2rem;
  }

  /* CTA cluster */
  .ed-hero__actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem 1.75rem;
  }

  /* Ghost button — editorial hero award pattern */
  .ed-hero__cta-ghost {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-body);
    font-weight: var(--fw-bold);
    font-size: var(--step-0);
    color: var(--text-on-dark);
    text-decoration: none;
    border: var(--border-weight) solid
      color-mix(in srgb, var(--text-on-dark) 50%, transparent);
    padding: 0.75em 1.6em;
    border-radius: var(--radius);
    transition:
      border-color var(--motion-fade) var(--motion-ease),
      background var(--motion-fade) var(--motion-ease),
      color var(--motion-fade) var(--motion-ease);
  }
  .ed-hero__cta-ghost:hover {
    border-color: var(--brand);
    background: var(--brand);
    color: var(--brand-contrast);
    text-decoration: none;
  }
  .ed-hero__cta-ghost:focus-visible {
    outline: 2px solid var(--ring);
    outline-offset: 3px;
  }

  /* Phone link */
  .ed-hero__phone {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-family: var(--font-body);
    font-weight: var(--fw-bold);
    font-size: var(--step-0);
    color: var(--text-on-dark);
    text-decoration: none;
    border-bottom: var(--border-weight) solid
      color-mix(in srgb, var(--text-on-dark) 40%, transparent);
    padding-bottom: 2px;
    transition: border-color var(--motion-fade) var(--motion-ease);
  }
  .ed-hero__phone:hover {
    text-decoration: none;
    border-color: var(--text-on-dark);
  }
  .ed-hero__phone:focus-visible {
    outline: 2px solid var(--ring);
    outline-offset: 3px;
    border-radius: 2px;
  }
  .ed-hero__phone-icon {
    width: 1.05em;
    height: 1.05em;
    flex-shrink: 0;
  }

  /* ── ⑥ Highlights ticker — pinned bottom ───────────────────────────────── */
  .ed-hero__highlights {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    margin: 0;
    padding: 1rem var(--gutter);
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 2.25rem;
    background: color-mix(in srgb, var(--bg-deep) 55%, transparent);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    font-family: var(--font-body);
    font-size: var(--step--1);
    font-weight: var(--fw-bold);
    letter-spacing: 0.09em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--text-on-dark) 78%, transparent);
    z-index: 4;
  }

  /* ── Mobile ─────────────────────────────────────────────────────────────── */
  @media (max-width: 720px) {
    .ed-hero {
      min-height: 78vh;
    }
    /* On small screens, allow normal wrapping — no overflow-right */
    .ed-hero__title {
      font-size: clamp(2.4rem, 10vw, 3.8rem);
      white-space: normal;
    }
    .ed-hero__badge {
      top: 1rem;
      right: 1rem;
    }
    .ed-hero__highlights {
      position: static;
      background: var(--brand-dark, var(--bg-deep));
      backdrop-filter: none;
      -webkit-backdrop-filter: none;
    }
    .ed-hero__inner {
      padding-inline-end: var(--gutter);
    }
  }

  /* ── Archetype tweaks ──────────────────────────────────────────────────── */
  [data-archetype="magazine"] .ed-hero__title {
    font-size: clamp(3.5rem, 12vw, 11rem);
  }
  [data-archetype="editorial"] .ed-hero__rule {
    border-radius: 0;
    height: 2px;
  }
  [data-archetype="classic"] .ed-hero__title {
    white-space: normal;
  }
</style>
