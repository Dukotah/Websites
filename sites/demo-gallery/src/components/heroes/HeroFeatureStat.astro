---
/**
 * HeroFeatureStat — asymmetric editorial hero: a copy column beside an OFFSET
 * image card (rounded, bordered, slightly nudged with a brand-tinted frame
 * peeking behind it), with a STAT STRIP of big-number credentials sitting under
 * the copy. Mined from Fulldev UI's two-column heroes (blocks/hero-7, hero-13:
 * a `grid-cols-[2fr_3fr]` copy/image split with a rounded-`border` image card)
 * fused with their KPI idiom, reworked into a local-business "offset image +
 * stat strip" the spec asked for.
 *
 * Distinct from `editorial-asym`: that one runs a flush, full-HEIGHT tight crop
 * to the page edge; this frames the photo as a contained, offset CARD and adds
 * the numbers band — so the two never read alike side by side.
 *
 * Photo TIER: the image renders in a CONTAINED ~45vw card (never full-bleed), so
 * it stays sharp even for a 'side'-tier (medium-res) photo — this hero is safe
 * in the side-column rotation. Degrades gracefully: with NO photo the copy goes
 * full-width and the stat strip still anchors the fold. Cover-fill is set INLINE
 * on SiteImage (fit="cover") since Astro scopes the parent's `img {}` rule to
 * the parent — it never pierces the SiteImage child.
 *
 * The stat strip is built from REAL config facts only (rating, founding year,
 * service area, a leading highlight) — never fabricated. With fewer than two
 * genuine stats the strip is omitted entirely (fail-soft), so it never invents
 * credibility.
 */
import type { ProspectConfig } from '../../types';
import SiteImage from '../SiteImage.astro';
const { config } = Astro.props as { config: ProspectConfig };

const { hero, images, contact, highlights = [], established, area, rating } = config;
const telHref = `tel:${contact.phone.replace(/[^+\d]/g, '')}`;
const hasPhoto = Boolean(images?.hero);

const badgeYear = (established || '').toString().replace(/^est\.?\s*/i, '');
const eyebrow = [badgeYear ? '' : established, area].filter(Boolean).join(' · ');

// ── Stat strip — REAL facts only, fail-soft. Each entry is { value, label } and
//    is added only when its source datum is genuinely present. ────────────────
const stats: { value: string; label: string }[] = [];
// Years in business (derived from a 4-digit founding year vs. today).
const yearNum = Number((badgeYear.match(/\d{4}/) ?? [])[0]);
if (yearNum && yearNum > 1800 && yearNum <= new Date().getFullYear()) {
  const years = new Date().getFullYear() - yearNum;
  if (years >= 1) stats.push({ value: `${years}+`, label: 'Years in business' });
}
// Real Google rating (only when genuine — mirrors the no-fake-reviews rule).
if (rating && rating.value > 0 && rating.count > 0) {
  stats.push({ value: `${rating.value}★`, label: `${rating.count} reviews` });
}
// Service area (only when a place is actually named).
if (area && area.trim()) {
  stats.push({ value: area.split(',')[0].trim(), label: 'Proudly serving' });
}
// A leading highlight as a flavor stat when we still have room and a short one.
if (stats.length < 3 && highlights[0] && highlights[0].length <= 22) {
  stats.push({ value: '✓', label: highlights[0] });
}
// Need at least two genuine stats for a strip to read as a credentials band.
const showStats = stats.length >= 2;
// Cap at three so the strip stays a single tidy row.
const statRow = stats.slice(0, 3);

const longTitle = (hero.heading ?? '').length > 28;
---

<section
  class="fs-hero"
  id="top"
  aria-label="Hero"
  data-has-photo={hasPhoto ? 'true' : undefined}
  data-long-title={longTitle ? 'true' : undefined}
>
  <div class="container fs-hero__grid">

    <!-- ① Copy column -->
    <div class="fs-hero__copy" data-reveal data-reveal-order="1">
      {eyebrow && <p class="fs-hero__eyebrow">{eyebrow}</p>}

      <h1 class="fs-hero__title">{hero.heading}</h1>

      {hero.subheading && (
        <p class="fs-hero__sub">{hero.subheading}</p>
      )}

      <div class="fs-hero__actions">
        <a href={hero.ctaHref} class="btn fs-hero__cta">{hero.ctaText}</a>
        {contact.phone && (
          <a href={telHref} class="fs-hero__phone">
            <svg class="fs-hero__phone-icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M6.62 10.79a15.05 15.05 0 006.59 6.59l2.2-2.2a1 1 0 011.01-.24 11.47 11.47 0 003.58.57 1 1 0 011 1V20a1 1 0 01-1 1A17 17 0 013 4a1 1 0 011-1h3.5a1 1 0 011 1c0 1.25.2 2.45.57 3.58a1 1 0 01-.25 1.01l-2.2 2.2z" fill="currentColor"/>
            </svg>
            {contact.phone}
          </a>
        )}
      </div>

      <!-- Stat strip — big-number credentials, real facts only -->
      {showStats && (
        <dl class="fs-hero__stats" data-reveal data-reveal-order="2" aria-label="At a glance">
          {statRow.map((s) => (
            <div class="fs-hero__stat">
              <dt class="fs-hero__stat-value">{s.value}</dt>
              <dd class="fs-hero__stat-label">{s.label}</dd>
            </div>
          ))}
        </dl>
      )}
    </div>

    <!-- ② Offset image card (decorative — the headline carries meaning) -->
    {hasPhoto && (
      <div class="fs-hero__media-wrap" aria-hidden="true">
        <!-- Brand-tinted frame peeking behind the card (the offset gesture) -->
        <div class="fs-hero__frame" aria-hidden="true"></div>
        <div class="fs-hero__media">
          <!-- Contained ~45vw card (never full-bleed) → sharp even for a
               'side'-tier photo. sizes is the real rendered card width. -->
          <SiteImage
            src={images.hero}
            alt=""
            placeholder={images.placeholder}
            sizes="(min-width: 920px) 45vw, 100vw"
            loading="eager"
            fetchpriority="high"
            fit="cover"
            objectPosition={config.images.heroFocal ?? 'center'}
          />
        </div>
      </div>
    )}
  </div>
</section>

<style>
  .fs-hero {
    position: relative;
    isolation: isolate;
    background: var(--bg);
    color: var(--text);
    min-height: min(88vh, 800px);
    display: flex;
    align-items: center;
  }

  .fs-hero__grid {
    width: 100%;
    display: grid;
    grid-template-columns: 1fr; /* single column until a photo is present */
    gap: clamp(2.5rem, 5vw, 4.5rem);
    align-items: center;
    padding-block: clamp(3.5rem, 8vw, 6.5rem);
  }
  /* Copy-led asymmetry: copy is the narrower column, image the wider — the
     inverse of the flush full-height crop, so it can't be mistaken for it. */
  .fs-hero[data-has-photo] .fs-hero__grid {
    grid-template-columns: 5fr 6fr;
  }

  /* ── ① Copy column ───────────────────────────────────────────────────────── */
  .fs-hero__eyebrow {
    font-family: var(--font-body);
    font-size: var(--step--1);
    font-weight: var(--fw-bold);
    letter-spacing: var(--tracking-eyebrow);
    text-transform: uppercase;
    color: var(--text-muted);
    margin: 0 0 1.3rem;
  }
  .fs-hero__eyebrow::before {
    content: '';
    display: inline-block;
    width: 1.8rem;
    height: 2px;
    margin-right: 0.7rem;
    vertical-align: middle;
    background: var(--accent);
  }

  .fs-hero__title {
    font-family: var(--font-display);
    font-weight: var(--fw-display);
    font-size: clamp(2.6rem, 5.2vw, 4.8rem);
    line-height: var(--leading-display);
    letter-spacing: var(--tracking-display);
    color: var(--text);
    margin: 0;
    max-width: 18ch;
    text-wrap: balance;
  }

  /* Long (full-sentence) headline: step the clamp down + widen the measure so a
     sentence wraps to a tidy block. Balanced wrap evens the lines; the smaller
     clamp is the CSS fallback where text-wrap: balance is unsupported. Doubled
     attribute raises specificity over the [data-archetype] title bumps. */
  @media (min-width: 641px) {
    [data-long-title][data-long-title] .fs-hero__title {
      font-size: clamp(2.3rem, 4.2vw, 3.8rem);
      max-width: 24ch;
    }
  }

  .fs-hero__sub {
    font-family: var(--font-body);
    font-size: clamp(1.02rem, 1.8vw, 1.3rem);
    line-height: var(--leading-body);
    color: var(--text-muted);
    max-width: 48ch;
    margin: 1.5rem 0 0;
  }

  .fs-hero__actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem 1.6rem;
    margin-top: 2.25rem;
  }
  .fs-hero__cta {
    font-size: var(--step-0);
    padding: 0.85em 1.7em;
  }
  .fs-hero__phone {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    color: var(--text);
    font-family: var(--font-body);
    font-weight: var(--fw-bold);
    font-size: var(--step-0);
    text-decoration: none;
    border-bottom: var(--border-weight) solid var(--border);
    padding-bottom: 2px;
    transition:
      border-color var(--motion-fade) var(--motion-ease),
      color var(--motion-fade) var(--motion-ease);
  }
  .fs-hero__phone:hover {
    text-decoration: none;
    border-color: var(--brand);
    color: var(--brand);
  }
  .fs-hero__phone:focus-visible {
    outline: 2px solid var(--ring);
    outline-offset: 3px;
    border-radius: 2px;
  }
  .fs-hero__phone-icon {
    width: 1.05em;
    height: 1.05em;
    flex-shrink: 0;
  }

  /* ── Stat strip ──────────────────────────────────────────────────────────── */
  .fs-hero__stats {
    margin: 2.75rem 0 0;
    padding: 1.6rem 0 0;
    border-top: var(--border-weight) solid var(--border);
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem 2.5rem;
  }
  .fs-hero__stat {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .fs-hero__stat-value {
    font-family: var(--font-display);
    font-weight: var(--fw-display);
    font-size: var(--step-3);
    line-height: 1;
    color: var(--brand-vivid, var(--brand));
  }
  .fs-hero__stat-label {
    margin: 0;
    font-family: var(--font-body);
    font-size: var(--step--1);
    font-weight: var(--fw-bold);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-muted);
    max-width: 16ch;
    line-height: 1.25;
  }

  /* ── ② Offset image card ─────────────────────────────────────────────────── */
  .fs-hero__media-wrap {
    position: relative;
    isolation: isolate;
  }
  /* Brand-tinted frame peeking behind the photo — the "offset" gesture. */
  .fs-hero__frame {
    position: absolute;
    inset: -1.25rem -1.25rem 1.25rem 1.25rem;
    background: color-mix(in srgb, var(--brand) 14%, var(--bg));
    border-radius: var(--radius-lg);
    z-index: 0;
  }
  .fs-hero__media {
    position: relative;
    z-index: 1;
    overflow: hidden;
    border-radius: var(--radius-lg);
    border: var(--border-weight) solid var(--border);
    box-shadow: var(--shadow-lg);
    aspect-ratio: 4 / 3;
    background: var(--surface);
  }
  .fs-hero__media :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  /* ── Mobile: stack copy over a shorter image band ────────────────────────── */
  @media (max-width: 919px) {
    .fs-hero[data-has-photo] .fs-hero__grid {
      grid-template-columns: 1fr;
    }
    .fs-hero__media-wrap { order: 2; }
    .fs-hero__frame { inset: -0.85rem -0.85rem 0.85rem 0.85rem; }
  }
  @media (max-width: 640px) {
    .fs-hero__title { font-size: clamp(2.3rem, 10vw, 3.4rem); max-width: none; }
    .fs-hero__actions {
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
    }
    .fs-hero__stats { gap: 1.25rem 1.75rem; }
    .fs-hero__stat-value { font-size: var(--step-2); }
  }

  /* ── Archetype tweaks ────────────────────────────────────────────────────── */
  [data-archetype="utility"] .fs-hero__stat-value {
    /* Data-first utility pages push the numbers harder. */
    font-size: var(--step-4);
  }
  [data-archetype="editorial"] .fs-hero__title,
  [data-archetype="magazine"] .fs-hero__title {
    letter-spacing: -0.035em;
  }
  [data-archetype="magazine"] .fs-hero__title {
    font-size: clamp(2.8rem, 6vw, 5.4rem);
  }
</style>
