---
/**
 * HeroSplit — editorial split hero where the PHOTO EDGE is the divider (no
 * border). Copy lives in a deep panel (55% left). Photo fills the remaining
 * 45% with an offset/overlap frame accent move. Oversized display heading,
 * ghost/outline CTA + phone link. Trust badge bleeds over the seam bottom-left.
 *
 * Award patterns applied:
 * - Winery heroPatterns[1]: "photo edge IS the dividing line … asymmetry signals agency work"
 * - Marina heroPatterns[3]: split-screen, dividing line "zero (pure juxtaposition)"
 * - The badge bleeds across the seam: offset via negative left (Dukhorn / split-hero idiom)
 */
import type { ProspectConfig } from '../../types';
const { config } = Astro.props as { config: ProspectConfig };

const { hero, images, contact, highlights = [], established, area } = config;
const telHref = `tel:${contact.phone.replace(/[^+\d]/g, '')}`;
const eyebrow = [established, area].filter(Boolean).join(' · ');
const badgeYear = (established || '').toString().replace(/^est\.?\s*/i, '');
const trustLine = highlights[0] ?? '';
---

<section class="spl-hero" id="top" aria-label="Hero">

  <!-- ① Deep copy panel (55%) -->
  <div class="spl-hero__panel">

    <!-- Mesh accent behind the copy — subtle warm radial, brand corner -->
    <div class="spl-hero__mesh" aria-hidden="true"></div>

    <div class="spl-hero__copy" data-reveal data-reveal-order="1">

      {eyebrow && (
        <p class="spl-hero__eyebrow">{eyebrow}</p>
      )}

      <!-- Oversized display heading: max-width forces 2–3 word per line cascade -->
      <h1 class="spl-hero__title">{hero.heading}</h1>

      {hero.subheading && (
        <p class="spl-hero__sub">{hero.subheading}</p>
      )}

      <!-- Ghost CTA + phone — award pattern: no filled pill in hero -->
      <div class="spl-hero__actions">
        <a href={hero.ctaHref} class="spl-hero__cta-ghost">{hero.ctaText}</a>
        {contact.phone && (
          <a href={telHref} class="spl-hero__phone">
            <svg class="spl-hero__phone-icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M6.62 10.79a15.05 15.05 0 006.59 6.59l2.2-2.2a1 1 0 011.01-.24 11.47 11.47 0 003.58.57 1 1 0 011 1V20a1 1 0 01-1 1A17 17 0 013 4a1 1 0 011-1h3.5a1 1 0 011 1c0 1.25.2 2.45.57 3.58a1 1 0 01-.25 1.01l-2.2 2.2z" fill="currentColor"/>
            </svg>
            {contact.phone}
          </a>
        )}
      </div>

      <!-- Highlights strip — thin top rule, uppercase tracked -->
      {highlights.length > 0 && (
        <ul class="spl-hero__highlights" aria-label="Key highlights" data-reveal data-reveal-order="2">
          {highlights.map((h: string) => <li>{h}</li>)}
        </ul>
      )}
    </div>
  </div>

  <!-- ② Photo panel (45%) — photo edge IS the seam, no border -->
  <div class="spl-hero__media-wrap">

    <!-- Offset frame accent: brand-tinted rectangle behind photo, bleeds slightly left -->
    <div class="spl-hero__frame-accent" aria-hidden="true"></div>

    <!-- Parallax photo — inset bleed so parallax never exposes edges -->
    <div class="spl-hero__media" data-parallax data-parallax-speed="0.3" aria-hidden="true">
      <img
        src={images.hero}
        alt={images.heroAlt}
        onerror={`this.onerror=null;this.src='${images.placeholder}'`}
        fetchpriority="high"
        decoding="async"
      />
    </div>

    <!-- Trust badge — bleeds across the seam (negative left value) -->
    {(badgeYear || trustLine) && (
      <div class="spl-hero__badge" data-reveal data-reveal-order="0" aria-label="Trust signal">
        {badgeYear && <strong class="spl-hero__badge-year">{badgeYear}</strong>}
        <span class="spl-hero__badge-label">{badgeYear ? 'Est.' : trustLine}</span>
        {badgeYear && trustLine && <span class="spl-hero__badge-trust">{trustLine}</span>}
      </div>
    )}
  </div>

</section>

<style>
  /* ── Shell: 55 / 45 grid, photo edge as divider ────────────────────────── */
  .spl-hero {
    display: grid;
    grid-template-columns: 55fr 45fr;
    min-height: min(92vh, 860px);
    overflow: hidden;
    background: var(--bg-deep);
  }

  /* ── ① Copy panel ────────────────────────────────────────────────────── */
  .spl-hero__panel {
    position: relative;
    isolation: isolate;
    background: var(--bg-deep);
    color: var(--text-on-dark);
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: clamp(3rem, 7vw, 6rem) clamp(2rem, 5vw, 5rem);
    overflow: hidden;
  }

  /* Brand gradient-mesh — warmth in bottom-left, accent top-right peek */
  .spl-hero__mesh {
    position: absolute;
    inset: 0;
    z-index: 0;
    background:
      radial-gradient(
        ellipse 80% 65% at -5% 110%,
        color-mix(in srgb, var(--brand) 22%, transparent) 0%,
        transparent 62%
      ),
      radial-gradient(
        ellipse 55% 45% at 108% -8%,
        color-mix(in srgb, var(--accent) 14%, transparent) 0%,
        transparent 58%
      );
    pointer-events: none;
  }

  .spl-hero__copy {
    position: relative;
    z-index: 1;
    /* max-width forces the 2–3 word cascade (award pattern) */
    max-width: 14ch;
  }

  /* Eyebrow: accent rule + tracked caps (HeroCinematic idiom) */
  .spl-hero__eyebrow {
    display: block;
    font-family: var(--font-body);
    font-size: var(--step--1);
    font-weight: var(--fw-bold);
    letter-spacing: var(--tracking-eyebrow);
    text-transform: uppercase;
    color: color-mix(in srgb, var(--text-on-dark) 72%, transparent);
    margin: 0 0 1.25rem;
  }
  .spl-hero__eyebrow::before {
    content: '';
    display: inline-block;
    width: 1.6rem;
    height: 2px;
    margin-right: 0.6rem;
    vertical-align: middle;
    background: var(--accent);
  }

  /* Oversized headline — deep panel means no scrim needed, type is clear */
  .spl-hero__title {
    font-family: var(--font-display);
    font-weight: var(--fw-display);
    font-size: clamp(2.8rem, 5.5vw, 5.4rem);
    line-height: var(--leading-display);
    letter-spacing: var(--tracking-display);
    color: var(--text-on-dark);
    margin: 0 0 1.25rem;
    text-wrap: balance;
  }

  .spl-hero__sub {
    font-family: var(--font-body);
    font-size: var(--step-0);
    line-height: var(--leading-body);
    color: color-mix(in srgb, var(--text-on-dark) 78%, transparent);
    max-width: 44ch;
    margin: 0 0 2rem;
  }

  /* CTA cluster */
  .spl-hero__actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem 1.75rem;
  }

  /* Ghost/outline button — award pattern: "CTA is ghost/outline in hero" */
  .spl-hero__cta-ghost {
    display: inline-flex;
    align-items: center;
    gap: 0.4em;
    font-family: var(--font-body);
    font-weight: var(--fw-bold);
    font-size: var(--step-0);
    color: var(--text-on-dark);
    text-decoration: none;
    border: var(--border-weight) solid
      color-mix(in srgb, var(--text-on-dark) 55%, transparent);
    padding: 0.75em 1.6em;
    border-radius: var(--radius);
    transition:
      border-color var(--motion-fade) var(--motion-ease),
      background var(--motion-fade) var(--motion-ease),
      color var(--motion-fade) var(--motion-ease);
  }
  .spl-hero__cta-ghost:hover {
    border-color: var(--brand);
    background: var(--brand);
    color: var(--brand-contrast);
    text-decoration: none;
  }
  .spl-hero__cta-ghost:focus-visible {
    outline: 2px solid var(--ring);
    outline-offset: 3px;
  }

  /* Phone link */
  .spl-hero__phone {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-body);
    font-weight: var(--fw-bold);
    font-size: var(--step-0);
    color: var(--text-on-dark);
    text-decoration: none;
    border-bottom: var(--border-weight) solid
      color-mix(in srgb, var(--text-on-dark) 38%, transparent);
    padding-bottom: 2px;
    transition: border-color var(--motion-fade) var(--motion-ease);
  }
  .spl-hero__phone:hover {
    text-decoration: none;
    border-color: var(--text-on-dark);
  }
  .spl-hero__phone:focus-visible {
    outline: 2px solid var(--ring);
    outline-offset: 3px;
    border-radius: 2px;
  }
  .spl-hero__phone-icon {
    width: 1.05em;
    height: 1.05em;
    flex-shrink: 0;
  }

  /* Highlights strip */
  .spl-hero__highlights {
    list-style: none;
    margin: 2.5rem 0 0;
    padding: 1.5rem 0 0;
    border-top: var(--border-weight) solid
      color-mix(in srgb, var(--text-on-dark) 16%, transparent);
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 2rem;
    font-family: var(--font-body);
    font-size: var(--step--1);
    font-weight: var(--fw-bold);
    letter-spacing: 0.09em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--text-on-dark) 70%, transparent);
  }

  /* ── ② Photo panel ────────────────────────────────────────────────────── */
  .spl-hero__media-wrap {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    /* no border — the photo edge IS the divider (award pattern) */
    background: var(--bg-deep);
  }

  /* Offset accent rectangle: sits behind photo, peeks ~12% to the left of the
     photo itself (into the gutter between columns). The brand tint is subtle. */
  .spl-hero__frame-accent {
    position: absolute;
    inset: 10% 5% 10% -8%;
    background: color-mix(in srgb, var(--brand) 16%, var(--bg-deep));
    border-radius: var(--radius-lg) 0 0 var(--radius-lg);
    z-index: 0;
  }

  /* Photo — parallax target, generous inset bleed */
  .spl-hero__media {
    position: absolute;
    inset: -10% 0;
    z-index: 1;
    will-change: transform;
  }
  .spl-hero__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }
  @media (prefers-reduced-motion: reduce) {
    .spl-hero__media { inset: 0; will-change: auto; }
  }

  /* Trust badge — bottom-left, bleeds across the panel seam (negative left) */
  .spl-hero__badge {
    position: absolute;
    bottom: 2.5rem;
    left: -1.5rem;        /* bleeds over the seam → overlap move */
    z-index: 2;
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.1rem;
    background: var(--brand);
    color: var(--brand-contrast);
    border-radius: var(--radius);
    padding: 0.85rem 1.15rem;
    min-width: 72px;
    box-shadow: var(--shadow-lg);
    text-align: center;
  }
  .spl-hero__badge-year {
    font-family: var(--font-display);
    font-size: var(--step-2);
    font-weight: var(--fw-display);
    line-height: 1;
  }
  .spl-hero__badge-label {
    font-size: var(--step--1);
    font-weight: var(--fw-bold);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    opacity: 0.85;
  }
  .spl-hero__badge-trust {
    font-size: 0.62rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    opacity: 0.75;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 110px;
  }

  /* ── Mobile ──────────────────────────────────────────────────────────── */
  @media (max-width: 860px) {
    .spl-hero {
      grid-template-columns: 1fr;
    }
    /* Photo stacks above copy on mobile */
    .spl-hero__media-wrap {
      order: -1;
      min-height: 48vh;
    }
    .spl-hero__media { inset: 0; }
    .spl-hero__frame-accent { display: none; }
    .spl-hero__badge {
      left: auto;
      right: 1rem;
      bottom: 1rem;
    }
    .spl-hero__copy { max-width: none; }
    .spl-hero__title { font-size: clamp(2.2rem, 8vw, 3.4rem); }
  }

  /* ── Archetype tweaks ─────────────────────────────────────────────────── */
  [data-archetype="classic"] .spl-hero__copy {
    max-width: 18ch;
  }
  [data-archetype="magazine"] .spl-hero__title {
    font-size: clamp(3rem, 6.5vw, 6rem);
  }
</style>
