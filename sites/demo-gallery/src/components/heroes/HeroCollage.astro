---
/**
 * HeroCollage — 2–3 photo collage with overlapping headline, a brand gradient-
 * mesh, and a floating trust badge that bleeds across the primary photo edge.
 * Spec §7: "collage" variant. Gracefully degrades to 1 image.
 */
import type { ProspectConfig } from '../../types';
import SiteImage from '../SiteImage.astro';
const { config } = Astro.props as { config: ProspectConfig };

const { hero, images, contact, highlights = [], established, area } = config;
const telHref = `tel:${contact.phone.replace(/[^+\d]/g, '')}`;
const eyebrow = [established, area].filter(Boolean).join(' · ');
const badgeYear = (established || '').toString().replace(/^est\.?\s*/i, '');
const trustLine = highlights[0] ?? '';

// Collect real images: primary hero first, then gallery extras.
type ImgSlot = { src: string; alt: string };
const allImages: ImgSlot[] = [];
if (config.images?.hero) {
  allImages.push({ src: config.images.hero, alt: config.images.heroAlt ?? config.name });
}
for (const gi of config.galleryImages ?? []) {
  if (allImages.length >= 3) break;
  if (gi.src && gi.src !== config.images?.hero) allImages.push(gi);
}
const imgs = allImages.slice(0, 3);
if (imgs.length === 0) {
  imgs.push({ src: config.images?.placeholder ?? '', alt: config.name });
}
const count = imgs.length; // 1 | 2 | 3
---

<section class="col-hero" id="top" data-count={count} aria-label="Hero">

  <!-- ① Collage grid (position: absolute behind content) -->
  <div class="col-hero__media" aria-hidden="true">
    {imgs.map((img, i) => (
      <div
        class="col-hero__frame"
        data-index={i}
        data-parallax={i === 0 ? '' : undefined}
        data-parallax-speed={i === 0 ? '0.3' : undefined}
      >
        <SiteImage
          src={img.src}
          alt={img.alt}
          placeholder={config.images?.placeholder ?? ''}
          fetchpriority={i === 0 ? 'high' : 'auto'}
          loading={i === 0 ? 'eager' : 'lazy'}
          sizes="(min-width: 640px) 50vw, 100vw"
        />
      </div>
    ))}

    <!-- Brand gradient-mesh overlay -->
    <div class="col-hero__mesh" aria-hidden="true"></div>

    <!-- Legibility scrim -->
    <span class="col-hero__scrim" aria-hidden="true"></span>
  </div>

  <!-- ② Floating trust badge (anchored bottom-right of primary photo) -->
  {(badgeYear || trustLine) && (
    <div class="col-hero__badge" data-reveal data-reveal-order="0" aria-label="Trust signal">
      {badgeYear && <strong class="col-hero__badge-year">{badgeYear}</strong>}
      <span class="col-hero__badge-label">{badgeYear ? 'Est.' : trustLine}</span>
      {badgeYear && trustLine && <span class="col-hero__badge-trust">{trustLine}</span>}
    </div>
  )}

  <!-- ③ Content -->
  <div class="container col-hero__inner">

    {eyebrow && (
      <p class="col-hero__eyebrow" data-reveal data-reveal-order="1">{eyebrow}</p>
    )}

    <h1 class="col-hero__title" data-reveal data-reveal-order="2">
      {hero.heading}
    </h1>

    {hero.subheading && (
      <p class="col-hero__sub" data-reveal data-reveal-order="3">
        {hero.subheading}
      </p>
    )}

    <!-- CTA cluster -->
    <div class="col-hero__actions" data-reveal data-reveal-order="4">
      <a href={hero.ctaHref} class="btn col-hero__cta">{hero.ctaText}</a>
      {contact.phone && (
        <a href={telHref} class="col-hero__phone">
          <svg class="col-hero__phone-icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M6.62 10.79a15.05 15.05 0 006.59 6.59l2.2-2.2a1 1 0 011.01-.24 11.47 11.47 0 003.58.57 1 1 0 011 1V20a1 1 0 01-1 1A17 17 0 013 4a1 1 0 011-1h3.5a1 1 0 011 1c0 1.25.2 2.45.57 3.58a1 1 0 01-.25 1.01l-2.2 2.2z" fill="currentColor"/>
          </svg>
          {contact.phone}
        </a>
      )}
    </div>

  </div>

  <!-- ④ Highlights bar (pinned bottom) -->
  {highlights.length > 0 && (
    <ul class="col-hero__highlights" data-reveal data-reveal-order="5" aria-label="Key highlights">
      {highlights.map((h: string) => <li>{h}</li>)}
    </ul>
  )}

</section>

<style>
  /* ── Shell ───────────────────────────────────────────────────────────────── */
  .col-hero {
    position: relative;
    isolation: isolate;
    min-height: min(92vh, 840px);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    color: #fff;
    overflow: hidden;
    background: var(--bg-deep);
  }

  /* ── ① Collage grid ──────────────────────────────────────────────────────── */
  .col-hero__media {
    position: absolute;
    inset: 0;
    z-index: 0;
    display: grid;
    gap: 3px;
    background: var(--bg-deep);
  }

  /* 1 image: single full-bleed */
  .col-hero[data-count="1"] .col-hero__media {
    grid-template-columns: 1fr;
  }
  /* 2 images: primary 62% | aside 38% */
  .col-hero[data-count="2"] .col-hero__media {
    grid-template-columns: 62fr 38fr;
  }
  /* 3 images: primary 55% | right column split 2 rows */
  .col-hero[data-count="3"] .col-hero__media {
    grid-template-columns: 55fr 45fr;
    grid-template-rows: 1fr 1fr;
  }
  .col-hero[data-count="3"] .col-hero__frame:first-child {
    grid-row: 1 / 3;
  }

  .col-hero__frame {
    overflow: hidden;
    background: var(--bg-deep);
    position: relative;
    will-change: transform; /* only primary gets parallax but ok on siblings */
  }
  .col-hero__frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s var(--motion-ease);
  }
  .col-hero__frame:hover img {
    transform: scale(1.04);
  }
  @media (prefers-reduced-motion: reduce) {
    .col-hero__frame { will-change: auto; }
    .col-hero__frame img { transition: none; }
    .col-hero__frame:hover img { transform: none; }
  }

  /* Brand gradient-mesh sits above photos, below scrim */
  .col-hero__mesh {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(
        ellipse 70% 55% at 80% 0%,
        color-mix(in srgb, var(--brand) 26%, transparent) 0%,
        transparent 60%
      );
    pointer-events: none;
    z-index: 1;
  }

  /* Bottom-heavy scrim for text legibility */
  .col-hero__scrim {
    position: absolute;
    inset: 0;
    z-index: 2;
    background: linear-gradient(
      162deg,
      rgba(12, 14, 18, 0.08) 0%,
      rgba(12, 14, 18, 0.26) 40%,
      rgba(12, 14, 18, 0.82) 100%
    );
    pointer-events: none;
  }

  /* ── ② Trust badge ───────────────────────────────────────────────────────── */
  .col-hero__badge {
    position: absolute;
    /*
     * Default (3-image): primary column = 55fr → badge centred on that boundary.
     * Overridden per data-count below.
     */
    left: clamp(42%, 54vw, 56%);
    bottom: 8rem;          /* above highlights bar */
    transform: translateX(-50%);
    z-index: 5;
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.1rem;
    background: var(--brand);
    color: var(--brand-contrast);
    border-radius: var(--radius);
    padding: 0.85rem 1.1rem;
    min-width: 72px;
    box-shadow: var(--shadow-lg);
    text-align: center;
  }
  .col-hero__badge-year {
    font-family: var(--font-display);
    font-size: var(--step-2);
    font-weight: var(--fw-display);
    line-height: 1;
  }
  .col-hero__badge-label {
    font-size: var(--step--1);
    font-weight: var(--fw-bold);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    opacity: 0.85;
  }
  .col-hero__badge-trust {
    font-size: 0.62rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    opacity: 0.75;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 110px;
  }

  /*
   * Count-specific badge positioning (desktop only — mobile overrides below).
   *
   * 3-image layout: primary column is 55fr of 100% → right edge ≈ 55%.
   *   Badge centre sits on that seam: left ≈ 55%.
   *
   * 2-image layout: primary column is 62fr of 100% → right edge ≈ 62%.
   *   Badge centre sits on that seam: left ≈ 62%.
   *
   * 1-image layout: full bleed — pin badge to right side instead.
   */
  .col-hero[data-count="3"] .col-hero__badge {
    left: clamp(42%, 54vw, 56%);  /* 55% seam, matches default */
  }
  .col-hero[data-count="2"] .col-hero__badge {
    left: clamp(48%, 61vw, 64%);  /* 62% seam */
  }
  .col-hero[data-count="1"] .col-hero__badge {
    left: auto;
    right: clamp(1rem, 4vw, 3rem);
    transform: none;
  }

  /* ── ③ Content layer ─────────────────────────────────────────────────────── */
  .col-hero__inner {
    position: relative;
    z-index: 4;
    padding-block: clamp(2.5rem, 6vw, 4.5rem);
    max-width: var(--maxw);
    width: 100%;
  }

  .col-hero__eyebrow {
    font-family: var(--font-body);
    font-size: var(--step--1);
    font-weight: var(--fw-bold);
    letter-spacing: var(--tracking-eyebrow);
    text-transform: uppercase;
    color: color-mix(in srgb, var(--brand) 55%, #fff 45%);
    margin-bottom: 0.85rem;
  }

  /* Oversized headline */
  .col-hero__title {
    font-family: var(--font-display);
    font-weight: var(--fw-display);
    font-size: clamp(2.4rem, 5.5vw, 5rem);
    line-height: var(--leading-display);
    letter-spacing: var(--tracking-display);
    color: #fff;
    margin-bottom: 0.85rem;
    max-width: 20ch;
    text-shadow: 0 2px 28px rgba(0, 0, 0, 0.32);
  }

  .col-hero__sub {
    font-family: var(--font-body);
    font-size: clamp(1rem, 1.8vw, 1.22rem);
    line-height: var(--leading-body);
    color: rgba(255, 255, 255, 0.88);
    max-width: 52ch;
    margin-bottom: 1.75rem;
  }

  /* CTA cluster */
  .col-hero__actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem 1.75rem;
  }

  .col-hero__cta {
    box-shadow: 0 4px 20px color-mix(in srgb, var(--brand) 40%, transparent);
  }

  .col-hero__phone {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    color: #fff;
    font-family: var(--font-body);
    font-weight: var(--fw-bold);
    font-size: var(--step-0);
    text-decoration: none;
    border-bottom: var(--border-weight) solid rgba(255, 255, 255, 0.45);
    padding-bottom: 2px;
    transition: border-color var(--motion-fade) var(--motion-ease);
  }
  .col-hero__phone:hover {
    text-decoration: none;
    border-color: #fff;
  }
  .col-hero__phone:focus-visible {
    outline: 2px solid var(--ring);
    outline-offset: 3px;
    border-radius: 2px;
  }
  .col-hero__phone-icon {
    width: 1.05em;
    height: 1.05em;
    flex-shrink: 0;
  }

  /* ── ④ Highlights bar ────────────────────────────────────────────────────── */
  .col-hero__highlights {
    position: relative;
    z-index: 4;
    list-style: none;
    margin: 0;
    padding: 1rem var(--gutter);
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-start;
    gap: 0.4rem 2rem;
    background: rgba(0, 0, 0, 0.34);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    font-family: var(--font-body);
    font-size: var(--step--1);
    font-weight: var(--fw-bold);
    letter-spacing: var(--tracking-eyebrow);
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.82);
  }

  /* ── Mobile ──────────────────────────────────────────────────────────────── */
  @media (max-width: 640px) {
    .col-hero[data-count="2"] .col-hero__media,
    .col-hero[data-count="3"] .col-hero__media {
      grid-template-columns: 1fr;
      grid-template-rows: 1fr;
    }
    .col-hero__frame:not(:first-child) { display: none; }
    .col-hero[data-count="3"] .col-hero__frame:first-child { grid-row: auto; }
    .col-hero__title { font-size: clamp(2rem, 8vw, 3rem); max-width: none; }
    .col-hero__badge {
      left: auto;
      right: 1rem;
      bottom: 7rem;
      transform: none;
    }
  }

  /* ── Archetype tweaks ────────────────────────────────────────────────────── */
  [data-archetype="magazine"] .col-hero__title {
    font-size: clamp(2.8rem, 6.5vw, 5.8rem);
  }
</style>
