---
/**
 * HeroEditorialAsym — type-dominant asymmetric split (65/35). The balanced 50/50
 * HeroSplit is a template tell; award-winning winery/boutique/cafe sites use a
 * wide display-type column beside a narrow, full-height, tightly-cropped photo.
 *
 * Degrades gracefully: with a real photo it's the asymmetric split; with none
 * the type column goes full-width (still intentional) — so it's safe in any
 * divergence pool regardless of media. The photo is decorative (the headline
 * carries meaning), so its container is aria-hidden and the image alt is empty.
 *
 * Cover-fill is set INLINE on SiteImage (fit="cover") — Astro scopes a parent's
 * `img` rules to the parent, so they never reach the SiteImage child (see the
 * c5de34b cover-fill fix). Don't rely on scoped `.x img { object-fit }` here.
 */
import type { ProspectConfig } from '../../types';
import SiteImage from '../SiteImage.astro';
import TrustBadge from '../TrustBadge.astro';
const { config } = Astro.props as { config: ProspectConfig };

const { hero, images, contact, highlights = [], established, area, artDirection, rating } = config;
const telHref = `tel:${contact.phone.replace(/[^+\d]/g, '')}`;
const eyebrow = [established, area].filter(Boolean).join(' · ');
const hasPhoto = Boolean(images?.hero);

// Art-direction photo treatment
const treatment = artDirection?.photoTreatment ?? 'natural';
const useGrain  = artDirection?.photoGrain ?? false;
const mediaClass = [
  'ea-hero__media',
  treatment === 'duotone' ? 'img-duotone' : '',
].filter(Boolean).join(' ');
const mediaTreat = treatment === 'muted' ? 'grade' : undefined;

const badgeYear = (established || '').toString().replace(/^est\.?\s*/i, '');
const trustLine = highlights[0] ?? '';
---

<section class="ea-hero" id="top" aria-label="Hero" data-has-photo={hasPhoto ? 'true' : undefined}>
  <!-- ① Type column (65%, dominant) -->
  <div class="ea-hero__copy">
    <div class="ea-hero__copy-inner">
      {eyebrow && <p class="ea-hero__eyebrow" data-reveal data-reveal-order="0">{eyebrow}</p>}

      <h1 class="ea-hero__title" data-reveal data-reveal-order="1">{hero.heading}</h1>

      {hero.subheading && (
        <p class="ea-hero__sub" data-reveal data-reveal-order="2">{hero.subheading}</p>
      )}

      <div class="ea-hero__actions" data-reveal data-reveal-order="3">
        <a href={hero.ctaHref} class="ea-hero__cta">{hero.ctaText}</a>
        {contact.phone && (
          <a href={telHref} class="ea-hero__phone">
            <svg class="ea-hero__phone-icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M6.62 10.79a15.05 15.05 0 006.59 6.59l2.2-2.2a1 1 0 011.01-.24 11.47 11.47 0 003.58.57 1 1 0 011 1V20a1 1 0 01-1 1A17 17 0 013 4a1 1 0 011-1h3.5a1 1 0 011 1c0 1.25.2 2.45.57 3.58a1 1 0 01-.25 1.01l-2.2 2.2z" fill="currentColor"/>
            </svg>
            {contact.phone}
          </a>
        )}
      </div>

      {highlights.length > 0 && (
        <ul class="ea-hero__highlights" data-reveal data-reveal-order="4" aria-label="Key highlights">
          {highlights.map((h: string) => <li>{h}</li>)}
        </ul>
      )}
    </div>
  </div>

  <!-- ② Photo column (35%, full-height tight crop) — decorative; treatment wired -->
  {hasPhoto && (
    <div
      class={mediaClass}
      aria-hidden="true"
      data-treat={mediaTreat}
      data-grain={useGrain ? '' : undefined}
    >
      <SiteImage
        src={images.hero}
        alt=""
        placeholder={images.placeholder}
        sizes="(min-width: 900px) 35vw, 100vw"
        loading="eager"
        fetchpriority="high"
        fit="cover"
      />
      {treatment === 'duotone' && useGrain && (
        <span class="grain-layer" aria-hidden="true"></span>
      )}
      <!-- Trust badge floated inside photo column, bottom-right -->
      <div class="ea-hero__badge-wrap">
        <TrustBadge
          year={badgeYear || undefined}
          rating={rating?.value}
          reviewCount={rating?.count}
          highlight={trustLine || undefined}
          position="bottom-right"
        />
      </div>
    </div>
  )}
</section>

<style>
  .ea-hero {
    position: relative;
    isolation: isolate;
    background: var(--bg);
    color: var(--text);
    min-height: min(88vh, 800px);
    display: grid;
    grid-template-columns: 1fr; /* single column until a photo is present */
  }
  .ea-hero[data-has-photo] {
    grid-template-columns: 65fr 35fr;
  }

  .ea-hero__copy {
    display: flex;
    align-items: center;
    padding-block: clamp(4rem, 10vw, 8rem);
  }
  .ea-hero__copy-inner {
    max-width: var(--maxw);
    margin-inline: auto;
    padding-inline: var(--gutter);
    width: 100%;
  }
  /* When a photo is present the copy stays clear of the divider. */
  .ea-hero[data-has-photo] .ea-hero__copy-inner {
    margin-inline: 0 auto;
    padding-inline-start: max(var(--gutter), calc((100vw - var(--maxw)) / 2));
    padding-inline-end: clamp(2rem, 4vw, 4rem);
  }

  .ea-hero__eyebrow {
    font-family: var(--font-body);
    font-size: var(--step--1);
    font-weight: var(--fw-bold);
    letter-spacing: var(--tracking-eyebrow);
    text-transform: uppercase;
    color: var(--text-muted);
    margin: 0 0 1.4rem;
  }
  .ea-hero__eyebrow::before {
    content: '';
    display: inline-block;
    width: 1.8rem;
    height: 2px;
    margin-right: 0.7rem;
    vertical-align: middle;
    background: var(--accent);
  }

  /* Oversized, tightly tracked display type — the dominant gesture. */
  .ea-hero__title {
    font-family: var(--font-display);
    font-weight: var(--fw-display);
    font-size: clamp(2.8rem, 8vw, 6.5rem);
    line-height: 1;
    letter-spacing: -0.03em;
    color: var(--text);
    margin: 0;
    max-width: 16ch;
    text-wrap: balance;
  }

  .ea-hero__sub {
    font-size: clamp(1.02rem, 1.8vw, 1.3rem);
    line-height: var(--leading-body);
    color: var(--text-muted);
    max-width: 48ch;
    margin: 1.6rem 0 0;
  }

  .ea-hero__actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem 1.6rem;
    margin-top: 2.25rem;
  }
  .ea-hero__cta {
    display: inline-flex;
    align-items: center;
    background: var(--brand);
    color: var(--brand-contrast);
    font-family: var(--font-body);
    font-weight: var(--fw-bold);
    font-size: var(--step-0);
    text-decoration: none;
    padding: 0.8em 1.7em;
    border-radius: var(--radius);
    box-shadow: var(--shadow-sm);
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }
  .ea-hero__cta:hover {
    text-decoration: none;
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }
  .ea-hero__cta:focus-visible {
    outline: 2px solid var(--ring);
    outline-offset: 3px;
  }
  .ea-hero__phone {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    color: var(--text);
    font-family: var(--font-body);
    font-weight: var(--fw-bold);
    font-size: var(--step-0);
    text-decoration: none;
    border-bottom: var(--border-weight) solid var(--border);
    padding-bottom: 2px;
    transition: border-color var(--motion-fade) var(--motion-ease), color var(--motion-fade) var(--motion-ease);
  }
  .ea-hero__phone:hover {
    text-decoration: none;
    border-color: var(--brand);
    color: var(--brand);
  }
  .ea-hero__phone:focus-visible {
    outline: 2px solid var(--ring);
    outline-offset: 3px;
    border-radius: 2px;
  }
  .ea-hero__phone-icon {
    width: 1.05em;
    height: 1.05em;
    flex-shrink: 0;
  }

  .ea-hero__highlights {
    list-style: none;
    margin: 2.5rem 0 0;
    padding: 1.4rem 0 0;
    border-top: var(--border-weight) solid var(--border);
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 2.25rem;
    font-family: var(--font-body);
    font-size: var(--step--1);
    font-weight: var(--fw-bold);
    letter-spacing: var(--tracking-eyebrow);
    text-transform: uppercase;
    color: var(--text-muted);
  }

  /* Photo column — full height, tight crop. SiteImage fills it (inline cover). */
  .ea-hero__media {
    position: relative;
    overflow: hidden;
    background: var(--bg-alt, var(--surface));
  }
  .ea-hero__media :global(img) {
    width: 100%;
    height: 100%;
  }

  /* Trust badge anchored inside photo column */
  .ea-hero__badge-wrap {
    position: absolute;
    bottom: 1.5rem;
    right: 1.5rem;
    z-index: 5;
  }

  /* ── Mobile: stack type over a shorter photo band ───────────────────────── */
  @media (max-width: 900px) {
    .ea-hero[data-has-photo] {
      grid-template-columns: 1fr;
    }
    .ea-hero[data-has-photo] .ea-hero__copy-inner {
      padding-inline: var(--gutter);
      margin-inline: auto;
    }
    .ea-hero__media {
      min-height: 280px;
      order: 2;
    }
  }
  @media (max-width: 640px) {
    .ea-hero__title {
      font-size: clamp(2.5rem, 12vw, 4rem);
      max-width: none;
    }
    .ea-hero__actions {
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
    }
  }

  [data-archetype="magazine"] .ea-hero__title,
  [data-archetype="editorial"] .ea-hero__title {
    letter-spacing: -0.045em;
  }
</style>
