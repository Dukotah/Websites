---
/**
 * HeroSpotlight — full-bleed photo with the copy held in a discrete, OPAQUE
 * boxed content card that floats over the lower image (bottom-left). Distinct
 * from `cinematic`, which paints the headline directly onto a scrim: here the
 * card is a self-contained, high-contrast surface (solid `--surface`), so the
 * type reads crisply over ANY photo and the layout never depends on a lucky
 * dark region of the image. That makes it a strong choice for trade/utility
 * businesses (towing/plumbing/auto) where the photo is busy but legibility and
 * a one-glance trust block matter most.
 *
 * Mined from Fulldev UI's full-bleed overlay heroes (blocks/hero-3, hero-9,
 * hero-11 — image absolutely behind, content card on top), reworked from their
 * centered free-text into a boxed card that suits a local-business CTA + phone.
 *
 * Photo TIER contract: this is a full-bleed slot, so it is only assigned when
 * the photo can fill the viewport (pickHero/divergence keep it OUT of the
 * 'side'-tier rotation, mirroring `cinematic`). object-position rides on the
 * SiteImage prop (`config.images.heroFocal`) because Astro scopes the parent's
 * `img {}` rule to the parent — it never reaches the SiteImage child.
 */
import type { ProspectConfig } from '../../types';
import SiteImage from '../SiteImage.astro';
const { config } = Astro.props as { config: ProspectConfig };

const { hero, images, contact, highlights = [], established, area } = config;
const telHref = `tel:${contact.phone.replace(/[^+\d]/g, '')}`;
const badgeYear = (established || '').toString().replace(/^est\.?\s*/i, '');
// De-dup (Fable idiom, mirrors HeroSplit/HeroCinematic): the card's corner badge
// states the founding year, so drop `established` from the eyebrow when the badge
// owns it; keep the area. Fall back to the full eyebrow when no year to surface.
const eyebrow = [badgeYear ? '' : established, area].filter(Boolean).join(' · ');
// Headline fit-to-box (Fable): the card headline runs at clamp(2.4–4rem) tuned
// for a short phrase. A full-sentence headline at that scale would tower the
// card past the fold, so step the clamp down by char count (the card's measure
// already wraps it).
const longTitle = (hero.heading ?? '').length > 28;
---

<section class="spot-hero" id="top" aria-label="Hero" data-long-title={longTitle ? 'true' : undefined}>

  <!-- ① Full-bleed photo — parallax target -->
  <div class="spot-hero__media" aria-hidden="true" data-parallax data-parallax-speed="0.35">
    <!-- Full-bleed `hero-fullbleed` slot: the box IS the viewport, so it keeps
         its viewport height (no fixed aspect-ratio to fight). object-position is
         set HERE as a prop so the framing actually reaches the <img> (scoped
         parent rules can't pierce the SiteImage child). -->
    <SiteImage
      src={images.hero}
      alt={images.heroAlt}
      placeholder={images.placeholder}
      fetchpriority="high"
      loading="eager"
      objectPosition={config.images.heroFocal ?? 'center'}
      sizes="100vw"
    />
  </div>

  <!-- ② Light wash over the photo — keeps the card's drop-shadow readable and
       lifts the un-carded area without flattening the photograph. -->
  <div class="spot-hero__wash" aria-hidden="true"></div>

  <!-- ③ Content layer: boxed card, bottom-left -->
  <div class="container spot-hero__inner">
    <div class="spot-hero__card" data-reveal data-reveal-order="1">

      <!-- Founding-year corner badge — bleeds over the card's top edge -->
      {badgeYear && (
        <div class="spot-hero__badge" data-reveal data-reveal-order="0" aria-label="Established">
          <strong class="spot-hero__badge-year">{badgeYear}</strong>
          <span class="spot-hero__badge-label">Est.</span>
        </div>
      )}

      {eyebrow && <p class="spot-hero__eyebrow">{eyebrow}</p>}

      <h1 class="spot-hero__title">{hero.heading}</h1>

      {hero.subheading && (
        <p class="spot-hero__sub">{hero.subheading}</p>
      )}

      <!-- CTA cluster: primary button + phone (matches the repo CTA idiom) -->
      <div class="spot-hero__actions">
        <a href={hero.ctaHref} class="btn spot-hero__cta">{hero.ctaText}</a>
        {contact.phone && (
          <a href={telHref} class="spot-hero__phone">
            <svg class="spot-hero__phone-icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M6.62 10.79a15.05 15.05 0 006.59 6.59l2.2-2.2a1 1 0 011.01-.24 11.47 11.47 0 003.58.57 1 1 0 011 1V20a1 1 0 01-1 1A17 17 0 013 4a1 1 0 011-1h3.5a1 1 0 011 1c0 1.25.2 2.45.57 3.58a1 1 0 01-.25 1.01l-2.2 2.2z" fill="currentColor"/>
            </svg>
            {contact.phone}
          </a>
        )}
      </div>

      <!-- Highlights strip pinned inside the card -->
      {highlights.length > 0 && (
        <ul class="spot-hero__highlights" data-reveal data-reveal-order="2" aria-label="Key highlights">
          {highlights.map((h: string) => <li>{h}</li>)}
        </ul>
      )}
    </div>
  </div>
</section>

<style>
  /* ── Shell ───────────────────────────────────────────────────────────────── */
  .spot-hero {
    position: relative;
    isolation: isolate;
    min-height: min(92vh, 840px);
    display: flex;
    align-items: flex-end;
    overflow: hidden;
    background: var(--bg-deep);
  }

  /* ── ① Photo layer (parallax target) ────────────────────────────────────── */
  .spot-hero__media {
    position: absolute;
    inset: -12% 0;          /* bleed so parallax doesn't expose edges */
    z-index: 0;
    will-change: transform;
  }
  .spot-hero__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 35%;
    display: block;
  }
  @media (prefers-reduced-motion: reduce) {
    .spot-hero__media { inset: 0; will-change: auto; }
  }

  /* ── ② Light wash ────────────────────────────────────────────────────────── */
  /* Gentle, even darken so the photo keeps detail while the floating card's
     shadow + edge stay legible against bright skies / pale storefronts. */
  .spot-hero__wash {
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--bg-deep) 20%, transparent) 0%,
        transparent 30%,
        color-mix(in srgb, var(--bg-deep) 32%, transparent) 100%
      );
    pointer-events: none;
  }

  /* ── ③ Content layer ─────────────────────────────────────────────────────── */
  .spot-hero__inner {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: var(--maxw);
    padding-block: clamp(2.5rem, 6vw, 5rem);
  }

  /* The boxed content card — solid surface so type reads over any photo. */
  .spot-hero__card {
    position: relative;
    background: var(--surface);
    color: var(--text);
    border: var(--border-weight) solid var(--border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
    padding: clamp(1.75rem, 3.5vw, 3rem);
    max-width: min(46ch, 100%);
  }

  /* Founding-year badge — bleeds over the card's top-left corner */
  .spot-hero__badge {
    position: absolute;
    top: -1.25rem;
    left: clamp(1.5rem, 3vw, 2.5rem);
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.05rem;
    background: var(--brand);
    color: var(--brand-contrast);
    border-radius: var(--radius);
    padding: 0.6rem 0.95rem;
    min-width: 64px;
    box-shadow: var(--shadow-md);
    text-align: center;
  }
  .spot-hero__badge-year {
    font-family: var(--font-display);
    font-size: var(--step-1);
    font-weight: var(--fw-display);
    line-height: 1;
  }
  .spot-hero__badge-label {
    font-size: var(--step--1);
    font-weight: var(--fw-bold);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    opacity: 0.85;
  }

  /* Eyebrow: accent rule + tracked caps (shared hero idiom) */
  .spot-hero__eyebrow {
    display: block;
    font-family: var(--font-body);
    font-size: var(--step--1);
    font-weight: var(--fw-bold);
    letter-spacing: var(--tracking-eyebrow);
    text-transform: uppercase;
    color: var(--text-muted);
    margin: 0 0 0.9rem;
  }
  .spot-hero__eyebrow::before {
    content: '';
    display: inline-block;
    width: 1.6rem;
    height: 2px;
    margin-right: 0.6rem;
    vertical-align: middle;
    background: var(--accent);
  }

  /* Oversized display headline (the card is opaque → no scrim/text-shadow) */
  .spot-hero__title {
    font-family: var(--font-display);
    font-weight: var(--fw-display);
    font-size: clamp(2.4rem, 4.6vw, 4rem);
    line-height: var(--leading-display);
    letter-spacing: var(--tracking-display);
    color: var(--text);
    margin: 0 0 1rem;
    text-wrap: balance;
  }

  /* Long (full-sentence) headline: step the clamp down so a sentence wraps to a
     compact card instead of pushing the CTA below the fold. Balanced wrap evens
     the lines; the smaller clamp is the CSS fallback where text-wrap: balance is
     unsupported. Doubled attribute raises specificity above the [data-archetype]
     bump so a long headline stays scaled down on magazine. */
  @media (min-width: 641px) {
    [data-long-title][data-long-title] .spot-hero__title {
      font-size: clamp(2.1rem, 3.6vw, 3.2rem);
    }
  }

  .spot-hero__sub {
    font-family: var(--font-body);
    font-size: var(--step-0);
    line-height: var(--leading-body);
    color: var(--text-muted);
    max-width: 44ch;
    margin: 0 0 1.75rem;
  }

  /* CTA cluster */
  .spot-hero__actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem 1.6rem;
  }
  .spot-hero__cta {
    font-size: var(--step-0);
    padding: 0.9em 1.8em;
  }
  .spot-hero__phone {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-family: var(--font-body);
    font-weight: var(--fw-bold);
    font-size: var(--step-0);
    color: var(--text);
    text-decoration: none;
    border-bottom: var(--border-weight) solid var(--border);
    padding-bottom: 2px;
    transition:
      border-color var(--motion-fade) var(--motion-ease),
      color var(--motion-fade) var(--motion-ease);
  }
  .spot-hero__phone:hover {
    text-decoration: none;
    border-color: var(--brand);
    color: var(--brand);
  }
  .spot-hero__phone:focus-visible {
    outline: 2px solid var(--ring);
    outline-offset: 3px;
    border-radius: 2px;
  }
  .spot-hero__phone-icon {
    width: 1.05em;
    height: 1.05em;
    flex-shrink: 0;
  }

  /* Highlights strip — thin top rule, uppercase tracked */
  .spot-hero__highlights {
    list-style: none;
    margin: 1.85rem 0 0;
    padding: 1.4rem 0 0;
    border-top: var(--border-weight) solid var(--border);
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 1.75rem;
    font-family: var(--font-body);
    font-size: var(--step--1);
    font-weight: var(--fw-bold);
    letter-spacing: 0.09em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  /* ── Mobile ──────────────────────────────────────────────────────────────── */
  @media (max-width: 640px) {
    .spot-hero { min-height: 80vh; align-items: flex-end; }
    .spot-hero__card { max-width: none; }
    .spot-hero__title { font-size: clamp(2.1rem, 9vw, 3rem); }
    .spot-hero__actions {
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
    }
  }

  /* ── Archetype tweaks ────────────────────────────────────────────────────── */
  [data-archetype="utility"] .spot-hero__card {
    /* Utility pages want the densest, most assertive trust block — square the
       card corners and lean on the brand border for a "dispatch panel" feel. */
    border-color: color-mix(in srgb, var(--brand) 45%, var(--border));
  }
  [data-archetype="magazine"] .spot-hero__title {
    font-size: clamp(2.6rem, 5.4vw, 4.6rem);
  }
</style>
