---
import Stats from './Stats.astro';
import Steps from './Steps.astro';
import Testimonials from './Testimonials.astro';
import Faq from './Faq.astro';
import ListBlock from './ListBlock.astro';
import CtaBand from './CtaBand.astro';
import type { Section } from '../types';

const { sections = [] } = Astro.props as { sections?: Section[] };
---

{
  sections.map((s) =>
    s.type === 'stats' ? (
      <Stats items={s.items} />
    ) : s.type === 'steps' ? (
      <Steps eyebrow={s.eyebrow} heading={s.heading} items={s.items} />
    ) : s.type === 'testimonials' ? (
      <Testimonials eyebrow={s.eyebrow} heading={s.heading} items={s.items} />
    ) : s.type === 'faq' ? (
      <Faq eyebrow={s.eyebrow} heading={s.heading} items={s.items} />
    ) : s.type === 'list' ? (
      <ListBlock eyebrow={s.eyebrow} heading={s.heading} intro={s.intro} groups={s.groups} />
    ) : s.type === 'cta' ? (
      <CtaBand heading={s.heading} text={s.text} buttonText={s.buttonText} buttonHref={s.buttonHref} />
    ) : null,
  )
}
