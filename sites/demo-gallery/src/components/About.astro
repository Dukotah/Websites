---
/**
 * About — bear-flag-quality story section: a real photo with a floating badge
 * beside the story copy and a checklist of highlights. Token-driven.
 */
import type { ProspectConfig } from '../types';
const { config } = Astro.props as { config: ProspectConfig };

const { about, images, highlights = [], established, name } = config;
const badgeLine = (established || '').toString().replace(/^est\.?\s*/i, '');
---

<section class="section about" id="about" data-tone="alt">
  <div class="container about__inner">
    <div class="about__media" data-frame data-reveal>
      <img
        src={images.story || images.hero}
        alt={images.storyAlt || `Inside ${name}`}
        loading="lazy"
        decoding="async"
        onerror="this.onerror=null;this.src='/images/about.svg'"
      />
      {badgeLine && (
        <div class="about__badge">
          <strong>{badgeLine}</strong>
          <span>Established</span>
        </div>
      )}
    </div>

    <div class="about__copy" data-reveal>
      <p class="eyebrow">Our story</p>
      <h2 class="about__heading">{about.heading}</h2>
      {about.body.map((p) => <p class="about__lead">{p}</p>)}

      {highlights.length > 0 && (
        <ul class="about__list">
          {highlights.map((h) => (
            <li>
              <span class="about__check" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none"><path d="m5 13 4 4L19 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" /></svg>
              </span>
              <span>{h}</span>
            </li>
          ))}
        </ul>
      )}

      {about.signature && <p class="about__sig">{about.signature}</p>}
    </div>
  </div>
</section>

<style>
  .about { padding-block: var(--section-pad); background: var(--bg-alt); }
  .container { max-width: var(--maxw); margin-inline: auto; padding-inline: var(--gutter); }
  .about__inner {
    display: grid;
    grid-template-columns: 0.85fr 1.15fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
  }
  .about__media { position: relative; }
  .about__media img {
    width: 100%;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
    aspect-ratio: 4 / 5;
    object-fit: cover;
  }
  .about__badge {
    position: absolute;
    right: -0.75rem;
    bottom: 1.25rem;
    background: var(--brand);
    color: var(--brand-contrast);
    padding: 0.8rem 1.1rem;
    border-radius: var(--radius);
    box-shadow: var(--shadow-lg);
    text-align: center;
  }
  .about__badge strong { display: block; font-family: var(--font-display); font-size: 1.3rem; line-height: 1; }
  .about__badge span { font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.08em; opacity: 0.9; }

  .eyebrow {
    font-family: var(--font-body); font-size: var(--step--1); font-weight: var(--fw-bold);
    letter-spacing: var(--tracking-eyebrow); text-transform: uppercase; color: var(--brand); margin: 0 0 0.5rem;
  }
  .about__heading {
    font-family: var(--font-display); font-size: var(--step-3); font-weight: var(--fw-display);
    letter-spacing: var(--tracking-display); line-height: var(--leading-display); color: var(--text); margin: 0 0 1rem;
  }
  .about__lead { font-size: var(--step-0); color: var(--text-muted); line-height: var(--leading-body); margin: 0 0 1rem; }

  .about__list {
    list-style: none; padding: 0; margin: 1.5rem 0 0;
    display: grid; grid-template-columns: repeat(2, 1fr); gap: 0.9rem 1.5rem;
  }
  .about__list li { display: flex; gap: 0.6rem; align-items: flex-start; font-size: var(--step--1); color: var(--text); font-weight: var(--fw-bold); }
  .about__check {
    flex-shrink: 0; display: grid; place-items: center; width: 26px; height: 26px; border-radius: 50%;
    background: color-mix(in srgb, var(--brand) 16%, var(--surface)); color: var(--brand);
  }
  .about__check svg { width: 15px; height: 15px; }
  .about__sig { margin-top: 1.5rem; font-family: var(--font-display); font-style: italic; color: var(--text-muted); }

  @media (max-width: 900px) {
    .about__inner { grid-template-columns: 1fr; }
    .about__media { max-width: 440px; }
  }
  @media (max-width: 520px) {
    .about__list { grid-template-columns: 1fr; }
  }
</style>
