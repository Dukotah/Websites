---
/**
 * About — bear-flag-quality story section: a real photo with a floating badge
 * beside the story copy and a checklist of highlights. Token-driven.
 */
import type { ProspectConfig } from '../types';
import SiteImage from './SiteImage.astro';
const { config } = Astro.props as { config: ProspectConfig };

const { about, images, highlights = [], established, name, tagline } = config;
const badgeLine = (established || '').toString().replace(/^est\.?\s*/i, '');

// A story photo only counts if it's a REAL image — not the category SVG/library
// placeholder. Stretching that placeholder into the media frame reads as an empty
// gradient box ("looks unfinished"). When there's no real photo we render an
// intentional typographic pull-quote panel instead, so the column still has weight.
const storySrc = images.story || images.hero || '';
const hasRealStory =
  Boolean(storySrc) && !storySrc.includes('/images/library/') && !storySrc.endsWith('.svg');
// The quote draws from the tagline, else the opening line of the story.
const pullQuote = (tagline || about.body?.[0] || '').toString();
const aboutClass = hasRealStory ? 'section about' : 'section about about--noimg';
---

<section class={aboutClass} id="about" data-tone="alt">
  <div class="container about__inner">
    {hasRealStory ? (
      <div class="about__media" data-frame data-reveal>
        <SiteImage
          src={storySrc}
          alt={images.storyAlt || `Inside ${name}`}
          placeholder="/images/about.svg"
          sizes="(min-width: 768px) 50vw, 100vw"
        />
        {badgeLine && (
          <div class="about__badge">
            <strong>{badgeLine}</strong>
            <span>Established</span>
          </div>
        )}
      </div>
    ) : (
      <figure class="about__quote" data-frame data-reveal>
        <span class="about__quotemark" aria-hidden="true">&ldquo;</span>
        <blockquote class="about__quotetext">{pullQuote}</blockquote>
        <figcaption class="about__quotecite">
          {name}{badgeLine ? ` · Est. ${badgeLine}` : ''}
        </figcaption>
      </figure>
    )}

    <div class="about__copy" data-reveal>
      <p class="eyebrow">Our story</p>
      <h2 class="about__heading">{about.heading}</h2>
      {about.body.map((p) => <p class="about__lead">{p}</p>)}

      {highlights.length > 0 && (
        <ul class="about__list">
          {highlights.map((h) => (
            <li>
              <span class="about__check" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none"><path d="m5 13 4 4L19 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" /></svg>
              </span>
              <span>{h}</span>
            </li>
          ))}
        </ul>
      )}

      {about.signature && <p class="about__sig">{about.signature}</p>}
    </div>
  </div>
</section>

<style>
  .about { padding-block: var(--section-pad); background: var(--bg-alt); }
  .container { max-width: var(--maxw); margin-inline: auto; padding-inline: var(--gutter); }
  .about__inner {
    display: grid;
    grid-template-columns: 0.85fr 1.15fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
  }
  .about__media { position: relative; }
  .about__media img {
    width: 100%;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
    aspect-ratio: 4 / 5;
    object-fit: cover;
  }
  .about__badge {
    position: absolute;
    right: -0.75rem;
    bottom: 1.25rem;
    background: var(--brand);
    color: var(--brand-contrast);
    padding: 0.8rem 1.1rem;
    border-radius: var(--radius);
    box-shadow: var(--shadow-lg);
    text-align: center;
  }
  .about__badge strong { display: block; font-family: var(--font-display); font-size: 1.3rem; line-height: 1; }
  .about__badge span { font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.08em; opacity: 0.9; }

  /* No-photo fallback: a deliberate typographic pull-quote panel instead of an
     empty image frame. Branded surface, oversized quote mark, display-font line. */
  .about__quote {
    position: relative;
    margin: 0;
    padding: clamp(2rem, 4vw, 3.25rem);
    border-radius: var(--radius-lg);
    background: color-mix(in srgb, var(--brand) 10%, var(--surface));
    border: var(--border-weight, 1px) solid color-mix(in srgb, var(--brand) 22%, transparent);
    box-shadow: var(--shadow-md);
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-height: 18rem;
    overflow: hidden;
  }
  .about__quotemark {
    position: absolute;
    top: clamp(-0.5rem, -1vw, -1rem);
    left: 1rem;
    font-family: var(--font-display);
    font-size: clamp(6rem, 14vw, 10rem);
    line-height: 1;
    color: color-mix(in srgb, var(--brand) 22%, transparent);
    pointer-events: none;
  }
  .about__quotetext {
    position: relative;
    margin: 0;
    font-family: var(--font-display);
    font-weight: var(--fw-display);
    font-size: var(--step-2);
    line-height: var(--leading-display);
    letter-spacing: var(--tracking-display);
    color: var(--text);
    text-wrap: balance;
  }
  .about__quotecite {
    margin-top: 1.25rem;
    font-family: var(--font-body);
    font-size: var(--step--1);
    font-weight: var(--fw-bold);
    letter-spacing: var(--tracking-eyebrow);
    text-transform: uppercase;
    color: var(--brand);
  }

  .eyebrow {
    font-family: var(--font-body); font-size: var(--step--1); font-weight: var(--fw-bold);
    letter-spacing: var(--tracking-eyebrow); text-transform: uppercase; color: var(--brand); margin: 0 0 0.5rem;
  }
  .about__heading {
    font-family: var(--font-display); font-size: var(--step-3); font-weight: var(--fw-display);
    letter-spacing: var(--tracking-display); line-height: var(--leading-display); color: var(--text); margin: 0 0 1rem;
  }
  .about__lead { font-size: var(--step-0); color: var(--text-muted); line-height: var(--leading-body); margin: 0 0 1rem; }

  .about__list {
    list-style: none; padding: 0; margin: 1.5rem 0 0;
    display: grid; grid-template-columns: repeat(2, 1fr); gap: 0.9rem 1.5rem;
  }
  .about__list li { display: flex; gap: 0.6rem; align-items: flex-start; font-size: var(--step--1); color: var(--text); font-weight: var(--fw-bold); }
  .about__check {
    flex-shrink: 0; display: grid; place-items: center; width: 26px; height: 26px; border-radius: 50%;
    background: color-mix(in srgb, var(--brand) 16%, var(--surface)); color: var(--brand);
  }
  .about__check svg { width: 15px; height: 15px; }
  .about__sig { margin-top: 1.5rem; font-family: var(--font-display); font-style: italic; color: var(--text-muted); }

  @media (max-width: 900px) {
    .about__inner { grid-template-columns: 1fr; }
    .about__media { max-width: 440px; }
  }
  @media (max-width: 520px) {
    .about__list { grid-template-columns: 1fr; }
  }
</style>
