---
/**
 * Header — sticky, solid header that works over ANY hero variant (the old one
 * was white-on-photo and vanished over light heroes). Token-driven.
 *
 * De-templated chrome: every site picks ONE of four distinct header treatments,
 * chosen DETERMINISTICALLY from a hash of config.name so the same business
 * always gets the same look but the 45-site batch no longer shares one nav. The
 * variant only re-arranges/re-skins the SAME markup via a `data-hdr-variant`
 * attribute + CSS — the DOM, links, phone CTA, focus states and mobile burger
 * are identical across all four, so accessibility is preserved everywhere.
 *
 *   0 — left monogram + serif name + nav + phone pill   (the original)
 *   1 — centered wordmark, nav split either side, phone pill right
 *   2 — left wordmark, underline-nav, ghost (outlined) call button
 *   3 — bold left wordmark + solid boxed/square CTA (no monogram)
 *
 * Mobile (≤720px): the About/Services/Contact links collapse into a hamburger
 * drawer (the phone CTA stays visible — it's the priority action). The toggle is
 * a pure-CSS checkbox hack, so the menu opens even if JS never loads; a tiny
 * progressive script only adds aria-expanded sync + close-on-navigate/Escape.
 * All variants flatten to this same mobile bar so the responsive contract holds.
 */
import type { ProspectConfig } from '../types';
const { config } = Astro.props as { config: ProspectConfig };
const telHref = `tel:${config.contact.phone.replace(/[^+\d]/g, '')}`;

// Stable per-business seed → variant index. djb2 over the name (no slug on the
// config object) keeps it deterministic + key-free, no token, no art-direction
// dependency. 4 chrome treatments.
function hashSeed(s: string): number {
  let h = 5381;
  for (let i = 0; i < s.length; i++) h = ((h << 5) + h + s.charCodeAt(i)) >>> 0;
  return h;
}
const HDR_VARIANTS = 4;
const variant = hashSeed(config.name || '') % HDR_VARIANTS;
// Variant 3 reads better as a pure wordmark (no monogram square).
const showMark = variant !== 3;
---

<header class="hdr" data-hdr-variant={variant}>
  <div class="container hdr__inner">
    <a href="#top" class="hdr__brand">
      {showMark && <span class="hdr__mark" aria-hidden="true">{config.name.charAt(0)}</span>}
      <span class="hdr__name">{config.name}</span>
    </a>

    <input type="checkbox" id="hdr-toggle" class="hdr__toggle" hidden />

    <div class="hdr__right">
      <nav class="hdr__nav" aria-label="Primary">
        <a href="#about" data-hdr-link>About</a>
        <a href="#services-detailed" data-hdr-link>Services</a>
        <a href="#contact" data-hdr-link>Contact</a>
      </nav>

      <a href={telHref} class="hdr__call">
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M6.6 10.8a15.5 15.5 0 0 0 6.6 6.6l2.2-2.2a1 1 0 0 1 1-.25 11.4 11.4 0 0 0 3.6.57 1 1 0 0 1 1 1V20a1 1 0 0 1-1 1A17 17 0 0 1 3 4a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1 11.4 11.4 0 0 0 .57 3.6 1 1 0 0 1-.25 1L6.6 10.8Z"/></svg>
        <span class="hdr__call-num">{config.contact.phone}</span>
      </a>

      <label for="hdr-toggle" class="hdr__burger" role="button" tabindex="0" aria-controls="hdr-toggle" aria-expanded="false" aria-label="Open menu">
        <span></span><span></span><span></span>
      </label>
    </div>
  </div>
</header>

<script is:inline>
  // Progressive enhancement only — the checkbox hack already opens/closes the
  // drawer with zero JS. This syncs aria-expanded and closes on navigate/Escape.
  (function () {
    var t = document.getElementById('hdr-toggle');
    var b = document.querySelector('.hdr__burger');
    if (!t || !b) return;
    var sync = function () { b.setAttribute('aria-expanded', t.checked ? 'true' : 'false'); };
    t.addEventListener('change', sync);
    // Space/Enter on the focusable label toggles it (labels don't do this natively for keyboards on all UAs).
    b.addEventListener('keydown', function (e) {
      if (e.key === ' ' || e.key === 'Enter') { e.preventDefault(); t.checked = !t.checked; sync(); }
    });
    document.querySelectorAll('[data-hdr-link]').forEach(function (a) {
      a.addEventListener('click', function () { t.checked = false; sync(); });
    });
    document.addEventListener('keydown', function (e) { if (e.key === 'Escape' && t.checked) { t.checked = false; sync(); } });
  })();
</script>

<style>
  .hdr {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--surface) 88%, transparent);
    backdrop-filter: saturate(1.2) blur(8px);
    border-bottom: var(--border-weight) solid var(--border);
  }
  .hdr__inner {
    display: flex; align-items: center; justify-content: space-between; gap: 1rem;
    min-height: 64px;
    max-width: var(--maxw); margin-inline: auto; padding-inline: var(--gutter);
  }
  .hdr__brand { display: inline-flex; align-items: center; gap: 0.6rem; min-width: 0; }
  .hdr__brand:hover { text-decoration: none; }
  .hdr__mark {
    display: grid; place-items: center; width: 34px; height: 34px; flex-shrink: 0;
    border-radius: var(--radius);
    background: var(--brand-vivid, var(--brand)); color: var(--brand-vivid-contrast, var(--brand-contrast));
    font-family: var(--font-display); font-weight: var(--fw-display); font-size: 1.1rem;
  }
  .hdr__name {
    font-family: var(--font-display); font-weight: var(--fw-display);
    font-size: 1.15rem; color: var(--text); letter-spacing: var(--tracking-display);
    /* Truncate a long business name so it can never shove the nav controls off-screen */
    overflow: hidden; text-overflow: ellipsis; white-space: nowrap; min-width: 0;
  }
  .hdr__right { display: flex; align-items: center; gap: 1.75rem; flex-shrink: 0; }
  .hdr__nav { display: flex; align-items: center; gap: 1.75rem; }
  .hdr__nav a { font-family: var(--font-body); color: var(--text-muted); font-weight: var(--fw-bold); font-size: 0.92rem; }
  .hdr__nav a:hover { color: var(--brand); text-decoration: none; }
  .hdr__call {
    display: inline-flex; align-items: center; gap: 0.45rem;
    background: var(--brand-vivid, var(--brand)); color: var(--brand-vivid-contrast, var(--brand-contrast)) !important;
    padding: 0.55rem 1.05rem; border-radius: var(--radius-pill);
    font-weight: var(--fw-bold); font-size: 0.9rem;
    min-height: 40px;
  }
  .hdr__call svg { width: 1em; height: 1em; }
  .hdr__call:hover { background: var(--brand-dark); text-decoration: none; }

  /* ── Chrome variants ──────────────────────────────────────────────────────
     Each only restyles/re-arranges the shared markup. Desktop only (≥721px);
     the mobile bar below is shared so the burger/drawer contract never changes. */
  @media (min-width: 721px) {
    /* Variant 1 — centered wordmark with the nav split either side of it.
       Grid: [nav]  [brand]  [right(call)]. The brand is visually centered. */
    .hdr[data-hdr-variant="1"] .hdr__inner {
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      justify-content: unset;
    }
    .hdr[data-hdr-variant="1"] .hdr__brand { grid-column: 2; justify-self: center; }
    .hdr[data-hdr-variant="1"] .hdr__right {
      grid-column: 1 / -1; grid-row: 1;
      display: contents; /* let nav + call land in the outer columns */
    }
    .hdr[data-hdr-variant="1"] .hdr__nav { grid-column: 1; justify-self: start; }
    .hdr[data-hdr-variant="1"] .hdr__call { grid-column: 3; justify-self: end; }

    /* Variant 2 — left wordmark, underline-nav, ghost (outlined) call button.
       Quieter, more editorial chrome. */
    .hdr[data-hdr-variant="2"] .hdr__nav a {
      position: relative; padding-bottom: 3px;
      color: var(--text);
    }
    .hdr[data-hdr-variant="2"] .hdr__nav a::after {
      content: ""; position: absolute; left: 0; right: 0; bottom: 0; height: 2px;
      background: var(--brand-vivid, var(--brand));
      transform: scaleX(0); transform-origin: left; transition: transform 0.18s ease;
    }
    .hdr[data-hdr-variant="2"] .hdr__nav a:hover::after,
    .hdr[data-hdr-variant="2"] .hdr__nav a:focus-visible::after { transform: scaleX(1); }
    .hdr[data-hdr-variant="2"] .hdr__call {
      background: transparent;
      color: var(--brand-vivid, var(--brand)) !important;
      border: 2px solid var(--brand-vivid, var(--brand));
      /* keep the same box size despite the added border */
      padding-block: calc(0.55rem - 2px);
    }
    .hdr[data-hdr-variant="2"] .hdr__call:hover {
      background: var(--brand-vivid, var(--brand));
      color: var(--brand-vivid-contrast, var(--brand-contrast)) !important;
    }

    /* Variant 3 — bold left wordmark + solid SQUARE/boxed CTA (no monogram). */
    .hdr[data-hdr-variant="3"] .hdr__name {
      font-size: 1.3rem; text-transform: uppercase; letter-spacing: 0.04em;
    }
    .hdr[data-hdr-variant="3"] .hdr__call {
      border-radius: var(--radius); /* boxed, not pill */
      padding: 0.6rem 1.25rem;
    }
  }

  /* Hamburger — hidden on desktop, shown on mobile */
  .hdr__burger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 40px; height: 40px;
    padding: 9px;
    flex-shrink: 0;
    cursor: pointer;
    border-radius: var(--radius);
  }
  .hdr__burger span {
    display: block; height: 2px; width: 100%;
    background: var(--text); border-radius: 2px;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }
  .hdr__burger:focus-visible { outline: 2px solid var(--ring); outline-offset: 2px; }

  @media (max-width: 720px) {
    .hdr__burger { display: flex; }
    .hdr__right { gap: 0.6rem; }
    /* All variants flatten to the shared mobile bar: reset any desktop grid /
       contents tricks so brand-left, call+burger-right always holds. */
    .hdr[data-hdr-variant] .hdr__inner {
      display: flex; grid-template-columns: none;
      justify-content: space-between;
    }
    .hdr[data-hdr-variant] .hdr__right { display: flex; }
    .hdr[data-hdr-variant] .hdr__brand,
    .hdr[data-hdr-variant] .hdr__nav,
    .hdr[data-hdr-variant] .hdr__call {
      grid-column: auto; justify-self: auto;
    }
    /* Hard-cap the brand so it can never crowd the call + burger off-screen
       even on the narrowest phones (~340px) */
    .hdr__name { max-width: 38vw; }

    /* Nav becomes a full-width dropdown drawer below the bar */
    .hdr__nav {
      position: absolute;
      top: 100%; left: 0; right: 0;
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      background: var(--surface);
      border-bottom: var(--border-weight) solid var(--border);
      box-shadow: var(--shadow-md);
      display: none;
    }
    .hdr__nav a {
      padding: 0.95rem var(--gutter);
      font-size: 1rem;
      border-top: var(--border-weight) solid var(--border);
      /* neutralize variant-2's underline treatment inside the drawer */
      color: var(--text); padding-bottom: 0.95rem;
    }
    .hdr[data-hdr-variant="2"] .hdr__nav a::after { content: none; }
    .hdr__toggle:checked ~ .hdr__right .hdr__nav,
    .hdr__toggle:checked ~ * .hdr__nav { display: flex; }

    /* Animate burger → X when open */
    .hdr__toggle:checked ~ .hdr__right .hdr__burger span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
    .hdr__toggle:checked ~ .hdr__right .hdr__burger span:nth-child(2) { opacity: 0; }
    .hdr__toggle:checked ~ .hdr__right .hdr__burger span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

    .hdr__name { font-size: 1.05rem; }
  }

  /* Phones: phone pill collapses to icon-only so brand + call + burger always fit
     (the number is still one tap via the tel: link). Number returns ≥521px. */
  @media (max-width: 520px) {
    .hdr__call-num { display: none; }
    .hdr__call { padding: 0.55rem 0.7rem; }
  }

  /* Narrowest phones: drop the brand NAME (keep the logo mark) so the call + menu
     never get crowded off-screen. The name is still in the claim bar, hero, title. */
  @media (max-width: 430px) {
    .hdr__name { display: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hdr__burger span { transition: none; }
    .hdr[data-hdr-variant="2"] .hdr__nav a::after { transition: none; }
  }
</style>
