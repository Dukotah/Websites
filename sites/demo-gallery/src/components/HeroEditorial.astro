---
// Editorial hero: centered, magazine-style headline over a softly-scrimmed
// photo. Quieter and more upscale than the bold full-bleed `Hero.astro`.
import type { ProspectConfig } from '../types';
const { config } = Astro.props as { config: ProspectConfig };
const telHref = `tel:${config.contact.phone.replace(/[^+\d]/g, '')}`;
const { images } = config;
---

<section class="edHero" id="top">
  <div class="edHero__media">
    <img
      src={images.hero}
      alt={images.heroAlt}
      onerror={`this.onerror=null;this.src='${images.placeholder}'`}
      fetchpriority="high"
    />
    <span class="edHero__scrim" aria-hidden="true"></span>
  </div>

  <div class="container edHero__inner">
    {(config.established || config.area) && (
      <p class="edHero__eyebrow">{[config.established, config.area].filter(Boolean).join('  ·  ')}</p>
    )}
    <h1 class="edHero__title">{config.hero.heading}</h1>
    <p class="edHero__sub">{config.hero.subheading}</p>
    <div class="edHero__actions">
      <a href={config.hero.ctaHref} class="btn">{config.hero.ctaText}</a>
      <a href={telHref} class="edHero__phone">{config.contact.phone}</a>
    </div>
  </div>

  <ul class="edHero__highlights">
    {config.highlights.map((h) => <li>{h}</li>)}
  </ul>
</section>

<style>
  .edHero {
    position: relative;
    color: #fff;
    isolation: isolate;
    min-height: min(90vh, 800px);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
  }
  .edHero__media { position: absolute; inset: 0; z-index: -1; background: var(--brand-dark); }
  .edHero__media img { width: 100%; height: 100%; object-fit: cover; }
  .edHero__scrim {
    position: absolute;
    inset: 0;
    background: radial-gradient(
      120% 90% at 50% 45%,
      rgba(15, 18, 16, 0.35) 0%,
      rgba(15, 18, 16, 0.62) 100%
    );
  }
  .edHero__inner {
    max-width: 720px;
    padding-block: clamp(3rem, 8vw, 6rem);
  }
  .edHero__eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.3em;
    font-size: 0.72rem;
    font-weight: 700;
    color: rgba(255, 255, 255, 0.85);
    margin-bottom: 1.5rem;
  }
  .edHero__title {
    color: #fff;
    font-size: clamp(2.8rem, 7vw, 5.4rem);
    margin-bottom: 1.25rem;
    text-shadow: 0 2px 40px rgba(0, 0, 0, 0.3);
  }
  .edHero__sub {
    font-size: clamp(1.05rem, 2vw, 1.3rem);
    color: rgba(255, 255, 255, 0.9);
    max-width: 54ch;
    margin: 0 auto 2rem;
  }
  .edHero__actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 1rem 1.5rem;
  }
  .edHero__phone {
    color: #fff;
    font-weight: 600;
    border-bottom: 1px solid rgba(255, 255, 255, 0.5);
    padding-bottom: 2px;
  }
  .edHero__phone:hover { text-decoration: none; border-color: #fff; }
  .edHero__highlights {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    margin: 0;
    padding: 1.1rem var(--gutter);
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem 2rem;
    background: rgba(0, 0, 0, 0.28);
    backdrop-filter: blur(3px);
    font-size: 0.8rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.88);
  }
  @media (max-width: 720px) {
    .edHero__highlights { position: static; background: var(--brand-dark); }
  }
</style>
