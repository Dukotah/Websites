---
import type { ProspectConfig } from '../types';
const { config } = Astro.props as { config: ProspectConfig };
const pad = (n: number) => String(n + 1).padStart(2, '0');
---

<section class="section section--alt" id="services">
  <div class="container">
    <div class="offerings__head">
      <p class="eyebrow">What we do</p>
      <h2>{config.servicesHeading}</h2>
    </div>

    <ul class="offerings__list">
      {
        config.services.map((item, i) => (
          <li class="offering">
            <span class="offering__num">{pad(i)}</span>
            <div>
              <h3>{item.title}</h3>
              <p>{item.description}</p>
            </div>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .offerings__head {
    max-width: 40ch;
    margin-bottom: 2.5rem;
  }
  .offerings__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0;
    border-top: 1px solid var(--border);
  }
  .offering {
    display: flex;
    gap: 1.25rem;
    padding: 1.75rem 2rem 1.75rem 0;
    border-bottom: 1px solid var(--border);
  }
  /* Vertical divider between the two columns. */
  .offering:nth-child(odd) {
    border-right: 1px solid var(--border);
    padding-right: 2.5rem;
  }
  .offering:nth-child(even) {
    padding-left: 2.5rem;
  }
  .offering__num {
    font-family: var(--serif);
    font-size: 0.95rem;
    color: var(--brand);
    padding-top: 0.25rem;
    min-width: 1.5rem;
  }
  .offering h3 {
    margin-bottom: 0.35rem;
  }
  .offering p {
    color: var(--text-muted);
    margin: 0;
    font-size: 0.98rem;
  }
  @media (max-width: 720px) {
    .offerings__list {
      grid-template-columns: 1fr;
    }
    .offering,
    .offering:nth-child(odd) {
      border-right: 0;
      padding: 1.5rem 0;
    }
    .offering:nth-child(even) {
      padding-left: 0;
    }
  }
</style>
