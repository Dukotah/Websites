---
import type { ProspectConfig } from '../types';
const { config } = Astro.props as { config: ProspectConfig };

const year = new Date().getFullYear();
const telHref = `tel:${config.contact.phone.replace(/[^+\d]/g, '')}`;
const socials = [
  { label: 'Facebook', href: config.social.facebook },
  { label: 'Instagram', href: config.social.instagram },
  { label: 'Reviews', href: config.social.google },
].filter((s) => s.href);
---

<footer class="footer">
  <div class="container footer__inner">
    <div class="footer__brand">
      <strong>{config.name}</strong>
      <p>{config.contact.address}</p>
      <p><a href={telHref}>{config.contact.phone}</a></p>
    </div>

    {
      socials.length > 0 && (
        <nav class="footer__social" aria-label="Social media">
          {socials.map((s) => (
            <a href={s.href} target="_blank" rel="noopener">
              {s.label}
            </a>
          ))}
        </nav>
      )
    }
  </div>

  <div class="container footer__base">
    <p>© {year} {config.name}</p>
    <p>{[config.area, config.established].filter(Boolean).join(' · ')}</p>
  </div>
</footer>

<style>
  .footer {
    background: var(--bg-deep);
    color: color-mix(in srgb, var(--text-on-dark) 80%, transparent);
    padding-block: 3.5rem 2rem;
  }
  .footer__inner {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem 2rem;
    align-items: flex-start;
    justify-content: space-between;
    max-width: var(--maxw);
    margin-inline: auto;
    padding-inline: var(--gutter);
  }
  .footer__brand strong {
    font-family: var(--font-display);
    font-weight: var(--fw-display);
    font-size: 1.3rem;
    color: var(--text-on-dark);
  }
  .footer__brand p {
    margin: 0.4rem 0 0;
    font-size: 0.92rem;
  }
  .footer__brand a {
    color: var(--text-on-dark);
  }
  .footer__brand a:hover {
    color: var(--accent);
  }
  .footer__social {
    display: flex;
    gap: 1.5rem;
  }
  .footer__social a {
    color: var(--text-on-dark);
    font-weight: var(--fw-bold);
    font-size: 0.92rem;
  }
  .footer__social a:hover {
    color: var(--accent);
  }
  .footer__base {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 2rem;
    justify-content: space-between;
    margin-top: 2.5rem;
    padding-top: 1.5rem;
    border-top: var(--border-weight) solid color-mix(in srgb, var(--text-on-dark) 16%, transparent);
    font-size: 0.85rem;
    max-width: var(--maxw);
    margin-inline: auto;
    padding-inline: var(--gutter);
  }
  .footer__base p {
    margin: 0;
  }
</style>
