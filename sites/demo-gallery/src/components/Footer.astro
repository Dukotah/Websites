---
import type { ProspectConfig } from '../types';
const { config } = Astro.props as { config: ProspectConfig };

const year = new Date().getFullYear();
const phone = config.contact.phone?.trim();
const telHref = phone ? `tel:${phone.replace(/[^+\d]/g, '')}` : '';
const email = config.contact.email || '';
const services = (config.services ?? []).slice(0, 5);
// Short about blurb from their real about copy, trimmed to a sentence-ish length.
const aboutRaw = config.about?.body?.[0] ?? config.seoDescription ?? '';
const blurb = aboutRaw.length > 150 ? aboutRaw.slice(0, 147).replace(/\s+\S*$/, '') + '…' : aboutRaw;
// Footer CTA reuses the category-aware hero CTA label (e.g. "Book a tasting",
// "Get a quote") and points at the booking link if one exists, else #contact.
const ctaText = config.hero?.ctaText || 'Get in touch';
const ctaHref = config.bookingUrl || '#contact';

const socials = [
  { key: 'facebook', label: 'Facebook', href: config.social.facebook },
  { key: 'instagram', label: 'Instagram', href: config.social.instagram },
  { key: 'google', label: 'Reviews on Google', href: config.social.google },
].filter((s) => s.href);
---

<footer class="footer">
  <div class="container footer__grid">
    <!-- Col 1: brand + blurb + socials -->
    <div class="footer__col footer__brand">
      <strong class="footer__name">{config.name}</strong>
      {blurb && <p class="footer__blurb">{blurb}</p>}
      {
        socials.length > 0 && (
          <nav class="footer__social" aria-label="Social media">
            {socials.map((s) => (
              <a href={s.href} target="_blank" rel="noopener" class="footer__social-link" aria-label={s.label} title={s.label}>
                {s.key === 'facebook' && (
                  <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" focusable="false">
                    <path d="M22 12.06C22 6.5 17.52 2 12 2S2 6.5 2 12.06c0 5.02 3.66 9.18 8.44 9.94v-7.03H7.9v-2.9h2.54V9.85c0-2.52 1.5-3.91 3.78-3.91 1.1 0 2.24.2 2.24.2v2.46h-1.26c-1.24 0-1.63.78-1.63 1.57v1.89h2.78l-.44 2.9h-2.34V22c4.78-.76 8.43-4.92 8.43-9.94Z" />
                  </svg>
                )}
                {s.key === 'instagram' && (
                  <svg viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false">
                    <rect x="3" y="3" width="18" height="18" rx="5" stroke="currentColor" stroke-width="2" />
                    <circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="2" />
                    <circle cx="17.5" cy="6.5" r="1.2" fill="currentColor" />
                  </svg>
                )}
                {s.key === 'google' && (
                  <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" focusable="false">
                    <path d="m12 2 2.95 5.97 6.59.96-4.77 4.65 1.13 6.56L12 17.02 6.1 20.14l1.13-6.56-4.77-4.65 6.59-.96L12 2Z" />
                  </svg>
                )}
              </a>
            ))}
          </nav>
        )
      }
    </div>

    <!-- Col 2: services -->
    {
      services.length > 0 && (
        <div class="footer__col">
          <h2 class="footer__head">{config.servicesHeading || 'What we do'}</h2>
          <ul class="footer__links">
            {services.map((s) => (
              <li><a href="#services-detailed">{s.title}</a></li>
            ))}
          </ul>
        </div>
      )
    }

    <!-- Col 3: contact + CTA -->
    <div class="footer__col">
      <h2 class="footer__head">Get in touch</h2>
      <ul class="footer__contact">
        {config.contact.address && <li>{config.contact.address}</li>}
        {phone && <li><a href={telHref}>{phone}</a></li>}
        {email && <li><a href={`mailto:${email}`}>{email}</a></li>}
        {config.area && <li class="footer__area">Serving {config.area}</li>}
      </ul>
      <a href={ctaHref} class="footer__cta">{ctaText}</a>
    </div>
  </div>

  <div class="container footer__base">
    <p>© {year} {config.name}</p>
    <p>{[config.area, config.established].filter(Boolean).join(' · ')}</p>
  </div>
</footer>

<style>
  .footer {
    background: var(--bg-deep);
    color: color-mix(in srgb, var(--text-on-dark) 80%, transparent);
    padding-block: 3.5rem 2rem;
  }
  .footer__grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1.2fr;
    gap: 2.5rem 2rem;
    align-items: start;
    max-width: var(--maxw);
    margin-inline: auto;
    padding-inline: var(--gutter);
  }
  .footer__name {
    font-family: var(--font-display);
    font-weight: var(--fw-display);
    font-size: 1.3rem;
    color: var(--text-on-dark);
    display: block;
  }
  .footer__blurb {
    margin: 0.7rem 0 0;
    font-size: 0.92rem;
    line-height: var(--leading-body);
    max-width: 42ch;
  }
  .footer__head {
    font-family: var(--font-body);
    font-size: 0.8rem;
    font-weight: var(--fw-bold);
    letter-spacing: var(--tracking-eyebrow);
    text-transform: uppercase;
    color: var(--text-on-dark);
    margin: 0 0 1rem;
  }
  .footer__links,
  .footer__contact {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    font-size: 0.92rem;
  }
  .footer__links a,
  .footer__contact a {
    color: color-mix(in srgb, var(--text-on-dark) 82%, transparent);
  }
  .footer__links a:hover,
  .footer__contact a:hover {
    color: var(--accent);
  }
  .footer__area {
    color: color-mix(in srgb, var(--text-on-dark) 60%, transparent);
  }
  .footer__cta {
    display: inline-flex;
    align-items: center;
    margin-top: 1.25rem;
    background: var(--brand);
    color: var(--brand-contrast) !important;
    font-weight: var(--fw-bold);
    font-size: 0.92rem;
    padding: 0.65rem 1.3rem;
    border-radius: var(--radius-pill);
  }
  .footer__cta:hover {
    background: var(--brand-dark);
    text-decoration: none;
  }
  .footer__social {
    display: flex;
    gap: 1.25rem;
    margin-top: 1.25rem;
  }
  .footer__social-link {
    color: var(--text-on-dark);
    display: inline-flex;
  }
  .footer__social-link svg {
    width: 1.25rem;
    height: 1.25rem;
  }
  .footer__social-link:hover {
    color: var(--accent);
  }
  .footer__base {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 2rem;
    justify-content: space-between;
    margin-top: 2.5rem;
    padding-top: 1.5rem;
    border-top: var(--border-weight) solid color-mix(in srgb, var(--text-on-dark) 16%, transparent);
    font-size: 0.85rem;
    max-width: var(--maxw);
    margin-inline: auto;
    padding-inline: var(--gutter);
  }
  .footer__base p {
    margin: 0;
  }

  /* Tablet: services + contact share a row under the brand */
  @media (max-width: 860px) {
    .footer__grid { grid-template-columns: 1fr 1fr; }
    .footer__brand { grid-column: 1 / -1; }
  }
  /* Mobile: single column */
  @media (max-width: 560px) {
    .footer__grid { grid-template-columns: 1fr; gap: 2rem; }
  }
</style>
