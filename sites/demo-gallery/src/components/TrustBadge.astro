---
/**
 * TrustBadge — glassmorphism floating badge with priority hierarchy:
 *   rating + count → "★ {rating} · {count} Reviews"
 *   year alone     → "Est. {year}"
 *   highlight      → fallback string
 * Renders nothing when no displayable data.
 *
 * Props:
 *   year        — founding year string/number, e.g. "1989" or 1989
 *   rating      — aggregate star rating number, e.g. 4.8
 *   reviewCount — total review count, e.g. 312
 *   highlight   — short copy fallback, e.g. "Licensed & Insured"
 *   position    — positioning hint for the parent wrapper; default "bottom-right"
 *
 * Accessibility: WCAG AA. White text (#fff) on rgba(12,14,18,0.55) achieves
 * contrast >7:1 (well beyond the 4.5 requirement).
 */

interface Props {
  year?: string | number;
  rating?: number;
  reviewCount?: number;
  highlight?: string;
  position?: 'bottom-right' | 'bottom-left' | 'top-right' | 'top-left';
}

const {
  year,
  rating,
  reviewCount,
  highlight,
  position = 'bottom-right',
} = Astro.props as Props;

// Resolve visibility flags
const hasRating    = rating != null && rating > 0;
const hasYear      = year != null && String(year).trim() !== '';
const hasHighlight = highlight != null && String(highlight).trim() !== '';
const hasData      = hasRating || hasYear || hasHighlight;

// Build display strings (only used when hasData is true)
const ratingStr = hasRating ? Number(rating).toFixed(1) : '';
const reviewLine = (hasRating && reviewCount != null && reviewCount > 0)
  ? `${ratingStr} · ${reviewCount.toLocaleString()} Reviews`
  : hasRating ? `${ratingStr} Stars` : '';

const mainLine = hasRating ? reviewLine
  : hasYear ? `Est. ${year}` : (highlight ?? '');

const subLine: string | null = hasRating && hasYear ? `Est. ${year}`
  : hasRating && hasHighlight ? (highlight ?? null)
  : null;
---

{hasData && (
  <div
    class={`trust-badge trust-badge--${position}`}
    aria-label="Trust signal"
    role="note"
  >
    {hasRating && (
      <span class="trust-badge__star" aria-hidden="true">★</span>
    )}
    <strong class="trust-badge__main">{mainLine}</strong>
    {subLine && (
      <span class="trust-badge__sub">{subLine}</span>
    )}
  </div>
)}

<style>
  /* ── Shell — glassmorphism card ─────────────────────────────────────────── */
  .trust-badge {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.18rem;
    text-align: center;

    /* Glassmorphism */
    background: rgba(12, 14, 18, 0.55);
    backdrop-filter: blur(12px) saturate(1.4);
    -webkit-backdrop-filter: blur(12px) saturate(1.4);
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: var(--radius);
    box-shadow:
      0 4px 24px rgba(0, 0, 0, 0.28),
      inset 0 1px 0 rgba(255, 255, 255, 0.10);

    padding: 0.7rem 1.05rem;
    min-width: 80px;
    max-width: 160px;
    /* AA: #fff on rgba(12,14,18,0.55) — contrast ratio > 7:1 */
    color: #fff;
    pointer-events: none;
  }

  /* ── Star icon ───────────────────────────────────────────────────────────── */
  .trust-badge__star {
    display: block;
    font-size: var(--step-1, 1.25rem);
    line-height: 1;
    color: var(--accent, var(--brand, #f5c842));
  }

  /* ── Main line ───────────────────────────────────────────────────────────── */
  .trust-badge__main {
    display: block;
    font-family: var(--font-body);
    font-size: var(--step--1, 0.875rem);
    font-weight: var(--fw-bold, 700);
    letter-spacing: 0.02em;
    line-height: 1.2;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 140px;
    color: #fff;
  }

  /* ── Sub line ─────────────────────────────────────────────────────────────── */
  .trust-badge__sub {
    display: block;
    font-family: var(--font-body);
    font-size: 0.65rem;
    font-weight: var(--fw-bold, 700);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255, 255, 255, 0.72);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 130px;
  }

  /* ── Hide on very small screens to avoid overlap ─────────────────────────── */
  @media (max-width: 380px) {
    .trust-badge {
      display: none;
    }
  }
</style>
