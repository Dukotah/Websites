---
const {
  eyebrow = 'In their words',
  heading = 'What people say',
  items = [],
} = Astro.props as {
  eyebrow?: string;
  heading?: string;
  items: { quote: string; author: string; source?: string }[];
};
---

<section class="section section--alt">
  <div class="container">
    <div class="tst__head">
      <p class="eyebrow">{eyebrow}</p>
      <h2>{heading}</h2>
    </div>
    <div class="tst__grid">
      {
        items.map((t) => (
          <figure class="tst">
            <blockquote>“{t.quote}”</blockquote>
            <figcaption>
              <span class="tst__author">{t.author}</span>
              {t.source && <span class="tst__source"> · {t.source}</span>}
            </figcaption>
          </figure>
        ))
      }
    </div>
  </div>
</section>

<style>
  .tst__head {
    max-width: 40ch;
    margin-bottom: 2.5rem;
  }
  .tst__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
  }
  .tst {
    margin: 0;
    background: var(--paper);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.75rem;
    box-shadow: var(--shadow);
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .tst blockquote {
    margin: 0;
    font-size: 1.05rem;
    line-height: 1.6;
    color: var(--text);
  }
  .tst figcaption {
    font-size: 0.9rem;
    color: var(--text-muted);
    margin-top: auto;
  }
  .tst__author {
    font-weight: 700;
    color: var(--brand-dark);
  }
</style>
