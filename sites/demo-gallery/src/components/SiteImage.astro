---
/**
 * SiteImage — the single image primitive every component renders through.
 *
 * For managed prospect rasters (resolved from src/assets via the registry) it
 * emits astro:assets <Image>, which gives:
 *   • a responsive WebP srcset (multiple widths) sized by `sizes`
 *   • Sharp-optimized bytes (smaller than the source JPEG/PNG)
 *   • a blur-up placeholder: the tiny LQIP data-URI is painted as the element's
 *     own background, so the box shows a blurred preview until the real image
 *     decodes over it. No wrapper div, no fade-in JS — the output is a plain
 *     <img>, so all existing component CSS keeps matching.
 *
 * For anything it can't manage (remote URLs, SVG placeholders) it falls back to
 * a plain <img>, optionally with an onerror swap to a public placeholder.
 *
 * Drop-in contract: replace `<img src alt class loading … />` with
 * `<SiteImage src alt class loading … />` — same attributes.
 */
import { Image } from 'astro:assets';
import { resolveAsset } from '../lib/assets';
import lqipMap from '../lib/lqip.json';

interface Props {
  src: string;
  alt: string;
  /** Responsive hint, e.g. "(min-width:640px) 33vw, 100vw". Default 100vw. */
  sizes?: string;
  /** Override candidate widths; defaults derive from the source width. */
  widths?: number[];
  loading?: 'lazy' | 'eager';
  fetchpriority?: 'high' | 'low' | 'auto';
  decoding?: 'async' | 'sync' | 'auto';
  /** Output format for the optimized variant. */
  format?: 'webp' | 'avif' | 'jpeg' | 'png';
  quality?: number;
  /** CSS object-position for cover crops, e.g. "center 30%". */
  objectPosition?: string;
  /**
   * How the image sits in its box. Default 'cover' makes it fill the parent
   * (the parent must define a height or aspect-ratio). 'contain' letterboxes;
   * 'none' opts out entirely (caller controls sizing).
   *
   * This lives here because the image is rendered inside THIS component —
   * Astro scopes a parent's `.x img {}` rules to the parent and they do NOT
   * pierce into a child component, so fill/object-fit must be applied here.
   */
  fit?: 'cover' | 'contain' | 'none';
  class?: string;
  style?: string;
  /** Public SVG/raster to swap in if an UNMANAGED src fails to load. */
  placeholder?: string;
}

const {
  src,
  alt,
  sizes = '100vw',
  widths,
  loading = 'lazy',
  fetchpriority,
  decoding = 'async',
  format = 'webp',
  quality = 74,
  objectPosition,
  fit = 'cover',
  class: className,
  style: styleProp,
  placeholder,
} = Astro.props as Props;

const asset = resolveAsset(src);

const lqip = (lqipMap as Record<string, string>)[src];

// Compose the inline style: fill rules + caller style + blur-up + object-position.
// Fill rules are inline so they reach the <img> regardless of style scoping.
const styleParts: string[] = [];
if (fit !== 'none') {
  styleParts.push('display:block', 'width:100%', 'height:100%', `object-fit:${fit}`);
}
if (styleProp) styleParts.push(styleProp);
if (asset && lqip) {
  styleParts.push(
    `background-image:url('${lqip}')`,
    'background-size:cover',
    // Keep the blur-up placeholder's framing in lock-step with the image's own
    // focal crop, so there's no visible shift when the real bytes decode in.
    `background-position:${objectPosition ?? 'center'}`,
    'background-repeat:no-repeat',
  );
}
if (objectPosition) styleParts.push(`object-position:${objectPosition}`);
const style = styleParts.length ? styleParts.join(';') : undefined;

// Candidate widths: capped to the source so Astro never upscales.
function candidateWidths(maxW: number): number[] {
  const pool = [320, 480, 640, 768, 1024, 1280, 1600, 2000, 2400];
  const fit = pool.filter((w) => w <= maxW);
  if (fit[fit.length - 1] !== maxW) fit.push(maxW);
  return fit.length ? fit : [maxW];
}
const resolvedWidths = asset ? (widths ?? candidateWidths(asset.width)) : undefined;

// The hero photo is the LCP element on full-bleed/split heroes and is ALWAYS sat
// under a darkening scrim, so a leaner compression quality is imperceptible there
// but meaningfully cuts the transfer bytes that gate LCP on Slow-4G (heavy-photo
// pages like canevaris/miguel were landing ~2630ms, just over the 2500ms budget).
// `fetchpriority="high"` is the hero/LCP signal, so we trim its quality; every
// other (lazy, below-fold) image keeps the full default. Caller can still override.
const effQuality = fetchpriority === 'high' ? Math.min(quality, 62) : quality;
---

{asset ? (
  <Image
    src={asset}
    alt={alt}
    widths={resolvedWidths}
    sizes={sizes}
    format={format}
    quality={effQuality}
    loading={loading}
    fetchpriority={fetchpriority}
    decoding={decoding}
    class={className}
    style={style}
  />
) : (
  <img
    src={src}
    alt={alt}
    loading={loading}
    fetchpriority={fetchpriority}
    decoding={decoding}
    class={className}
    style={style}
    onerror={placeholder ? `this.onerror=null;this.src='${placeholder}'` : undefined}
  />
)}
