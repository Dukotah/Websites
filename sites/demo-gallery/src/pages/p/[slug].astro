---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ClaimBanner from '../../components/ClaimBanner.astro';
import Header from '../../components/Header.astro';
import About from '../../components/About.astro';
import Contact from '../../components/Contact.astro';
import Footer from '../../components/Footer.astro';
import HeroRenderer from '../../components/heroes/HeroRenderer.astro';
import SectionRenderer from '../../components/sections/SectionRenderer.astro';
import { resolveArtDirection } from '../../lib/art-direction';
import { composePage } from '../../lib/compose';
import { assertValidProspectConfig } from '../../lib/contract.mjs';
import type { ProspectConfig } from '../../types';

// One static page per prospect JSON in src/data/prospects/.
// Add a file there (e.g. via the generator) and a new /p/<slug> appears.
export async function getStaticPaths() {
  const modules = import.meta.glob<ProspectConfig>('../../data/prospects/*.json', {
    eager: true,
    import: 'default',
  });

  return Object.entries(modules).map(([path, config]) => {
    const slug = path.split('/').pop()!.replace(/\.json$/, '');
    // Enforce the data contract at the render boundary: a structurally-broken
    // config fails the build loudly (with the slug + reason) instead of silently
    // rendering a half-empty page.
    assertValidProspectConfig(config, slug);
    return { params: { slug }, props: { config } satisfies { config: ProspectConfig } };
  });
}

const { config } = Astro.props as { config: ProspectConfig };

// Resolve the visual identity (matches BaseLayout's seeding) and compose a
// distinct, data-gated page plan: a hero variant + an ordered set of sections.
const ad = resolveArtDirection(config);
const plan = composePage(config, ad);
---

<BaseLayout config={config}>
  {!config.outreach?.published && <ClaimBanner config={config} />}
  <Header config={config} />
  <main id="main">
    <HeroRenderer config={config} variant={plan.hero} />
    <About config={config} />
    <SectionRenderer sections={plan.sections} />
    <Contact config={config} />
  </main>
  <Footer config={config} />
</BaseLayout>
