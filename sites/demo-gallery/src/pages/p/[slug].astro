---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Hero from '../../components/Hero.astro';
import About from '../../components/About.astro';
import Services from '../../components/Services.astro';
import Sections from '../../components/Sections.astro';
import Contact from '../../components/Contact.astro';
import Footer from '../../components/Footer.astro';
import type { Prospect, ProspectConfig } from '../../types';

// One static page per prospect JSON in src/data/prospects/.
// Add a file there (e.g. via the generator) and a new /p/<slug> appears.
export async function getStaticPaths() {
  const modules = import.meta.glob<ProspectConfig>('../../data/prospects/*.json', {
    eager: true,
    import: 'default',
  });

  return Object.entries(modules).map(([path, config]) => {
    const slug = path.split('/').pop()!.replace(/\.json$/, '');
    return { params: { slug }, props: { config } satisfies { config: ProspectConfig } };
  });
}

const { config } = Astro.props as { config: ProspectConfig };
---

<BaseLayout config={config}>
  <Header config={config} />
  <main>
    <Hero config={config} />
    <About config={config} />
    <Services config={config} />
    <Sections sections={config.sections} />
    <Contact config={config} />
  </main>
  <Footer config={config} />
</BaseLayout>
