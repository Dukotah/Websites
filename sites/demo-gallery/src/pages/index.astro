---
import '../styles/global.css';
import type { PremiumConfig, PremiumSection } from '../premium/lib/premium-types';
import { resolveArtDirection } from '../lib/art-direction';

// Internal dashboard of every PREMIUM demo — YOUR view, not prospect-facing. It
// scores each demo from its real material (sections, photos, contact, trust) so
// you can tell a genuinely strong, finished site from a thin one at a glance, and
// surfaces the needs-review ones first. Sites render at /s/<slug>.
const modules = import.meta.glob<PremiumConfig>('../data/premium/*.json', {
  eager: true,
  import: 'default',
});

const isStock = (src?: string) =>
  !src || src.includes('/images/library/') || src.endsWith('.svg');

/**
 * Premium-aware score (0..100) from the REAL material the multi-page config
 * carries. No legacy compose/art plan needed — premium sites are section-stacks,
 * so we count what actually shipped: real photos, content sections, contact
 * completeness, and trust signals. `status: needs-review` (set by the author /
 * premium-validate gate) caps the grade so an unfinished site can't read green.
 */
function scorePremium(config: PremiumConfig) {
  const pages = config.pages ?? [];
  const sections: PremiumSection[] = pages.flatMap((p) => p.sections ?? []);
  const kinds = new Set(sections.map((s) => s.kind));

  // Collect every image src referenced anywhere (hero + section images).
  const srcs: string[] = [];
  if (config.images?.hero) srcs.push(config.images.hero);
  const walk = (node: any) => {
    if (!node || typeof node !== 'object') return;
    if (Array.isArray(node)) return node.forEach(walk);
    for (const [k, v] of Object.entries(node)) {
      if (k === 'src' && typeof v === 'string') srcs.push(v);
      else walk(v);
    }
  };
  walk(pages);
  const realPhotos = [...new Set(srcs)].filter((s) => !isStock(s));

  // realPhotos 25 — hero photo + a bonus for gallery depth.
  const heroReal = !isStock(config.images?.hero);
  let photos = (heroReal ? 16 : 0) + Math.min(9, realPhotos.length * 3);
  photos = Math.min(25, photos);

  // sectionRichness 30 — content sections (beyond hero/contact) + page depth.
  const RICH = new Set(['story', 'services', 'stats', 'testimonials', 'gallery', 'faq']);
  const richCount = sections.filter((s) => RICH.has(s.kind)).length;
  const richVariety = [...kinds].filter((k) => RICH.has(k)).length;
  const multiPage = Math.max(0, pages.length - 1); // home is a given
  let richness = Math.min(18, richCount * 3) + Math.min(6, richVariety * 2) + Math.min(6, multiPage * 2);
  richness = Math.min(30, richness);

  // contactComplete 15 — phone + real email + address + hours.
  const c = config.contact ?? {};
  const contact =
    (c.phone ? 4 : 0) +
    (c.email ? 5 : 0) +
    (c.address ? 3 : 0) +
    (config.hours?.length ? 3 : 0);

  // trustSignals 15 — rating, real testimonials, established year.
  const hasTestimonials = sections.some(
    (s) => s.kind === 'testimonials' && (s as any).items?.length,
  );
  const trust =
    (config.rating?.value ? 7 : 0) +
    (hasTestimonials ? 5 : 0) +
    (config.established ? 3 : 0);

  // seoMeta 15 — description present + mentions the town + tagline.
  const seoLen = (config.seoDescription ?? '').length;
  const area = (config.area ?? '').toLowerCase();
  const mentionsTown = area && config.seoDescription?.toLowerCase().includes(area.split(',')[0]);
  const seo =
    (seoLen >= 80 && seoLen <= 165 ? 7 : seoLen ? 4 : 0) +
    (mentionsTown ? 5 : 0) +
    (config.tagline ? 3 : 0);

  let score = Math.round(photos + richness + contact + trust + seo);
  // An author/validator needs-review verdict caps a site at "C" so a flagged,
  // unfinished demo can never surface as green.
  if (config.status === 'needs-review') score = Math.min(score, 72);
  score = Math.max(0, Math.min(100, score));

  const grade =
    score >= 90 ? 'A' : score >= 78 ? 'B' : score >= 66 ? 'C' : score >= 50 ? 'D' : 'F';

  return { score, grade, sectionCount: sections.length, pageCount: pages.length };
}

const prospects = Object.entries(modules)
  .map(([path, config]) => {
    const slug = path.split('/').pop()!.replace(/\.json$/, '');
    // Bridge the v2 `brand` (color + fontId) onto the fields the brand engine
    // reads, exactly as PremiumBase does — so the dashboard swatches match the
    // live site's palette.
    const adInput = {
      ...config,
      theme: config.brand?.color ? { brand: config.brand.color } : (config as any).theme,
      artDirection: config.brand?.fontId ? { fontId: config.brand.fontId } : (config as any).artDirection,
    };
    const ad = resolveArtDirection(adInput as any);
    const s = scorePremium(config);
    const flags = config.flags ?? [];
    return { slug, config, ad, flags, ...s };
  })
  // needs-review / weakest first — the ones needing work surface to the top.
  .sort((a, b) => {
    const ar = a.config.status === 'needs-review' ? 0 : 1;
    const br = b.config.status === 'needs-review' ? 0 : 1;
    if (ar !== br) return ar - br;
    return a.score - b.score;
  });

const avg = prospects.length
  ? Math.round(prospects.reduce((n, p) => n + p.score, 0) / prospects.length)
  : 0;
const gradeCounts = prospects.reduce<Record<string, number>>((acc, p) => {
  acc[p.grade] = (acc[p.grade] ?? 0) + 1;
  return acc;
}, {});
const GRADES = ['A', 'B', 'C', 'D', 'F'];
const reviewCount = prospects.filter((p) => p.config.status === 'needs-review').length;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Demo dashboard — {prospects.length} sites · avg {avg}</title>
  </head>
  <body>
    <main class="container" style="padding-block: 3rem;">
      <p class="eyebrow">Outreach demos</p>
      <h1>{prospects.length} premium demo {prospects.length === 1 ? 'site' : 'sites'}</h1>
      <p class="summary">
        <span class="pill pill--avg">Avg score {avg}</span>
        {reviewCount > 0 && (
          <span class="pill pill--review">{reviewCount} needs-review</span>
        )}
        {GRADES.map((g) =>
          gradeCounts[g] ? (
            <span class={`pill grade grade--${g}`}>{gradeCounts[g]} × {g}</span>
          ) : null,
        )}
      </p>
      <p class="lede">
        Multi-page sites rendered at <code>/s/&lt;slug&gt;</code>. Scored on real
        photos, section richness, contact completeness, trust signals & SEO.
        Needs-review surfaces first.
      </p>

      <ul class="grid">
        {
          prospects.map(({ slug, config, ad, score, grade, flags, sectionCount, pageCount }) => (
            <li class="card" style={`--spine:${ad.palette.brand}`}>
              <div class="card__body">
                <div class="card__top">
                  <h2>{config.name}</h2>
                  <span class={`gradechip grade--${grade}`}>{grade}</span>
                </div>
                <p class="card__meta">
                  {config.area}
                  {config.status === 'needs-review' && (
                    <span class="reviewchip">needs-review</span>
                  )}
                </p>

                <div class="identity" title={`font: ${ad.fontId} · shape: ${ad.shape} · ${ad.category}`}>
                  <span class="swatches" aria-hidden="true">
                    <span style={`background:${ad.palette.brand}`} />
                    <span style={`background:${ad.palette.accent}`} />
                    <span style={`background:${ad.palette.bg}`} />
                    <span style={`background:${ad.palette.bgDeep}`} />
                  </span>
                  <span class="identity__tags">
                    <code>{ad.fontPairing.mood}</code>
                    <code>{pageCount} pages</code>
                    <code>{sectionCount} sections</code>
                  </span>
                </div>

                <div class="scorebar" aria-label={`Score ${score} of 100`}>
                  <span class={`scorebar__fill grade--${grade}`} style={`width:${score}%`} />
                  <span class="scorebar__num">{score}</span>
                </div>

                {flags.length > 0 && (
                  <ul class="card__flags">
                    {flags.slice(0, 4).map((f) => (
                      <li>{f}</li>
                    ))}
                  </ul>
                )}

                <div class="card__actions">
                  <a href={`/s/${slug}`}>View demo →</a>
                  <code class="card__link">/s/{slug}</code>
                </div>
              </div>
            </li>
          ))
        }
      </ul>

      {
        prospects.length === 0 && (
          <p style="color: var(--text-muted);">
            No demos yet. Add a JSON to <code>src/data/premium/</code> (npm run generate).
          </p>
        )
      }
    </main>

    <style>
      .summary {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin: 0.5rem 0 1rem;
      }
      .lede {
        color: var(--text-muted);
        max-width: 64ch;
      }
      .pill {
        font-size: 0.8rem;
        font-weight: 700;
        padding: 0.3rem 0.8rem;
        border-radius: 999px;
        background: var(--bg-alt);
        color: var(--text);
      }
      .pill--avg {
        background: #e6edf7;
        color: #1f3a63;
      }
      .pill--review {
        background: #fbe9d8;
        color: #9a5b2e;
      }
      .grid {
        list-style: none;
        padding: 0;
        margin: 1.5rem 0 0;
        display: grid;
        gap: 1.25rem;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
      }
      .card {
        border: 1px solid var(--border);
        border-left: 5px solid var(--spine);
        border-radius: 10px;
        background: var(--surface, #fff);
        overflow: hidden;
      }
      .card__body {
        padding: 1.25rem;
      }
      .card__top {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        gap: 0.5rem;
      }
      .card h2 {
        margin: 0 0 0.15rem;
        font-size: 1.12rem;
      }
      .card__meta {
        margin: 0 0 0.75rem;
        color: var(--text-muted);
        font-size: 0.88rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
      }
      .reviewchip {
        font-size: 0.68rem;
        font-weight: 700;
        background: #fbe9d8;
        color: #9a5b2e;
        padding: 0.12rem 0.45rem;
        border-radius: 4px;
      }
      .gradechip {
        flex: 0 0 auto;
        width: 1.9rem;
        height: 1.9rem;
        display: grid;
        place-items: center;
        border-radius: 999px;
        font-weight: 800;
        font-size: 0.95rem;
        color: #fff;
      }
      .grade--A { background: #1f9d57; }
      .grade--B { background: #5aa736; }
      .grade--C { background: #c79a18; }
      .grade--D { background: #d2702a; }
      .grade--F { background: #c23b32; }
      .grade.pill { color: #fff; }

      .identity {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        margin-bottom: 0.85rem;
      }
      .swatches {
        display: inline-flex;
        flex: 0 0 auto;
        border-radius: 6px;
        overflow: hidden;
        border: 1px solid var(--border);
      }
      .swatches span {
        width: 18px;
        height: 18px;
        display: block;
      }
      .identity__tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.3rem;
      }
      .identity__tags code {
        font-size: 0.68rem;
        background: var(--bg-alt);
        color: var(--text-muted);
        padding: 0.12rem 0.4rem;
        border-radius: 4px;
      }
      .scorebar {
        position: relative;
        height: 1.25rem;
        background: var(--bg-alt);
        border-radius: 999px;
        overflow: hidden;
        margin-bottom: 0.85rem;
      }
      .scorebar__fill {
        position: absolute;
        inset: 0 auto 0 0;
        border-radius: 999px;
      }
      .scorebar__num {
        position: absolute;
        right: 0.6rem;
        top: 50%;
        transform: translateY(-50%);
        font-size: 0.72rem;
        font-weight: 800;
        color: var(--text);
      }
      .card__flags {
        margin: 0 0 0.75rem;
        padding-left: 1.1rem;
        font-size: 0.8rem;
        color: #9a5b2e;
      }
      .card__flags li {
        margin: 0.15rem 0;
      }
      .card__actions {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.5rem;
      }
      .card__link {
        font-size: 0.76rem;
        color: var(--text-muted);
      }
    </style>
  </body>
</html>
