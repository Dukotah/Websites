{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "astro",
  "buildCommand": "astro build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/greysquirrelmanor", "destination": "https://greysquirrel-site.vercel.app/greysquirrelmanor" },
    { "source": "/greysquirrelmanor/:path*", "destination": "https://greysquirrel-site.vercel.app/greysquirrelmanor/:path*" }
  ]
}
