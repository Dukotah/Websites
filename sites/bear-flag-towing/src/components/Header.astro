---
import { config } from '../config';
const telDigits = config.contact.phone.replace(/[^+\d]/g, '');
---

<!-- Top emergency strip -->
<div class="topbar">
  <div class="container topbar__inner">
    <span class="topbar__pulse" aria-hidden="true"></span>
    <span>24/7 Emergency Towing &middot; Santa Rosa &amp; Sonoma County</span>
    <a href={`tel:${telDigits}`}>{config.contact.phone}</a>
  </div>
</div>

<header class="header" id="top">
  <div class="container header__inner">
    <a href="#top" class="brand" aria-label={`${config.name} home`}>
      <span class="brand__mark" aria-hidden="true">
        <svg viewBox="0 0 24 24">
          <path
            d="M12 2.2l2.6 5.6 6.1.8-4.5 4.1 1.2 6L12 15.9 6.6 18.7l1.2-6-4.5-4.1 6.1-.8z"
            fill="#fff"></path>
        </svg>
      </span>
      <span class="brand__text">Bear&nbsp;Flag <em>Towing</em></span>
    </a>

    <nav class="nav" aria-label="Primary">
      <a href="#services">Services</a>
      <a href="#why">Why us</a>
      <a href="#area">Service area</a>
      <a href="#contact">Contact</a>
    </nav>

    <a href={`tel:${telDigits}`} class="btn header__cta">
      <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path
          d="M6.6 10.8a15.5 15.5 0 0 0 6.6 6.6l2.2-2.2a1 1 0 0 1 1-.25 11.4 11.4 0 0 0 3.6.57 1 1 0 0 1 1 1V20a1 1 0 0 1-1 1A17 17 0 0 1 3 4a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1 11.4 11.4 0 0 0 .57 3.6 1 1 0 0 1-.25 1L6.6 10.8Z"
          fill="currentColor"></path>
      </svg>
      <span class="header__cta-text">Call {config.contact.phone}</span>
      <span class="header__cta-short">Call now</span>
    </a>
  </div>
</header>

<style>
  .topbar {
    background: var(--ink);
    color: rgba(255, 255, 255, 0.85);
    font-size: 0.85rem;
  }
  .topbar__inner {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    min-height: 38px;
  }
  .topbar__inner a {
    color: #fff;
    font-weight: 700;
    margin-left: auto;
  }
  .topbar__pulse {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: #ff5b4a;
    box-shadow: 0 0 0 0 rgba(255, 91, 74, 0.6);
  }
  @media (prefers-reduced-motion: no-preference) {
    .topbar__pulse {
      animation: pulse 2s infinite;
    }
  }
  @keyframes pulse {
    0% {
      box-shadow: 0 0 0 0 rgba(255, 91, 74, 0.55);
    }
    70% {
      box-shadow: 0 0 0 9px rgba(255, 91, 74, 0);
    }
    100% {
      box-shadow: 0 0 0 0 rgba(255, 91, 74, 0);
    }
  }

  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(255, 255, 255, 0.88);
    backdrop-filter: saturate(180%) blur(10px);
    border-bottom: 1px solid var(--border);
  }
  .header__inner {
    display: flex;
    align-items: center;
    gap: 1rem;
    min-height: 70px;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--text);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.3rem;
    letter-spacing: 0.01em;
    text-transform: uppercase;
  }
  .brand:hover {
    text-decoration: none;
  }
  .brand__mark {
    display: grid;
    place-items: center;
    width: 38px;
    height: 38px;
    border-radius: 9px;
    background: var(--brand);
    box-shadow: var(--shadow-sm);
  }
  .brand__mark svg {
    width: 22px;
    height: 22px;
  }
  .brand__text em {
    font-style: normal;
    color: var(--brand);
  }

  .nav {
    display: flex;
    align-items: center;
    gap: 1.75rem;
    margin-left: auto;
  }
  .nav a {
    color: var(--text);
    font-weight: 600;
    font-size: 0.97rem;
  }
  .nav a:hover {
    color: var(--brand);
    text-decoration: none;
  }

  .header__cta {
    padding: 0.6rem 1.1rem;
    min-height: 44px;
    font-size: 0.95rem;
  }
  .header__cta-short {
    display: none;
  }

  /* Tablet: collapse the text nav, keep brand + call */
  @media (max-width: 880px) {
    .nav {
      display: none;
    }
    .header__cta {
      margin-left: auto;
    }
  }
  @media (max-width: 460px) {
    .header__cta-text {
      display: none;
    }
    .header__cta-short {
      display: inline;
    }
    .topbar span:not(.topbar__pulse) {
      display: none;
    }
    .topbar__inner a {
      margin: 0 auto;
    }
  }
</style>
