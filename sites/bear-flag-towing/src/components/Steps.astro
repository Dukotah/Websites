---
import { config } from '../config';
---

<section class="section">
  <div class="container">
    <div class="section__head">
      <p class="eyebrow">How it works</p>
      <h2>{config.stepsHeading}</h2>
    </div>

    <ol class="steps">
      {
        config.steps.map((step, i) => (
          <li class="step">
            <span class="step__num">{i + 1}</span>
            <h3>{step.title}</h3>
            <p>{step.description}</p>
          </li>
        ))
      }
    </ol>
  </div>
</section>

<style>
  .steps {
    list-style: none;
    counter-reset: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  .step {
    position: relative;
    padding: 2rem 1.75rem;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    box-shadow: var(--shadow-sm);
  }
  .step__num {
    display: grid;
    place-items: center;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: var(--brand);
    color: #fff;
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 700;
    margin-bottom: 1rem;
    box-shadow: var(--shadow-sm);
  }
  .step h3 {
    margin-bottom: 0.35rem;
  }
  .step p {
    margin: 0;
    color: var(--text-muted);
  }
  /* Connector arrows between steps on wide screens */
  .step:not(:last-child)::after {
    content: '';
    position: absolute;
    top: 2.55rem;
    right: -0.95rem;
    width: 1.9rem;
    height: 2px;
    background: color-mix(in srgb, var(--brand) 35%, var(--border));
    z-index: 1;
  }
  @media (max-width: 760px) {
    .steps {
      grid-template-columns: 1fr;
    }
    .step:not(:last-child)::after {
      display: none;
    }
  }
</style>
