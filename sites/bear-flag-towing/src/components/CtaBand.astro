---
import { config } from '../config';
const telDigits = config.contact.phone.replace(/[^+\d]/g, '');
---

<section class="cta">
  <div class="container cta__inner">
    <div>
      <h2>Need a tow right now?</h2>
      <p>We’re standing by 24/7 across Santa Rosa &amp; Sonoma County. One call and we’re on the way.</p>
    </div>
    <a href={`tel:${telDigits}`} class="btn btn--light cta__btn">
      <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path
          d="M6.6 10.8a15.5 15.5 0 0 0 6.6 6.6l2.2-2.2a1 1 0 0 1 1-.25 11.4 11.4 0 0 0 3.6.57 1 1 0 0 1 1 1V20a1 1 0 0 1-1 1A17 17 0 0 1 3 4a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1 11.4 11.4 0 0 0 .57 3.6 1 1 0 0 1-.25 1L6.6 10.8Z"
          fill="currentColor"></path>
      </svg>
      {config.contact.phone}
    </a>
  </div>
</section>

<style>
  .cta {
    background:
      radial-gradient(600px 300px at 12% 0%, color-mix(in srgb, #fff 16%, transparent), transparent),
      var(--brand);
    color: #fff;
  }
  .cta__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1.5rem 2rem;
    padding-block: clamp(2.5rem, 6vw, 3.75rem);
  }
  .cta h2 {
    margin: 0 0 0.35rem;
    color: #fff;
  }
  .cta p {
    margin: 0;
    color: rgba(255, 255, 255, 0.88);
    font-size: 1.08rem;
    max-width: 46ch;
  }
  .cta__btn {
    font-size: 1.1rem;
    padding: 1rem 1.9rem;
    flex-shrink: 0;
  }
</style>
