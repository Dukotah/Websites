---
import { config } from '../config';
---

<section class="section section--alt" id="area">
  <div class="container area">
    <div class="area__copy">
      <p class="eyebrow">Where we work</p>
      <h2>{config.serviceAreaHeading}</h2>
      <p class="area__lead">
        From a roadside breakdown to a scheduled tow, we cover Santa Rosa and the surrounding
        communities. If you’re nearby and not listed, give us a call — chances are we can still help.
      </p>
      <ul class="area__tags">
        {config.serviceArea.map((town) => <li>{town}</li>)}
      </ul>
    </div>

    <div class="area__map">
      <iframe
        title="Bear Flag Towing service area map"
        src="https://www.google.com/maps?q=Santa%20Rosa%2C%20CA&z=10&output=embed"
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"></iframe>
    </div>
  </div>
</section>

<style>
  .area {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 5vw, 3.5rem);
    align-items: center;
  }
  .area__lead {
    color: var(--text-muted);
    font-size: 1.08rem;
    max-width: 46ch;
  }
  .area__tags {
    list-style: none;
    padding: 0;
    margin: 1.5rem 0 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }
  .area__tags li {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 0.5rem 1rem;
    font-weight: 600;
    font-size: 0.92rem;
    box-shadow: var(--shadow-sm);
  }
  .area__map {
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow);
    border: 1px solid var(--border);
    aspect-ratio: 4 / 3;
  }
  .area__map iframe {
    width: 100%;
    height: 100%;
    border: 0;
    display: block;
    filter: saturate(1.05);
  }
  @media (max-width: 880px) {
    .area {
      grid-template-columns: 1fr;
    }
  }
</style>
