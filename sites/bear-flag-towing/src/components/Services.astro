---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { config } from '../config';

// Resolve the filenames in config.services[].image to optimized image assets.
const imported = import.meta.glob<{ default: ImageMetadata }>('../assets/images/svc-*.jpg', {
  eager: true,
});
const images: Record<string, ImageMetadata> = {};
for (const [path, mod] of Object.entries(imported)) {
  images[path.split('/').pop()!] = mod.default;
}

const telDigits = config.contact.phone.replace(/[^+\d]/g, '');
---

<section class="section" id="services">
  <div class="container">
    <div class="section__head">
      <p class="eyebrow">What we do</p>
      <h2>{config.servicesHeading}</h2>
      <p>{config.servicesSub}</p>
    </div>

    <div class="grid">
      {
        config.services.map((service) => (
          <article class="card">
            <div class="card__media">
              <Image
                src={images[service.image]}
                alt={service.title}
                widths={[300, 520]}
                sizes="(max-width: 700px) 100vw, 360px"
                loading="lazy"
              />
            </div>
            <div class="card__body">
              <h3>{service.title}</h3>
              <p>{service.description}</p>
              <a href={`tel:${telDigits}`} class="card__link">
                Request this service
                <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <path
                    d="M5 12h14m-6-6 6 6-6 6"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
              </a>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .grid {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  }
  .card {
    display: flex;
    flex-direction: column;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
  }
  .card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
    border-color: color-mix(in srgb, var(--brand) 30%, var(--border));
  }
  .card__media {
    aspect-ratio: 16 / 10;
    overflow: hidden;
  }
  .card__media :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }
  .card:hover .card__media :global(img) {
    transform: scale(1.05);
  }
  .card__body {
    padding: 1.4rem 1.5rem 1.6rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  .card__body h3 {
    margin-bottom: 0.4rem;
  }
  .card__body p {
    color: var(--text-muted);
    margin: 0 0 1.1rem;
    flex: 1;
  }
  .card__link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-weight: 700;
    font-size: 0.92rem;
    color: var(--brand);
  }
  .card__link svg {
    width: 1.05em;
    height: 1.05em;
    transition: transform 0.2s ease;
  }
  .card__link:hover {
    text-decoration: none;
  }
  .card:hover .card__link svg {
    transform: translateX(3px);
  }
</style>
