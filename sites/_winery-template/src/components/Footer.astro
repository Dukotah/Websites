---
import { config } from '../config';
const year = new Date().getFullYear();
const telDigits = config.contact.phone.replace(/[^+\d]/g, '');
---

<footer class="footer">
  <div class="container footer__inner">
    <div class="footer__brand">
      <p class="footer__name">{config.name}</p>
      <p class="footer__tag">{config.tagline}</p>
      <p class="footer__muted">{config.area}</p>
    </div>

    <nav class="footer__col" aria-label="Sections">
      <h3>Explore</h3>
      {config.nav.map((item) => <a href={item.href}>{item.label}</a>)}
    </nav>

    <div class="footer__col">
      <h3>Get in touch</h3>
      <a href={`tel:${telDigits}`}>{config.contact.phone}</a>
      {config.contact.email && (
        <a href={`mailto:${config.contact.email}`}>{config.contact.email}</a>
      )}
      {config.social.instagram && (
        <a href={config.social.instagram} target="_blank" rel="noopener">Instagram</a>
      )}
      {config.social.facebook && (
        <a href={config.social.facebook} target="_blank" rel="noopener">Facebook</a>
      )}
      {config.social.yelp && (
        <a href={config.social.yelp} target="_blank" rel="noopener">Yelp</a>
      )}
    </div>
  </div>

  <div class="container footer__bottom">
    <p>© {year} {config.name}. All rights reserved.</p>
    <p>Please enjoy responsibly. Must be 21+ to purchase wine.</p>
  </div>
</footer>

<style>
  .footer {
    background: var(--ink);
    color: #e8ddcf;
    padding-block: 3.5rem 1.5rem;
  }
  .footer__inner {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr;
    gap: 2rem;
    padding-bottom: 2.5rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.12);
  }
  .footer__name {
    font-family: var(--font-display);
    font-size: 1.5rem;
    color: #fff;
    margin: 0 0 0.25rem;
  }
  .footer__tag {
    color: var(--gold);
    font-style: italic;
    margin: 0 0 0.75rem;
  }
  .footer__muted {
    color: rgba(255, 255, 255, 0.6);
    font-size: 0.92rem;
    margin: 0;
  }
  .footer__col h3 {
    font-family: var(--font);
    font-size: 0.74rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: rgba(255, 255, 255, 0.5);
    margin: 0 0 1rem;
  }
  .footer__col a {
    display: block;
    color: rgba(255, 255, 255, 0.85);
    margin-bottom: 0.55rem;
    font-size: 0.96rem;
  }
  .footer__col a:hover {
    color: #fff;
  }
  .footer__bottom {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 0.5rem;
    padding-top: 1.5rem;
    color: rgba(255, 255, 255, 0.45);
    font-size: 0.82rem;
  }
  .footer__bottom p {
    margin: 0;
  }
  @media (max-width: 700px) {
    .footer__inner {
      grid-template-columns: 1fr;
      gap: 1.75rem;
    }
  }
</style>
