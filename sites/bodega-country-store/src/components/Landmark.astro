---
import { config } from '../config';
const { landmark, images } = config;
---

<section class="landmark" id="landmark">
  <img
    class="landmark__bg"
    src={images.landmark}
    alt={images.landmarkAlt}
    loading="lazy"
    onerror={`this.onerror=null;this.src='${images.placeholder}'`}
  />
  <span class="landmark__scrim" aria-hidden="true"></span>

  <div class="container landmark__inner">
    <div class="landmark__copy">
      <p class="eyebrow eyebrow--light">{landmark.eyebrow}</p>
      <h2>{landmark.heading}</h2>
      <p class="landmark__body">{landmark.body}</p>
      <p class="landmark__note">{landmark.note}</p>
    </div>
  </div>

  {images.landmarkCredit && <p class="landmark__credit">{images.landmarkCredit}</p>}
</section>

<style>
  .landmark {
    position: relative;
    color: #fff;
    isolation: isolate;
    overflow: hidden;
    background: var(--brand-dark);
  }
  .landmark__bg {
    position: absolute;
    inset: 0;
    z-index: -2;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .landmark__scrim {
    position: absolute;
    inset: 0;
    z-index: -1;
    background: linear-gradient(
      90deg,
      rgba(20, 30, 26, 0.9) 0%,
      rgba(20, 30, 26, 0.7) 45%,
      rgba(20, 30, 26, 0.35) 100%
    );
  }
  .landmark__inner {
    padding-block: clamp(4.5rem, 11vw, 8rem);
  }
  .landmark__copy {
    max-width: 52ch;
  }
  .eyebrow--light {
    color: color-mix(in srgb, var(--brand) 60%, #fff);
  }
  .landmark h2 {
    color: #fff;
  }
  .landmark__body {
    font-size: 1.12rem;
    color: rgba(255, 255, 255, 0.88);
  }
  .landmark__note {
    margin: 1.5rem 0 0;
    font-size: 0.82rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.7);
    padding-top: 1.25rem;
    border-top: 1px solid rgba(255, 255, 255, 0.2);
    display: inline-block;
  }
  .landmark__credit {
    position: absolute;
    right: 0.75rem;
    bottom: 0.5rem;
    margin: 0;
    font-size: 0.68rem;
    color: rgba(255, 255, 255, 0.55);
  }
</style>
