---
import { config } from '../config';

const year = new Date().getFullYear();
const telHref = `tel:${config.contact.phone.replace(/[^+\d]/g, '')}`;
const socials = [
  { label: 'Facebook', href: config.social.facebook },
  { label: 'Instagram', href: config.social.instagram },
  { label: 'Reviews', href: config.social.google },
].filter((s) => s.href);
---

<footer class="footer">
  <div class="container footer__inner">
    <div class="footer__brand">
      <strong><span aria-hidden="true">☀</span> {config.name}</strong>
      <p class="footer__muted">{config.contact.address}</p>
      <p class="footer__muted">
        <a href={telHref}>{config.contact.phone}</a>
      </p>
    </div>

    {
      socials.length > 0 && (
        <nav class="footer__social" aria-label="Social media">
          {socials.map((s) => (
            <a href={s.href} target="_blank" rel="noopener">
              {s.label}
            </a>
          ))}
        </nav>
      )
    }
  </div>

  <div class="container footer__base">
    <p class="footer__muted">© {year} {config.name}. All rights reserved.</p>
    <p class="footer__muted">{config.area} · {config.established}</p>
  </div>
</footer>

<style>
  .footer {
    background: var(--ink);
    color: #fff;
    padding-block: 3rem 2rem;
  }
  .footer__inner {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem 2rem;
    align-items: flex-start;
    justify-content: space-between;
  }
  .footer__brand strong {
    font-size: 1.2rem;
  }
  .footer__brand strong span {
    color: var(--brand);
  }
  .footer__muted {
    color: rgba(255, 255, 255, 0.65);
    margin: 0.35rem 0 0;
    font-size: 0.92rem;
  }
  .footer__muted a {
    color: rgba(255, 255, 255, 0.85);
  }
  .footer__social {
    display: flex;
    gap: 1.5rem;
  }
  .footer__social a {
    color: #fff;
    font-weight: 600;
  }
  .footer__base {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 2rem;
    justify-content: space-between;
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.12);
  }
</style>
