---
import { config } from '../config';
const telHref = `tel:${config.contact.phone.replace(/[^+\d]/g, '')}`;
---

<section class="hero" id="top">
  <span class="hero__sun" aria-hidden="true"></span>

  <div class="container hero__inner">
    <p class="hero__badge">{config.established}</p>
    <h1 class="hero__title">{config.hero.heading}</h1>
    <p class="hero__sub">{config.hero.subheading}</p>

    <div class="hero__actions">
      <a href={config.hero.ctaHref} class="btn">{config.hero.ctaText}</a>
      <a href={telHref} class="btn btn--ghost">{config.contact.phone}</a>
    </div>

    <ul class="hero__pills" aria-label="What's inside">
      {config.highlights.map((item) => <li>{item}</li>)}
    </ul>
  </div>

  <!-- Rolling coastal hills -->
  <svg class="hero__hills" viewBox="0 0 1440 140" preserveAspectRatio="none" aria-hidden="true">
    <path
      d="M0,70 C240,20 360,110 600,80 C840,50 960,120 1200,80 C1320,60 1400,80 1440,70 L1440,140 L0,140 Z"
      fill="var(--bg-alt)"
    ></path>
  </svg>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    background:
      radial-gradient(120% 90% at 80% -20%, #ffe7a8 0%, #ffd989 22%, transparent 55%),
      linear-gradient(180deg, #fef6e3 0%, var(--bg) 70%);
    border-bottom: 1px solid var(--border);
  }
  .hero__sun {
    position: absolute;
    top: -90px;
    right: -60px;
    width: 320px;
    height: 320px;
    border-radius: 50%;
    background: radial-gradient(circle at 50% 50%, #fff4cf 0%, var(--brand) 60%, var(--brand-dark) 100%);
    box-shadow: 0 0 120px 40px color-mix(in srgb, var(--brand) 45%, transparent);
    opacity: 0.9;
  }
  .hero__inner {
    position: relative;
    z-index: 1;
    padding-block: clamp(4rem, 12vw, 8rem) clamp(5rem, 11vw, 8rem);
    max-width: 780px;
  }
  .hero__badge {
    display: inline-block;
    background: color-mix(in srgb, var(--brand) 16%, #fff);
    color: var(--brand-dark);
    font-weight: 700;
    font-size: 0.85rem;
    letter-spacing: 0.02em;
    padding: 0.4rem 0.95rem;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--brand) 30%, transparent);
    margin-bottom: 1.25rem;
  }
  .hero__title {
    font-family: var(--serif);
    letter-spacing: -0.02em;
    margin-bottom: 1rem;
  }
  .hero__sub {
    font-size: clamp(1.05rem, 2.2vw, 1.3rem);
    color: var(--text-muted);
    max-width: 60ch;
    margin-bottom: 1.75rem;
  }
  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
  }
  .hero__pills {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    padding: 0;
    margin: 2.25rem 0 0;
  }
  .hero__pills li {
    background: #fff;
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 0.4rem 0.95rem;
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--text);
    box-shadow: var(--shadow);
  }
  .hero__hills {
    position: absolute;
    left: 0;
    bottom: -1px;
    width: 100%;
    height: clamp(70px, 9vw, 130px);
    display: block;
  }
  @media (max-width: 640px) {
    .hero__sun {
      width: 200px;
      height: 200px;
      top: -60px;
      right: -50px;
    }
  }
</style>
