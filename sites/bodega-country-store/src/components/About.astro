---
import { config } from '../config';
const { images } = config;
---

<section class="section" id="story">
  <div class="container story">
    <figure class="story__media">
      <span class="story__frame">
        <img
          src={images.story}
          alt={images.storyAlt}
          loading="lazy"
          onerror="this.onerror=null;this.src='/images/storefront.svg'"
        />
      </span>
      {(images.storyCaption || images.storyCredit) && (
        <figcaption>
          {images.storyCaption}
          {images.storyCredit && <span class="story__credit"> · {images.storyCredit}</span>}
        </figcaption>
      )}
    </figure>

    <div class="story__copy">
      <p class="eyebrow">Our story</p>
      <h2>{config.about.heading}</h2>
      {config.about.body.map((para) => <p>{para}</p>)}
      <p class="story__sign">— The Bodega Country Store</p>
    </div>
  </div>
</section>

<style>
  .story {
    display: grid;
    gap: clamp(2rem, 5vw, 4rem);
    grid-template-columns: 1fr 1fr;
    align-items: center;
  }
  .story__media {
    margin: 0;
  }
  .story__frame {
    display: block;
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--bg-alt);
    aspect-ratio: 4 / 3;
    box-shadow: var(--shadow);
  }
  .story__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .story__media figcaption {
    margin-top: 0.6rem;
    font-size: 0.8rem;
    color: var(--text-muted);
  }
  .story__credit {
    opacity: 0.8;
  }
  .story__copy p:not(.eyebrow) {
    color: var(--text-muted);
    font-size: 1.08rem;
  }
  .story__sign {
    font-family: var(--serif);
    font-style: italic;
    color: var(--brand-dark) !important;
    margin-top: 1.25rem;
  }
  @media (max-width: 800px) {
    .story {
      grid-template-columns: 1fr;
    }
    .story__media {
      order: -1;
    }
  }
</style>
