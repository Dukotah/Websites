---
import { config } from '../config';
const telHref = `tel:${config.contact.phone.replace(/[^+\d]/g, '')}`;
---

<header class="header">
  <div class="container header__inner">
    <a href="#top" class="header__brand">{config.name}</a>
    <nav class="header__nav" aria-label="Primary">
      <a href="#about">About</a>
      <a href="#services">Services</a>
      <a href="#contact">Contact</a>
      <a href={telHref} class="header__call">{config.contact.phone}</a>
    </nav>
  </div>
</header>

<style>
  .header {
    position: absolute;
    inset: 0 0 auto 0;
    z-index: 50;
  }
  .header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    min-height: 76px;
  }
  .header__brand {
    font-family: var(--serif);
    font-weight: 600;
    font-size: 1.2rem;
    color: #fff;
    letter-spacing: 0.01em;
  }
  .header__brand:hover {
    text-decoration: none;
  }
  .header__nav {
    display: flex;
    align-items: center;
    gap: 2rem;
  }
  .header__nav a {
    color: rgba(255, 255, 255, 0.92);
    font-weight: 500;
    font-size: 0.95rem;
  }
  .header__nav a:hover {
    color: #fff;
    text-decoration: none;
  }
  .header__call {
    border: 1px solid rgba(255, 255, 255, 0.4);
    border-radius: 999px;
    padding: 0.5rem 1.1rem;
  }
  .header__call:hover {
    background: rgba(255, 255, 255, 0.12);
  }
  @media (max-width: 720px) {
    .header__nav a:not(.header__call) {
      display: none;
    }
  }
</style>
