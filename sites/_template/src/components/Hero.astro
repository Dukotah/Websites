---
import { config } from '../config';
---

<section class="hero" id="top">
  <div class="container hero__inner">
    <p class="eyebrow">{config.area}</p>
    <h1>{config.hero.heading}</h1>
    <p class="hero__sub">{config.hero.subheading}</p>
    <div class="hero__actions">
      <a href={config.hero.ctaHref} class="btn">{config.hero.ctaText}</a>
      <a href={`tel:${config.contact.phone.replace(/[^+\d]/g, '')}`} class="btn btn--ghost">
        {config.contact.phone}
      </a>
    </div>
  </div>
</section>

<style>
  .hero {
    background:
      radial-gradient(1200px 400px at 70% -10%, color-mix(in srgb, var(--brand) 14%, transparent), transparent),
      var(--bg-alt);
    border-bottom: 1px solid var(--border);
  }
  .hero__inner {
    padding-block: clamp(3.5rem, 10vw, 7rem);
    max-width: 760px;
  }
  .hero__sub {
    font-size: 1.2rem;
    color: var(--text-muted);
    max-width: 60ch;
  }
  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.5rem;
  }
</style>
