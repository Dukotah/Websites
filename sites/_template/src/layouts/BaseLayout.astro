---
import { config } from '../config';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = config.name,
  description = config.seoDescription,
} = Astro.props;

const fullTitle = title === config.name ? `${config.name} — ${config.area}` : `${title} | ${config.name}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />

    <!-- Open Graph (link previews on social / messaging) -->
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />

    <!-- Brand colors injected from config.ts -->
    <style
      is:inline
      set:html={`:root{--brand:${config.theme.brand};--brand-dark:${config.theme.brandDark};}`}
    ></style>
  </head>
  <body>
    <slot />
  </body>
</html>
