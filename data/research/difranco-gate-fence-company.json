    {
      "title": "Electric gate entry & access systems",
      "description": "Electric-automated gate entry systems, operators, and access control, professionally installed and serviced for residential and commercial properties."
    },
    {
      "title": "Custom fencing",
      "description": "Picket, solid and recessed board, bamboo, corral, wire, and ornamental iron fencing — built from quality materials and crafted to fit your property and style."
    },
    {
      "title": "Ornamental iron & fabrication",
      "description": "Hand-fabricated ornamental iron gates, guard and stair railings, hand rails, and custom metalwork, with powder coating in black or your choice of colors."
    },
    {
      "title": "Custom redwood decks",
      "description": "Custom-built decks of all shapes and sizes — including sustainable redwood construction — designed to extend your outdoor living space."
    },
    {
      "title": "Repairs, restoration & replacement",
      "description": "Restoration, alterations, repairs, replacement, and tear-down services to keep existing gates, fences, and decks looking and working their best."
    }
