{
  "name": "websites",
  "private": true,
  "type": "module",
  "description": "A monorepo of independent Astro websites for local businesses, deployed on Vercel.",
  "scripts": {
    "new-site": "node scripts/new-site.mjs",
    "fetch-photos": "node scripts/fetch-photos.mjs",
    "build-research": "node scripts/build-research.mjs",
    "verify-research": "node scripts/verify-research.mjs",
    "generate": "node scripts/generate.mjs",
    "premium-validate": "node scripts/premium-validate.mjs",
    "push-to-crm": "node scripts/push-to-crm.mjs",
    "register-bespoke": "node scripts/register-bespoke.mjs",
    "make-thumbnail": "node scripts/make-thumbnail.mjs",
    "sameness-check": "node scripts/sameness-check.mjs",
    "image-qa": "node scripts/image-qa.mjs",
    "lighthouse": "node scripts/lighthouse.mjs",
    "perf-budget": "node scripts/lighthouse.mjs --budget",
    "qa": "npm --prefix sites/demo-gallery run build && node scripts/premium-validate.mjs && A11Y_ENFORCE=1 node scripts/audit.mjs && npm --prefix sites/demo-gallery run shots -- --no-build && node scripts/sameness-check.mjs && node scripts/image-qa.mjs"
  },
  "devDependencies": {
    "chrome-launcher": "^1.2.1",
    "lighthouse": "^13.4.0",
    "sharp": "^0.34.0",
    "smartcrop": "^2.0.5",
    "smartcrop-sharp": "^2.0.8"
  }
}
